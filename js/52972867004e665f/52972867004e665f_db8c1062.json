[{"date": "2021-03-26", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X01120210326/6", "sentence": ["…代表いたしまして、ただいま議題となりました令和三年度予算三案に対し、賛成の立場から討論いたします。討論に先立ち、昨日、弾道ミサイルを発射した…", "…ることが何より大切です。それでは、以下、令和三年度予算三案について、賛成の主な理由を申し述べます。まず、本予算案は、新型コロナウイルス感染症…", "…直しを行うことで、予算の質も併せて向上させています。以上、本予算案に賛成する理由を申し述べました。ここまで予算委員会の与野党理事間で熱心な協…", "…げます。最後に、議員各位の御賛同を賜りますことを強くお願い申し上げまして、私の賛成討論とさせていただきます。ありがとうございました。（拍手）"]}]}]}, {"date": "2022-03-30", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/192", "sentence": ["…御意見もないようですから、これより直ちに採決に入ります。沖縄振興特別措置法等の一部を改正する法律案に賛成の方の挙手を願います。〔賛成者挙手〕", "…御意見もないようですから、これより直ちに採決に入ります。沖縄振興特別措置法等の一部を改正する法律案に賛成の方の挙手を願います。〔賛成者挙手〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/195