[{"date": "2020-11-13", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/105", "sentence": ["…ざいます。そういった今後の取組を重ねてお願いいたします。最後に、北方領土に関して少し質問させていただきます。先ほども、ほかの委員の方からも、…", "…としロシア国内で憲法の改正があった、そういう中で、憲法が改正されて、領土に関して、国境画定を除き、領土の割譲に向けた行為や呼びかけを許さない…", "…った、そういう中で、憲法が改正されて、領土に関して、国境画定を除き、領土の割譲に向けた行為や呼びかけを許さないと言及されている部分がございま…", "…許さないと言及されている部分がございます。当然、我々から見ると、北方領土は国境画定の交渉の部類であるとの認識でございますけれども、果たしてロ…", "…がかりでございます。ちょうど、先般も、十一月九日、今週月曜日に、北方領土返還促進に関する要請の請願が議員会館でも行われました。私自身も、昨年…", "…っております。大臣に改めてお伺いいたします。先般の大臣挨拶でも、北方領土問題に関しましては、領土問題を解決し、平和条約を締結するとの基本方針…", "…てお伺いいたします。先般の大臣挨拶でも、北方領土問題に関しましては、領土問題を解決し、平和条約を締結するとの基本方針のもと、粘り強く取り組み…", "…けれども、この原則論、何回も伺っております。改めて、ロシア憲法改憲が今後の北方領土の交渉に与える影響について、大臣の認識をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303968X00220201113/110", "sentence": ["…とから、アビガンの話ですとかワクチンの国内生産体制の充実、そして北方領土、幅広い分野を質問させていただきました。本当に茂木大臣にそれぞれ丁寧…"]}]}]}, {"date": "2022-03-30", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00720220330/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00720220330/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00720220330/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00720220330/37", "sentence": ["…かなと思っておりますけ