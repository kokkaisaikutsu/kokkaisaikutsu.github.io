[{"date": "2022-10-27", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/97", "sentence": ["…カードは押すのはやめておこうって、また言われるけんって、そうやって虚偽報告が後を絶たないのです。資料三を御覧ください。管理職から過少報告を求…", "…一二・六％となっています。大臣、今年は文科省も教員勤務実態調査をしていますが、この虚偽報告をどうお考えになりますか。見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/99", "sentence": ["…底というところを十分お願いしたいと思っております。教職員が管理職に虚偽報告を行わざるを得ない、このような状況は、先ほどもありましたが、労基法…", "…既に限界に来ているということが百二十三時間で分かります。このような虚偽報告が次々と行われ、教員は次々と倒れ、病休に入る、そして早期退職をして…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/101", "sentence": ["○古賀千景君勤務実態調査が、先ほども申しましたとおり、虚偽報告などがたくさん出ているということは十分知っていただきたいと思っております。そし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/105", "sentence": ["…なかったということも実態でありますし、先ほど申し上げましたとおり、虚偽報告がたくさんそこにも含まれているということを感じていただきたいと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/124", "sentence": []}]}]}]