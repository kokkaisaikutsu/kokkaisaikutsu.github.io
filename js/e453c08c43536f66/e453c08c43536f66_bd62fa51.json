[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/411", "sentence": []}]}, {"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/43", "sentence": ["…ただきました。全国には三万人近い、あっ、三万校近い小中学校がありますが、二千四百校が抽出されました。なぜこの数字になったかを教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/45", "sentence": ["○古賀千景君じゃ、その専門家の、過去のこととか専門家のことで抽出で一割弱だったということは、この子供たちがやっている全国学力・学習状況調査も…", "…この子供たちがやっている全国学力・学習状況調査も悉皆の必要性はなく、抽出で十分なのではないかと私は考えます。今おっしゃってくださいました四十…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/55", "sentence": ["…います。全国学力・学習状況調査の廃止、それが無理ならせめて悉皆を以前やっていた抽出へ戻すべきだと私は考えますが、どのようにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/57", "sentence": ["…のテストで十分だと私は現場を経験していたときに思いました。是非、せめて抽出への、全国学力状況調査への変更を求めます。ありがとうございました。"]}]}]}]