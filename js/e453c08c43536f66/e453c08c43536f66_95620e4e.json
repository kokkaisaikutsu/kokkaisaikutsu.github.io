[{"date": "2023-05-23", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/41", "sentence": ["…に関しては、消防庁の救急企画室から、学校等における口腔用液ブコラムの投与についてという文書の中のその他に、救急現場における救急救命士を含む救…", "…ける救急救命士を含む救急隊員が傷病者やその家族に代わって当該医薬品を投与することはできないことを申し添えると書いてあります。なぜ救急隊員の方…", "…やその家族に代わって当該医薬品を投与することはできないことを申し添えると書いてあります。なぜ救急隊員の方が投与できないのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/45", "sentence": ["○古賀千景君救急救命士さえ投与ができないのに専門知識のない教職員がやるというのは、これはいかがなもんかと思いますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/47", "sentence": ["○古賀千景君では、もし教職員が投与をして何か状況が悪化したりとか、そんな急変したりした場合のときの責任、また反対に、投与ができずに体調が急変…", "…が悪化したりとか、そんな急変したりした場合のときの責任、また反対に、投与ができずに体調が急変したときの責任、この二つの責任はどこにあるとお考…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/64", "sentence": []}, {