[{"date": "2024-03-12", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/8", "sentence": ["…ております。私は、最近、地元で有権者の皆様方の前でお話をするときに、不易流行という言葉を紹介をさせていただいております。この言葉は、いつまで…", "…しく変化を重ねているものを取り込んでいく、こういう言葉でございます。不易というものは、変わらない、変えてはいけないこと、流行というのが、変わ…", "…と、変えていく、こういうことだというふうに思っております。私は、この不易流行という言葉はいろんな分野で通用する言葉ではないかなというふうに思…", "…ます。なるほどなというふうに得心をいたしまして、先ほど申し上げました不易流行、そして変わらないために変わる、この言葉を大切にしていきたいなと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314889X00220240312/28", "sentence": []}]}]}]