[{"date": "2020-10-30", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315254X00320201030/27", "sentence": ["…安倍内閣で七年八か月間、内閣官房長官を務められました。官房長官は参謀、側近であり、大規模災害などの際の危機管理から省庁にまたがる政策調整に至…", "…な中小企業には雇用者負担は重いものです。負担額を決めるに当たり、事業者側の経営状況が考慮されなければ給与の切下げにつながるのではないかと懸念…"]}]}]}, {"date": "2022-04-12", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00820220412/159", "sentence": ["…岐にわたる新たな課題の出現等を踏まえまして、有識者の方には、事前に政府側から有識者の発言を開示することはしないので忌憚なく意見を開陳してほし…", "…す。このため、有識者との信頼関係維持等の観点から、現時点において、政府側から意見交換の内容を公表することは差し控えさせていただきたいというふ…"]}]}]}]