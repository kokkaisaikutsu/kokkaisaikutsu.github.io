[{"date": "2022-10-28", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/33", "sentence": ["…であります。そして、台風十五号では、静岡県で十二時間で四百ミリ以上の降雨、残念ながら三名の方が犠牲になられました。そして、その復旧は進んでい…", "…屋、私、地元は名古屋でありますが、新幹線に乗っておりましたときにこの大雨に遭遇しました。急に大雨が降ってきて新幹線が止まって、私が乗った列車…", "…りますが、新幹線に乗っておりましたときにこの大雨に遭遇しました。急に大雨が降ってきて新幹線が止まって、私が乗った列車はまだ一時間半ほど遅れた…", "…とおり、その後の新幹線はもっと遅れた、こういうような状況があって大変な雨だった。私も、列車の中からかいま見たといいましょうか、経験をしたわけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/41", "sentence": []}]}]}]