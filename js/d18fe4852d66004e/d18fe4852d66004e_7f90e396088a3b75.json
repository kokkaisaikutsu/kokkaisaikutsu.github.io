[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 経済産業委員会環境委員会原子力問題調査特別委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/57", "sentence": ["…ないということだと思うんです。さて、次の質問に行きたいと思います。避難計画の実効性、福島からの避難者についてということであります。二〇二一年…", "…難者についてということであります。二〇二一年三月の水戸地裁判決は、避難計画の実効性不備などを理由に、茨城県の東海第二原発の運転差止めを命じま…", "…原電が再稼働の事前同意を県や立地周辺六市村に求める大前提となる広域避難計画策定が進んでいないということであります。策定義務がある県と三十キロ…", "…で、昨年一年間で新たに作成した市町村はないと報道されています。この避難計画の策定義務のある県と十四市町村の避難対象者の数は何人であって、避難…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/59", "sentence": ["…ざいます。状況によっては避難、退避もということでありますが、ただ、避難計画は、最悪というか、とにかく厳しいときにどういうふうに対応するかとい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/75", "sentence": []}]}]}]