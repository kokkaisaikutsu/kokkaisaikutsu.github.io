[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 経済産業委員会環境委員会原子力問題調査特別委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/49", "sentence": ["…の福島第一原発事故では、使用済核燃料プールへの放水活動、これは、東京消防庁を始めとする大阪市、横浜市、川崎市といった大都市の消防本部に属する…", "…十六日に予算委員会の第二分科会で私は質問させていただきました。当時の消防庁次長は、東日本大震災で東京消防庁等が行っていただいた放水作業あるい…", "…私は質問させていただきました。当時の消防庁次長は、東日本大震災で東京消防庁等が行っていただいた放水作業あるいは冷却作業、そういったことは基本…", "…ますが、基本的にはオンサイトについては事業者が行うということであり、消防庁としては今申し上げたように想定していないという答弁だったわけであり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/51", "sentence": ["…的にはオンサイトは事業者だというふうに規定しているんだと思うんです。消防庁は基本的にはやらないということなんだと思うんです。そして、いろいろ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/53", "sentence": ["…認したいと思います。当時は、ある種の特別な状況の中で当時の政権が東京消防庁に依頼をしてやった、例外的な対応だったと思います。例外的な対応であ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/75", "sentence": []}]}]}]