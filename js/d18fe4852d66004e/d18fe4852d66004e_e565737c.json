[{"date": "2022-12-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/36", "sentence": ["…より、米軍に通報を求める根拠が明確になったと思います。これまでも、在日米軍基地から出ているのではないかと、ＰＦＯＳ、ＰＦＯＡ、このことについ…", "…通報を求める根拠は明確になったんだと私は思うんです。これまで以上に在日米軍に対してきちんと対応するよう求めるべきだと思いますけれども、いかが…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/38", "sentence": ["…いうことであります。先ほど申し上げましたように、日本でも、この問題、日米地位協定があったりして、日米地位協定の中で、私は一つの課題として、な…", "…し上げましたように、日本でも、この問題、日米地位協定があったりして、日米地位協定の中で、私は一つの課題として、なかなか米軍の基地内の調査等々…", "…行われていない、こういう課題もあると思うんですね。そういう意味では、日米合同委員会もあるわけでありまして、そして、今申し上げましたように、米…", "…衛省の北尾審議官にもお答えいただきましたけれども、私は環境省としても日米合同委員会の環境の関係のところでしっかりと主張していただきたいと思う…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/68", "sentence": []}]}]}]