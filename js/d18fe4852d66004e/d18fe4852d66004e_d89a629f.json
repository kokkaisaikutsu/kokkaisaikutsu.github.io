[{"date": "2022-10-28", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/23", "sentence": ["…射線の問題があって、大臣も御承知のとおり、家族が分断をされてしまう。高齢の方は、こういう言い方をするとあれですが、やはり高齢の方は早く戻りた…", "…をされてしまう。高齢の方は、こういう言い方をするとあれですが、やはり高齢の方は早く戻りたいということがある、しかし、若い方は、若い夫婦、子供…", "…難生活を余儀なくされることになるわけであります。被災、避難者の多くが高齢化していることを重く考えて、行政の都合だけで解除の手順、方法を決める…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/29", "sentence": ["…中で、先ほど申し上げました、あれから時間がたつ中でそれぞれの皆さんが高齢化をしていくわけであります。そして、長いこと地元に戻れない、生まれ育…", "…、例えば、そうしたそれぞれの個別の事情に応じてなるべく制限なく、特に高齢の方からはそういう要望が多いと思いますけれども、制限のない立入りとか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/37", "sentence": ["…いう指摘をさせていただきました。残念ながら温暖化の影響です。そして、高齢化社会というものもあります。廃棄物行政ですから環境省の所管であります…", "…特に、清掃職員というものは非常に大きく減少しています。しかしながら、高齢化社会の中で、ごみを家庭に取りに行く、高齢者が出てこられない、家庭に…", "…しています。しかしながら、高齢化社会の中で、ごみを家庭に取りに行く、高齢者が出てこられない、家庭に一部入るようなところがある、そうするとプラ…", "…いて環境、廃棄物行政の業務執行に当たり、今申し上げた自然災害あるいは高齢化社会、こうした課題に確実に対応できるような体制の確保が必要だと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/41", "sentence": []}]}]}, {"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 経済産業委員会環境委員会原子力問題調査特別委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/49", "sentenc