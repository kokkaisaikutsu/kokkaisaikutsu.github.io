[{"date": "2022-10-28", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/33", "sentence": ["…いう中で、環境省が行っている電力レビューのことであります。環境省は、電気事業分野は我が国全体のＣＯ2排出量の約四割を占める最大の排出源であり…", "…の排出源であり、他部門の排出削減努力にも大きく影響を及ぼすことから、電気事業分野の地球温暖化対策は温室効果ガス排出の大幅削減のための最も重要…", "…減のための最も重要な対策の一つとして、二〇一六年から二〇一九年まで、電気事業分野における地球温暖化対策の進捗状況の評価、いわゆる電力レビュー…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00220221028/41", "sentence": []}]}]}]