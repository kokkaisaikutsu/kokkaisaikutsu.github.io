[{"date": "2022-12-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/42", "sentence": ["…たいと思います。岸田首相は、今年一月の施政方針演説でアジア・ゼロエミッション共同体についてこのように述べられました。我が国が、水素やアンモニ…", "…整備をアジア各国とともに主導していくことです、いわばアジア・ゼロエミッション共同体と呼び得るものをアジア有志国と力を合わせてつくることを目指…", "…ゃいました。ＣＯＰ27では西村大臣もステートメントでアジア・ゼロエミッション共同体について触れておられますが、日本はアジアの有志国から成るプ…", "…省エネ、再エネ、水エネ、ＣＣＵＳなどの有効活用によりアジア・ゼロエミッション共同体構想の実現を目指しますと述べられて、実はアンモニアについて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/68", "sentence": []}]}]}]