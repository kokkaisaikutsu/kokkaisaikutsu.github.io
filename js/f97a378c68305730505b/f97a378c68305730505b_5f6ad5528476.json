[{"date": "2021-02-02", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414024X00520210202/30", "sentence": ["…何とか希望をつないでいただけるように、予備費を活用して新たな支援策を機動的に打ち出していくことが必要だと思います。菅総理に伺います。公明党は…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X00520210202/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X00520210202/34", "sentence": []}]}]}, {"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/223", "sentence": ["…要があると思います。総理として我が国への影響をどのように見ているのか、また機動的対応策はどのようにお考えになっているのか、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/225", "sentence": ["○竹谷とし子君国民生活を断じて守るため、機動的な対応策を重ねて強く求めます。政府は、ガソリンなどの小売価格の更なる上昇を抑えるために対策を速…", "…に速やかな対応をお願いいたします。また、時期を決めていない残りの二千億円についても機動的な対応をお願いしたいと思います。野田大臣に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/243", "sentence": []}]}]}]