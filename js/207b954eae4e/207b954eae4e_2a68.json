[{"date": "2023-05-31", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/160", "sentence": ["…期限は撤廃すべきだということを私は強く求めておきたいと思います。次に、株式会社商工中金法改定案について質問いたします。前回、二〇一五年の改正…", "…社商工中金法改定案について質問いたします。前回、二〇一五年の改正で、政府保有株式の売却期間というのはどういうふうに規定されているでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/162", "sentence": ["○笠井委員大臣に伺います。株式会社商工中金法制定時とその後の二回、二〇〇九年と一一年の改正では、いずれも五年から七年を目途とするとしていたの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/174", "sentence": ["○笠井委員国庫収入の最大化を図る考え方は変わらないと。では、その国庫収入を最大化するための株価水準というのは幾らになりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X01820230531/182", "sentence": ["…る保証なんかないじゃないですか。大臣、法律上、二年の期限が来たら政府は株を持てなくなる、今度やれば。それで、結局、期