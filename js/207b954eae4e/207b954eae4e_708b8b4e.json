[{"date": "2021-02-26", "meeting": [{"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/146", "sentence": ["…大臣が、有識者委員会の検証ということで、原因究明をめぐって、十二日の議事概要、私も見ましたが、特殊な地盤条件下においてというふうに言っている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/148", "sentence": ["…った数については、適切だったか検証したのか。その二十四本を適切だと検証したということについて、議事概要ではどのように書いているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/150", "sentence": ["…ので、それは二十四本で事前調査は適切だったのか、その検証についてこの議事概要にどう書いてあるかと言われたら、今、別のことを言われたんですね。…", "…てくると思うんです。つまり、異常が起こった際の事業者の対応が適切だったか検証したということに関して、議事概要にはどう書いてあるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405273X00220210226/179", "sentence": []}]}]}, {"date": "2022-04-05", "meeting": [{"mee