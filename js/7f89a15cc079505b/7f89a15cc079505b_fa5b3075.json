[{"date": "2022-10-27", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/193", "sentence": ["…き、ありがとうございます。本日は、大臣所信に対する質疑ということで、寺田大臣、よろしくお願いいたします。総務省は八月に令和五年度地方財政収支…", "…で、感染症対策、原油価格、物価高騰対策等の財源確保、その影響を考慮した財政支援措置が必要だと考えますが、寺田大臣の御所見をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/197", "sentence": ["…の検証が十分に生かされず発生をし、そして多発をいたしております。この事態に対して、所管する総務大臣として、寺田大臣の見解をお尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/199", "sentence": ["…ローミング導入というものを議論をされていると聞いております。このことについて、今後の方針も含めて、寺田大臣の御見解をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/209", "sentence": []}]}]}, {"date": "2022-11-17", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/159", "sentence": ["…経営方針に対しても適宜適切なタイミングで国民の声が伝わらないことにつながるのではないかと考えます。寺田総務大臣の御見解をお尋ねをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/161", "sentence": ["…ついて、公共放送の役割としての視点からどのように考えておられるのか、ＮＨＫ会長の見解、そして寺田総務大臣の見解をそれぞれお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/166", "sentence": ["…値下げについての言及があったような内容の報道がございましたけれども、寺田総務大臣の御見解、どのような受け止めで、どのような御発言をされていた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/172", "sentence": []}