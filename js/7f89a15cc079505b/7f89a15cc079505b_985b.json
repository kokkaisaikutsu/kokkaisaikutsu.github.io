[{"date": "2022-04-05", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/186", "sentence": ["…、二〇一八年の厚労省の統計不正を受けまして新設をされました統計分析審査官、これを各省庁に配置をされましたけれども、これが十分に機能していない…", "…るまでこの事態を把握することができておりませんでした。この統計分析審査官の役割が十分に果たせるように、体制強化、どのように取り組んでいかれる…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/192", "sentence": ["…先般、総務大臣にもお尋ねをさせていただきましたので、本日は鳩山二郎政務官にお尋ねをさせていただきたいと思います。先ほど守島委員からもございま…", "…積極的に、その制度整備に是非お取組をいただきたいと考えておりますけれども、市長を経験された鳩山政務官にその御所見をお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00920220405/194", "sentence": []}]}]}, {"date": "2022-04-19", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/164", "sentence": ["…、ありがとうございました。今、副大臣から御説明があったような形で、審査官という形で新しく設置をされるということで、審査官自体は一名ということ…", "…あったような形で、審査官という形で新しく設置をされるということで、審査官自体は一名ということで、そのチームを組まれるというふうに御説明を受け…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/176", "sentence": []}]}]}]