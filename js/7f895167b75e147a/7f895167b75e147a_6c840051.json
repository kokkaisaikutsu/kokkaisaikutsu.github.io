[{"date": "2023-03-08", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104080X00120230308/4", "sentence": []}]}, {"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00720230308/24", "sentence": []}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/186", "sentence": ["…ましい事案であります。誠に遺憾であるというふうに私も感じております。葬儀業界では、御遺体に対する敬意や関係法令の遵守といった葬儀サービス提供…", "…ております。葬儀業界では、御遺体に対する敬意や関係法令の遵守といった葬儀サービス提供に当たっての原則、これを規定をいたしましたガイドラインを…", "…則、これを規定をいたしましたガイドラインを策定しております。葬祭業、葬儀業を所管する経産省としては、この御遺体を取り扱う葬儀業界の信頼性の確…", "…ります。葬祭業、葬儀業を所管する経産省としては、この御遺体を取り扱う葬儀業界の信頼性の確保に向けて、それぞれの葬儀事業者あるいは従業員の皆様…", "…ては、この御遺体を取り扱う葬儀業界の信頼性の確保に向けて、それぞれの葬儀事業者あるいは従業員の皆様に、方々において改めてこのガイドラインの趣…", "…のガイドラインの趣旨が徹底されるように、業界団体に対して注意喚起を行い、葬儀業界全体としての取組を促していきたいというふうに考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/258", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/302", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/304", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/306", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/325", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/327", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00720230308/329", "sentence": []}]}]}]