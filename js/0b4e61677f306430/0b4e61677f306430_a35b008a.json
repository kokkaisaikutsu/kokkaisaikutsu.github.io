[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/49", "sentence": ["…本金十億円以上で常時使用従業員千人以上の企業にマルチステークホルダー宣言を課しましたよね。何で、この十億円以上また千人以上だけにマルチステー…", "…課しましたよね。何で、この十億円以上また千人以上だけにマルチステークホルダー宣言をしたのか、これを聞きたいと思います。いかがでございますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/51", "sentence": ["…は、今は余り、これは皆さん、釈迦に説法だから言わないけれども、一つの宣言ですよね。僕は、十億以上じゃなくて、一億以上もどんどん課せばいいんで…", "…課せばいいんですよ。これをやりました、この関係はどうですか、どんどん宣言させればいいんだと思うんです。そこはちょっと、だんだん時間が迫ってき…", "…っしゃいましたね、さっき、答えでね。私は、このマルチステークホルダー宣言の中に、取引適正化とか、それから非正規社員に対する同一労働同一賃金の…", "…から非正規社員に対する同一労働同一賃金の徹底を含めるべきだと思っているんですよ、マルチステークホルダー宣言に。これはいかがですか、お考えは。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/53", "sentence": ["…から、再分配というんだったら、そういう人たちに行けるように、そこに、宣言の中に入れてくれということを議事録に残しておきたいと思いますので、是…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00520220216/64", "sentence": []}]}]}]