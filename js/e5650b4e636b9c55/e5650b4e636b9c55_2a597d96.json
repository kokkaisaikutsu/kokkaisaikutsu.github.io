[{"date": "2023-03-10", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/196", "sentence": ["○日下委員ありがとうございます。次に、国産の次世代型太陽電池、ペロブスカイトについてお聞きします。フィルム化され、軽量なため、屋根や壁面など…", "…た、先月、広島大学と京都大学の共同研究チームは、塗って作れる次世代の太陽電池であるＯＰＶについて、半導体ポリマーの結晶化促進により、有機太陽…", "…太陽電池であるＯＰＶについて、半導体ポリマーの結晶化促進により、有機太陽電池の高効率化、従来の約二倍に成功しております。私は、国内の工場など…", "…量で施工しやすいのが特徴でございますが、耐重性、重さには弱く、既存の太陽光パネルを設置している屋根は余り見かけません。炎天下など直射日光を受…", "…ても苦労されていると思います。環境省としても、企業等による自家消費型太陽光発電、自家消費ＰＰＡを促進しておられますが、初期投資ゼロ円で自家消…", "…、また、環境への影響も少ないものと思われます、スレート屋根の上に薄型太陽電池を設置するだけでも直射日光は防げますから、まさに一石三鳥の効果が…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00220230310/204", "sentence": []}]}]}]