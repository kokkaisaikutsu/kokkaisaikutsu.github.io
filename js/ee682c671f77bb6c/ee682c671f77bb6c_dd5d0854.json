[{"date": "2022-03-04", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/110", "sentence": ["…そんな中で、当委員会で、これは三月二日だったと思います。国民民主党の川合孝典議員が、ウクライナ大使が林外務大臣に対して面会を申し入れたんだけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/121", "sentence": ["…いらっしゃいますかね、事務方、いらっしゃいますね。先般の予算委員会、川合委員は、一か月も、面会を外務省に求めたが、一か月たっても面会をできて…", "…面会を外務省に求めたが、一か月たっても面会をできていないということを川合委員が質問をされたときに、そこの中で、外務省にそれを川合委員が確認を…", "…ということを川合委員が質問をされたときに、そこの中で、外務省にそれを川合委員が確認をされたら、外務省の方は、事実関係としては確かにそうである…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X0