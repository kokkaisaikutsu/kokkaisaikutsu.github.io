[{"date": "2022-03-04", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/110", "sentence": ["…に重要であるというふうに思っております。我が党の泉代表もウクライナの大使と二度にわたって面会をし、この予算委員会でも政府に要請をさせていただ…", "…し、この予算委員会でも政府に要請をさせていただきました。泉代表が直接大使から受けた要請、インフラの整備であったり、先ほど石垣委員も質問をされ…", "…れは三月二日だったと思います。国民民主党の川合孝典議員が、ウクライナ大使が林外務大臣に対して面会を申し入れたんだけれども、一か月も放置をされ…", "…のを承知していなかったということで御答弁をされました。そして、二日に大使と会われたんだと思うんですけれども、大臣は、面会要請があるということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/112", "sentence": ["…れは昨日ですか、これＴＢＳのニュースで、なぜ会えなかった、ウクライナ大使空白の一か月めぐり外務省と食い違いというニュースがこれ報道されて、先…", "…確認をしないといけないというふうに思っておりますので取り上げますが、大使は林大臣はすぐ対応してくれたというふうにツイートをされたと。恐らく二…", "…けれども、鈴木副大臣は、お越しになられ、あっ、いらっしゃいますね、鈴木副大臣は、大使から面会要請があると、それを認識したのはいつなんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/116", "sentence": ["○森本真治君大臣が、まず大使館からの面会要請が来たら事務方が整理しますね。政務三役にそれが上がると答弁をされたので、副大臣に対する依頼ではな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/123", "sentence": ["○森本真治君ちょっと外務省の手続について確認させてください。大使館から面会依頼が、政務三役等も含めて日本政府の方に面会依頼が来たときは、これ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/125", "sentence": ["…の口上書の以前に、例えば事務方とのいろんなやり取りの中で、ウクライナ大使からの面会要請というようなことが来ているというような、正式ではなくて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/132", "sentence": ["○森本真治君事前にいろんな大使館の方からも相談というか、そういう事務的なやり取りは恐らくあったんだということは今御答弁をされました。その中で…", "…うような対応というのは、この一か月も空いたということで、恐らくこれ、大使も、外務省との間には技術的レベルでの誤解がありましたというようなコメ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/134", "sentence": ["…情勢の中で、本当にウクライナの皆さんに寄り添って、恐らくウクライナの大使館の皆さんもかなり動揺していて冷静さがないような状況だと思うんですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/165", "sentence": []}]}]}]