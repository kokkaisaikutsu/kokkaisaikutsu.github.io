[{"date": "2021-05-13", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/24", "sentence": ["…すように、これ、全事業所、広島市と福山市なんですけれども、全事業所でＰＣＲ検査を受けてもらおうということで今事業者の方にお願いをしておるとこ…", "…んですけれども、例えば、営業自粛、独自に広島も始めましたが、従業員がＰＣＲ検査を受けてくれるお店に対しては支援金をちょっと多めに払いましょう…", "…夫をして広島県は努力をしておるんですけれども。ただ、この全事業所でのＰＣＲ検査というのも、何か専門家の皆さんのコメントが出るんですけれども、…", "…伺ったんですけれども、政府として、厚労省としては、この集中的に一斉にＰＣＲ検査をやっていこうということについてはどのように見解を持たれている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/26", "sentence": ["…ね。一方で、先ほどのちょっと政務官とのやり取りにもあったように、このＰＣＲの集中検査についても事業者の方からは不安の声というので、資料の一に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/47", "sentence": []}]}]}]