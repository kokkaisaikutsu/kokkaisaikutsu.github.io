[{"date": "2021-06-15", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X03120210615/4", "sentence": ["…ついても、衆議院では受け入れられなかった連合審査、参考人質疑を行い、参議院らしい質疑が重ねられてきたのです。立場の違いはありつつも、誰もが円…", "…いるのですか。国会軽視も甚だしいと断ぜざるを得ません。第四の理由は、参議院軽視の姿勢です。会期末が迫る中、参議院における十分な審議時間が確保…", "…ざるを得ません。第四の理由は、参議院軽視の姿勢です。会期末が迫る中、参議院における十分な審議時間が確保されないことが明らかな状況で、言わば荷…", "…より質疑が終局され、強行採決されたことは言語道断であります。その際、参議院に審議時間を確保するという大義名分があったと仄聞しておりますが、笑…", "…ますが、笑止千万であります。確かに、従来から、衆議院に対し二十日間の参議院の審議時間の確保についての配慮方を申し入れてきています。これはあく…", "…が前提であることは言わずもがなです。不正常な中で議決されたとなると、参議院での審議にはより時間が掛かるのは自明の理です。特に、本法案は、与党…", "…ように審議しろというのでしょうか。二院制の意義を没却するものであり、参議院軽視も甚だしく、怒りを覚えるものであります。そもそも、参議院での審…", "…であり、参議院軽視も甚だしく、怒りを覚えるものであります。そもそも、参議院での審議時間を確保しようというのであれば、全ての元凶が法案が未成熟…", "…り抜け、何としても成立させるために、わざわざ遅いタイミングで提出し、参議院での審議時間を確保するためという大義名分で衆議院の審議を切り上げよ…"]}]}]}, {"date": "2021-12-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/32", "sentence": ["…広島を訪問された歴史的な日があったわけでございます。私も、あのときは参議院の本会議があったんで、平和公園に御招待もいただいたんですが、参議院…", "…は参議院の本会議があったんで、平和公園に御招待もいただいたんですが、参議院議員は参加することはできませんでしたけれども、映像で見させていただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/42", "sentence": []}, {"url": "https://kokkai.ndl.