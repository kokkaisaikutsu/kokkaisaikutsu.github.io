[{"date": "2020-11-19", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/35", "sentence": ["…なかったという実情があります。この経過からも、生殖補助医療というのがいかに重いテーマであるかということも示唆されるところでもありますし、また…", "…、一体これまでなぜ議論が進んでこなかったのかというところ、大切な点だというふうに考えております。この点、石橋発議者、いかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/37", "sentence": ["…うにしていくべきかというのは、まだこれから様々な観点から議論を進めていかなければならないものだというふうに承知をしております。一方で、これま…", "…の実施が困難になっているというふうな状況もお聞きをしているところでもあります。この点につきまして、発議者の古川議員、いかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/41", "sentence": []}]}]}, {"date": "2021-05-11", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/69", "sentence": ["…中で、特定少年に対する調査、処遇についても健全な育成を期すという少年法の目的及び理念が及ぶということでよいかどうか、確認をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/87", "sentence": ["…だけでは足りないというふうに考えます。犯情とともに要保護性についても十分な調査、鑑別が必要であると考えますけれども、この点いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/89", "sentence": ["…てよい特段の事情があるかどうかと、そこだけ調査すれば足りるんだということではないというふうに思いますけれども、大臣、いかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/91", "sentence": ["…対象事件における調査官調査の在り方、調査票の作成に対し、最高裁からはいかなる考え方また方向性を示しているのかという点について改めてお聞きいた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/95", "sentence": ["…るんだと思うんですけれども、なぜそこで得られた情報をはしょる必要があるのかというのが全く分からないんですが、この点、いかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/99", "sentence": ["…な調査がなされていないという批判、たくさんされていることはもちろん最高裁は御存じだと思いますが、その点についての受け止め、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/101", "sentence": ["…が改正されても全く変わらないというふうに思っているところです。これをいかに裁判官や調査官に周知徹底するのか、きちんと運用してもらうのかという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/103", "sentence": ["…範囲内で要保護性に応じた処分の決定を行うという考え方かと思うんですが、この考え方でいいかどうかについてまず確認させていただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X01220210511/119", "sentence": []}]}]}]