[{"date": "2020-11-19", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/39", "sentence": ["…今後とも御指導いただければというふうに思います。では、最後に発議者の秋野議員にお伺いをいたします。秋野発議者は平成二十四年から本法案に携わっ…", "…うふうに思います。では、最後に発議者の秋野議員にお伺いをいたします。秋野発議者は平成二十四年から本法案に携わってきておられるということをお聞…", "…今審議に至っているわけですけれども、この法案審議に当たるまでの所感であったり、また今後の決意について、秋野議員からお願いできますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315206X00320201119/41", "sentence": ["○伊藤孝江君ありがとうございます。今、秋野議員からもいただきましたけれども、本当に、生まれてくる子供、また出産をすることになる、また人工授精…"]}]}]}, {"date": "2021-03-08", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/268", "sentence": ["…隊の協力が必要になりますが、昨年四月、参議院外交防衛委員会で我が党の秋野議員の質問に対し、当時、河野大臣が、「今後とも、消防庁もし検討される…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/290", "sentence": []}]}]}]