[{"date": "2021-03-08", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/280", "sentence": ["…進むよう、どうかよろしくお願いいたします。続きまして、ワクチン接種の看護師の確保についてお伺いをいたします。小規模の自治体におきまして、ワク…", "…に一括で委託をせざるを得ないというようなところもあります。ところが、看護師の派遣が認められないということの中で、民間業者としてはこの看護師さ…", "…が、看護師の派遣が認められないということの中で、民間業者としてはこの看護師さんを手配できず、自治体自身で取り組まなければならない、そのために…", "…種準備が進んでいないというところもあります。このワクチン接種のための看護師の確保に関しまして、厚労省として、紹介事業の周知など、自治体が現時…", "…明確に示して周知徹底をしていただきたい。また、全ての自治体が最終的に看護師を確保できるまで国が側面から様々に支援をしていただきたいというふう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00620210308/290", "sentence": []}]}]}, {"date": "2021-04-06", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/51", "sentence": ["…確保につきまして、この四月から、へき地においてはワクチン接種会場への看護師等の労働者派遣が可能となったところです。ただ、このへき地という縛り…", "…いう縛りがありますので、そうではない接種対象者が多い都市部においても看護師確保に御苦労されているという切実な声も伺っておりますし、また知事会…", "…ますし、また知事会からも、へき地と同様に、へき地以外の地域においても看護師及び准看護師の労働者派遣を可能とするなど国として必要な支援を行うと…", "…知事会からも、へき地と同様に、へき地以外の地域においても看護師及び准看護師の労働者派遣を可能とするなど国として必要な支援を行うという要望がな…", "…いるというふうに承知をしているところです。この現場の声に耳を傾けて、看護師等を確保するためのあらゆる選択肢を用意すべきだというふうに考えます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00520210406/53", "sentence": []}]}]}]