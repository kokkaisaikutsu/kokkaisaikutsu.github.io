[{"date": "2023-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/14", "sentence": ["…ってくれている自衛隊の人材確保と処遇改善について伺います。これまで、防衛省・自衛隊として人材確保に取り組んできたというふうに理解しております…", "…低く、特に任期制の士の確保に困難があると聞いています。この点も含め、防衛省として人材確保にどのように取り組むのか、井野防衛副大臣に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/16", "sentence": ["…て自衛隊について知る教育を行うべきと考えますが、子供たちの国防意識を高めるための施策について、これは防衛省側の見解をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/18", "sentence": ["…十分ではない、そうした話も伺います。このような処遇の現状を早急に改善しなければならないと考えますが、井野防衛副大臣はいかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/27", "sentence": []}]}]}]