[{"date": "2023-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/10", "sentence": ["…いを申し上げ、次の質問に入ります。犯罪や非行をした人たちに寄り添い、社会復帰をサポートする保護司について伺います。経済、教育、福祉、あらゆる…", "…、教育、福祉、あらゆる活動を行う上で、平和や独立、治安、秩序といった社会環境がしっかり保たれているということは大きな前提となるわけであります…", "…。そこで、保護司制度が今までどおり十分に機能して、安全、安心な日本の社会を維持できるようにするためにはどのようなことが必要と考えるか、門山法…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/27", "sentence": []}]}]}, {"date": "2024-03-15", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121315261X01020240315/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01020240315/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01020240315/28", "sentence": ["…きに御検討いただきたいというふうに思っています。次に、日本が活力ある社会であり続けるためには、真面目に努力した人が正当に報われる社会、頑張れ…", "…活力ある社会であり続けるためには、真面目に努力した人が正当に報われる社会、頑張れば必ず報われる、そう実感できる社会でなければなりません。私は…", "…努力した人が正当に報われる社会、頑張れば必ず報われる、そう実感できる社会でなければなりません。私は、教育こそこの視点が重要だと考えております…", "…を防ぎ、一生懸命努力すればその努力が将来報われると学生が希望を持てる社会にしていかなければならない、強くそう考えています。そのために政治がす…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01020240315/30", "sentence": []}, {"ur