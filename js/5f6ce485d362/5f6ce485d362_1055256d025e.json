[{"date": "2023-08-08", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/3", "sentence": ["…百六十六件の土砂災害などの被害が発生しております。また、佐賀県では、唐津市から佐賀市の山間部で最大時間雨量九十二ミリが観測され、七月二十日現…", "…軽減に向けた予算措置の必要性などについて意見交換を行いました。次に、唐津市浜玉町平原今坂地区において、佐賀県県土整備部永松理事及び農林水産部…", "…理事及び農林水産部島内副部長から、それぞれ佐賀県の被害状況、並びに峰唐津市長から唐津市の被害状況を聴取するとともに、同地区の土石流被害現場を…", "…水産部島内副部長から、それぞれ佐賀県の被害状況、並びに峰唐津市長から唐津市の被害状況を聴取するとともに、同地区の土石流被害現場を視察しました…", "…が発生しており、復旧のための一層の支援が求められております。最後に、唐津市役所において、落合佐賀県副知事、峰唐津市長、池田佐賀市副市長、深浦…", "…求められております。最後に、唐津市役所において、落合佐賀県副知事、峰唐津市長、池田佐賀市副市長、深浦伊万里市長から、それぞれ被害状況の説明を…", "…市長から、それぞれ被害状況の説明を改めて聴取するとともに、佐賀県及び唐津市から、激甚災害指定の早期指定、農林水産事業者支援の必要性、国土強靱…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/134", "sentence": []}]}]}]