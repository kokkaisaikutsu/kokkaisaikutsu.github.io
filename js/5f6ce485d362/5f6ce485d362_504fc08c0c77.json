[{"date": "2023-08-08", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/3", "sentence": ["…日、令和五年梅雨前線による大雨に係る被害状況等調査のため、福岡県及び佐賀県に委員派遣を行いましたので、派遣委員を代表いたしまして、私から調査…", "…の住家被害や百六十六件の土砂災害などの被害が発生しております。また、佐賀県では、唐津市から佐賀市の山間部で最大時間雨量九十二ミリが観測され、…", "…ついて意見交換を行いました。次に、唐津市浜玉町平原今坂地区において、佐賀県県土整備部永松理事及び農林水産部島内副部長から、それぞれ佐賀県の被…", "…いて、佐賀県県土整備部永松理事及び農林水産部島内副部長から、それぞれ佐賀県の被害状況、並びに峰唐津市長から唐津市の被害状況を聴取するとともに…", "…めの一層の支援が求められております。最後に、唐津市役所において、落合佐賀県副知事、峰唐津市長、池田佐賀市副市長、深浦伊万里市長から、それぞれ…", "…深浦伊万里市長から、それぞれ被害状況の説明を改めて聴取するとともに、佐賀県及び唐津市から、激甚災害指定の早期指定、農林水産事業者支援の必要性…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/134", "sentence": []}]}]}]