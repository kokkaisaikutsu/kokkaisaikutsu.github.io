[{"date": "2023-08-08", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/3", "sentence": ["…在で死者五名などの人的被害、四千六百二十棟の住家被害や百六十六件の土砂災害などの被害が発生しております。また、佐賀県では、唐津市から佐賀市の…", "…れ、七月二十日現在で死者三名などの人的被害、約百四十棟の住家被害や土砂災害などの被害が発生しております。さらに、河川や道路等の公共インフラ、…", "…から千之尾川の土石流による被害状況について説明を聴取するとともに、土砂災害警戒区域等における被害状況、災害関連緊急砂防事業の採択状況、河川の…", "…、災害関連緊急砂防事業の採択状況、河川の流木捕捉のための取組状況、土砂災害の未然防止のための対策状況、県による治山対策状況、豪雨災害により変…", "…等に関して意見交換を行いました。今回の被害は、流域周辺の山林からの土砂災害で千之尾川の本来の流路が変わるといった影響が考えられることから、流…", "…同地区では、過去にも甚大な被害を受けていたため、その教訓を踏まえた土砂災害対策等を進めてきた場所でありますが、今般の災害においても、同様な被…", "…豪雨被害対策に関する提案がありました。また、内水氾濫対策の重要性、土砂災害対策として有効な砂防ダム等の整備状況及び課題、避難指示発令の在り方…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00820230808/134", "sentence": []}]}]}]