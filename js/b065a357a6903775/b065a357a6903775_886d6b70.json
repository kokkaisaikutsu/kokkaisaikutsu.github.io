[{"date": "2022-06-03", "meeting": [{"meeting_name": "衆議院 安全保障委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/57", "sentence": ["…に、沖縄県内の海兵隊基地や施設で、ＰＦＯＳやＰＦＯＡを高濃度で含む泡消火剤を全て代替品に交換したと発表しております。新たな消火剤は米国防総省…", "…高濃度で含む泡消火剤を全て代替品に交換したと発表しております。新たな消火剤は米国防総省の要求を満たし、火災時にこれまでと同等の効果を発揮する…", "…ますが、その製品名や安全性について明確に説明をしておりません。新たな消火剤の製品名、新製品の安全性、特にＰＦＯＳを含まないのかどうか等につい…", "…側に確認をしているのでしょうか。まず、これが一点。そして、県内の海兵隊以外の施設の泡消火剤も新製品に代わっているのかを確認したいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/59", "sentence": ["○新垣委員新製品に全て泡消火剤は交換した、特に海兵隊はやりましたよということですが、ただ、普天間基地周辺では、飲み水ではないんですが、湧き水…", "…たいと思っているんですが、じゃ、いつまでに海兵隊、普天間基地以外の泡消火剤の製品を替えるということが、まあ、確認中と言っているんですが、いつ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00720220603/73", "sentence": []}]}]}]