[{"date": "2020-12-02", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/10", "sentence": ["○秋野参議院議員私の方から、附帯決議の意義につきまして御答弁をさせていただきたいと思います。参議院における法案審議を通じまして、与野党、会派…", "…す。参議院における法案審議を通じまして、与野党、会派を超えて多くの附帯決議を賜ったところであります。これらは検討すべき事項にとどまらず、留意…", "…留意すべき事柄についても細かくいただきまして、今後の議論はこれらの附帯決議に沿って行われるべきことと、発議者一同、考えております。また、附帯…", "…決議に沿って行われるべきことと、発議者一同、考えております。また、附帯決議がなされたこと自体がこの法案提出を契機としたものと御評価をいただけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/124", "sentence": ["…討をするということとしているとともに、参議院の法務委員会におけます附帯決議においては、政府は、生殖補助医療の質の確保のために、自由診療のもと…"]}]}]}]