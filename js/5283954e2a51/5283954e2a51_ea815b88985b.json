[{"date": "2023-04-26", "meeting": [{"meeting_name": "衆議院 沖縄及び北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/63", "sentence": ["…職する機会もございます。御承知のように、八割ぐらいの人が陸上自衛隊、自衛官の場合は高卒の方がなられているかというふうに思いますので、僕自身も…", "…ていて、募集相談員の役割もお引受けして、高校生や保護者の皆さんにも、自衛官の仕事の大切さというのは理解をしながら伝えてきたつもりでもあります…", "…のは理解をしながら伝えてきたつもりでもあります。一方では、逆に、今、自衛官の募集も大変厳しくて難しい中で、こういった事故が、未然に防ぐような…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/65", "sentence": ["…したが、全ての分野で今人材が不足しているところですから、これは決して自衛官だけではないというふうに思いますので、給料を上げれば人が集まるわけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103895X00320230426/79", "sentence": []}]}]}]