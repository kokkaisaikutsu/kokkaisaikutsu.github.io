[{"date": "2022-11-29", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005254X01220221129/13", "sentence": ["…きると強く期待しております。さて、私は、会派を代表して、令和四年度補正予算案に反対の立場から討論をいたします。今回の補正予算では、長期化する…", "…積み増しました。その結果、今年度の予備費は、一般予備費を含めて、本補正予算案も合わせると十一兆七千六百億円に達し、大規模な予備費の計上は財政…", "…、政府・与党にその姿勢が見られないことは大変残念です。そもそも、本補正予算案の基盤となった政府の経済対策は、与党内の議論で増額要求が相次ぎ、…", "…持率の回復目当てに、額ありきで、一夜漬けで、密室で積み上げられた本補正予算案は、到底、国民全体の切実な声に応え得るものではありません。以上の…", "…、国民全体の切実な声に応え得るものではありません。以上の理由から本補正予算案に反対するものとし、会派を代表しての討論といたします。ありがとう…"]}]}, {"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00820221129/177", "sentence": []}]}, {"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/123", "sentence": []}]}]}]