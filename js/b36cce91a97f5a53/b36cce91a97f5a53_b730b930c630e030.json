[{"date": "2021-03-05", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/294", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/296", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/298", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/300", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/302", "sentence": ["○河野義博君ありがとうございます。次に、電力システム改革について梶山大臣に伺います。東日本大震災から十年がたちます。原発事故を契機に地域独占…", "…す。東日本大震災から十年がたちます。原発事故を契機に地域独占の電力システムを改めまして、電力の小売や発電事業の自由化、送配電部門の中立性の確…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/304", "sentence": ["…環境をしっかりこれ整備していかなければならないなと思っております。システム改革後は、発電所は各々の市場取引から得られる収入で投資コストを回収…", "…ですけれども、これはちょっと遅れております。そういったことも含めて、システム改革完遂に向けたこれ取組状況、これは政府参考人からお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/306", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/310", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/316", "sentence": []}]}]}, {"date": "2021-05-12", "meeting": [{"meeting_name": "参議院 資源エネルギーに関する調査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/75", "sentence": ["…題でありまして、早くやっぱり商業ベースに乗るような回収・リサイクルシステムというのを確立させなければならないし、その過程において立法府が果た…"]}]}]}]