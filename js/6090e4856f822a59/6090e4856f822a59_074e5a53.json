[{"date": "2022-03-29", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/92", "sentence": ["…たいと思います。先週、環境委員会で、我が党の漆間議員から、大阪・関西万博における国産木材の活用についての質問をしました。木材の利用拡大を促進…", "…いくとの御答弁をいただいております。会場に設けられる建物や設備などは万博が終わった後に会場から撤去されることになっていますけれども、博覧会協…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/94", "sentence": ["…で今活用されているということなんですけれども、国産の木材の活用では、万博だけではなくて、古代の宮殿の再建、こういったものも考えられるのじゃな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/97", "sentence": []}]}]}]