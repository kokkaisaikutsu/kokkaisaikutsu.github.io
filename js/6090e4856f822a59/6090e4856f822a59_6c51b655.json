[{"date": "2022-03-17", "meeting": [{"meeting_name": "衆議院 政治倫理の確立及び公職選挙法改正に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/53", "sentence": ["…挙運動についての質問をさせていただきたいと思います。今回の改正では、公営掲示板の費用について改定があった。一つの掲示板での区画数が多いと増額…", "…いと減額になります。実態に合わせた改定とのことで、一方で、木でできた公営掲示板に紙のポスターを貼ることをそもそも変えていくべきなんじゃないか…", "…も変えていくべきなんじゃないかなというふうに考えています。選挙では、公営掲示板にポスターを貼るのに人と労力を要します。公営掲示板ポスターは、…", "…います。選挙では、公営掲示板にポスターを貼るのに人と労力を要します。公営掲示板ポスターは、有権者に候補者を知っていただく点では非常に優れてい…", "…挙区のところを回って貼っていくのは非常に大変な作業になると思います。公営掲示板を電子化していく、こういったことで、ポスターを貼る手間であった…", "…者を含め様々な人が選挙に立候補できる、こういったことにもつながると思いますけれども、公営掲示板の電子化についてはどのようにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00420220317/65", "sentence": []}]}]}]