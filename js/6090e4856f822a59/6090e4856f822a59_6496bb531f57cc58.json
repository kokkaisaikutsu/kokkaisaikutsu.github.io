[{"date": "2022-03-08", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/134", "sentence": ["○遠藤（良）委員除去土壌については、総理官邸であったりとかの鉢植えで土を使われているということを聞いています。いろいろなところで今後、安全性…", "…性の確認をしてきましたが、問題はありませんでした。二〇四五年までに除去土壌等の県外処分の実現を図るとのことですが、それに向けて今後どのように…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/136", "sentence": ["…ばいいのかということを、本当に全体で考えていかないといけないです。除去土壌を用いた取組については、積極的に我々としても協力をしていきながら、…"]}]}]}]