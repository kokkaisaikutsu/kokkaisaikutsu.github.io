[{"date": "2022-04-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/97", "sentence": ["…ちろん必要だと思いますので、これが本当に重要だと思います。次に、竹のバイオマス発電についての質問をしていきたいと思います。今、各地で放置竹林…", "…の質問をしていきたいと思います。今、各地で放置竹林問題があって、竹をバイオマス発電に活用することも考えられると思うんですけれども、実際、竹と…", "…れると思うんですけれども、実際、竹というのはカリウムや塩素が多くて、バイオマス発電には適しないということを言われています。技術開発によって現…", "…ス発電には適しないということを言われています。技術開発によって現在はバイオマス発電は可能ということを聞いているんですけれども。最近、務台副大…", "…る竹林の竹からＪ２サッカーチームの応援グッズを作ったりとか、あとは、バイオマス発電の活用も目指しているというようなことを聞いています。他方で…", "…ジェクトから約十三億円の助成を受けて、ある企業が熊本県で竹を活用したバイオマス発電の実証実験を行っていました。しかし、生産開始が遅れ、昨年債…", "…に陥っています。建材製造以外、既にほかの企業に事業譲渡を行っておられます。竹のバイオマス発電の可能性と課題についてお尋ねをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/103", "sentence": []}]}]}, {"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第七分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/245", "sentence": ["○遠藤（良）分科員コーヒー残渣を炭にして、バイオ炭にして、農地への活用。これはＪクレジットで収益を得られるんじゃないかと思うんですけれども、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/247", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/249", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/251", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/253", "sentence"