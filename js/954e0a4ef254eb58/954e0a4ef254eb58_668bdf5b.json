[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/176", "sentence": ["…共産党の井上哲士です。まず、反社会的活動を繰り返してきた統一協会への警察の対応についてお聞きいたします。二〇〇七年から一〇年にかけて、統一協…", "…ず、必要な捜査がそれ以上進まなかったことで、結果的に組織的、継続的な犯行が続けられ、被害が増えたのではないか。警察の認識はいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/178", "sentence": ["…一協会が宗教法人の解散命令に発展しかねないと危惧をして、複数の有力な警察官僚出身の国会議員への庇護を求めたと。以降、警察が教団本部に迫った形…", "…をして、複数の有力な警察官僚出身の国会議員への庇護を求めたと。以降、警察が教団本部に迫った形跡はないとしています。これ以降、教団は改めて政治…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/180", "sentence": ["…べられました。そうであれば、私はやっぱり、こういう協会の捜査と国家、警察の対応がどうだったか、国家公安委員長のこういう姿勢が影響を与えなかっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/182", "sentence": ["…は、反省なしに真の改善はないということで、きちっと対応していただきたいと重ねて申し上げたいと思います。警察と国家公安委員長はこれで結構です。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00220221101/203", "sentence": []}]}]}]