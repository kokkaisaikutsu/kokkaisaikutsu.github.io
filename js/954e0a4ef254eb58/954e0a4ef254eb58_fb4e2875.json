[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/111", "sentence": ["…と思うんですね。非常勤職員のうち期間業務職員は二〇一一年に新設された任用・勤務形態ですが、当初の三万千五百二十六人から二〇二一年には三万九千…", "…三万九千五百八十七人と一・三倍に増加をしております。人事院にお聞きしますが、この期間業務職員というのはどういう官職に就く任用制度でしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/119", "sentence": ["…の増大に新規増員なしで対応しようというのは、本来、一時的な、臨時的な任用であるはずの非常勤職員に常勤職員の肩代わりをすることにほかならないと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/124", "sentence": []}]}]}]