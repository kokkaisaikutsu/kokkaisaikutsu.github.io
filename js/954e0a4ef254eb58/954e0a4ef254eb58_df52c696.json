[{"date": "2023-04-21", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X01720230421/19", "sentence": ["…お答えください。後藤大臣に法案について伺います。通常、業務委託では、募集、契約、発注という流れになります。一方、本法案は、第十二条で募集時の…", "…は、募集、契約、発注という流れになります。一方、本法案は、第十二条で募集時の的確な情報表示、第三条で発注時の給付の内容、報酬の額、支払期日等…", "…いるものの、業務委託契約締結時の条件明示義務がありません。これでは、募集時より発注時の報酬額が減額されていても、フリーランスは応じざるを得ず…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115254X01720230421/30", "sentence": []}]}, {"meeting_name": "参議院 北朝鮮による拉致問題等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115253X00320230421/117", "sentence": []}]}]}]