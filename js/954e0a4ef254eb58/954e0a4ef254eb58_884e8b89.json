[{"date": "2021-06-10", "meeting": [{"meeting_name": "参議院 内閣委員会、外交防衛委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/148", "sentence": ["…の例示がございました。小此木大臣にちょっと追加してお聞きしますけど、予見可能性の確保のために、閣議決定する基本方針で可能な限り具体的に例示す…", "…示すると答弁をしてこられました。そうしますと、例示されていないものは予見可能性がないわけですね。そういうものについてはこの機能阻害行為には当…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/150", "sentence": ["…すから、住民にとっては、例示されてないものがどうなるかというのは全く予見ができないという状況なんですね。この問題で小此木大臣は、命令を行う前…", "…付きの命令が行われるわけですよ。勧告されるまで何が機能阻害行為になるか分からないということでは、住民は全く予見できないんじゃないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415356X00120210610/170", "sentence": []}]}]}]