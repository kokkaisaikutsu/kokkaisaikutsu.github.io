[{"date": "2022-12-07", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/69", "sentence": ["…田中（健）委員国民民主党、田中健です。よろしくお願いします。本日は、宮下先生、川井先生、朝からお越しいただきまして、ありがとうございます。是…", "…りがとうございます。是非よろしくお願いをいたしたいと思います。まず、宮下参考人にお伺いしたいと思います。これまで霊感商法等の悪質商法への対策…", "…まして、私も何度か見せていただきました。この報告書を出されたときに、宮下参考人は、いろいろと御意見はあったけれども、現状を踏まえればかなり踏…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/73", "sentence": ["…は反するんじゃないかという思いを持っていますが、これについて、川井先生、また宮下先生、それぞれの認識をお聞きをさせていただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/80", "sentence": ["…を設けて救済を広げるというようなことができないかと思ったんですけれども、これはそれぞれ、川井先生とまた宮下先生、御見解を伺えればと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/83", "sentence": ["…ができないかと思っているんですけれども、そのような基準をつくることについては、それぞれ、宮下参考人、川井参考人、どのようにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/418", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/420", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/422", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/424", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/426", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/428", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/430", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/432", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/434", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/436",