[{"date": "2020-11-04", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/431", "sentence": ["…我々維新の会、これまで進めてきた、我々はベストだと思ってやってきた統治機構改革である大阪都構想、恐らくこれで、チャレンジすることは恐らくもう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/433", "sentence": ["…が出ました。だからといって我々、大都市の改革の必要性がなくなった、統治機構改革の必要性がなくなったとは思っておりません。我々はやはり、時々報…", "…頼りの運営をせざるを得ないのが現状です。そういう意味で、これからも統治機構の改革をすべきだと私どもは思っておりますけれども、総理はいかがでし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/435", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/437", "sentence": ["…ましたので、そういったことも選択肢の一つだと思っています。我々は、統治機構の改革を憲法改正の項目にも掲げて今までやってきています。その中で、…", "…ってきています。その中で、できることをやってきたというつもりです。統治機構改革というのを、頂上を諦めるつもりはありません。登山ルートは今度変…", "…えてまた議論していきたいと思っておりますけれども、政府としても、そういった統治機構の改革について前向きに検討されるという考えはございますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/439", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/441", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/443", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/445", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/447", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/449", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/451", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/453", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/455", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/457", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/459", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/462", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/464", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00320201104/46