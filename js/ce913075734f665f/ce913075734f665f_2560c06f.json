[{"date": "2022-06-08", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/71", "sentence": ["…この同じ日の発言で、これまたもう一つ、私は気になる発言があるんです。急激な変動ではなく安定的な円安方向の動きであれば、経済全体にプラスに作用…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/77", "sentence": ["…ゃったんですが、残っていただいているのは、おとといの発言というのは、急激な変動ではなく安定的な円安の動きであればという言い方をしているんです…", "…変動ではなく安定的な円安の動きであればという言い方をしているんです。急激な変動は駄目だよ、でも安定的に円安ならばプラスの方向というお話ですよ…", "…向というお話ですよね。そこで、私は大臣にお聞きしたいんですけれども、急激な変動とか無秩序な動きじゃなくて、安定的に円安に動いているという場合…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X02020220608/85", "sentence": []}]}]}]