[{"date": "2022-02-09", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/44", "sentence": ["…年やったこと、おととしやったことは、通常だったら何百万人も確定申告の会場に来るのを、期間を延ばすことによって密を避けようという措置じゃないで…", "…、確定申告に行って感染したという人はいなかったと思います。確定申告の会場がクラスターを発生した、なかったと思います。効果があったんじゃないん…", "…、地元の税理士会の皆さんがいわゆるボランティアでやっている無料相談の会場に行ったんです。そうすると、やはりｅ―Ｔａｘとは無関係な、お年を召し…", "…、いっぱい持ってきているんですよね。その人たちが、これから確定申告の会場、そういう年代の人たちがいっぱい行くと思いますよ。そうすると、医療費…", "…ような高齢者、重症リスクを持っている人たちが残念ながら集まってしまう会場になりかねない。だとするならば、去年もおととしも感染者が出なかった、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/68", "sentence": []}]}]}]