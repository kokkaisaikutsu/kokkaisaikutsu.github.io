[{"date": "2021-04-26", "meeting": [{"meeting_name": "参議院 行政監視委員会国と地方の行政の役割分担に関する小委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415352X00220210426/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415352X00220210426/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415352X00220210426/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415352X00220210426/16", "sentence": ["…土交通省の更なるバックアップをお願いするということで、今日は朝日大臣政務官にも御出席いただいております。政務官も、私はいつもこの主張をしてい…", "…するということで、今日は朝日大臣政務官にも御出席いただいております。政務官も、私はいつもこの主張をしていますからよくお聞きしていただいておる…", "…らよくお聞きしていただいておると思いますし、東京でも西多摩地区、もう政務官も、大臣政務官もよく私の地元の方にも来ていただいておりますから、ど…", "…ていただいておると思いますし、東京でも西多摩地区、もう政務官も、大臣政務官もよく私の地元の方にも来ていただいておりますから、どういう地域状況…", "…この地域の一番身近な乗り合いバスが本当に必要になっています。朝日大臣政務官に最後ここはお聞きをして、本当に力強い答弁をいただきたいところであ…", "…で以上の国の役割、責任を果たすことが求められていると思いますけれども、朝日大臣政務官、御答弁をお願いしたいと思います。よろしくお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415352X00220210426/18", "sentence": ["○森屋隆君朝日大臣政務官、ありがとうございます。そういったガイドラインを、分かりやすいガイドラインを地方行政に出していただいて、あるいは今回…"]}]}]}, {"date": "2022-04-21", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/49", "sentence": ["…いろんなものが上がっているというんですけれども、大臣は国土交通大臣の政務官も歴任している見地から、今の状況についてコメントいただければ有り難…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00920220421/67", "sen