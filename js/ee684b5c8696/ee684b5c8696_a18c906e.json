[{"date": "2022-03-18", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X00820220318/35", "sentence": ["…政の見通しを厚生労働大臣に伺います。また、今回の特例措置延長によって財源不足に陥り、雇用保険制度の各給付の支給が滞る事態だけは避けなくてはな…", "…感染症対応という事情によるものであることを踏まえると、令和四年度中に財源不足に陥ったときには、保険料率の引上げや給付の削減ではなく、国庫から…", "…などには、時点を問わず雇用保険部会に報告し、財政安定化のために必要な財源の内容やその確保策も含めて議論を行い、その意見を踏まえて必要な対応を…", "…繰入れが必要との結果に至った場合には、財政当局とも議論を行い、必要な財源を確保する、そうお約束いただけないでしょうか。厚生労働大臣の御決意を…"]}]}]}, {"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/92", "sentence": ["…々増しているようでありますから、今大臣が御答弁いただいたように、是非財源も含めて、人員も含めてよろしくお願いしたいと、こういうふうに思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/104", "sentence": []}]}]}]