[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/96", "sentence": ["…審議でも様々な課題が指摘されてきました。具体的には、児童福祉司に人事異動があるために専門性の積み上げがなかなか難しいのではないかということで…", "…ているのかということについても少し伺っていきたいと思います。この人事異動の課題に関して、前回の法改正のときにも、この衆参両院の附帯決議におい…", "…十分な経験を積み上げることが必要不可欠であることから、当該職員の人事異動等に際し、地方自治体に対し配慮を求めるなど、必要な措置を講じることな…", "…いますが、政府は、この附帯決議を踏まえ、児童福祉司について頻繁な人事異動が行われないよう配慮を求めるなどの措置、この措置をどのように講じてき…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/98", "sentence": ["○森屋隆君この人事異動の頻繁さについては、本改正案の審査においても何度も指摘がありました。例えば、先日の参考人質疑でも津崎参考人から、多くの…", "…て、そして安心して悩みを打ち明けられると、こうした観点からは、職員の異動頻度や担当者の変更の頻度などについてやっぱり下げていくべきではないか…", "…が求められる福祉職の地方公務員には、通常の行政職の職員と異なった人事異動のルールを設定することが必要ではないかと、こう思っています。そこで伺…", "…ます。そこで伺いますけれども、児童福祉司に携わるこの地方公務員の人事異動に関する特別なルールを設定するには、実際にはなかなか難しいということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/100", "sentence": ["○森屋隆君ありがとうございます。当然、それぞれの自治体の人事異動はこれ裁量でありますから、国がどうこうということは難しいのかもしれないですけ…", "…的なお願いもしているということで、理解をいたします。そして、この人事異動の頻度に関する問題意識、非常に高まっていることもこれ事実だと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/104", "sentence": []}]}]}, {"date": "2023-05-25", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114319X01520230525/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X01520230525/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X01520230525/14", "sentence": []}, {"url": "https:/