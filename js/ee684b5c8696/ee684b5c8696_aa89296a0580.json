[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/94", "sentence": ["…まれているのかもしれませんけれども、社会養育専門委員会の報告書では、親権者等が一時保護に同意した場合であっても、子供が一時保護されることに反…", "…でも、浜田参考人は、子供が一時保護されることに反対している場合でも、親権者等が同意すれば司法審査なく一時保護が開始されることになるため、子供…", "…の上で、子供が反対している場合にも一時保護が可能であるなら、その際、親権者の同意があれば司法審査を不要とした理由、これ併せて御説明いただきた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/104", "sentence": []}]}]}]