[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/15", "sentence": ["…も、本当に専門家の先生が多い中で素朴な質問で恐縮なんですけれども、臨床試験と治験について伺いたいと思います。厚労省のホームページのＱアンドＡ…", "…ームページのＱアンドＡでは、新型コロナワクチンは医療品開発に必要な臨床試験、括弧、治験のプロセスを経て世界中で承認されていますと、こういうふ…", "…中で承認されていますと、こういうふうに書いてあるんですが、ここでは臨床試験の後ろに括弧書きで治験というふうに書いてあります。両者が同一のもの…", "…けれども、しかし、国立がん研究センターのホームページなどを見ると、臨床試験は新しい治療法の安全性や有効性を確認するための試験のことを指しまし…", "…しい治療法の安全性や有効性を確認するための試験のことを指しまして、臨床試験のうち新しい医薬品や医療機器の製造販売の承認を国から得るために行う…", "…うと。まあ厳密には違う概念のように思われるんですけれども。そこで、臨床試験とこの治験の違い、その関係性について、それぞれ目的等に触れながら説…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/35", "sentence": []}]}]}]