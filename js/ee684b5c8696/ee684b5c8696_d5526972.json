[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/13", "sentence": ["…法の第八十三条において、これもこの間質問あったかと思いますけれども、動物のために使用されることが目的とされる医薬品等について、人のための医薬…", "…れると、こういうふうに聞いています。条文では、当該医薬品が有する対象動物について、残留性の程度から見て、その使用に係る対象動物の肉、乳その他…", "…品が有する対象動物について、残留性の程度から見て、その使用に係る対象動物の肉、乳その他食用に供される生産物で人の健康を損なうものが生産される…", "…があることというふうになっていると思います。人間が食する可能性がある動物以外、例えばペット等に対する医薬品もこの対象になるんでしょうか。また…", "…に対する医薬品もこの対象になるんでしょうか。また、対象となる疾病は、動物から人間には感染しない病気、動物だけが感染する病気もこの対象になるの…", "…でしょうか。また、対象となる疾病は、動物から人間には感染しない病気、動物だけが感染する病気もこの対象になるのか、併せてお聞きしたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01320220512/35", "sentence": []}]}]}]