[{"date": "2021-12-09", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715254X00220211209/2", "sentence": ["…害の際、安倍政権の失政、過ちにより、私の地元千葉で多数の家屋がブルーシートの設置がなされず、大きな被害が生じたからです。当時、外交防衛委員会…", "…員会所属であった私は政治的調整を行い、防衛省に二千名の自衛隊のブルーシート設置部隊を創設していただきました。しかし、それには政府の内閣府防災…", "…し、それには政府の内閣府防災などによる大きな抵抗がありました。ブルーシート設置の災害派遣要請の発動から一週間後の九月二十二日の日曜日の夜、南…", "…を実現することができました。増派された自衛隊部隊は、たくましくブルーシートの設置を進めてくれました。防衛省はその任務を調整する事務官を二名、…", "…る事務官を二名、千葉県に派遣してくれました。しかし、千葉県内でブルーシートの設置が必要な災害弱者以外の一般家屋が約千七百軒あるのに、晴れ渡っ…", "…れは、当時の森田県政が、自衛隊は高齢者などの災害弱者の家のみにブルーシートを設置し、一般家屋は設置しなくてよいという災害対策基本法、災害救助…", "…りませんでした。私が防衛省にお願いし、現地の自衛隊は一般家屋もブルーシートを設置をしますと千葉県、内閣府に内々に意思表示してくれましたが、拒…", "…内々に意思表示してくれましたが、拒否されています。また、張ったブルーシートは剥がれます。屋根の本格修理まで張り直しも自衛隊はやりますと防衛省…", "…府が調整に動くことはありませんでした。南房総には今でも剥がれたブルーシートの朽ちた家屋があり、多くの救われた暮らしの一方で、救えたはずの多く…", "…伺います。また、将来に備えて、自衛隊の災害派遣任務の一環としてブルーシートの設置訓練を行っていただきたいと思いますが、総理の見解をお伺いしま…"]}]}]}, {"date": "2022-05-30", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/179", "sentence": []}, {"url": 