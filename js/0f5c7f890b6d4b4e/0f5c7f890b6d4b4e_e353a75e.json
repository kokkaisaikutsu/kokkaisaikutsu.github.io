[{"date": "2022-11-16", "meeting": [{"meeting_name": "参議院 政治倫理の確立及び選挙制度に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/9", "sentence": ["○小西洋之君出納責任者が、なぜ第三者である寺田稔竹原後援会の口座を使って支払をすることができるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/11", "sentence": ["…挙が終わった後、なぜ大臣の、寺田大臣の集めた資金を使わずに竹原後援会にある口座、これ政治資金のはずなんですけども、それを使ったんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/13", "sentence": ["○小西洋之君じゃ、大臣の説明は、大臣の選挙資金が竹原後援会の口座に入っていたということをおっしゃっているんですね。端的に答えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/25", "sentence": ["…お金を出納責任者が、さっき聞いたら答えたんですが、なぜわざわざ竹原後援会の口座にお金を入れる必要があったんですか。これをまず答えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00520221116/44", "sentence": [