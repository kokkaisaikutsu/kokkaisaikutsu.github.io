[{"date": "2022-11-17", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/32", "sentence": ["…ことができる環境整備も含まれると考えております。谷間世代からの救済の願いに対する大臣の所見をお伺いしたいと思います。是非、若い人たちが希望を…", "…願いに対する大臣の所見をお伺いしたいと思います。是非、若い人たちが希望を持てるように、また納得がいくように応援の気持ちを込めてお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/40", "sentence": ["…国民の財産であり被害者遺族も公表を求めているので、もうちょっとはっきりと公表を明言していただきたいと思います。納得のいく説明をお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/42", "sentence": ["○牧山ひろえ君できるだけ納得がいくような公表をお願いしたいと思います。今回、詳細調査が決まったのは神戸家裁の事件のみです。神戸連続児童殺傷事…", "…を行って、さきに挙げたようなそのほかの重大事件の調査は行わない。整合性がないのではないかなと思うんですが、最高裁の御説明をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00720221117/56", "sentence": []}]}]}]