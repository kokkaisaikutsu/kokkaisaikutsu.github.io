[{"date": "2022-03-15", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/56", "sentence": ["…ての答弁は、次のようなものでした。災害関連税制の常設化、それから災害減免法、これを理由として当局から前向きな答弁は結局いただけませんでした。…", "…当該措置を受けられる者が限られるものとなっているんですね。また、災害減免法については、災害のあった年の所得金額が一千万円超の者は適用を受けら…", "…でも起こり得る災害に関する税制については、災害関連税制の常設化や災害減免法だけでは不十分でありまして、災害における担税力の喪失を最大限に勘案…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/58", "sentence": ["…べきだと思います。被災者に寄り添った税制の構築という視点に立って災害減免法と災害損失控除の両制度が整備されることで、被災者に対し力強く税制面…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/60", "sentence": []}]}]}]