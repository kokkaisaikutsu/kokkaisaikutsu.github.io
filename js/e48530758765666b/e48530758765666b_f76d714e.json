[{"date": "2021-12-14", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/272", "sentence": ["…援なわけです。じゃ、なぜクーポンというアイデアが出てきて、これだけいろいろな混乱を来したかというわけでありますが、これはなぜですかね、総理。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/274", "sentence": ["○藤田委員今回の混乱で明らかになったように、クーポンでやることで失われるものはたくさんあるんですね。例えば自治体事務が間に合わずに、例えば入…", "…消費喚起とか地域振興だとかという、そういう政策目的が曖昧になってこの混乱を来しているわけであります。だから、私が思うに、この政策目的は何であ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/290", "sentence": []}]}]}, {"date": "2022-11-21", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005254X01120221121/33", "sentence": ["…強まっています。感染症法上の扱いが異なる両者が同時流行すれば、国民の混乱に拍車をかけかねません。ウィズコロナ下での社会経済活動を円滑に進める…"]}]}]}]