[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/293", "sentence": ["…と思います。こちらのパネルを見ていただけますでしょうか。これは、菊栄親睦会というものがありまして、平成六年に百一名が御出席されたもので、これ…", "…しょうか、昭和天皇は旧宮家の方々を非常に大切にされ、皇籍離脱後も菊栄親睦会等を通じて旧皇族の方々と親しく交流されてきたと伺っております。かつ…", "…っしゃられているわけでありますが、こちら、お示しさせていただいた菊栄親睦会、これは私、二年前の質疑でも少し聞かせていただいたんですが、まず、…", "…いうことは事実かということをもう一度確認したいことと、それから、菊栄親睦会はこれまでどの程度の頻度、そして直近ではいつどこで行われたか、それ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/305", "sentence": []}]}]}]