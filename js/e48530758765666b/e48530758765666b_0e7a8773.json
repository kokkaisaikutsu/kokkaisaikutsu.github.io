[{"date": "2023-01-31", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/211", "sentence": ["…税、たばこ税を増税すると。つまり、これは、今ある枠組みを変えずに、今挙げた税項目の税率を上げるということでよろしいんですか。一応、確認です。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/213", "sentence": ["○藤田委員これ、税率を上げることだと思うんですけれども、何か表現ぶりがすごく工夫をされていてよく分からないんですけれども、税率を上げる、つま…", "…、何か表現ぶりがすごく工夫をされていてよく分からないんですけれども、税率を上げる、つまり増税するとおっしゃっていただいたらいいと思うんですよ…", "…から、このぐらいだったらまだ許容できるんじゃないかというのを探して、税率を上げようという発想にしかならないんですかね。自民党さんの中にも増税…", "…た政策パッケージという議論にならないのか。なぜ、今上げやすいところだけ税率を上げましょうという議論にしかならないのか。お答えいただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/237", "sentence": []}]}]}]