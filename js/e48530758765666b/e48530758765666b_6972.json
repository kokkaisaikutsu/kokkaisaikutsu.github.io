[{"date": "2021-05-14", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/10", "sentence": ["○藤田委員もう一点、授業目的の方で、著作物の一部メール送信等には、著作権者の利益を不当に害することとなる場合には送信を行うことができない旨の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/12", "sentence": ["…のは、一定の要件を満たした公正な利用の場合には、著作権者の許諾なく著作物を利用しても著作権侵害にはならないとする考え方で、アメリカ等で運用さ…", "…に、包括的な例外規定という形で、例えば、利用の目的や性格、使われる著作物の性質又は使われる部分の量、重要性、そしてオリジナル作品に対する悪影…", "…あっても、プロフェッショナルのクリエーターではない素人の人が新しい著作物を作って、世界に、もう次の日にアップロードして拡散していくということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405124X01420210514/24", "sentence": []}]}]}]