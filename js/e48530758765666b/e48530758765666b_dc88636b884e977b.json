[{"date": "2021-12-14", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/276", "sentence": ["…たしたわけですよ。だから、私たちは、これの対案として、そして、この補正予算の対案として、消費税の五％減税、無駄な配り方、不公平な配り方をする…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00320211214/290", "sentence": []}]}]}, {"date": "2022-11-21", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005254X01120221121/33", "sentence": ["…かつ効果的な対策を切に求めています。しかし、総合経済対策を裏づける補正予算案は、その願いに応えるものとなっていません。規模は総額二十九兆円に…", "…性も乏しい施策、事業のオンパレードです。総合経済対策で掲げた目的と補正予算案との内容もリンクせず、円安も物価高も止められません。多くの予算が…", "…れず、即効性も望めません。総理にお尋ねします。今回の総合経済対策と補正予算案は、適切な分析と課題設定ができておらず、解決策もどきを総花的に羅…", "…茶を濁していると言わざるを得ません。認識をお伺いいたします。今回の補正予算案も、歳出の八割に当たる二十三兆円が赤字国債で賄われ、無制限の国債…", "…対し、できる部分は取り入れていくと応じましたが、今回の政府の対策、補正予算には反映させるべき施策がなかったということですか。その理由も併せて…"]}]}]}]