[{"date": "2022-11-21", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005254X01120221121/33", "sentence": ["…から一年がたちました。さきの通常国会で、日本維新の会は、日割り支給、使途の公開、残金の国庫返納の三点セットによる抜本改革を訴え、会期中に結論…", "…を取り付けました。ところが、日割り支給と名称変更のみが先行し、本丸の使途公開と残金返納には自民党が背を向け、合意はほごにされたままです。十五…", "…ましたが、自民党の委員長に却下されました。そこで、我が党は、十七日、使途公開と残金返納を義務づける歳費法改正案を立憲民主党、国民民主党と三党…", "…党のみとなりました。自民党総裁たる岸田総理に御質問いたします。税金の使途を透明化し、不用分を国に戻すのは至極当然のことでありますが、なぜ自民…"]}]}]}, {"date": "2024-01-29", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00120240129/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X