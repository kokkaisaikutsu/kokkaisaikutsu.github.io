[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/293", "sentence": ["○藤田委員ありがとうございます。次に、現在の皇室と旧宮家の方々の交流関係について幾つかお話を聞きたいと思います。こちらのパネルを見ていただけ…", "…常に大切にされ、皇籍離脱後も菊栄親睦会等を通じて旧皇族の方々と親しく交流されてきたと伺っております。かつて、親しみを込めてひげの殿下と呼ばれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/295", "sentence": ["…というのは、歴史的背景においても、そして、親戚関係においても、現在の交流関係においても、皇室と非常に近しい立場であるというのは事実としてござ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/305", "sentence": []}]}]}]