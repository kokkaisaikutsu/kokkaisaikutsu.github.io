121315261X01620240328/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/129", "sentence": ["…上げます。国民にもう処分決めてもらうしかないんじゃないですか。総理も解散のタイミング探っているじゃないですか。そう見えますよ。処分まではしな…", "…か。そう見えますよ。処分まではしないとおっしゃった。じゃ、処分するんでしょう。解散で決着付けたらいいんじゃないですか。どうですか。最後だけ。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01620240328/132", "sentence": []}]}]}, {"date": "2024-05-29", "meeting": [{"meeting_name": "参議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314183X00420240529/10", "sentence": ["…投票を強行したんですね。その後、感染者が増えました。これ、危機の中で解散につながりかねない不信任案を出したり住民投票を強行したりした政党が、…"]}]}]}]