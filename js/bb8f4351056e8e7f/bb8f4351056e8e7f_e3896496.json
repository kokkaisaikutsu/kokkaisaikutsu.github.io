[{"date": "2021-03-01", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/82", "sentence": ["○辻元委員日曜日なんですよね。いろいろな人、解除されるかどうかということでいろいろな段取りが狂ってきますから、週の半ばぐらいかなと私は思って…", "…思っております。やはり、この間、尾身会長の記者会見ですね、大阪などを解除するとき、相当緊迫していたというか、ちょっと怒っていたような感じもし…", "…ましたと、想像していなかったとおっしゃったんですね。そして、一か月で解除できなかったらどうしますかと問われて、仮定のことは考えないとおっしゃ…", "…この新型感染症の問題は一年間対応してこられていますから、もう今度は、解除したら、こんなことは想像しませんでしたとか、仮定のことは考えないとい…", "…。専門家の方は相当慎重ですね、今。そこで、どういう決断をされるのか。解除して、再度また第四波が来て緊急事態宣言を出すような事態になったら、私…", "…てしまうと思います。そこで、総理に覚悟を聞いておきたいんです、今度の解除の。場合によっては総理の進退が懸かるくらいの責任が生じる、今回全面解…", "…の解除の。場合によっては総理の進退が懸かるくらいの責任が生じる、今回全面解除するときはそれぐらいの覚悟で決断するということでよろしいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X01720210301/115", "sentence"