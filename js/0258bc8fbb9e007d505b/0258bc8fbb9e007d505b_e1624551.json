[{"date": "2023-03-16", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/79", "sentence": ["…それを注目していきたいと思っております。続いて、ＮＩＳＡ制度の抜本的拡充、恒久化についてです。現行のつみたてＮＩＳＡの機能を引き継ぐつみたて…", "…さらに、制度全体の総枠である非課税保有限度額、こちらを千八百万円まで拡充するとし、成長投資枠については、その内数として千二百万円まで保有する…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00420230316/83", "sentence": ["…、日本の市場への投資拡大を目指すというのであれば、今ＮＩＳＡの抜本的拡充が、その日本の企業の成長というところに、価値の向上というところに確実…"]}]}]}]