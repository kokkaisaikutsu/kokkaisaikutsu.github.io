[{"date": "2023-04-06", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/108", "sentence": ["…支援のために設置される基金については、ＩＢＲＤのウクライナ向け融資を信用補完する枠組みがなされることが想定されているという一方で、現時点で日…", "…金への参加国が日本のみとなった場合に、ＩＢＲＤのウクライナ向けの融資を信用補完するという目的が十分に果たせるのかというところをお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/110", "sentence": ["…るからには、実際に償還が必要となる事態も想定し、その新設される基金が信用補完する、ウクライナになされる融資が効率的、効果的に活用されているか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/114", "sentence": []}]}]}]