[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/196", "sentence": ["…た。同時に、その際、日米間では、今後とも空中給油訓練は陸地から離れた海域の上空でしか実施せず、陸地の上空では実施しないことを確認したとし、こ…", "…ます。資料もお配りしております。防衛省に伺いますが、空中給油は危険な訓練であるから陸地の上空では実施しない、海域で行うと確認したものですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/198", "sentence": ["○山添拓君それは、空中給油が危険な訓練であるから陸地の上空ではなく海域の上空でとしたものだと、そういうことでよろしいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/200", "sentence": ["○山添拓君ちょっとお答えいただいていないんですよ。私はなぜ海域の上空かと聞いているんです。陸地の上空ではなく海域の上空で、それは安全性のため…", "…お答えいただいていないんですよ。私はなぜ海域の上空かと聞いているんです。陸地の上空ではなく海域の上空で、それは安全性のためではないんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/202", "sentence": ["○山添拓君危険な訓練だから海域の上空で行うこととしたと、それは答えられないんですか。何か答えられない事情があるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/207", "sentence": ["…安全性のためであるということはもうこれ明らかだと思うんですね。一応伺いますけれども、自衛隊機が空中給油を行う場合も海域上空で行っていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/209", "sentence": ["…定に保つ必要があり、事故が絶えません。危険だからこそ、米軍も自衛隊も海域上空で行うこととしてきたものです。ところが、今回、米軍は山梨県上空で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/211", "sentence": ["○山添拓君海域で行うことを確認したのは空中給油訓練であり、今回米側が認めたのは空中給油、だからそごはないと、こうおっしゃるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/219", "sentence": ["…君これは区別なんかしていないですよ。運用上の所要だと言いさえすれば、海域上空で行うべき空中給油訓練なのか、それとも政府が陸域も認めたと言って…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/247", "sentence": []}]}]}]