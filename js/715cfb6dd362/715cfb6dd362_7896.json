[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/196", "sentence": ["…大問題となりました。同時に、その際、日米間では、今後とも空中給油訓練は陸地から離れた海域の上空でしか実施せず、陸地の上空では実施しないことを…", "…間では、今後とも空中給油訓練は陸地から離れた海域の上空でしか実施せず、陸地の上空では実施しないことを確認したとし、これはオスプレイに限らず全…", "…ます。資料もお配りしております。防衛省に伺いますが、空中給油は危険な訓練であるから陸地の上空では実施しない、海域で行うと確認したものですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/198", "sentence": ["○山添拓君それは、空中給油が危険な訓練であるから陸地の上空ではなく海域の上空でとしたものだと、そういうことでよろしいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/200", "sentence": ["…お答えいただいていないんですよ。私はなぜ海域の上空かと聞いているんです。陸地の上空ではなく海域の上空で、それは安全性のためではないんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/215", "sentence": ["…伺いますけれども、空中給油訓練は危険だから海上で行わなくちゃいけない、しかし空中給油は安全だから陸上でも構わない、それ根拠でもあるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/219", "sentence": ["…と言いさえすれば、海域上空で行うべき空中給油訓練なのか、それとも政府が陸域も認めたと言っている空中給油なのか、区別のしようがないと思うんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/223", "sentence": ["○山添拓君もう一度伺います。大臣は、稲田大臣とは異なって、米軍機が陸地の上空で空中給油を行うのをお認めになるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/247", "sentence": []}]}]}]