[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/371", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/373", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/375", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/377", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/379", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/381", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/383", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/385", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/387", "sentence": ["…返し述べています。そこで伺います。（資料提示）歴代政府は、憲法九条と自衛隊の関係を説明するために、専守防衛を基本としてきました。最新の防衛白…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/389", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/393", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/395", "sentence": ["…衛とは相入れないものだと言わなければなりません。衆議院で防衛大臣は、自衛隊機が相手国の領空に入り軍事拠点を爆撃することも自衛の範囲として排除…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/397", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/399", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/401", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/403", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/405", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/407", "sentence": ["…な役割分担、いずれも政府の従来の見解すら踏み越えて、これは攻撃できる自衛隊、戦争する自衛隊に変えようとするものにほかならないと言わなければな…", "…れも政府の従来の見解すら踏み越えて、これは攻撃できる自衛隊、戦争する自衛隊に変えようとするものにほかならないと言わなければなりません。先ほど…", "…人か調べてみました。例えば、折木良一元統合幕僚長は、昨年十一月、他の自衛隊最高幹部とともに政策提言を発表し、専守防衛を見直し、非核三原則の是…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X006202