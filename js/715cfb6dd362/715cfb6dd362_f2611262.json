[{"date": "2023-04-11", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/184", "sentence": ["…起こっているから問題になっているんですよね。防衛省は、二〇一九年度、懲戒の処分事由にハラスメントを新設し、二〇二〇年一月にはその厳罰化のため…", "…〇二〇年一月にはその厳罰化のためとして、暴行等を伴う違反行為に関する懲戒処分などの基準を策定しました。違反行為の態様とその適用基準が事細かに…", "…六段階もに分かれているんですね。防衛省に伺います。こうして細分化をし、まあ防衛省の言葉では厳罰化ですが、その結果、懲戒処分は減ったんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/186", "sentence": ["…める考慮事項等についての細部についてという通知があります。ここでは、懲戒処分の軽減事由が規定され、パワハラであっても被害者が挑発した場合、重…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/188", "sentence": ["…かにするということと、それによってハラスメントを行った加害者に対する懲戒処分を軽減する理由になるかどうかということは別だと思うんですね。つま…", "…うかということは別だと思うんですね。つまびらかにするべきですよ。しかし、だからといって懲戒処分を軽減する理由にはならないんじゃありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00720230411/200", "sentence": []}]}]}]