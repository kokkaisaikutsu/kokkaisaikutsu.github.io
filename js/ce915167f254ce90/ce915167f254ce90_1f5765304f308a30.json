[{"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/27", "sentence": ["…臣（野村哲郎君）お答え申し上げます。石垣委員おっしゃるように、この土づくりというのはやっぱり農業にとっては一番基礎中の基礎でありまして、物づ…", "…のはやっぱり農業にとっては一番基礎中の基礎でありまして、物づくりは土づくりからということで、私もたたき込まれたことがございます。隣におります…", "…、農水省としては、土壌診断を実施する農業者への費用の助成、あるいは土づくりに必要な堆肥等の購入、運搬、散布等の支援を更にやっていきたいと思い…", "…ことを今回補正予算の中で検討を今やっているところでございますので、今後とも農業者の土づくりの取組を支援をさせていただきたいと思っております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X0032022110