[{"date": "2023-03-15", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/76", "sentence": ["…げたいと思いますが、私のところも四方を海に囲まれておりまして、水産加工業者も多いところでございます。漁業とともに、加工業者の皆さん方は車の両…", "…ておりまして、水産加工業者も多いところでございます。漁業とともに、加工業者の皆さん方は車の両輪としての役割を担っておられる、こういうふうに思…", "…担っていただいておるというふうに認識しております。その一方で、水産加工業者の多くは、中小零細企業でありまして、大変厳しい経営を強いられている…", "…導入や業務の共同化による生産性の向上等を推進することによりまして、水産加工業界の産業全体としての体質強化を目指していきたいと思っております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00420230315/96", "sentence": []}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01020230315/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01020230315/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01020230315/297", "sentence": []}]}]}]