[{"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/48", "sentence": ["…ましたけれども、農福連携等推進ビジョンにおいても、農福連携の対象を、障害者だけではなく、高齢者、引きこもりの状態にある者といった働きづらさや…", "…重要だというふうに思っております。我が省としては、ビジョンに基づき、障害者等の農林水産業に関する技術習得や、その作業に配慮した生産、加工、販…", "…めてきたところでございます。今後も引き続き、農福連携の推進を通じて、障害者を含む多様な人々が生きがいを共につくり、高め合うことができる社会の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/50", "sentence": ["…とうございました。農福連携の現場では、先ほど来お話がありますように、障害者だけではなくて、引きこもり状態にある方もその対象となっております。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108