[{"date": "2021-06-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/4", "sentence": ["…。まず、決算委員長として総括的な質問を内閣総理大臣にいたします。新型コロナ感染源の収束に向けて効果が期待されるワクチンについて、政府は七月末…", "…をどのように考えておられるのか、総理の見解をお伺いいたします。また、コロナウイルスの変異株については従来株と比べて若年層の重症化が高いとも言…", "…うか。政府の対応状況について総理に伺います。次に、我が国経済は、新型コロナウイルス感染拡大により、非常に厳しい状況が続いております。令和三年…", "…ナス四・〇％と八年ぶりのマイナス成長と公表されました。昨年以降、新型コロナウイルス感染症対策で財政出動が避けられない状況にありますが、財政状…", "…した中間指標を大幅に超えるものであります。また、財政需要については、コロナ対策だけではなく、来年令和四年には、いわゆる団塊の時代が七十五歳以…", "…を下ろさず、歳出改革努力を続けていくと述べられておられますが、ポストコロナにおける経済再生、財政再建の道筋について、総理の見解を伺います。次…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/182", "senten