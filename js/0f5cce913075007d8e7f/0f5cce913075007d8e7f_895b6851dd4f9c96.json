 []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/44", "sentence": []}]}]}, {"date": "2022-04-15", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X01720220415/9", "sentence": ["…どの地域においても許されるものではないし、欧州とインド太平洋地域の安全保障を切り離して論じることはできないと語りました。今回の侵略行為に対し…", "…を守り抜くために、価値観を共有する国々と連携しながら、外交、そして安全保障政策をどう進めていくおつもりでしょうか。お聞かせください。日本を始…"]}]}]}]