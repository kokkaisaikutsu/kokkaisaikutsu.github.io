[{"date": "2022-03-09", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/80", "sentence": ["…長給付とか追加給付が少しでもあれば、支出は一兆五千五百億円を超えて、国庫負担は四十分の一のままだと単年度赤字になってしまうのではないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/82", "sentence": ["…んとんですということなので、当然、特例延長とか追加給付があれば単年度赤字になる想定なんですね。もう一つ伺いたいのが、失業給付の受給者数、これ…", "…す。受給者数が七十万人を超えたら失業給付の支出が増えて雇用保険財政が赤字になるから、だから雇用保険の国庫負担割合を本則の四分の一に戻しますよ…", "…助成金など二事業への貸出しが増加することによって、雇用保険財政は大幅に赤字になるんじゃないですか。現に赤字になっていますよね。お伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00420220309/106", "sentence": []}]}]}, {"date": "2023-03-29", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104260X00520230329/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X0052023032