[{"date": "2022-01-25", "meeting": [{"meeting_name": "衆議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/12", "sentence": ["○井坂委員感染者数の予測をしていないと、ベッドや物資が足りなくなります。検査キットの需要と供給の状況はどうですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/18", "sentence": ["…に行かずに検査だけで自ら陽性と判断して自宅療養する方法も認めるとのことですが、個人が薬局で自由に買える検査キットなど、本当に供給できますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/20", "sentence": ["…必要不可欠な仕事の人は十日から六日に短縮できます。しかし、これも検査キットがなければ短縮できないわけです。各自治体にきちんと供給できますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804024X00420220125/26", "sentence": []}]}]}]