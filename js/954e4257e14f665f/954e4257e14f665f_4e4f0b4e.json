[{"date": "2022-04-07", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/56", "sentence": ["…す。三点目に、検討会では、消費者側は、認知症ぎみの高齢者など判断力が低下をしている消費者の契約は取消しができるようにと求めて、逆に事業者側は…", "…うことで議論がありました。その結果、検討会報告書では、判断力が著しく低下をした消費者が、現在又は将来の生活に著しい支障を及ぼす契約をした場合…", "…であります。しかし、ここまで明確に限定をしても、法改正では、判断力が低下をした消費者の取消権が盛り込まれることはありませんでした。実際、どう…", "…私も求めておりませんから、法制上何が原因で、こんな限定された、判断力低下の消費者の取消権すら盛り込めなかったのかということで、お答えをいただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00420220407/84", "sentence": []}]}]}]