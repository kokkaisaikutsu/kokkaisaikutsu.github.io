[{"date": "2022-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/6", "sentence": ["…もう七年前に、そのパーマネント、永遠の地位を保証されたはずの一角のフランスからとても重大な提案が行われています。これ実は余り知られていないん…", "…な提案が行われています。これ実は余り知られていないんですけれども、フランスがメキシコと協力して、Ｐ５ではないメキシコと協力をして、もしも大規…", "…く失敗に終わりました。むしろ、その失敗経験も生かして、日本は今こそフランスと組んで、国連改革の一番リアルな、現実的な第一歩として、まず拒否権…", "…それこそ拒否権が発動されて何も動きません。したがって、このことについて、総理、まずはフランスのマクロン大統領とお話をいただけないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/8", "sentence": ["…るとおりだと思います。そして、今総理がおっしゃったのは事実で、このフランスの提案について実は百五か国という多くの国が支持をし、日本もきちんと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/14", "sentence": []}]}]}, {"date": "2023-05-15", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/13", "sentence": ["…専門家の時代の方がはるかに長いんですが、事件記者から始まりまして、フランスの国家憲兵隊やアメリカのＦＢＩを始め、世界の治安当局とも連携をし、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00420230515/29", "sentence": []}]}]}]