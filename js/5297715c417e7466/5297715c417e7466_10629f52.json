[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/13", "sentence": ["…志大臣の御答弁には非常に大事な点が幾つも含まれておりました。例えば、成功体験のない世代にこそやるべきを伝えて伸ばしたいとおっしゃって、これは…", "…ゃいました。そのとおりなんですよね。明治維新以来、残念ながら我が国は成功体験にとらわれる癖があって、敗戦を経ても、なぜ戦争になってしまったか…", "…因追及はほとんどしてこなかったのがこの七十六年間でありますから、その成功体験をとらわれずに生かすということができていないということは非常にあ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00920210608/19", "sentence": []}]}]}]