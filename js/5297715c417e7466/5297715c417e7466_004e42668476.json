[{"date": "2020-11-24", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/22", "sentence": ["○青山繁晴君ＲＣＥＰの第九章を見ますと、そこに自然人の一時的な移動という項目があります。自然人という言葉自体が一般の国民の方々にはなかなかな…", "…普通は法人に対するものですね。このＲＣＥＰの第九章のところに自然人の一時的な移動という章のタイトルが付いています。つまり、恒久的な移民とかで…", "…タイトルが付いています。つまり、恒久的な移民とかではなくて、あくまで一時的な移動であって、その際に査証などの出入国管理に関する文書を要求する…", "…です。これは主権者への説明が足りないということですから、この自然人の一時的な移動、それが第九章に定められていることについて、大臣が何度もおっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/34", "sentence": []}]}]}]