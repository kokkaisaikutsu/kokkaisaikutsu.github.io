[{"date": "2022-05-30", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/450", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/452", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/454", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/456", "sentence": ["…価高騰分が反映されますと、保護者にとって大きな負担になってしまうのが給食費であります。基礎自治体で期待が高いこの給食費の支援としては、一旦給…", "…な負担になってしまうのが給食費であります。基礎自治体で期待が高いこの給食費の支援としては、一旦給食費を、値上げ分を御家庭に請求した後、払い戻…", "…食費であります。基礎自治体で期待が高いこの給食費の支援としては、一旦給食費を、値上げ分を御家庭に請求した後、払い戻す、若しくは負担額は変わら…", "…御家庭に請求した後、払い戻す、若しくは負担額は変わらず物価の高騰分を給食の担当現場のところで充当をしていくということが想定をされます。給食調…", "…を給食の担当現場のところで充当をしていくということが想定をされます。給食調理に掛かる光熱水料の増加も給食費負担に付加せざるを得ない場合もあり…", "…していくということが想定をされます。給食調理に掛かる光熱水料の増加も給食費負担に付加せざるを得ない場合もあります。また、自治体が事業者と一括…", "…まず対応について伺いたいと思いますけれども、地方創生臨時交付金を学校給食の費用負担軽減へ、現場の実情に即した自由度の高い対応ができるように、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/458", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/460", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/462", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/464", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/466", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/468", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/470", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/472", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/474", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/476", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/478", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/480", "sentence": []}]}]}]