[{"date": "2022-05-30", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/450", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/452", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/454", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/456", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/458", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/460", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/462", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/464", "sentence": ["…本の安全保障環境の、また体制の強化には、外交力、防衛力、経済、金融、財政のマクロ経済力、技術力などを俯瞰的に整える必要があると私は考えており…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/466", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/468", "sentence": ["…弁をいただきました。ありがとうございます。財務省の諮問機関であります財政制度審議会の分科会における防衛関係費の議論がなされ、先日二十五日には…", "…効な防衛力の強化への具体的な議論を求めることと並行して、経済、金融、財政のマクロ経済の脆弱性解消、強化を示しております。この提言の背景、なぜ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/470", "sentence": ["…。そして、脆弱性が結果として防衛力へ甚大な影響を及ぼす、経済、金融、財政への脆弱性を当局が示したということは、これ、財務省の皆さん、ふだんは…", "…具体例が挙げられています。日本において、有事に想定される経済、金融、財政の脆弱性として、物資を確保するために必要な外貨確保が急務となること、…", "…おります。平時から、防衛力強化のみならず、有事に耐え得る経済、金融、財政とするマクロ経済運営が必要であります。防衛力の面と金融、経済、財政面…", "…、財政とするマクロ経済運営が必要であります。防衛力の面と金融、経済、財政面における脆弱性の解消というのは両輪であり、両立を図るべきであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/472", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/474", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/476", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/478", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/480", "sentence": []}]}]}]