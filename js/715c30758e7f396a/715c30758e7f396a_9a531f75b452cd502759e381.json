[{"date": "2020-11-27", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304260X00720201127/4", "sentence": ["…は、来春以降も厳しい状況が続く企業も数多くあろうかと思います。来年三月以降はどのように対応していくのか、田村厚生労働大臣にお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00720201127/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00720201127/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00720201127/10", "sentence": []}]}]}, {"date": "2022-02-18", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/26", "sentence": ["…から重症者や死亡者数の増加に直結する高齢者施設等での医療体制について、政府はそれぞれどのように対応を進めるのか、厚生労働大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/28", "sentence": ["…はや限界だという声も伺っています。経営が逼迫している地域の歯科診療所に対して、国は手厚い支援を行うべきと考えますが、厚生労働大臣に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/30", "sentence": ["…対象範囲については、医薬品の流通、取引の実態もしっかり把握した上で、改めてゼロベースで検討すべきではないでしょうか。厚生労働大臣に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/36", "sentence": []}]}]}]