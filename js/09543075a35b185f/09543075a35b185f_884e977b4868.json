[{"date": "2022-03-09", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/163", "sentence": ["…ます。ところで、先般衆議院を通過した、今、参議院で審議中の令和四年度予算案、この中で、防衛省予算案において、防衛分野での技術的優越の確保のた…", "…院を通過した、今、参議院で審議中の令和四年度予算案、この中で、防衛省予算案において、防衛分野での技術的優越の確保のため、必要な体制及びゲーム…", "…らも確保していかなければならないと思いますが、この点に関する防衛省の御認識を、令和四年度防衛省予算案に触れながら御説明いただきたく存じます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/165", "sentence": ["…っております。防衛省としてどのように防衛基盤を強化されようとされておられるのか、令和四年度予算案に触れながら御説明をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00320220309/179", "sentence": []}]}]}]