[{"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/51", "sentence": ["…、この視点とともに質疑をさせていただきたいと思っております。まずは農水大臣に、食料安全保障についてお伺いをさせていただきたく存じます。もう私…", "…化、そしてまた確立という意味でも、食料安全保障の強化という考え方を明確に打ち出していくべきだと考えますが、農水大臣、見解はいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/59", "sentence": ["…いているということは、大きなメッセージになることと思っております。農水大臣に、最後もう一点、いわゆる国内の課題と国際協力という形で質問をさせ…", "…ができれば、私は双方にとってウィン・ウィンな形ではないかと思いますが、この食料援助の重要性、意義について、農水大臣、いかがお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/69", "sentence": []}]}]}]