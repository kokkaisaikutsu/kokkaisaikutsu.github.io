[{"date": "2022-11-29", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/67", "sentence": ["○菊田委員そうなんです。そこはごまかさないでいただきたい。ということは、令和四年度中に経済効果は表れるんでしょうか。内閣府に確認します。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/69", "sentence": ["…ということなんですけれども、令和五年度以降も含めた補正予算全体での経済効果ではなくて、令和四年度中は実際に執行されない事業に、なぜ令和四年度…", "…めた補正予算全体での経済効果ではなくて、令和四年度中は実際に執行されない事業に、なぜ令和四年度以内の経済効果が出てくるのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/71", "sentence": ["…るために策定されたものだというふうに考えていたんですが、この事業の経済効果は来年度以降に表れるということです。これで喫緊の経済対策と果たして…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00420221129/83", "sentence": []}]}]}]