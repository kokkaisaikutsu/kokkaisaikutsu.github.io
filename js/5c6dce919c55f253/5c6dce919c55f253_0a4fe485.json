[{"date": "2021-06-01", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00720210601/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00720210601/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00720210601/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00720210601/46", "sentence": ["○浜野喜史君ありがとうございました。最後に、伊藤参考人にお伺いいたします。中小企業政策をめぐりましては様々な説が交錯しているということも言え…", "…うな見方もございます。それぞれ見方が分かれるところなんですけれども、伊藤参考人は実情をどのように捉えておられるのか、御見解をお伺いしたいと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00720210601/48", "sentence": []}]}]}, {"date": "2022-03-04", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/27", "sentence": ["…、処遇といった人事であり、組織の行く末を決定付けるものだというふうに私は考えております。伊藤参考人の基本的な御認識をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/29", "sentence": ["…ておられます。そこで、国家公務員が従来に比べて選択されていない原因を伊藤参考人はどのように推察をされておられるのか、お伺いをしたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/31", "sentence": ["…展望が持てるかどうかということが結局のところ私はもう最重要ポイントではないかなと捉えるんですけれども、伊藤参考人の御見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X01120220304/95", "sentence": []}]}]}]