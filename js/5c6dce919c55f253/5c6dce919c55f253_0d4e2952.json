[{"date": "2022-12-06", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/131", "sentence": ["…た議論を進めているのか、また国際的に見て、カーボンプライシングを導入しないことが我が国にとって不利になるのか、見解をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/133", "sentence": ["…ライシングと呼ばれるものを導入しないということが我が国の産業にとって不利になるということであればやはり導入をしていかなければならないというふ…", "…ければならないというふうに考えるんですけれども、例えばこういう面において不利になる可能性があるんだということがあれば御説明をいただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/146", "sentence": []}]}]}]