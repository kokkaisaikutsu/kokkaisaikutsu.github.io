[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/69", "sentence": ["…思います。それは、十月二十日付けの日経新聞に掲載されました国土強靱化後回しにという題名の記事でございまして、その内容は、建設業の人手不足が続…", "…つ建設業者の手持ち工事量が多いために、小規模事業が多い緊急対策事業が後回しになっている、その証拠に、予算の支出率が低く、契約率との乖離が顕著…", "…す。建設業の人手不足や建設業者の施工余力がないために三か年緊急対策が後回しになっているという指摘がございますが、国交省にこの事実について確認…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/71", "sentence": ["…は安定しているというふうに理解をいたしました。三か年緊急対策が決して後回しになっているわけではないということでございます。それで、更に国交省…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/85", "sentence": []}]}]}]