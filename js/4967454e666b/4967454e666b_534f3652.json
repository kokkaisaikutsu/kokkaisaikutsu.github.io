[{"date": "2022-03-15", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/80", "sentence": ["…、中小企業の皆様が制度を十分に理解し活用できるよう、丁寧な周知と相談体制の一層の充実を行うべきと考えます。取組状況の確認とともに、例えば大企…", "…場合、大企業が下請に妥当な対価を支払うよう、取引の適正化に向けた監督体制についても強化すべきと考えますが、経産省の見解を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/82", "sentence": ["○杉久武君是非、丁寧な周知と相談体制の一層の拡充、そして賃上げに伴う取引適正化に対する管理監督の体制の強化について一層の取組をよろしくお願い…", "…相談体制の一層の拡充、そして賃上げに伴う取引適正化に対する管理監督の体制の強化について一層の取組をよろしくお願いしたいと思います。この賃上げ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/102", "sentence": []}]}]}]