[{"date": "2022-02-28", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/330", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/332", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/334", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/336", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/338", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/340", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/342", "sentence": ["…の支給額で不利になるということを指摘をさせていただきました。当時の文科大臣からは、これはしっかり結果を出していくと、萩生田文科大臣から当時お…", "…た。当時の文科大臣からは、これはしっかり結果を出していくと、萩生田文科大臣から当時おっしゃっていただきまして、その後、私も文科省の担当者とは…", "…、本予算案でこれは対応していただいたというふうに理解をしておりますが、改善の方法、実施時期、対象人数など、文科大臣にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/344", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/346", "sentence": ["…で、十二万円の差ということで差は小さくなりますが、同じ問題が生じております。こちらも解決すべき課題だと思いますが、文科大臣の見解を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/348", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/350", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/352", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/354", "sentence": []}]}]}]