[{"date": "2023-02-28", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/158", "sentence": ["…うになし得るのかという、なし得ると思われるのかということについての御所見と、そして、それに向けて、経済政策として日銀の金融政策が果たすべき役…", "…ほかの政策かもしれませんけれども、それを含めて令和の成長をつくっていくためにどのように政策を機能させていくべきと考えるか、御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/160", "sentence": ["…その眼目の一つはこの人口制約論からの脱却でありました。ついては、この日本における人口制約による成長悲観論について御所見を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/164", "sentence": []}]}]}]