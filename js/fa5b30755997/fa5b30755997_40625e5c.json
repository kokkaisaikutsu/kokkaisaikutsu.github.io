[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/207", "sentence": ["○寺田静君無所属の秋田県選出の寺田静と申します。まずは冒頭、大臣の御就任を心からお祝いを申し上げます。農家の皆さんが、この方だったら自分自身…", "…げたいと思います。農業県の秋田の選出ということもあって、この委員会に所属をできて大変うれしく思いますけれども、午前中から、委員の皆さん、また…", "…いて、大変勉強になります。夫も、また義理の父も、恐らく農水の委員会に所属したことがほとんどなかったかと思いまして、私自身もサラリーマン家庭の…", "…は人一倍強く持っているつもりであります。また、過去三年は環境委員会に所属をして、子育て中の一消費者としても、この食べ物の安全のこと、また、農…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/215", "sentence": []}]}]}, {"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/142", "sentence": ["○寺田静君無所属の寺田と申します。今日もよろしくお願いいたします。秋田では、先週、第百四十五回の種苗交換会というものが開かれておりまして、こ…", "…させていただきました。その種苗交換会の席でですけれども、長年自民党に所属をされ、農家をしながら農政を一筋でやってこられた自治体議員の方にこう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/156", "sentence": []}]}]}, {"date": "2023-05-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/151", "sentence": ["○寺田静君無所属の寺田と申します。本日もよろしくお願いいたします。私の地元の秋田魁新報では、今、大潟村の涌井氏の人生について語られております…", "…たということでした。このプラスチックの肥料の殻の流出に関しては、以前所属をしておりました環境委員会でも質問させていただいておりましたけれど