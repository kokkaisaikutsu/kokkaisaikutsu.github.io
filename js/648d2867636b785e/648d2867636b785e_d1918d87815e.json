[{"date": "2022-02-04", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/108", "sentence": ["…Ｇ投資の現状把握をするために、日本におけるＥＳＧ投資の現状認識、例えば時系列推移とか国家間比較等を用いて、金融庁の御見解をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/110", "sentence": ["…があると理解しております。このＥＳＧ投資の現状を踏まえて、今後の具体的な支援策等がもしあれば、金融庁の方針についてお伺いできますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/114", "sentence": ["…いただきました。この不動産売買価格の変化、高騰について、原因分析若しくは評価について、こちらは金融庁の御見解をお願いいただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/116", "sentence": []}]}]}]