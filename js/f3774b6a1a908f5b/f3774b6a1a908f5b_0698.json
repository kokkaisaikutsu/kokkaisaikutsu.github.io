[{"date": "2022-05-11", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/2", "sentence": ["…め方について申し上げます。まず、佐々木参考人、平野参考人、浅岡参考人の順にお一人十分以内で御意見をお述べいただき、その後、委員の質疑にお答え…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/8", "sentence": ["…述は終わりました。これより参考人に対する質疑を行います。なお、質疑及び答弁は着席のままで結構でございます。質疑のある方は順次御発言願います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/19", "sentence": ["○委員長（石橋通宏君）それでは、順番にお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00820220511/94", "sentence": []}]}]}]