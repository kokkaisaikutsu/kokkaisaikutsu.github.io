[{"date": "2023-05-31", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会、厚生労働委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/8", "sentence": ["…発生してしまった。厚労大臣にお伺いします。マイナ保険証の別人が情報がひも付けされていたこのミス、七千件以上のミスがあったということ。何かこれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/10", "sentence": ["…れが現場で、ではこの三情報でということで本人確認をされた。ところが、ひも付けが誤った三情報でやってしまったがために誤ってしまったということで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/17", "sentence": ["…てくるのかというと、何かシステム上は同一番号に複数の二人の情報とかがひも付ける可能性があるんですと。これ、一体どういうシステムですか、ちょっ…", "…れ、こんなシステムなんですか。何でこんな二人とか三人とか同一のナンバーでひも付くんですか。そんなシステムなんですか。大臣、説明してください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115375X00120230531/25", "sentence": []}]}]}]