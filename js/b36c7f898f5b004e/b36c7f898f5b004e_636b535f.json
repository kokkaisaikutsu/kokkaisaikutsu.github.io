[{"date": "2022-03-25", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/59", "sentence": ["…で、財産権を侵してはならないと規定しつつも、第三項で、「私有財産は、正当な補償の下に、これを公共のために用ひることができる。」というふうにご…", "…、経済的自由に対して国が公共の福祉を目的として制約をかける場合には、正当な補償が求められてくるわけでございます。そこで、規制色が強い特許出願…", "…と第八十条一項にも明記をされておりますが、これは補償金、すなわち憲法が要請する正当な補償であると承知をしておりますが、政府の見解を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/61", "sentence": ["○河西委員ありがとうございます。正当な補償を講ずるのであれば、まさに公平性を担保する意味でも、出願者ごとに極めて丁寧な対応が求められるんだろ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/63", "sentence": ["…支払い元である政府が決めることになっているわけでございますが、やはり正当な補償、先ほど確認をさせていただきましたとおり、この政府の審査内容、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01220220325/80", "sentence": []}]}]}]