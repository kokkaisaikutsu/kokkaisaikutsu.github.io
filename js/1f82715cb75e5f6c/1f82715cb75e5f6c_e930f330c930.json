[{"date": "2022-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/257", "sentence": ["…うことでありますけれども、実は先週金曜日の三月十一日、私、日本・ポーランド友好議員連盟に所属をしているんですけれども、そこで緊急集会が開かれ…", "…いるんですけれども、そこで緊急集会が開かれました。ミレフスキ駐日ポーランド大使から様々な話を伺いました。今のウクライナからの避難民の多くをポ…", "…大使から様々な話を伺いました。今のウクライナからの避難民の多くをポーランドは受け入れているということで、金曜日の時点で既に百四十万人の人々を…", "…ていると、こんなことでありました。本当にすばらしいなと思います。ポーランド、かなり大戦のときに苦労されたということもあって、人ごとではないと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/259", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/261", "sentence": ["…受入れ国に対して、まあ国際機関を通じてもいいんですけれども、特にポーランドなんかかなり友好関係を持って、日本とポーランドは友好関係があります…", "…ですけれども、特にポーランドなんかかなり友好関係を持って、日本とポーランドは友好関係がありますので、やはりそういった国々との密接な連携の中で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/269", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314