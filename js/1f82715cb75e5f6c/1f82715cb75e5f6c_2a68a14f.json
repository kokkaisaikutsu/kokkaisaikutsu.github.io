[{"date": "2020-11-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/169", "sentence": ["…立っていかないと経済運営誤ってしまうというふうに思うんです。一方で、株価は高水準になっています。昨日、今日と二日連続で、東証ではバブル後、終…", "…更新したということですけれども、パネルを御覧いただきたいと思います。株価は確かにずっと上がっていますよね。この株価が高い理由はどこにあると、…", "…れども、パネルを御覧いただきたいと思います。株価は確かにずっと上がっていますよね。この株価が高い理由はどこにあると、総理、お考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/171", "sentence": ["…。こういう影響がある。その証拠に今経済良くないですよ。にもかかわらず株価がこれだけ高いというのは、経済と株価は連動していないということではな…", "…がある。その証拠に今経済良くないですよ。にもかかわらず株価がこれだけ高いというのは、経済と株価は連動していないということではないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X002202