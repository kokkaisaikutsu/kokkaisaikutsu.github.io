[{"date": "2021-06-10", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/16", "sentence": ["○舟山康江君国民民主党の舟山康江でございます。公共建築物等木材利用促進法は、先ほど田名部委員からもありましたけれども、二〇〇九年の民主党政権…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/18", "sentence": ["…君ありがとうございました。今大臣からもありましたけれども、たくさん木材利用促進によって様々な効果が得られる、山元の利益還元、それから森林の適…", "…れております。そういったことで、やっぱりいろんな効果があるからこそ木材利用を促進していこう、整備とともに使うことでその効果を発揮していこうと…", "…、なぜあえてこの限定的な枕言葉を入れたのか、それがなくても十分この木材利用促進の意義が伝わるんではないかというふうに、むしろ伝わるんではない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/20", "sentence": ["…いえばそうかもしれませんけれども、逆にその森林の持つ多面的機能とか木材利用促進の、先ほど大臣からも御答弁ありましたけれども、様々な役割自体の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/22", "sentence": ["…たって更に範囲を拡大し、様々な施策も前に進めるということで、更に、木材利用の促進によってその森林の持つ多面的機能、様々な役割を発揮するために…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/25", "sentence": []}]}]}, {"date": "2023-04-25", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/85", "sentence": ["…法伐採という表現なんですね。違法伐採対策を含む持続可能な森林経営、木材利用を促進したいということと、もう一つ、違法伐採等の環境犯罪を効果的に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00820230425/103", "sentence": []}, {"