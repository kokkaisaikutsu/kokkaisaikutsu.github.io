[{"date": "2022-04-26", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/87", "sentence": ["…ーン、この水田中心という中で水田をどう生かしていくのか、本当に多面的な役割もありますので、ここ改めて私からもお願いをさせていただきたいと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/102", "sentence": ["…られたわけですから、その課題解決に向けて取り組んでいくのが農林水産省の役割だと思います。それで進まないというのではなくて、やっぱり進めるため…", "…上にも結び付かないと思いますので、そこを本当に是非しっかりと取り組んでいただきたいということを政務三役にもお願い申し上げ、質問を終わります。"]}]}]}]