[{"date": "2022-05-19", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/82", "sentence": ["…十一日現在の合計数字は、まさにこの二枚目の右側、令和元年現在の農用地区域内農地面積四百・二万ヘクタールと整合しておりますので、積み上げの結果…", "…数字が違うかというと、つまり、この右側、農振法に関しては、農振農用地区域内の農地面積であるということだからこのずれがあるということなんですけ…", "…のため確認ですけれども、この四百十四万ヘクタール、これは、農振農用地区域内農地面積の三百九十七万ヘクタールに加えて、例えば農振の白地とか市街…", "…農地面積の三百九十七万ヘクタールに加えて、例えば農振の白地とか市街化区域内農地を含めてのものであるという、そんな理解でよろしいんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/84", "sentence": ["…、先ほどちょっと示しましたけれども、農振法に基づく、これは農振農用地区域内の農地に限られていますけれども、これに関しては地域ごとにかなり細か…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01520220519/112", "sentence": []}]}]}]