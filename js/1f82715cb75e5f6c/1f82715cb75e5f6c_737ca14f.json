[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/116", "sentence": ["…ある水田、米作り、これが今曲がり角を迎えていると思っています。昨年、米価が残念ながら大きく下落をいたしました。この米価下落の農家経済への影響…", "…えていると思っています。昨年、米価が残念ながら大きく下落をいたしました。この米価下落の農家経済への影響はどのように分析されているでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/120", "sentence": ["…二枚目のグラフ、御覧いただきたいと思います。大体一俵当たり、先ほども米価でいうとやっぱり大体六十キロ当たり幾らというのが一番分かりやすいです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/122", "sentence": ["…農業やっていこうということで頑張っておられるんですね。そういう中で、米価の下落。そしてそのほかの今おっしゃっていただいたような支援策がない。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/140", "sentence": []}]}]}]