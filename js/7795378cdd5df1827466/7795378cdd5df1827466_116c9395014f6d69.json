, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01720240424/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01720240424/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X01720240424/23", "sentence": []}]}]}, {"date": "2024-06-04", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/9", "sentence": ["…まとめられ、静脈企業の成長と底上げが書かれています。そこで、幾つか民間企業における具体的な取組を紹介させていただきまして、御意見をいただきた…", "…果に値しています。そこで、伊藤環境大臣にお伺いしますけれども、このような民間企業の取組について率直な御感想をお聞かせいただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/11", "sentence": ["…。今の大臣の発言、本当に私自身も有り難く感じております。こういった民間企業、今、日本郵政グループの話をさせていただきましたけれども、こういっ…", "…ること、これは本当に必要なことだというふうに思います。今後も多くの民間企業がリサイクル活動を通じて持続可能な社会の実現に貢献していくことを期…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01120240604/19", "sentence": []}]}]}]