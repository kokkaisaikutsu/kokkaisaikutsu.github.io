[{"date": "2022-03-08", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/6", "sentence": ["…お願いさせていただきたいと思います。そしてまた、続いてでありますが、省エネ。私の小さい頃から、電気をつけっ放しにするなと、よく母親から注意を…", "…しにするなと、よく母親から注意を受けました。身近な生活の中で、我々は省エネというものに自然と取り組んできました。もう一度、やはりこの省エネと…", "…々は省エネというものに自然と取り組んできました。もう一度、やはりこの省エネというものについて我々自身が見詰め直して取り組んでいかなければなら…", "…イナの侵略の中で、岸田総理自身も記者会見の中で、国民の皆さんに対して省エネの協力をお願いしますということをおっしゃられたわけであります。今は…", "…という指摘がなされている昨今でありますので、やはり従前にも増してこの省エネというものにも取り組んでいかなければならないというふうに思っており…", "…ト・ゼロ・エネルギー、いわゆるＺＥＨなどの基準について引上げをして、省エネ政策を政策的に誘導していかなきゃいけない、そういう時期に来たのでは…", "…なきゃいけない、そういう時期に来たのではないかというふうに思っておりますので、省エネ政策の展開についての大臣の御所見を是非お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/18", "sentence": []}]}]}, {"date": "2023-03-29", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/1", "sentence": ["…庁長官神谷崇君、水産庁資源管理部審議官高瀬美和子君、資源エネルギー庁省エネルギー・新エネルギー部長井上博雄君の出席を求め、説明を聴取いたした…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00520230329/38", "sentence": []}, {"url": "htt