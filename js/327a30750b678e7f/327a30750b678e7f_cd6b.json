[{"date": "2021-04-16", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/31", "sentence": ["…うなことも指摘されています。民事局長にお伺いをいたします。離婚をして、母親が復氏をして元の姓に戻って、単独の戸籍を作り、しかも子供の親権者と…", "…に戻って、単独の戸籍を作り、しかも子供の親権者となって養育している場合、母親と子供は同じ氏でしょうか。また、戸籍は一つになりますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/33", "sentence": ["○稲田委員今申しましたように、このような場合、母親と子供は名前も違うし戸籍も違うんです。そういう場合を今の現行民法は認めております。ですから…", "…籍も違うんです。そういう場合を今の現行民法は認めております。ですから、母と子供が同じ名前でないと一体感がないとか、家族は戸籍が一つで、同じ名…", "…を想定をしているわけです。もっと言うと、民法が想定している、そういった母親と子供が名前が違うとか戸籍が違う、そういう場合について、それは親子…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405206X01420210416/47", "sentence": []}]}]}]