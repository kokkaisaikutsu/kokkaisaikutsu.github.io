[{"date": "2020-11-13", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/12", "sentence": ["…で、養育費について文書で取決めをしているのはわずか三一％、養育費の支払いを受けているのは二四％。世界で最低レベルなんです。ＯＥＣＤ三十三カ国…", "…を相手に請求できるセーフティー養育費額制度や制裁の強化、また立てかえ払い制度など、諸外国の仕組みを参考とした我が国の独自の仕組みづくりが必要…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/14", "sentence": ["…をされてきたところです。確かに、必ずしも大きな金額ではない養育費の支払いを求める一人親が本人で裁判を進めることは、いろいろとハードルがあって…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00220201113/24", "sentence": []}]}]}]