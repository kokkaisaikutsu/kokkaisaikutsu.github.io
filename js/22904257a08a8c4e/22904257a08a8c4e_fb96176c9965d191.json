[{"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/250", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/252", "sentence": ["…うに思います。それと、先ほど公明党の高木委員からも出ていましたが、電気料金のこと。これは今大変な状況になっているのは総理も御承知のとおりだと…", "…これはとんでもない状況になっています。昨日も私のところに、一か月の電気料金が十万を超えたという方も来ました。総理がおっしゃるとおり、今度、去…", "…いう方も来ました。総理がおっしゃるとおり、今度、去年の補正予算で、電気料金、二割程度相当額引き下げるということでありますけれども、例えば北海…", "…りますけれども、例えば北海道電力でいいますと、今年の夏から三五％の電気料金の引上げ、これを今、国に申請をしております。総理、二割、引き上げる…", "…先ほど公明党の高木さんも言いましたけれども、予備費を使うなりなんなりして、緊急事態には電気料金に対してもしっかり備える、それはいかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/254", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/256", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/258", "sentence": []}]}]}]