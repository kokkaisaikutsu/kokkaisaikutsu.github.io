[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 経済産業委員会環境委員会原子力問題調査特別委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/135", "sentence": ["…だきたい、そう思います。それから、次に、経産大臣にお伺いをしますが、政府は、原子力発電所を今後何年まで使うつもりでいらっしゃるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/141", "sentence": ["…定をしているはずですので、だから、電力会社が意思決定をしてから実際に発電所が稼働するまでというのはもう少し長い時間がかかるんだと思っています…", "…うに思います。そういうことを考えてみると、政府は、今回、廃炉の原子力発電所についてリプレース、また新たに造るということを考えているわけなんで…", "…また新たに造るということを考えているわけなんですが、申請を行ってから発電まで八年とか十年とか十数年とかかかる。さらに、今回の法案によれば、六…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/167", "sentence": ["○逢坂委員それで、また改めて事務方にお伺いをしますが、現在、再処理後のＭＯＸ燃料を使用している発電所というのはどこがございますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/169", "sentence": ["…についてはＭＯＸ燃料がもう既に手持ちがないということで、プルサーマル発電は今のところは中止しているところです。それで、高浜三、四号機で年間に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/177", "sentence": ["○逢坂委員経産大臣、私は、泊原子力発電所から十数キロのところに住んでいました。当時、ニセコという町の町長をやっていて、議会から、原子力防災、…", "…いうことで、泊地区の防災計画の中に今入っています。ただ、日本の原子力発電所というのは過酷事故が起こることを前提にして立地しておりませんので、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/183", "sentence": []}]}]}]