[{"date": "2022-10-17", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/183", "sentence": ["…う一方、私、全く理解できないことがあるんですよ。寺田大臣の政務秘書の迫田誠さんという方、この方はお名前も出されておりますので。寺田事務所が脱…", "…脱税的なことを行っていることをにおわせる発言を週刊誌の記者などにしているようです。この迫田秘書というのはどんな仕事をされている方なんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/185", "sentence": ["○逢坂委員迫田さんの話はまた後で伺わせていただきます。それで、寺田大臣、御地元の呉の事務所家賃として奥様に十年で大体三千万近くの支払いがある…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/193", "sentence": ["…床面積の狭い建物だったというふうに承知をしております。それで、これは迫田誠秘書のフェイスブックによれば、迫田秘書は杉並区に住んでいるというふ…", "…知をしております。それで、これは迫田誠秘書のフェイスブックによれば、迫田秘書は杉並区に住んでいるというふうにフェイスブックに記載しているんで…", "…杉並区に住んでいるというふうにフェイスブックに記載しているんですね。迫田秘書は、いわゆる杉並区、これは高円寺南というふうに承知していますが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/197", "sentence": ["…、毎年人件費を五百三十万から五百七十万円程度支出をしていると。これも迫田秘書の話ですよ。地元の私設秘書らに対して本来の月給に上乗せして払う、…", "…明しているんですけれども、さらに、源泉徴収もない、だから脱税みたいなものだということを迫田さんは言っているんですが、これは間違いなんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/201", "sentence": ["○逢坂委員大臣、もう一点確認です。迫田秘書が、大上さんですか、いや、どなたか分からないんですけれども、誰か税理士にお願いして、こういう文書を…", "…、本人も確定申告書の必要性を認識しないまま今日に至っておりますという、こういう文書を迫田さんが出されたんですが、これを作成したのは誰ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/207", "sentence": []}]}]}]