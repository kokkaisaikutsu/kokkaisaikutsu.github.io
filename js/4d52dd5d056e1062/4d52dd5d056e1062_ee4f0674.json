[{"date": "2023-03-29", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/78", "sentence": ["…講ずべき橋が十三あった、去年の八月の段階で、こういうことなんですが、現在までに、この十三の橋については修理、修繕は終わっているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/82", "sentence": ["…四。ですから、八五％の橋は、緊急か早期か、あるいはいつかは別にして、修理が必要、こういうことになります。実は、奈良県というのは人口も面積も大…", "…国で八十五万の橋について、早期か、あるいは緊急か、いつかは別にして、修理が必要になっているということになるんでしょうか。また、橋に限らず、全…", "…ず、全国のトンネル、道路、既存のインフラについて、一体どれだけの数、修理、修繕が必要な場所、何か所ぐらいあるのか、この辺、分かっていればお答…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/84", "sentence": ["…ネルの修繕、あと、道路もあると思うんです、この後詳しくやりますけれども、それらの修理、修繕のためにどれぐらいのお金が必要になるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00620230329/106", "se