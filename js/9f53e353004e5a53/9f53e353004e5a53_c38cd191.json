ence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/28", "sentence": ["…よ。最後に、税について言います。これは、消費税を増税するたびに大きく賃金は下がっています。皆さんは、十月にインボイスを無理やり入れようとして…", "…加価値税なんです。日本の弱体化装置じゃないですか。お答えください。消費増税のたびにこうやって賃金が大きく落ちている、この数字は正しいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104127X00220230410/34", "sentence": []}]}]}]