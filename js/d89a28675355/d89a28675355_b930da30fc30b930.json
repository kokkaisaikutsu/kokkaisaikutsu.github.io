[{"date": "2024-02-27", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/11", "sentence": ["…い、このように思います。さて、都市部においては、特に災害時の避難所スペースが私は圧倒的に足りないというふうに思っています。避難所スペースの確…", "…難所スペースが私は圧倒的に足りないというふうに思っています。避難所スペースの確保に今後どのように取り組んでいくのか、所見を伺いたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/13", "sentence": ["…いうところが避難所になっていくわけでありますけれども、圧倒的に多分スペース的には足りないと思っています。それで、スペースにも限りがあって、常…", "…れども、圧倒的に多分スペース的には足りないと思っています。それで、スペースにも限りがあって、常時避難所を用意しておくということ、これはなかな…", "…というのは分かるんですが、何かあったときには転用ができる、そういうスペースをやはりできるだけ確保していくことが必要なんだろう、こう思っていま…", "…口の違いもあるでしょうし、そういうことを是非思いを致しながら避難所スペースの確保に努めていただきたい、このように思います。そして、避難所のこ…", "…ませんよとお断りができるんでしょうかということであります。それが、スペースがあれば、あちらだったらまだありますからどうぞということは言えるか…", "…序がないんですね。ですから、この秩序をどう維持するかというときに、スペースの問題を含めて、人の確保、そして最終的には自治体職員がどういう役割…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305272X00120240227/26", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305273X00120240227/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305273X00120240227/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305273X00120240227/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305273X00120240227/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305273X00120240227/107", "sentence": []}, {"url": "https://kokkai.ndl.go.j