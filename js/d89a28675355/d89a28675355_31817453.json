[{"date": "2022-03-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/54", "sentence": ["…る諸課題について伺いたいと思います。我が国の経済の目標として、デフレ脱却ということはずっと言われてきたと思います。我が国の現下の情勢は、率直…", "…言われてきたと思います。我が国の現下の情勢は、率直に言って、デフレを脱却した、成し遂げた、これを言えるのかどうか、まずそのことをお伺いしたい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/56", "sentence": ["…でございまして、なかなかこの判断は難しいと思いますけれども、デフレを脱却したと言えるような状況ではない、これは多分誰もが思っている、感じてい…", "…に、多くの苦悩の声も実は聞かせていただいているわけであります。デフレ脱却まだ道半ばという中で、そして経済再生には、私はやはり、大企業だけが潤…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/64", "sentence": []}]}]}]