[{"date": "2022-03-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/52", "sentence": ["…極的な意義があると私は考えるわけでございます。一方で、同三原則の運用指針は、現下のような侵略が行われているような状況下では、移転執行の迅速性…", "…と思います。そこで、我が国の基本原則は貫きながらも、この三原則の運用指針というのは、私、より柔軟であってほしい、あってよいというふうに思うの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/54", "sentence": ["○高木（啓）委員今回の件で改めて感じたのは、運用指針の改正をしなければいけない。これは、いわゆる法体系として、やれることを書いていくわけです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/64", "sentence": []}]}]}]