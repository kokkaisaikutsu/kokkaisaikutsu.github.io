[{"date": "2022-03-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/52", "sentence": ["…十九日のこの内閣委員会で、尖閣諸島の自然環境調査について、同じように環境省に問いかけました。上陸調査をすべきだという趣旨で私が問いかけたら、…", "…省に問いかけました。上陸調査をすべきだという趣旨で私が問いかけたら、環境省の答弁は、当時、人工衛星を使って上から見て調査をするんだ、こういう…", "…いということだったんですけれども、今回のこのごみ問題も含めて、じゃ、環境省は、このごみの数、掌握していますか、全体として。どうでしょう、人工…", "…員にはしっかり報告をするぐらいのことはすべきじゃないですか。これは、環境省は何をやっているんでしょうかと言わざるを得ません。尖閣諸島の問題は…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/64", "sentence": []}]}]}]