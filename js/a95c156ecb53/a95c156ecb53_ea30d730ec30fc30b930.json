[{"date": "2021-06-03", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/132", "sentence": ["…されています。その中には、次期のエネルギー基本計画に原発の新増設、リプレース、これを明記するように求める要望もあります。まさか、カーボンニュ…", "…ュートラルだと、脱炭素だということを理由にして、この原発の新増設、リプレースを次のエネ基に書き込むことはないか、これを確認したいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/138", "sentence": ["…きますけれども、結局、こうした状況の下で原発の運転延長をすることになるんじゃないか、新増設、リプレースをすることになるんじゃないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/144", "sentence": []}]}]}]