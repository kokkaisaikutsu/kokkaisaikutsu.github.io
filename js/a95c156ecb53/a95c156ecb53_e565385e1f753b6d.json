[{"date": "2023-05-31", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X02720230531/24", "sentence": []}]}, {"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/154", "sentence": ["…す。そして、この特定帰還居住区域のイメージということで、帰還住民の日常生活に必要な宅地、道路、集会所、墓地等を含む範囲で設定するというふうに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/170", "sentence": ["…やっぱり山の除染、やるべきだと思うんですよ。これ、非常に希望も多いし、日常生活の圏内なので、大臣、この山の除染、行うべきではないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/172", "sentence": ["…そこを犬を散歩させたりすることだというお話も伺ったんですね。山林は日常生活の一部なので、これ山林の除染もしっかり行うべきだというふうに求めま…", "…の家と敷地とか、家につながる道路だけが除染をされても、それだけでは日常生活成り立たないんですよね。そのことが帰還をためらわせるということにも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00620230531/203", "sentence": ["…ますが、自宅に戻れればよいのではありません。限定的な範囲の除染では日常生活は成り立ちません。自治体が求めてきた面的除染が行われず、将来が見通…"]}]}]}]