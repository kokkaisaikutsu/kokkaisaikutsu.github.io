[{"date": "2022-03-10", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/269", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/283", "sentence": ["…島県漁連から、建屋内の水は多核種除去設備等で処理した後も、発電所内のタンクにて責任を持って厳重に保管管理を行い、漁業者、国民の理解を得られな…", "…は、いかなる処分も行わず、多核種除去設備で処理した水は発電所敷地内のタンクに貯留をすると回答をしています。東京電力に聞きますけれども、漁業者…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/295", "sentence": ["…発の敷地の図なんですけれども、これ、北側のところが空いているんですよね。ここをタンクの置場に活用することができるんじゃないでしょうか、総理。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/301", "sentence": ["…のかということです。時間の経過とともに放射線量も低減をしていきます。タンク保管は継続させて、その間にあらゆる英知を結集させて海洋放出以外の方…", "…すと言っているんです。それを達成しても、汚染水の発生をなくさない限りタンクは増え続けることになるんですね。それで、この地質とか地下水の研究を…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/303", "sentence": []}]}]}, {"date": "2022-12-02", "meeting": [{"meeting_name":