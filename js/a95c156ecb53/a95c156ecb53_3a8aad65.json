[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/90", "sentence": ["…グを行った結果を見てみますと、省エネ設備への更新や専門家による省エネ診断の実施によって大きな排出削減効果を得られる可能性があると、こういう意…", "…見が紹介をされています。自治体の担当者の方からも伺った話でも、省エネ診断を受けた事業者は省エネの取組効果が上がっているというお話でした。とこ…", "…お話でした。ところが、先ほど議論もいろいろありましたけれども、省エネ診断事業は、二〇年度までは全額補助で年間五回まで行われていたんですけれど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/92", "sentence": ["…がとうございます。大臣、特別交付税で雇用や委託の経費を措置をして、恒常的に省エネ診断を行う人的配置を行うよう検討するべきではないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00920220512/126", "sentence": []}]}]}]