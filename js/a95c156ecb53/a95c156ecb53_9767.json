[{"date": "2023-04-06", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/72", "sentence": ["…正式な起訴というのはこれまでとは違う新たな段階ということで、いよいよ貸付実行の停止の措置をとるべきだと思いますが、林総裁、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/78", "sentence": ["…総務部長の贈収賄への関わりが示されたっていうことなんですね。財務大臣も林総裁も、三月二十八日に国際環境ＮＧＯ、ＦｏＥＪａｐａｎなどの団体から…", "…資未実行残高の取消し、少なくても贈収賄事件の公判中は新たな貸付実行はしないということを約束すべきではないでしょうか。林総裁と大臣に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00920230406/116", "sentence": []}]}]}]