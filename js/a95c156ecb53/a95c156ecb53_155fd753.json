[{"date": "2022-04-07", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/102", "sentence": ["…、資本金十億円未満というのは一社もないんですよね。この三十社が占める引受保険金額の割合は七四％を占めています。日本の貿易保険は諸外国と比べて…", "…たことと比べても高いものとなっています。その一方で、じゃ、中小企業の引受割合はというと、件数で一五・三％、金額で四％にしかすぎないんですね。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/106", "sentence": ["…ですね。一方で、東南アジアを中心に、石炭火力発電所プロジェクトの保険引受けも行われてきています。石炭火力発電所プロジェクトの保険引受けは、二…", "…トの保険引受けも行われてきています。石炭火力発電所プロジェクトの保険引受けは、二〇一五年度以降の公表分のみで件数と保険金額の合計、幾らになっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00520220407/134", "sentence": []}]}]}]