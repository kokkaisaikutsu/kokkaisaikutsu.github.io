[{"date": "2021-12-21", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715254X00520211221/26", "sentence": ["…護の減免措置を早ければ二三年度に見直すと言います。事故から十年たった避難者の生活の実態を政府の責任で把握し、支援を続けるべきではありませんか…"]}]}]}, {"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/219", "sentence": ["…健康と生活への影響に関する検証委員会が昨年一月に行った報告によると、避難者は仕事や生きがい、人間関係の喪失などの点で多くの犠牲を払っている、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/221", "sentence": []}]}]}, {"date": "2022-05-18", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/191", "sentence": ["…れだけの方々が避難をしているのかということで、国と福島県は昨年三月、避難者数が実態に即していない可能性が高いということで、県外への避難をする…", "…いない可能性が高いということで、県外への避難をする方々を把握する全国避難者情報システムに基づいて文書を送ったと。三一・九％に当たる三千八百七…", "…世帯分が配達をされずに差し戻されたということです。この三千八百七十七世帯の方々は避難者数から除かれるということになるのでしょうか、西銘大臣。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/193", "sentence": ["○岩渕友君済みません、もう一回確認するんですけど、避難者にはカウントされないということになるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/195", "sentence": ["…とそこがよく分かんないんですけど、結局、この三千八百七十七世帯の方々は避難者数から除かれるということになるのか、ちょっともう一回いいですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/199", "sentence": ["…です。避難指示区域の外から避難をする方々や復興住宅に入居した方などは避難者数に含まれていないんですよ。ふるさとに戻ることができない方々は八万…", "…れども、原発事故の被害が終わっていないのに、被害を小さく見せるために避難者数が少なくされて、そのことが支援の打切りにつながってきているんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/203", "sentence": ["○岩渕友君そもそも、あの法案の条文に避難者ということ書かれていないんですよね。昨日確認をしたら、書かれていないというような答えだったんです。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/209", "sentence": ["…関係なく、負の遺産にもなりかねません。復興といいながら法案の条文には避難者という言葉もなく、被災者、被害者の姿が全く見えてきません。決まって…", "…万人を超えると言われています。被害が続いているにもかかわらず、政府は避難者を対象にした医療や介護の保険料などの減免措置について段階的に縮小、…"]}]}]}]