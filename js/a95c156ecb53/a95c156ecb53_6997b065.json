[{"date": "2022-10-24", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/178", "sentence": ["…た新増設にまで踏み込もうとしています。この実用化に最も近いというふうに言われているのが革新軽水炉です。これ、どこが革新だというのでしょうか。", "…た新増設にまで踏み込もうとしています。この実用化に最も近いというふうに言われているのが革新軽水炉です。これ、どこが革新だというのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00320221024/184", "sentence": []}]}]}, {"date": "2023-04-25", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/120", "sentence": ["○岩渕友君今答弁があった高速炉も、そして高温ガス炉も、経産省が次世代革新炉というふうにしているものです。今後十年間で約一兆円の投資をするとし…", "…にとても間に合わないということですよね。しかも、フィンランドの次世代革新炉、オルキルオト三号機というのがありますけれども、これは、二〇〇五年…", "…二二年です。建設費も当初の三倍以上に膨らんだということで、この次世代革新炉には膨大な時間、そして開発費用が掛かるということも懸念をされます。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X00620230425/130", "sentence": []}]}]}]