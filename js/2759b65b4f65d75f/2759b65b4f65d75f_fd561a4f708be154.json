[{"date": "2021-03-15", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/5", "sentence": ["…私の尊敬する元北九州市長末吉興一さんから何度も聞いた言葉であります。ＮＴＴが国会議員と会食を行ってきたのは事実でしょうか、お尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/7", "sentence": ["○大家敏志君与野党超えて国会議員と意見交換を行ってきたと、目的は何だったんでしょうか。もう一度というか、具体的にあればお答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/9", "sentence": ["○大家敏志君まあ国会議員の見識にも個人差はあると思いますが。次にお伺いいたしますが、ＮＴＴと総務省幹部との会食についての事実関係、それから、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/23", "sentence": []}]}]}]