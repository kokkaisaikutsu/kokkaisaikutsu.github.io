[{"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/181", "sentence": ["…―Ｔａｘによる確定申告を普及させるためには、マイナンバーカードによる利便性の向上に取り組むとともに、その周知に取り組んでいくことが重要である…", "…ル経由で入手した上で申告データに自動入力できる仕組みを導入するなど、利便性の向上に取り組んでいます。また、このようなマイナンバーカードの利便…", "…利便性の向上に取り組んでいます。また、このようなマイナンバーカードの利便性について、税理士会や青色申告会などの民間団体を通じて周知を行うほか…", "…ナンバーカードは様々な行政手続やサービスを利用するための共通基盤であります。引き続き、利便性の向上や取得促進に向けた取組を進めてまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/199", "sentence": []}]}]}]