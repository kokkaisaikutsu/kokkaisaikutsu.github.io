[{"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/52", "sentence": ["…する立場からの御質問であると認識をしております。農林水産物・食品の輸出拡大実行戦略では、農林水産物・食品の輸出額を、先生も今申されましたけれ…", "…しては、この戦略を踏まえ、重点三品目を中心として日本産酒類の一層の輸出拡大を図るため、販売拡大や認知度向上等に積極的に取り組んでおります。具…", "…一体として実施する等々、努力を続けているところであります。引き続き、関係省庁とも連携をして、一層の輸出拡大に取り組んでまいりたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00420220316/199", "sentence": []}]}]}]