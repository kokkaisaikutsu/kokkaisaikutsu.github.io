[{"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/293", "sentence": ["…としては通称使用を提案しなかった。平成八年二月に選択的夫婦別姓制度を答申した。法務省は答申に基づいて改正法案を準備した。ところが、その年の六…", "…提案しなかった。平成八年二月に選択的夫婦別姓制度を答申した。法務省は答申に基づいて改正法案を準備した。ところが、その年の六月に行われた世論調…", "…はなぜか選択肢に加えられた。私、法務大臣、法務大臣は国会で、法制審の答申を重く受け止めると答弁されました。でも、こういうことでは法制審の答申…", "…答申を重く受け止めると答弁されました。でも、こういうことでは法制審の答申を軽視したと言われても仕方がないんじゃないでしょうか。いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/295", "sentence": ["…晃君いや、今の答弁は本当に矛盾していると思いますよ。だって、法制審の答申には入っていないということを言ったじゃないですか。その後のいろんな議…", "…うんですね。野田大臣、当時からこの問題に関わってこられました。法制審答申になかったものがなぜ突然盛り込まれたのか、どういう背景でどういう経過…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/305", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/309", "sentence": []}]}]}]