[{"date": "2021-06-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/211", "sentence": ["…に向けて富裕層への増税が大きな流れになっています。アメリカは金融所得課税を二倍にする、イギリスも引き上げていく、ニュージーランド、スペイン、…", "…けですね。財務大臣、やっぱり日本も株の譲渡益、配当益、こういうときこそ金融課税、金融所得課税引き上げて格差の是正を図るべきではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/213", "sentence": []}]}]}, {"date": "2021-10-13", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120515254X00420211013/13", "sentence": ["…ている大きな原因が、日本の不公平税制です。日本の所得税の現状は、累進課税とは名ばかりで、実際には、所得が一億円程度を超えると負担率が逆に下が…"]}]}]}, {"date": "2022-05-31", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/250", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/252", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/254", "sentence": ["○小池晃君一番肝腎なことやらないじゃないですか。内部留保の課税も先におっしゃいましたけど、私たち提案しているんですよ。十億円以上の大企業に、…", "…除して、二〇一二年以降、すなわちアベノミクスで増えた内部留保に二％の課税をすれば五年間で十兆円の財源が生まれる。こういうことをやっぱりやらな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/256", "sentence": ["…を始めるきっかけがこれじゃないかと我々は提案している。財務大臣、二重課税という話があります。二重課税の規定はありますか。二重課税は法律的にど…", "…いかと我々は提案している。財務大臣、二重課税という話があります。二重課税の規定はありますか。二重課税は法律的にどうだと、そういうのあるんです…", "…務大臣、二重課税という話があります。二重課税の規定はありますか。二重課税は法律的にどうだと、そういうのあるんですか。二重課税は法律で禁止され…", "…課税という話があります。二重課税の規定はありますか。二重課税は法律的にどうだと、そういうのあるんですか。二重課税は法律で禁止されていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/258", "sentence": ["○小池晃君大臣、法律の規定ないと言ったのに、二重課税の指摘がありますって、それおかしくないですか。何でそんな答弁するんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/260", "sentence": ["○小池晃君もうね、いいんですかね、それで。二重課税というのは、これ定義ないんですよ。それで、最大の二重課税、私は所得税取られた上に消費税取ら…", "…それで。二重課税というのは、これ定義ないんですよ。それで、最大の二重課税、私は所得税取られた上に消費税取られることだと思いますよ。そういうこ…", "…と分配の好循環と言いながら、総理、分配どこに行ったんですか。金融所得課税の見直しも言わなくなった。そして、肝腎なところには切り込まない、内部…", "…直しも言わなくなった。そして、肝腎なところには切り込まない、内部留保課税はしない、消費税の減税は絶対しない。成長と分配、これどこに行ったんで…", "…の減税は絶対しない。成長と分配、これどこに行ったんですか。分配ないじゃないですか。本当に分配するんだったら、内部留保課税、検討すべきですよ。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/262", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/290", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/292", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/294", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/296", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/298", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/304", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/306", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01920220531/308", "sentence": []}, {