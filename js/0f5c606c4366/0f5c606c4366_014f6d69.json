[{"date": "2020-10-30", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315254X00320201030/15", "sentence": ["…わりをする一千三百億円もの政府保証が付けられました。一方、日産の下請企業では経営が悪化し、早期退職者募集などリストラが横行しています。今、政…", "…います。今、政府が真っ先にやるべきは、四兆円もの内部留保を抱える巨大企業ではなく、立場の弱い中小企業を直接支援することではありませんか。雇用…", "…るべきは、四兆円もの内部留保を抱える巨大企業ではなく、立場の弱い中小企業を直接支援することではありませんか。雇用者の数は、リーマン・ショック…", "…、中でも女性の減少が目立ちます。東京商工リサーチの調査によれば、上場企業六十社が一万人以上の早期希望退職者を募集しています。これから年末に向…", "…い。これが今求められる最大の経済対策ではありませんか。政府として、大企業に対し、リストラに走るな、今こそ内部留保を吐き出し、雇用を守る責任を…", "…長続きするのかが根本から問われているのではありませんか。暮らしと中小企業の危機に対処するためにも、緊急に消費税を五％に減税し、財源はアベノミ…", "…も、緊急に消費税を五％に減税し、財源はアベノミクスで潤った富裕層や大企業に応分の負担を求める税財政の改革が必要であります。以上、総理の答弁を…"]}]}]}, {"date": "2020-11-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/321", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/323", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/329", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/331", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/333", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/335", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/343", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/345", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/349", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/353", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/355", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/362", "se