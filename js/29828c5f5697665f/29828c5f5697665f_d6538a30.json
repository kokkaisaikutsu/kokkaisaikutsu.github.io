[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/250", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/254", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/258", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/262", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/264", "sentence": ["…教職員給与特別措置法改正案の質疑の際に、教員の多忙の原因について聞き取りをしました。教員生活二十年、都内の小学校に勤める先生は、この十年間で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/274", "sentence": ["…も、教育実習の機会、教職課程を学べる機会が当たり前に提供されるように取り組んでいくことが重要です。ちょっと関心があるな、選択肢として教職課程…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/281", "sentence": ["…教員が自主的、内発的に研修を受けられる時間的、精神的余裕を学校現場に取り戻すことです。そのためには、教育に対する公的支出割合がＯＥＣＤ諸国内…", "…拡充するべきです。そして、正規教員の数を増やし、教員の働き方改革、待遇改善に最優先で取り組むべきであることを申し上げ、反対討論といたします。"]}]}]}]