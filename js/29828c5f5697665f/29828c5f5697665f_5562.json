[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/197", "sentence": ["…し、十二月のイベントでコロナと天候に起因する集客の減少などで赤字、立替払などで約三百万円、今月末の支払もできず、このまま首をつるしかない状況…", "…天候に起因する集客の減少などで赤字、立替払などで約三百万円、今月末の支払もできず、このまま首をつるしかない状況に追い込まれています。この事業…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/199", "sentence": ["…す。その経験から、今回も死を選択される方もおられると思います。大臣、是非三月末までに補助金の支払、お約束を実行していただけませんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/211", "sentence": ["…代読いたします。先ほどのアーツ・フォー・ザ・フューチャーの質問にいま一度戻りますが、最後に大臣のお言葉でユーザーへのお支払をお約束ください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/215", "sentence": []}]}]}]