[{"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/112", "sentence": ["…法、不正競争防止法、著作権法等の縦割りの刑罰体系が足りないのであれば、穴があるなら埋めたらいいんです。それは国会の仕事だから、私たちが、与党…", "…じゃない、僕らが悪いんだけれども、まずは皆様とこうやって討論する中で、穴があるのかないのかということをこの委員会で明らかにしていきたいと思う…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/118", "sentence": ["…幾つか忘れていまして、今御指摘いただいたように、まさに私は今日、法令に穴があるんじゃないか、こう申し上げた。これは、サイバー局ができるんだっ…", "…法とか、著作権法とか、まずは刑法を所管している法務省が中心になって、サイバーの観点から穴がないのか検証すべきだと思うんですが、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/120", "sentence": ["…、これはまたいろいろな場で質疑していきたいと思いますが、ちょっと、法の穴があるのかないのか、恐らくそうした目で検証していないと私は見ています…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/132", "sentence": []}]}]}]