[{"date": "2020-11-12", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/129", "sentence": ["…振る舞いが大事なんですよ。ところが、大阪の自民党、大阪では野党です。共産党と一緒になって、今申し上げた毎日新聞の報道に乗っかって、これをでか…", "…日本にはもう一つの翼が必要ですということを地元で訴えています。立憲、共産ではだめだ、維新の会が二大政党の一翼を担うべきだと言っているんだけれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/153", "sentence": ["…二十六日です。ここからは推測ですよ、推測ですが、これは恐らく自民党と共産党の合作なんです。なぜか。大臣、ごめんなさい。大臣がいないところでや…", "…う。都構想の住民投票の前に行われたＮＨＫかどこかのテレビの討論会で、共産党の大阪市会議員が、松井代表から、いや、そんな、何か二百億、二百億と…", "…そんな、何か二百億、二百億と自民党みたいな丸いこと言うなよといって、共産党に、ちゃんと数字があるなら出しなさいということを松井代表が共産党に…", "…て、共産党に、ちゃんと数字があるなら出しなさいということを松井代表が共産党に言いました。共産党がぱっと紙をめくって、テレビですよ、テレビ、二…", "…と数字があるなら出しなさいということを松井代表が共産党に言いました。共産党がぱっと紙をめくって、テレビですよ、テレビ、二百十八億円という数字…", "…阪市財政局とうんたらうんたらやっている。その横で、テレビで、自民党と共産党はその人たちとつながって、先ほど局長からあった、全く意味のない数字…", "…意味のない数字をテレビで流しまくったわけですね。それが大阪の自民党と共産党だということは、残念ながら申し上げておかざるを得ないわけであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304601X00220201112/157", "sentence": ["