[{"date": "2020-11-05", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/723", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/725", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/727", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/729", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/731", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/733", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/735", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/737", "sentence": ["…、各分野の政策はウエルビーイングを念頭に置いて進められるべきと考えますが、大臣はどう思われますか。担当の坂本大臣、よろしくお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/739", "sentence": ["○上野通子君坂本大臣、ありがとうございます。是非とも、ここでちゃんと積み上げてきたこの調査を各省庁に発信していただきたいなと思います。よろし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/741", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/743", "sentence": ["…次に、地方公共団体へのウエルビーイング施策の支援や普及について、再び坂本大臣にお伺いします。我が国においては、例えば、私も今年の八月に佐賀市…", "…すが、今後は是非ともウエルビーイングの観点も含めて、頑張っているところに対して応援をしていただきたいと思うんですが、坂本大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/745", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/747", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00120201105/749", "sentence": []}]}]}]