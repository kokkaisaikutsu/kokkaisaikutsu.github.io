[{"date": "2022-02-24", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/490", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/492", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/494", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/496", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/498", "sentence": ["…に高評価を受けたというものの例も紹介されました。そこで、人的資本と非財務的な情報の見える化についてお伺いします。新しい資本主義の時代には、人…", "…伺いします。新しい資本主義の時代には、人はコストではなく貴重な資産、財務的な指標に表れない、そのような非財務的な情報の見える化によって企業が…", "…、人はコストではなく貴重な資産、財務的な指標に表れない、そのような非財務的な情報の見える化によって企業がより人を重視していく、より人に投資し…", "…視していく、より人に投資していく方向に進むことが期待されると思います。非財務的な情報の見える化について、現在の状況を山際大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/500", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/502", "sentence": ["…会議所のプレゼンのときに、中小零細企業の経営状況を反映するために、非財務指標の一つとして従業員のウエルビーイングを位置付けたガイドラインを国…", "…成を望んでおりますので、是非ともよろしくお願いします。そして、現在、財務情報の四半期開示に関しては既に見直しの方向が表明されているところです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/504", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/506", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/509", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/511", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/513", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/515", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/517", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/519", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00220220224/521", "sentence": []}]}]}]