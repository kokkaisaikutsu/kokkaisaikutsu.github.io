[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/15", "sentence": ["…二十三区は、今までは、入る方、二十三区に受け入れるといいますか、転入超過が当たり前であったわけでございますが、昨年は、初めてと言っていいほど…", "…たり前であったわけでございますが、昨年は、初めてと言っていいほど転出超過、僅か五千四百三十三人でございますが、入るよりも出る方が多い。だから…", "…に埼玉、千葉、神奈川を加えた東京圏で見ると、やはり八万人ぐらいの転入超過がある。学者によっては、都内から郊外にテレワークなどのために移住した…", "…ただ、大きな目で見ると、先ほどの東京圏のように、やはり、まだまだ転入超過だ。さらに、視点を変えて、私は自民党の過疎対策の委員長をしております…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/31", "sentence": []}]}]}]