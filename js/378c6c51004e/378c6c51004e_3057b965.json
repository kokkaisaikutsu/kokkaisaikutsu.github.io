[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/15", "sentence": ["…は広いんですけれども、大都市に比較的近い、いわゆる丹波篠山などの丹波地方だけではなくて、兵庫県北部の豊岡とか養父とか朝来などでも着実に移住す…", "…二〇年の国調で、全国の過疎団体が更に増えた。六十五団体増えて、全国の地方自治体の過半を超える自治体が過疎団体になった。そういう、見方によって…", "…そういう、見方によっていろいろあろうかと思いますが、トータルとして、地方創生を閣内で先頭になって頑張っておられる野田大臣、この辺をどう見て、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/17", "sentence": ["…委員ありがとうございます。野田大臣の答弁にもありましたように、結局、地方創生ということと人口急減対策、子供の出生率を上げるということは裏腹だ…", "…減対策、子供の出生率を上げるということは裏腹だと思います。ですから、地方創生なくして我が国の人口減少に歯止めをかけることはできないと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/31", "sentence": []}]}]}]