[{"date": "2023-04-12", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/64", "sentence": ["…給を行っていくためには、安定した活用、消費先と、次の時代を見据えた再造林が重要なことは、説明するまでもありません。そこで、国産材の利用促進、…", "…でもありません。そこで、国産材の利用促進、また、次につながるための再造林の強化、特にエリートツリーの推進など、未来を見詰めた林業促進にどのよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00620230412/66", "sentence": ["…ています。エリートツリーが広がれば、下草刈りの省力化など、本当に、再造林を妨げている要素を低減させていくということにも確実につながるというふ…", "…くということにも確実につながるというふうに思っています。宮崎県では再造林率八〇％を目指していますが、現状は七〇％台で推移をしているところです…"]}]}]}]