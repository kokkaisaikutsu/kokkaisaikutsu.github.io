[{"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/135", "sentence": ["…消火剤が大量に流出する事故が起こりました。泡消火剤には、以前から水質汚染で問題になっていた有機フッ素化合物、ＰＦＯＳやＰＦＯＡなどが含まれて…", "…物の一種で、発がん性などが指摘されております。ＰＦＯＳは、残留性有機汚染物質に関するストックホルム条約で国際的に製造、使用が制限され、国内で…", "…川に大量に流出し、付近には泡が立ち込めていました。以前から地元の水質汚染で問題視されていた中、この事故は改めて基地と水問題に注目を集めました…", "…量の泡消火剤流出事故にて、後日、水質調査が行われました。その結果、水汚染の判断基準値の六倍に及ぶフッ素化合物が検出されました。米軍の嘉手納基…", "…辺の河川で高濃度のＰＦＯＳとＰＦＯＡが検出されていることから、基地が汚染源だと指摘をされております。米軍は、二〇一六年七月の説明によりますと…", "…あったとのことであります。調査結果や状況から考えて、ほぼ米軍基地内が汚染源と考えて間違いないのではないかと私の地域では言われております。日米…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00120230220/146", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第七分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00120230220/168", "sentence": []}]}]}]