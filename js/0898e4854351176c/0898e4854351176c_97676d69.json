[{"date": "2021-03-25", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/123", "sentence": ["○須藤元気君こんにちは。本日は、林業に関連した法案質疑ですが、林野庁は、国産材の利用を国民に幅広く訴えるため、木づかい運動の取組を平成十七年…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/125", "sentence": ["…労働力の確保が大きな課題となります。私の勝手なイメージですけれども、林業と聞くと、何かチェーンソーを持ったブルース・ウィリスのようなマッチョ…", "…すね。話は戻りますが、この世界はやはりイメージででき上がっています。林業もイメージを変えて、若者や女性たちにとっても魅力的な産業になれば山村…", "…も魅力的な産業になれば山村振興になるとも考えております。そのために、林業イノベーションによる生産性向上等も重要だと認識していますが、今回の間…", "…ベーションによる生産性向上等も重要だと認識していますが、今回の間伐等特措法の改正によって林業活性化はどの程度進んでいくのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/135", "sentence": []}]}]}, {"date": "2022-04-05", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/102", "sentence": ["…ちょしているという声も聞かれます。と申しますのも、農業者からすると、林業や水産業といった同じ第一次産業に連携するということについてはイメージ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/111", "sentence": []}]}]}]