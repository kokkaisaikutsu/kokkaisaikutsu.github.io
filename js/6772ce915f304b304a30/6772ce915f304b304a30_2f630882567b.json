[{"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/25", "sentence": ["…、私も九年前にやらせていただいて、沖縄にも入らせていただいていろんな振興策の現地を見てきたんですが、そのときからちょっと感じていることで、な…", "…そのときからちょっと感じていることで、なかなかこの五十年間、いろんな振興策は取られてきましたけれども、必ずしも成果が出てきたものばかりではな…", "…二二年度の予算で二千六百八十四億円の沖縄振興予算が付いておりますが、こうしたことも含めてこれからどのように振興策を図っていくのか、伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/27", "sentence": ["○牧野たかお君西銘大臣ならではの振興策を期待しております。以上で終わります。"]}]}]}]