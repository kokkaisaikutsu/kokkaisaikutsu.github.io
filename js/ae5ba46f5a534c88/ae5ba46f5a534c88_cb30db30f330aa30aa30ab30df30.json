[{"date": "2024-03-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/8", "sentence": ["…うということも別の観点から説明していただきたいんですね。例えば、ニホンオオカミの絶滅というものがありました。そのニホンオオカミ、日本の自然界…", "…ですね。例えば、ニホンオオカミの絶滅というものがありました。そのニホンオオカミ、日本の自然界における食物連鎖の頂点に立っていたと言われるわけ…", "…以降、やはり家畜の飼育が始まって、大神、大きい神様と称されていたニホンオオカミが、害獣というふうに扱われてしまって駆除されてしまい、絶滅に至…", "…されてしまい、絶滅に至ったというようなことも漏れ聞いております。ニホンオオカミというのは犬ぐらいの大きさですから、イノシシをどうやって食べた…", "…した。子供の数が減れば、当然成体も少なくなっていく。このように、ニホンオオカミが絶滅したことによって今イノシシとか鹿が増えてしまっているんだ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00420240322/34", "sentence": []}]}, {"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304889X00420240322/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00420240322/58", "sentence": []}, {"url": "https://kokkai.ndl