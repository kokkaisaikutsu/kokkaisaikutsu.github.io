[{"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/23", "sentence": ["…の取組について、この新機構の今度行う官民ファンドとの関係性ですとか役割分担というところをどのように整理をするおつもりなのか、環境省にお尋ねを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/27", "sentence": ["…ァンドなんというのもありますので、ここの、その日本政策投資銀行との役割分担だったり、お互いに民間のその事業に融資で争っても、まあ規模だったり…", "…何というんですか、競争みたいなのを排しながら、うまく混乱を回避して役割分担をしていかなきゃいけないなというふうに思っているんですが、このＤＢ…", "…分担をしていかなきゃいけないなというふうに思っているんですが、このＤＢＪとの役割分担について今お考えがあればお聞かせいただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/29", "sentence": ["○熊谷裕人君ありがとうございます。しっかりと役割分担をして、ウイン・ウインの関係になるように進めていただければと思います。次に、収益性の確保…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00620220517/41", "sentence": []}]}]}]