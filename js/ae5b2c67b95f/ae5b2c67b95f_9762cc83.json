[{"date": "2023-04-12", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/217", "sentence": ["…向けた文言が盛り込まれております。こう書いているわけですね。「適正な抗菌薬使用などを含め、こどもにとってより良い医療の在り方について、今後、…", "…いしたいと思います。これは参考人で結構ですので。二〇一五年に比べて、抗菌薬の使用量、販売量はどれだけ減少しているでしょうか。二〇一九年と二〇…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/221", "sentence": ["…ていただきましたけれども、紛れもなく、二〇一九年までの傾向を見ても、抗菌薬の使用、抗生物質の使用は減っている、とりわけ小児の分野で顕著に減っ…", "…ことをまず初めに申し上げておきたいと思います。その上で、小児医療において抗菌薬の適正使用の取組、どう進んでいるのか、紹介していただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/225", "sentence": ["…ういうことなんですよね。ですから、子供の医療費有料化によって不適切な抗菌薬を減らそうなんて、そういう邪道な方針は元々政府は考えていなかったわ…", "…、医師などへの普及啓発、教育活動だとかこういうことを通じて、不適切な抗菌薬の使用は減らしていくというのが王道だと思いますよ。これを自己負担に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/305", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00820230412/320", "sentence": []}]}]}]