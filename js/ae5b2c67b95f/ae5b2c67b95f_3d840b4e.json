[{"date": "2023-04-26", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/134", "sentence": ["…。羽田の新飛行ルートの運用が始まりまして三年たちました。騒音だとか、落下物、事故への不安などから、新ルートの撤回を求める声が大変強い状況です…", "…ングの一部欠落というのが報告されております。仮にこうした大きなものが都心上空の住宅密集地で落下すれば、重大な事態が生じるんじゃありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/136", "sentence": ["…ますように主脚タイヤの一部、五キロだとか、発見されていない、飛行中に落下した可能性があるものが、たくさん報告されているということであります。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/142", "sentence": ["…根本から間違っているんじゃないですか。住民の皆さんが求めているのは、落下物だとかの危険があるから、都心上空は飛ばないでくれということですよ。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X01120230426/154", "sentence": []}]}]}]