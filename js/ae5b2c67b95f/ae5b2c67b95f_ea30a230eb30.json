[{"date": "2022-04-13", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/247", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/249", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/251", "sentence": ["…いと。当然の発言だというふうに思います。政府は、例外的に、使用成績、リアルワールドデータで代替し得るということをおっしゃいますけれども、この…", "…は、第三相試験はプラセボ群と対比して有効性を確認する、一方、承認後のリアルワールドデータでは、患者に承認薬を投与しないというのは倫理的に難し…", "…い、こういう指摘がございました。伺いますけれども、厚労省は、第三相試験と比べてリアルワールドデータの限界というのはどこにあるとお考えですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/253", "sentence": ["○宮本（徹）委員もうちょっと分かりやすく。リアルワールドデータでは、やはり不十分な面があるという認識だということでよろしいわけですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/255", "sentence": ["○宮本（徹）委員限界があるわけでございます、リアルワールドデータには。その上で、その期限内に改めて行う正式の承認について、これは前回お伺いし…", "…ついて、これは前回お伺いしたんですけれども、感染症が収束した場合にはリアルワールドデータでいいというお話があったわけですよね。例外規定ですね…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/257", "sentence": ["…績について、安全性をしっかり見ていく、有効性もしっかり見ていく上で、リアルワールドデータのお話がございました。ちょっと通告していないんですけ…", "…した。ちょっと通告していないんですけれども、確認だけですが、基本は、リアルワールドデータ、使用成績というのは、悉皆性をもって収集していくとい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/259", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/261", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01320220413/269", "sentence": []}]}]}, {"date": "2022-11-01", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004260X00420221101/75", "sentence": ["…阪や沖縄などに看護師を派遣した自分の病院の医療体制が厳しくなったというお話が先ほどございましたが、リアルな実態を教えていただけるでしょうか。"]}, {"url": "h