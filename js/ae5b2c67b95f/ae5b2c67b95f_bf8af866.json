[{"date": "2022-10-18", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/321", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/323", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/325", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/327", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/329", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/331", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/333", "sentence": ["…。これは、被害者が国と統一協会と信者らを訴えた損害賠償請求訴訟の和解調書であります。この裁判は、国が統一協会を野放しにして解散命令請求や質問…", "…の提案を受けて、国は、宗教法人法の趣旨目的にのっとり、適切にその職務を行っていく、こう約束をされました。総理、この和解調書は御存じですよね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/335", "sentence": ["○宮本（徹）委員今初めて見たということですけれども、この和解調書を受けて国はどういう改善策を取ったんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/338", "sentence": ["○宮本（徹）委員そうなんですね。この赤字の部分は、その後、更正調書を作らせて、国が圧力をかけて削除させたという、とんでもないことまでやってい…", "…削除させたという、とんでもないことまでやっているわけですよ。この和解調書そのものは、国の代理人も含めて全ての代理人、当事者が参加した場で一言…", "…た場で一言一句裁判長が読み上げた言葉ですよ。それを、終わった後に更正調書を作らせるという異様なことまでやったわけでございますが。この中では、…", "…行っていく、こう約束されたわけですけれども、もう一度お伺いします。この和解調書を受けて、国は統一協会に対する宗務行政をどう改善したんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/340", "sentence": ["…んですよ。宗務行政を……（発言する者あり）何言っているんですか。和解調書そのものは、宗教法人法の趣旨目的にのっとり、適切にその職務を行ってい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/342", "sentence": ["…んちんかんな答弁をされても困るんですよ。結局、皆さんのところにも和解調書、事務連絡の部分、つけてありますので御覧になってください。国は、宗教…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/346", "sentence": ["…説明できないということじゃないですか。次に行きます。二〇一四年の和解調書の翌年、統一協会の被害防止のための適切な宗務行政と真逆のことが行われ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/348", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/350", "sentence": ["…〇一三年の参院選で統一協会が自民党の組織的支援をした。それ以降、和解調書で約束した宗務行政の改善、解散命令請求や質問権行使はやらない、安倍政…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/352", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/354", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/356", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/358", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/360", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/363", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/365", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/367", "sentence": []}]}]}]