[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305254X00620201119/11", "sentence": ["…ていただきます。気候非常事態宣言決議案近年、地球温暖化も要因として、世界各地を記録的な熱波が襲い、大規模な森林火災を引き起こすとともに、ハリ…", "…風・豪雨が毎年のように発生し深刻な被害をもたらしている。これに対し、世界は、パリ協定の下、温室効果ガスの排出削減目標を定め、取組の強化を進め…", "…各国が掲げている目標を達成しても必要な削減量には大きく不足しており、世界はまさに気候危機と呼ぶべき状況に直面している。私たちは「もはや地球温…", "…問題は気候変動の域を超えて気候危機の状況に立ち至っている」との認識を世界と共有する。そしてこの危機を克服すべく、一日も早い脱炭素社会の実現に…"]}]}]}, {"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/198", "sentence": ["…これだけの長期化もあり、かつ、地政学的リスクもこれだけ高まって、もう世界が全然変わったんだと思うんです、今。ですから、やはりそこは発想を改め…", "…は単に観光産業だけじゃないと思います。やはり、グローバル化、とにかく世界は一つのマーケットだ、そういう時代はもう終わったと思わなきゃいけない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/214", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00220220302/218", "sentence": []}]}]}]