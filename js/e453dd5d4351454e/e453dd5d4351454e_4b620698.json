[{"date": "2020-11-17", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/199", "sentence": ["…してくれというような、急に目の前のですよ。ですから、そういう見直しの手順、どういう手順でやるのか。前も、東京を除外したときも、もう既にだあっ…", "…ような、急に目の前のですよ。ですから、そういう見直しの手順、どういう手順でやるのか。前も、東京を除外したときも、もう既にだあっと予約が入って…", "…準、どういうことになったら、どういう形で見直すのか、ちゃんと基準とか手順、そういうものをはっきりしておくという必要が、それは、旅行する利用者…", "…とっても、またホテルとか観光業界の人たちにとっても大事なことだと思います。この辺の基準とか手順、それはどういうふうに考えているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/203", "sentence": ["…、そういうことが大事だと思いますので、ぜひそういった意味で、基準とか手順というものを客観的に明確にわかるようにしていただきたいというふうに思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304319X00220201117/211", "sentence": []}]}, {"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00320201117/146", "sentence": []}]}]}]