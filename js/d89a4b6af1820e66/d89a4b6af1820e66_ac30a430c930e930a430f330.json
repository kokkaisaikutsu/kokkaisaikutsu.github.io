[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/94", "sentence": ["…聞かせを願いたいと思うんですけれども、こちらに在留特別許可に係るガイドラインというのがあるんですけれども、まず、これは不法滞在者に在留許可を…", "…可に係るガイドラインというのがあるんですけれども、まず、これは不法滞在者に在留許可を与えるためのガイドラインなのかどうか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/96", "sentence": ["○高橋（英）分科員ありがとうございます。このガイドラインを見ると、「その他の積極要素」というところをちょっと読みますけれども、「当該外国人が…", "…思うんです。要は、常日頃からきちんとした生活を送るようになると思うんですね。より具体的なガイドラインというのはもうちょっとないんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/102", "sentence": ["…は日本のためにもなると思いますので、しっかりとした、より具体的なガイドラインを作っていただきたいというふうに思います。そして、仮に親御さんが…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/108", "sentence": []}]}]}]