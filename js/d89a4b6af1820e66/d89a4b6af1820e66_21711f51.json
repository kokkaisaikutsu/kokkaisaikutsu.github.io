[{"date": "2023-04-24", "meeting": [{"meeting_name": "衆議院 決算行政監視委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/82", "sentence": ["…なずいていただければいいですけれども。はい、分かりました。じゃ、これはいいですけれども。次に、デジタル教科書、これは無償でよろしいんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/84", "sentence": ["○高橋（英）分科員それは、無償ということでいいんですよね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/86", "sentence": ["○高橋（英）分科員そうしましたら、デジタル教科書ですから、端末は、これは無償になるのかどうか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/88", "sentence": ["○高橋（英）分科員大臣、無償にしないと意味がないと思うんですけれども、検討云々ではなくて。だって、無償にしないと、家庭環境だとかいろいろな面…", "…しないと意味がないと思うんですけれども、検討云々ではなくて。だって、無償にしないと、家庭環境だとかいろいろな面でやはり差が出てくると思います…", "…て、無償にしないと、家庭環境だとかいろいろな面でやはり差が出てくると思いますので、これは無償にすべきだと思いますが、もう一度よろしいですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/90", "sentence": ["…何もないので。必ずこれは、やはり一人一台ないと、不可欠ですから、まず無償化でちょっとやっていただかないと、これはどうしようもないと思いますの…", "…もないと思いますので。これ以上は質問にはしませんけれども、是非これは無償化でお願いをしたいというふうに思います。あと、これまでの教科書検定は…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/122", "sentence": ["…ここでもやはり格差が生じないという答弁がありましたけれども、だったらなおのこと、必ずやはり端末は無償化にすべきだと思いますが、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/128", "sentence": []}]}]}]