[{"date": "2022-03-04", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/37", "sentence": ["…への丁寧な発信に取り組んでいるところでございます。御指摘の紙媒体での広報については、例えば、昨年十二月、厚生労働省について、モデルナの有効性…", "…摘の、いわゆる新聞広告も作成させていただきました。私からも、これらの広報資材を各自治体の皆様や医療関係団体に直接紹介し、周知していただくよう…", "…ろいろございます。紙媒体の情報は重要でありまして、新聞広告やポスターなども活用し、効果的に広報に努めてまいりたいというふうに思っております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/51", "sentence": []}]}]}]