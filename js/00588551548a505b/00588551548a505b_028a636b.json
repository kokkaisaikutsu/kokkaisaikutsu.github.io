[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/209", "sentence": ["○堀内国務大臣済みません、まず先ほどの訂正なんですが、モデルナの単位を千七百万回というふうに申し上げさせていただきます。最初、一万七千回と言…", "…ったやに聞いております。しっかりと、千七百万回とそこの部分については訂正させていただきます。追加接種におきまして選べるのかといった御下問です…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/211", "sentence": []}]}]}, {"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805124X00220220302/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00220220302/71", "sentence": ["○堀内国務大臣ただいま、まず、先ほどの答弁で一つ訂正させていただきます。組織委員会が六千三百四十三億円といった内訳でございましたが、そのとき…", "…四十三億円といった内訳でございましたが、そのとき億をつけずに円というふうに申し上げてしまいました。ここだけ一つ、まず訂正させていただきます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00220220302/256", "sentence": []}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/183", "sentence": []}]}]}]