[{"date": "2022-02-09", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/36", "sentence": ["…ゾンチームに対する認識があれだと。私自身は、リエゾンチームが存続して仕事を、きちっと職務を果たしていただいていると。人数についてはそのときに…", "…人員が入れ替わったりしているかもしれませんが、リエゾンチームとして十三名の方がしっかりと仕事をしていただいているというふうに認識しています。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/38", "sentence": ["…すが、リエゾンチームについては、今十三名の方がいらっしゃって、そして仕事を継続していただいているというふうに、私自身が、それが認識でございま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/41", "sentence": ["…たのをいつ知ったんですか。今ですか」と呼ぶ）リエゾンチームは、まだお仕事をしてくださっております。その中で、体制、そして人数が変わることにつ…", "…報告を受けている状況ではございません。ただ、リエゾンチームとしては、しっかりと存続してお仕事をしていただいているというふうに認識しています。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01320220209/148", "sentence": []}]}]}]