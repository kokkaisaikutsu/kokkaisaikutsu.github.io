[{"date": "2022-12-08", "meeting": [{"meeting_name": "衆議院 原子力問題調査特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/22", "sentence": ["…ります。そういった中で、いわゆる放射線の高い透過性、そういったものを利用して、医療分野で今放射線は多く使われているというふうに思っております…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/30", "sentence": ["○堀内委員ありがとうございます。是非、これから様々な放射線の医療的な利用が増えるに従って、今まで以上に、医療被曝の線量管理、そして患者さんの…", "…るところでございます。また一方、放射線自身の正しい理解と原子力の平和利用、こういったものについて皆さんのお考えをもっともっと深めていただくた…"]}]}]}]