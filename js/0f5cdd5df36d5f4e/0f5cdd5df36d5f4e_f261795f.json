[{"date": "2021-01-25", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/151", "sentence": ["…全国で三万人、四万人と言われている。この状況の中で、入院を拒否したら懲役刑だ。私はちょっと気が知れないんですよ、どういう神経でこれを議論して…", "…。詳しくはまた後続の質疑者が行われると思いますが、端的に、この入院拒否に対する懲役刑については、撤回の上、修正に応じることを求めます、総理。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/153", "sentence": ["…そして、自宅で亡くなる方も多発していますよね。そういう状況の中でこの懲役刑を議論すること自体が笑えないんですよ、これ。皮肉にもほどがある。逆…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00220210125/163", "sentence": []}]}]}]