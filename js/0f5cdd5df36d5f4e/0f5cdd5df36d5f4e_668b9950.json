[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/6", "sentence": ["…認したいと思います。その上で、ちょっと事件直後ですから酷なんですが、警備当局の見解も聞いておきたいと思って、今日は出席を依頼しております。警…", "…見解も聞いておきたいと思って、今日は出席を依頼しております。警察庁の警備局の受け止め及び、報道で目にしていることですので私もちょっと事実確認…", "…ます。この事実関係なり、あるいは、その経緯を踏まえた今回の事件の受け止め、ちょっと警察庁の警備当局として見解をお聞きしておきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/8", "sentence": ["…ですから酷であることは分かった上でお尋ねしているんですが、ちょっと、警備局長は聞いてくださいよ、この手の話はやはりどうしたって結果責任が問わ…", "…御答弁からも感じるし、あるいは松野長官の御発信からも感じるんですが、警備に問題はなかったという立場なんでしょう。そして、最善を尽くしておられ…", "…ば、ちょっと信じ難い惨劇になっていた可能性もあるということも含めて、警備は適切だったとかではちょっと済まない事態に立ち至っているということは…", "…ります。この点、インターネット上の巡回、サイトの巡回など、ネット上の警備の強化に当たられるという報道に接しました。この事実関係も改めて確認し…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104260X00920230419/34", "sentence": []}]}]}]