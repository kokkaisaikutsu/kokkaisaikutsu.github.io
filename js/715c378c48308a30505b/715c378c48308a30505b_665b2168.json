[{"date": "2020-10-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/19", "sentence": ["…事なので、今、オンライン教育が進んで、オープンスペースをつくろうとか学校の改修が進んでいます。その中に是非和室をつくるというのを入れてほしい…", "…室をつくるというのを入れてほしいんです。中学、高校などには和室のある学校あります。でも、それは茶道部が使うだけみたいな、非常に限定的です。今…", "…化していて、和室がないうちがもう本当に多くなりました。そんな中で、小学校で一年生から六年生まで全ての子供たちが和室で文化の体験をする。お軸が…", "…なっていく、そこがまたイノベーションにつながっていくということで、小学校、一つずつ和室をつくる、このプロジェクトを考えていただきたいと思うん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/29", "sentence": []}]}]}, {"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/33", "