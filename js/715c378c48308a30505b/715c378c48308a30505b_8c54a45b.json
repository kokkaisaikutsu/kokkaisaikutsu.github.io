[{"date": "2020-10-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/19", "sentence": ["…オープンスペースをつくろうとか学校の改修が進んでいます。その中に是非和室をつくるというのを入れてほしいんです。中学、高校などには和室のある学…", "…中に是非和室をつくるというのを入れてほしいんです。中学、高校などには和室のある学校あります。でも、それは茶道部が使うだけみたいな、非常に限定…", "…だけみたいな、非常に限定的です。今、住環境がどんどん洋式化していて、和室がないうちがもう本当に多くなりました。そんな中で、小学校で一年生から…", "…なりました。そんな中で、小学校で一年生から六年生まで全ての子供たちが和室で文化の体験をする。お軸がある、書道、和歌、しつらえ、美術工芸品の鑑…", "…音はドレミファじゃありません、邦楽は。あるいは立ち居振る舞いですね。和室が一つあることによって非常に子供たちの心が豊かになっていく、そこがま…", "…こがまたイノベーションにつながっていくということで、小学校、一つずつ和室をつくる、このプロジェクトを考えていただきたいと思うんですが、このＳ…", "…、このプロジェクトを考えていただきたいと思うんですが、このＳＴＥＡＭ教育、個別教育、個別最適化、和室づくりについて何かお考えがありましたら。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214889X00120201008/29", "sentence": []}]}]}, {"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/35", "sentence": ["…けれども、今住宅で畳の部屋少なくなってきております。小学校に一つずつ和室をつくってほしいというふうに思います。書道、華道、茶道、武道、舞踊、…", "…なくて、ちゃんと授業として一クラス三十五人が入れるきっちりした大きな和室をつくって、そこで学ぶということを考えてほしいというふうに思います。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/47", "sentence": []}]}]}]