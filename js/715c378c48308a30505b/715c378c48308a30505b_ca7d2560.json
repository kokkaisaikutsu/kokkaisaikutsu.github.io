[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/29", "sentence": ["…その辺もしていただきたいと思います。三月三日、衆議院の憲法審査会で、緊急事態が発生した場合等において例外的にオンライン出席も含まれると解釈で…", "…き、どうやってオンライン出席するのかとか、むしろ解釈では乗り切れない緊急事態条項を憲法に記すことを真っ正面から議論すべきというふうな課題が明…", "…すべきというふうな課題が明確になってきたというふうに思っております。緊急時の内閣の権限や議員の任期というのも延長をしなければならない事態も生…", "…あります。個人の財産権、自由と公益、公共の福祉、人々の命を救うための緊急対応をどう考えていくか、救える命を救うという、そして復旧復興をスピー…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/47", "sentence": []}]}]}]