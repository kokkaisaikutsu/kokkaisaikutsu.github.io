[{"date": "2022-04-27", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804080X01320220427/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01320220427/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01320220427/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01320220427/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01320220427/27", "sentence": []}]}, {"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/37", "sentence": ["…とも規定をされています。これは我が党からの意見も踏まえて記述したものと承知をしておりますが、この規定の趣旨や狙いについて、提出者に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/39", "sentence": ["…。大綱、白書、閣僚会議の取扱い等といった観点も含めまして、従来三法との関係を、野党案との対比も含めまして、提出者にお伺いできればと存じます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/41", "sentence": ["…というのが記述されているわけですけれども、その狙い、あるいは、今後期待される取組としてどのような内容を想定されているのか、提出者に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/43", "sentence": ["…を受けられなくなることの弊害が様々なところで指摘されてきたと承知をしておりますが、改めて、提出者の意図するところをお伺いできればと存じます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/51", "sentence": []}]}]}]