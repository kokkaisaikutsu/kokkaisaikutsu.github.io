[{"date": "2022-10-27", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/4", "sentence": ["…我が国の様々な諸課題の中で、この国土を次の世代へつないでいくための新たな国土形成計画の策定に向けての御所見を国土交通大臣にお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/6", "sentence": ["…役割を担うインフラの機能強化に向けての施策を更に推進をしていくべきであると存じますが、これまでの取組状況を踏まえ、御所見をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/10", "sentence": ["…消が求められております。今後の四国地方の高規格道路の整備促進と早期のミッシングリンクの解消について、国土交通大臣の御所見をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00220221027/14", "sentence": []}]}]}, {"date": "2024-03-21", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/9", "sentence": ["…まった言葉であろうと存じております。そこで、改めて、この考え方について、これまでに至る経緯や背景も含め、環境大臣の御所見をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/15", "sentence": ["…ジアの脱炭素化をリードしていくことが世界での一・五度目標の実現に向けて大変重要であると考えますが、環境大臣の御所見を併せてお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X00220240321/17", "sentence": []}]}]}, {"date": "2024-05-14", "meeting": [{"meeting_name": "参議院 経済産業委員会、環境委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314081X00120240514/2", "sentence": ["…我が国の取組の方向性を変更するものでないのかということで、そのことについての御所見も齋藤経済産業大臣にお伺いをさせていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314081X00120240514/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314081X00120240514/6", "sentence": []}, {"ur