[{"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第五分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/305", "sentence": ["…。昨年の質疑の際には、令和二年度以降も、引き続き、国立長寿医療研究センターにおいて、インハウス研究として、難聴者を二群に分けた補聴器の装着の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/309", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/311", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/313", "sentence": ["…研究所で研究が進められております。そこで、厚労省に確認をいたします。耳を含む感覚器に関する国立の研究センターは、我が国にはあるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/315", "sentence": ["…國重分科員存在しないということでありました。では、これまで国立の研究センターはどのような設置基準の下で整備されてきたのか、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/317", "sentence": ["…りであります。しかし、今、厚生労働省が注力をしているはずの国立長寿センターの耳鼻咽喉科には常勤の医師がおりません。また、こういったこともござ…", "…っております。私は、この耳、感覚器の分野につきましても、国立の研究センターをつくって、そこがリードをしてしっかりと進めていく、そして新たな治…", "…ら、これからの人生百年時代を見据えて、耳や感覚器に関する国立の研究センターを設置する、そしてこの分野の研究に力を入れていくべきと考えますが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/321", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/323", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/325", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/327", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/329", "sentence": []}]}]}]