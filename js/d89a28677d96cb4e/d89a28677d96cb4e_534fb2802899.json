[{"date": "2024-02-05", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/116", "sentence": ["○高木（陽）委員続いて、体育館の空調について質問したいと思うんですが、石川県において避難所になっている小中学校は三十六校、石川県内で避難所と…", "…法を改正いたしまして、学校耐震化が進みました。さらに、東日本大震災で体育館の天井が落下するケースがあり、非構造部材、この耐震化も進めてまいり…", "…いりました。一方、二〇一八年の西日本豪雨で、真夏の中、避難所となった体育館でエアコンがなく、高齢者、持病を持っている被災者の健康に大変大きな…", "…ました。その後、東京都では、都議会公明党の提言を踏まえて、小中学校の体育館の空調設置率、実はこれは八二・一％にもなっています。一方、全国で見…", "…見ると、まだ一五・三％。今回の地震でも、厳寒の中、避難所となっている体育館で、毛布にくるまって寒さに耐えている被災者の方々が数多くおります。…", "…豪雨災害などどこでも起こり得る自然災害のことを考えると、避難所となる体育館の空調設置が重要であると考えますが、国の財政支援も含めて総理の御見…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00320240205/134", "sentence": []}]}]}]