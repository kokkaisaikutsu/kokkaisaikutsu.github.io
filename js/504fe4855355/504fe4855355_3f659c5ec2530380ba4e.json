[{"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/12", "sentence": ["…に思っておりますけれども、ローカルスタートアップの推進に向けて総務省として今後どのように取り組んでいくのか、政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/14", "sentence": ["…要だと思いますが、総務省としてこれ頑張っていただきたいと思いますけれども、今後どのように取り組んでいくのか、政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/16", "sentence": []}]}]}, {"date": "2024-05-09", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/18", "sentence": ["…表示する見える化の取組を開始したというふうに認識していますが、この見える化の取組、どのように広げていくのか、政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/26", "sentence": ["…定供給を懸念する声が一部に聞かれています。米、野菜の種子の供給状況、また今後の安定供給に向けた施策について、政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/30", "sentence": ["…たが、これ具体的に、こういった農村ＲＭＯの推進に向けて具体的にどのように取り組んでいくのか、政府参考人にお伺いをしたいというふうに思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/32", "sentence": ["…置付けられているわけでありますが、この地域資源の活用といったときにどういった事業を推進していくのか、こちらも政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/34", "sentence": ["…かなと、そのように思っているところであります。今後、鳥獣被害の対策を具体的にどのように進めていくのか、こちら政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/36", "sentence": ["…うことが重要なわけでありますが、今後このスマート農業の現場の実装に向けてどのように取り組んでいくのか、これも政府参考人にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X00820240509/43", "sentence": []}]}]}]