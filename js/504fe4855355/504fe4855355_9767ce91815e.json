[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/18", "sentence": ["○佐藤啓君ありがとうございました。そこを、もちろん農水省の中に林野庁もあるわけでありますので、しっかりと連携の方をしていただきたいというふう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/20", "sentence": ["…業だなというふうに思っておりますので、積極的な関わりを農水省に、また林野庁にも求めて、私の質問とさせていただきたいと思います。よろしくお願い…"]}]}]}]