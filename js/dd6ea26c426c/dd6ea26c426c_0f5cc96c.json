[{"date": "2021-05-20", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/5", "sentence": ["○滝沢求君自由民主党の滝沢求でございます。質疑に入る前に、小泉大臣、急な入院から公務復帰、おめでとうございます。本日からいよいよ国会審議、こ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/15", "sentence": ["○滝沢求君ありがとうございます。次の質問は、小泉大臣にお伺いしたいと思います。本法案における実行計画の再エネ導入目標や地域脱炭素化促進事業の…", "…体に対する支援を実施していくことが私は必要不可欠だと考えております。小泉大臣は、脱炭素の先行地域をモデルケースとして、次々とほかの地域に広が…", "…すが、環境省として、どのように地方自治体に寄り添って、いわゆる伴走しながら脱炭素化に向けた支援策を行っていくのか、小泉大臣の所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01020210520/24", "sentence": []}]}]}]