[{"date": "2023-02-28", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/31", "sentence": ["…異次元の金融緩和というのはドーピングだという話がありましたが、確かに景気悪化時のカンフル剤で、これについてはもう、十年前のあのもうずうっとデ…", "…て見えてきたのが、なかなかやっぱり金融政策だけで物価目標を達成する、景気を回復していく、一定のプラス面はあったと思います、ただ、これだけでや…", "…あるのかなと。これも、植田総裁候補も以前、これも新聞の取材に対して、景気回復には金融政策以外の理由が必要だということもコメントされております…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/123", "sentence": ["…ですが、ちょっとこれも質問四番のところで入れております金融政策以外の景気刺激策というのをお聞かせいただきたいと思います。金融庁に長い間いらっ…", "…、今の金融緩和策というのは異次元と言われていますので、あくまでこれは景気悪化時のカンフル剤で、いつかは正していくというか、戻していく必要があ…", "…届かないと。だから、金融政策だけでも、やはりなかなか経済成長をする、景気回復を目指していくというのは難しい。もちろんプラスの面もあったと思い…", "…まだ結び付いていない中で、金融政策以外の部分で、じゃ、どうしたらこの景気回復につながっていくのか、物価上昇につながっていくのか、この点に関す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114024X00920230228/131", "sentence": []}]}]}]