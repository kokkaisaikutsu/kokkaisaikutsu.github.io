[{"date": "2022-03-23", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/89", "sentence": ["…、その先には、やはり自分たちが生まれ育った場所が返ってくるというその願いを込めてこういう活動をされてこられているわけですね。交流は、コロナで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/93", "sentence": ["○清水貴之君是非よろしくお願いいたします。続いて、ロシアと取引をする企業、これ日本にもたくさんあるわけですが、こういった企業に対する対策を聞…", "…中で、こういう状況になるとそういった企業対策というのもますます必要になってくるのではないかと思いますが、これについて、経産省、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/97", "sentence": ["…も考えるとか、いろいろやり方はあるというふうに思います。この辺りも対応しっかりお願いしたいと思いますが、これ最後の質問にさせていただきます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00420220323/99", "sentence": []}]}]}]