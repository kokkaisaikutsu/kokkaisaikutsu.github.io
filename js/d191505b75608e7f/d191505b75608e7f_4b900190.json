[{"date": "2023-05-17", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/40", "sentence": ["…も、遊漁船業については登録制が取られている、遊覧船等については、人を運送する海上運送業において許可制が取られているということになっているんで…", "…については登録制が取られている、遊覧船等については、人を運送する海上運送業において許可制が取られているということになっているんです。当然、許…", "…るんですが、遊漁船業は登録制ということですね。今回の法改正では、海上運送法における遊覧船等に関する許可の欠格期間の延長と同様の改正内容を含む…", "…ないかと思いまして、やはり、そもそものその規制の部分で考えれば、海上運送業と同じように許可制にすべきなのではないか、そういう議論というのはな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X01120230517/56", "sentence": []}]}]}]