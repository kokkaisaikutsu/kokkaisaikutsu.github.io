[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/214", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/226", "sentence": ["…またま駐留国における経費負担の国際比較でございました。今度は、日米地位協定に係る各国との比較を資料三で用意させていただきました。国内法等との…", "…いけないという特別な思いを持っていることもあると思います。ドイツの地位協定においても、人、動物、植物の伝染病の予防と駆除については、同法の法…", "…ますが。そこで、大臣にお伺いするところですが、私はかねてから、この地位協定は日本の治外法権を放棄しているものだと、多分小村寿太郎は怒っている…", "…、こういう状況になっていますが、治外法権ともいうべき状態がこの日米地位協定の中に起こっているんですが、このことについて何か、何も思わないので…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/233", "sentence": []}]}]}]