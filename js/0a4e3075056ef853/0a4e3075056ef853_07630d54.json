[{"date": "2022-01-21", "meeting": [{"meeting_name": "参議院 国家基本政策委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/2", "sentence": ["…を行いたいと存じます。理事の選任につきましては、先例により、委員長の指名に御一任願いたいと存じますが、御異議ありませんか。〔「異議なし」と呼…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/3", "sentence": ["…委員長（上田清司君）異議がないものと認めます。それでは、理事に野村哲郎君、郡司彰君及び難波奨二君を指名いたします。─────────────"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814292X00120220121/7", "sentence": []}]}]}, {"date": "2022-03-29", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/66", "sentence": ["○上田清司君はい、続行します。グレンコさんにはまた改めて。今はお二方にだけ御指名させていただきました。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00520220329/74", "sentence": []}]}]}]