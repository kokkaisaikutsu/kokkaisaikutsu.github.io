[{"date": "2022-04-28", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/60", "sentence": ["○上田清司君では、米国が攻撃されれば、日本も一緒になって反撃するという考えですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/62", "sentence": ["…。そこで、最近では、例えば自衛官が国籍不明の国から攻撃される、これに反撃するのが自衛のための能力を発揮する、こんなふうに私は理解しております…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/64", "sentence": ["…はないかというふうに私は理解しておりますが、岸大臣、この比例の法則における反撃能力、自衛能力というのは今のような判断でよろしいんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01120220428/67", "sentence": []}]}]}]