[{"date": "2021-06-09", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X02920210609/21", "sentence": ["…付け、病床削減を促進しようとする医療法改悪法まで成立をさせました。公立病院、公的病院の再編、統廃合を進めることをやめません。コロナ禍に対応す…"]}]}]}, {"date": "2022-03-09", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/51", "sentence": ["○福島みずほ君このコロナ禍、圧倒的にコロナ感染症を受けているのが公立病院です。それの再編、統廃合を撤回しないって、あり得ないと思いますが、い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/53", "sentence": ["○福島みずほ君入院できなくて亡くなる人がいる。公立病院を廃止して医療体制を脆弱にしてきた厚労省の責任があるんじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/55", "sentence": ["…島みずほ君命守れてないですよ、命救ってないですよ。それって厚労省の責任じゃないですか。何でこの期に及んで公立病院を廃止しようとするんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/59", "sentence": ["○福島みずほ君大阪は公立病院廃止して独立行政法人化したからではないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/61", "sentence": ["…福島みずほ君国民の命守るために検討してください。今、東京都議会に、公立病院を廃止する、独立行政法人化の条例案が出ています。なぜ、このコロナ禍…", "…ぜ、このコロナ禍の中で、人の命守っていなくて、入院できなくて、何で公立病院民営化なんですか。おかしいですよ。政府も東京も大阪もおかしいですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01020220309/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X0102022030