[{"date": "2021-05-11", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/49", "sentence": ["…ングメモに、会議の場では厚労省と議論することになるが、しっかりと理論武装をする必要があると思うとあります。中立的であるべき行政が、日本派遣看…", "…る必要があると思うとあります。中立的であるべき行政が、日本派遣看護協会に、厚生労働省と議論するときに理論武装せよと言っている理由は何ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/51", "sentence": ["…ろが申請していて、そして、そのことを認めて厚生労働省と闘うように理論武装せよって、立場が明確じゃないですか。こんなのどこに中立性、公平性があ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01420210511/73", "sentence": []}]}]}]