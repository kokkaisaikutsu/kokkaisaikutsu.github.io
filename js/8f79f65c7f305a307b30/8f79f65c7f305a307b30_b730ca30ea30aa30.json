[{"date": "2021-02-03", "meeting": [{"meeting_name": "参議院 内閣委員会、厚生労働委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/13", "sentence": ["…おります。これは一月十五日の第五十一回厚生科学審議会感染症部会で、シナリオとあります。これはまさに脇田座長のシナリオなんですね。これ、ひどい…", "…科学審議会感染症部会で、シナリオとあります。これはまさに脇田座長のシナリオなんですね。これ、ひどいんじゃないですか。つまり、これ衆議院で後藤…", "…たのか、一体これやったの誰なんですかということなんですね。初めからシナリオがあった、演劇のように。これは厚生労働省からいただきましたが、これ…", "…田座長の発言、早期の常会提出を目指していただきとなっておりまして、シナリオがあるんですよ。こんなの茶番じゃないですか、出来レースじゃないです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/15", "sentence": ["…懸念が出ているんですよ。反対意見多いですよ。懸念が多いですよ。で、シナリオって書いてあるんですよ。賛成が多くても、反対意見、修正意見が多くて…", "…れ国会に出すとなっているんですよ。こんなばかな話ないですよ。こんなシナリオがあるんですよ。おかしいじゃないですか。専門家の意見って何なんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414894X00120210203/45"