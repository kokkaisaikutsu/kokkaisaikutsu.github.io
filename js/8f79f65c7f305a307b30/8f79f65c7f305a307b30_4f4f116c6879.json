[{"date": "2022-12-08", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/92", "sentence": ["…日は戸籍の続き柄について一言お聞きをいたします。私は、弁護士として、住民票の続き柄差別裁判、戸籍の続き柄差別裁判、法定相続分の差別撤廃裁判を…", "…判、法定相続分の差別撤廃裁判をほかの弁護士と一緒に担当してきました。住民票の続き柄は、かつて長男、長女、二男、二女、養子、子。婚外子は子でし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/94", "sentence": ["…意見があります。でも、婚外子は今まで男、女って書かれてきたんですよ。この長男、長女、二男、二女、住民票はなくしました。なくしたらどうですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X01020221208/102", "sentence": []}]}]}]