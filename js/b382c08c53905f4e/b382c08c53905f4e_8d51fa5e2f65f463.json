[{"date": "2022-05-18", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/70", "sentence": ["…多く、雇用のミスマッチが生じ、失業や人口流出が生じやすかった。住宅再建支援がない代わりに仮設住宅、公営住宅が建設されて、避難所から応急仮設住…", "…担は三千万円を超えたとも言われます。これらの公的支援を被災者の住宅再建支援に直接充てた方が効率的だったという指摘があります。また、復興事業で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/78", "sentence": ["…べきですが、我が国の災害補償では、ほかの先進国で実施されている住宅再建支援が欠けているのではないか。例えば、アメリカでは、二〇〇五年にハリケ…", "…の連邦議会で、一戸当たり最大十五万ドル、日本円で千九百三十五万円の再建支援金を支給するロードホーム・プログラムを可決し、実施されました。ルイ…", "…山善博氏の音頭により、再建三百万円、補修百五十万円という一律の住宅再建支援がなされ、被災した多くの世帯から感謝の声が上がりました。一世帯当た…", "…している人の生活再建を第一に置いて、政府として、持家のある人の住宅再建支援を百万円単位から一千万円単位で行う制度を設けるべきではないでしょう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00620220518/96", "sentence": []}]}]}, {"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/30", "sen