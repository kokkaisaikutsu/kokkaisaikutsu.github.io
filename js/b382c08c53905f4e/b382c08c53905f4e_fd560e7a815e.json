[{"date": "2022-04-11", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/176", "sentence": ["○芳賀道也君その大臣の答弁を聞いて安心いたしました。ただ、国税庁ＯＢであるとか税務署のＯＢの方が会計士になっているというケースもあるんですけ…", "…電子取引を行う全国の納税者に対して変更を行う重要な法改正なのに、特に国税庁の事前の説明にも問題があったのではないかという点です。昨年十二月半…", "…に尋ねても、税務署の職員は、実務がどうなるか分からない、質問されても国税庁に聞いてくださいと答えるしかないという回答だったと聞いています。確…", "…省令が改正されたのが何と十二月二十七日、そして、その通達の趣旨として国税庁から公表されたのは実施直前、一月一日からの話なのに、お知らせがあっ…", "…、一月一日からの話なのに、お知らせがあったのは十二月二十八日、しかも国税庁のホームページ上での公表でした。実施直前になって経過措置を発表する…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00420220411/185", "sentence": []}]}]}]