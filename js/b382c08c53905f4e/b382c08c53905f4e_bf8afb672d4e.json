[{"date": "2021-03-23", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/142", "sentence": ["…。でも、一つ私懸念するのは、これからの答弁が、いや、今第三者委員会で調査中ですから調査中ですからといって延々と答えないなどということが起こる…", "…懸念するのは、これからの答弁が、いや、今第三者委員会で調査中ですから調査中ですからといって延々と答えないなどということが起こると困るなと思う…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/144", "sentence": ["…か、あるいは、その後、明白に調査に影響を与えない事実関係については、調査中を理由に答えないというようなことはないということをお約束していただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/146", "sentence": ["○芳賀道也君でしたら、延々と、調査中だからお答えできませんという、これが慣用句になるようなことはないということはお約束いただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00620210323/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X0062