[{"date": "2021-12-20", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/61", "sentence": ["…に生じた災害などのために特別の財政需要がある、いわゆる現年災の費用を算定すると明確に規定しています。市町村の特別交付税の現年災についてはマイ…", "…進めるためにも、道府県の特別交付税でも現年災の項目を市町村と同じように減額なしで算定すべきではないかと考えますが、御見解をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120714601X00120211220/68", "sentence": []}]}]}, {"date": "2022-03-09", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X00720220309/14", "sentence": ["…ナ対策も含んだ感染症対策のため、保健所に勤める保健師の人件費の交付税算定を千八百人分から二千七百人分へと一・五倍にしました。しかし、直近でも…", "…税は、令和二年度当時千八百人の一・五倍では足りません。今年度の交付税算定では二倍以上へと更に引き上げる必要があるのではないでしょうか。総務大…", "…が山形よりやや低く、定められたルールにより、より多くの交付税が必要と算定されたものです。知事や首長が与党系かそうでないかということで都道府県…"]}]}]}, {"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/214", "sentence": ["…じております。エールを送って、次の質問です。続いて、基準財政需要額の算定に当たって、人口を係数とするものはかなりあります。地方交付税法の条文…", "…のはかなりあります。地方交付税法の条文を見ると、都道府県の二十二ある算定項目のうち人口を含むものは七つあり、人口又は人口関連の指標を考慮する…", "…