[{"date": "2022-06-02", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/154", "sentence": ["…への意見の集中などがないよう、公平中立、公正を期していただきたいと、形式的な公平、量的な公平を求めています。このとおりにすると、各候補の発言…", "…ッチで計って公平にするとか、どの候補にも同じ質問をするなど、放送局は形式的な公平を図ることに終始し、また、放送局が不公正な放送で選挙結果が左…", "…あれば批判するのは選挙報道でも当然のことではないでしょうか。さらに、形式的な公平、量的公平に沿った報道をするということは、放送局に保障された…", "…自由を放送局が自らゆがめ、放棄することに等しい。選挙報道においては、形式的公平性、量的な公平性ではなく、正確な情報をゆがめることなく編集して…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01020220602/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/12081