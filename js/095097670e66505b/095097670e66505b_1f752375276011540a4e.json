[{"date": "2023-05-09", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/177", "sentence": ["…倉林明子君日本共産党の倉林明子です。法案では、都道府県に介護現場の生産性向上を促進する努力義務ということで規定がされました。厚労省は、既に、…", "…すよね。センサーには、そういうテクノロジーの活用ということを進めて生産性向上と言うんだけれども、こういうことを進めることが、介護現場で今本当…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/180", "sentence": ["…ると思うんですよ。でも、人の代わりにはならないんですよね。そもそも生産性向上という言葉なんですけれども、いろいろ説明あったんだけれども、要は…", "…うふうに経済的には使われ、経済用語としては使われているわけですよ、生産性向上の定義でいえばね。介護現場の生産性をどうやって上げるかということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01020230509/190", "sentence": []}]}]}]