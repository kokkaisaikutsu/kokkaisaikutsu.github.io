[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/123", "sentence": ["…阪間の延伸計画についてまず質問します。質問の前に、今年三月三十一日に工事実施計画の変更が認可された北海道新幹線、これについてまず確認したいと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/125", "sentence": ["…着工条件とされているわけですが、再評価で下回ることが明らかになっても工事の継続は可能だということになっているんですけれども、その理由は何か。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/127", "sentence": ["…るわけですね。北陸新幹線敦賀―新大阪の延伸計画は、もう地下が圧倒的な工事区間となっておりまして、更なる難工事が想定されております。着工五条件…", "…の延伸計画は、もう地下が圧倒的な工事区間となっておりまして、更なる難工事が想定されております。着工五条件の、これはまだ着工されておりません、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/129", "sentence": ["…新大阪間の延伸なんですね。これ、北陸新幹線というのは、金沢―敦賀間の工事費が増えたことで、財務省からは開業後三十一年後の貸付料を前倒しで活用…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/145", "sentence": []}]}]}]