[{"date": "2022-11-17", "meeting": [{"meeting_name": "衆議院 地方創生に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/8", "sentence": ["…のこと。当時、予算規模で一億二千万から一億五千万でした。ちなみに、小学校の近くの商業施設には、民間のプールつきのスポーツセンターが入っていま…", "…っています。仮にプールの耐用年数が三十年として、一年ごとで五百万。小学校の児童数は三百六十人。一人一万円でプールを民間委託ができたら、百四十…", "…らえるので水泳が上達する、スポーツセンターも売上げが増える、そして、学校もプールの授業の負担が減る、予算も縮小と、いいこと尽くしのように思い…", "…る、予算も縮小と、いいこと尽くしのように思います。さらに、周辺の小中学校が同様にできるなら、そのスポーツセンターのプールは温水プールなので、…", "…で柔軟にできればと思いますが、文科省、地方創生に関わる地域への波及効果のある政策、学校外民間施設の活用等について御見解を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/12", "sentence": []}]}]}, {"date": "2023-03-08", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/4", "sentence": ["…うふうに思います。先週、地元鹿児島でも県立高校の入試が終わりました。学校ごとの志願倍率も発表されましたが、少子化の影響か、地方は軒並み定員割…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/9", "sentence": ["…ゃないかと思われるかもしれませんが、今の時代、そういう細かなところで学校が選ばれる時代でもあります。せっかく地元に子供がいるのだから、将来の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00220230308/25", "sentence": []}, 