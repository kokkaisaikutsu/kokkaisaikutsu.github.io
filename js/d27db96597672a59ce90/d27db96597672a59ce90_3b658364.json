[{"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/142", "sentence": ["…題提起させていただきたいと思います。続きまして、サイバー捜査における攻撃の可能性、先ほど足立議員の方からもありましたが、足立議員と問題意識を…", "…ですけれども、ずっとディフェンドしていると言っているけれども、実は、攻撃は最大の防御なりという言葉もありますが、攻撃の話はないのかなという気…", "…っているけれども、実は、攻撃は最大の防御なりという言葉もありますが、攻撃の話はないのかなという気がしたんですね。この法律には「職務に必要な限…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/144", "sentence": ["…たときに、そこに、どこまでやるかというのはありますが、何かこちらから攻撃をする、マルウェアみたいなものとか、ああいうものがないと、ひたすら攻…", "…撃をする、マルウェアみたいなものとか、ああいうものがないと、ひたすら攻撃されているのをずっとこっちはこうしているだけというのではよくないと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/146", "sentence": []}]}]}, {"date": "2023-02-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/320", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/322", "sentence": ["…手を壊滅させる能力を持つわけではないわけですよね。限られた軍事目標を攻撃する能力を今回持つということなんですが、それで相手の攻撃を抑止できる…", "…ですよね。限られた軍事目標を攻撃する能力を今回持つということなんですが、それで相手の攻撃を抑止できる、そういうふうにお考えですか、岸田総理。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/324", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/326", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/328", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/330", "sent