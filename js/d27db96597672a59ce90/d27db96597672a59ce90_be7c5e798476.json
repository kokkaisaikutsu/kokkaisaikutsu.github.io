[{"date": "2022-10-18", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/369", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/371", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/373", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/379", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/381", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/383", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/385", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/387", "sentence": ["…がフランスの刑法にはあります。これに対して、いろいろな仕掛けをもって精神的な従属状態に置いて、その無知、さらには薄弱といったものを悪用するよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/391", "sentence": ["…すけれども、マインドコントロールという言葉が出てきていないんですね。精神的な従属に置かれると。いろいろな仕掛けを通じて精神的な従属に置かれた…", "…ていないんですね。精神的な従属に置かれると。いろいろな仕掛けを通じて精神的な従属に置かれた、そこから、実は元々刑法にこれは存在していて、例え…", "…いうのが元々存在していたのに対して、これに、いろいろな仕掛けを通じて精神的な従属に置くという規定を新しく入れたというのが法改正だったんですけ…", "…いと思います。しかしながら、民事の取消しとかの要件の中に、こういった精神的な従属に置く行為、そしてそれに伴う、無知、薄弱、そういうものにつけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/393", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/395", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00320221018/397", "sentence": []}]}]}]