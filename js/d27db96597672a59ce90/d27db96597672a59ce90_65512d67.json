[{"date": "2022-05-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/244", "sentence": []}]}, {"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/130", "sentence": ["…。そういう中、昨年度末、一般輸入で立て続けに三回、一万二千七百トンの入札不調を出しているんですね。理由は、入札をアメリカ産のウルチ米中粒種に…", "…続けに三回、一万二千七百トンの入札不調を出しているんですね。理由は、入札をアメリカ産のウルチ米中粒種に指定したからです。現在、アメリカ産米は…", "…さらには国民負担を増大させる、そういうアメリカ産米をマーケットメカニズムに沿わない形で三回も無理をして入札をかけたのでしょうか、農林水産省。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/132", "sentence": ["○緒方委員今、需要がある、需要があると局長は言われましたよ。しかし、入札して、応札者がいたけれども落札しなかったんじゃなくて、そもそも応札す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/136", "sentence": ["…と思いますが、答えになっていないんですね。質問を続けたいと思います。入札が一回、二回、三回と不調で、そして年度末、一番最終日にぎりぎりで一万…", "…三回と不調で、そして年度末、一番最終日にぎりぎりで一万二千七百トンの入札を打ってタイ産米にしたわけですが、入札が不調であった後、アメリカと何…", "…最終日にぎりぎりで一万二千七百トンの入札を打ってタイ産米にしたわけですが、入札が不調であった後、アメリカと何らかの調整をされましたか、局長。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01420220511/146", "sentence": []}]}]}]