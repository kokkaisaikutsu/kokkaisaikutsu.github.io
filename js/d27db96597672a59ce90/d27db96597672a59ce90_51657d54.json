[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/27", "sentence": ["…そして、もう一件消防についてお伺いさせていただきたいと思います。救急救命士の活動についてということなんですが、救急救命士、本当に今頑張ってい…", "…きたいと思います。救急救命士の活動についてということなんですが、救急救命士、本当に今頑張っていただいている、コロナ禍の中で頑張っていただいて…", "…ナ禍の中で頑張っていただいているんですが、よく聞くのが、もう少し救急救命士の活動領域を拡大できないだろうかというお話をいただきます。もちろん…", "…結構たらい回しになっているケースとか、そういうのがあったりして、救急救命活動の一環としてもう少し活動領域を広く認めてもいいのではないかと思い…", "…としてもう少し活動領域を広く認めてもいいのではないかと思います。救急救命士は公務員が多いため、例えば業界団体をつくって声を上げるとか、そうい…", "…ない方が大半であります。なので、私がそれを代弁して申し上げさせていただいておりますが、救急救命士の活動領域の拡大ということについて、消防庁。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/41", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第五分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/310", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805267X00120220216/320", "sentence": []}, {"url": "https