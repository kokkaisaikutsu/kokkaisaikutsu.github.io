[{"date": "2022-05-18", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/73", "sentence": ["…が調整された場合には、例えば、この国にこれだけの量を輸出したいという会員の意向が必ずしもかなわずに、認定団体の意向に沿って取り組む場合もある…", "…が今年の三月は落ち込みました。産地や事業者への適切な調整が行われて、会員がそれに従って輸出した場合に、輸出先やタイミングによって会員に不利益…", "…われて、会員がそれに従って輸出した場合に、輸出先やタイミングによって会員に不利益が生じたり、それによって別の会員との利益に差が生じた場合には…", "…、輸出先やタイミングによって会員に不利益が生じたり、それによって別の会員との利益に差が生じた場合にはどのように対応されていくのか、伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01520220518/146", "sentence": []}]}]}]