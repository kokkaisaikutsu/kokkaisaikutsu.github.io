[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第七分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/49", "sentence": ["…そも小さくて済んだのではないかという公聴会での意見もございました。規制委員会の審査結果が出ていませんし、そして地元の理解も進んでいない。そし…", "…んし、そして地元の理解も進んでいない。そして、先月、大臣御自身も、規制委員会の追加検査中であって、再稼働の時期を見通せる状況ではないというふ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/53", "sentence": ["○緑川分科員やはり、安全審査をつかさどる番人である規制委員会でも、この十三日の会合では、六十年を超える稼働を可能にする、その制度の見直し方針…", "…。それが果たして本当に安全と言えるのかどうかということは、これは、規制委員会からの疑問の声ということが挙がっているというふうに思っています。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/66", "sentence": []}]}]}]