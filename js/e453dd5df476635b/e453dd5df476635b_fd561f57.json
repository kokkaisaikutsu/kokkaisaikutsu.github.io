[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/93", "sentence": ["…日本モデルの提示をうたっています。日本モデルといえば、やはり、日本は国土の六七％を豊かな森林に覆われ、木の文化を育んできたことに思いをはせな…", "…最も低かったそうです。私は、脱炭素社会やＳＤＧｓの達成、安心、安全な国土保全、我が国の資源を活用した成長戦略、そして子供たちの豊かな心を育む…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/99", "sentence": ["…しているのが正直な思いでございます。そこで、本連続立体交差事業の推進に向けて、国土交通省としての見解、これは決意をお伺いできればと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/105", "sentence": []}]}]}]