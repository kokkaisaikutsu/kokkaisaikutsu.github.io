[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/95", "sentence": ["…敬意を表したいと思います。ただ、ボトルネックになっているのは、多くの設計者、施工者はこれまで木造建築に接する機会が少なく、知見が蓄積されてい…", "…ります。鉄筋コンクリート造や鉄骨造建築物と木造建築物では、建物の基本設計や構造計算等が全く異なる中で、法令の規制緩和が進んでも、担い手の技能…", "…。大学の建築学科でも鉄筋コンクリート造や鉄骨造が教育の中心で、既存の設計者、施工者に対しても木造建築に関する技術情報が十分共有されておらず、…", "…ういった課題も踏まえ、中高層の木造建築に対する国交省の取組の現状と、今後の設計、施工関係者における木造知見の向上に対する取組方針を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/105", "sentence": []}]}]}]