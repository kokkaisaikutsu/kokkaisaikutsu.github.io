[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/93", "sentence": ["…ろしくお願い申し上げます。次に、国際園芸博覧会とも非常に親和性のある国産木材の利用促進と、中高層木造建築の推進について伺います。横浜国際園芸…", "…略、そして子供たちの豊かな心を育む点でも、国会議員として、是非とも、国産木材の利用拡大と、その結果として、将来世代につなげられる森林の更新に…", "…用木材供給、利用強化対策を大幅に拡充されているようであります。私は、国産木材の利用をより一層拡大させるためには、中高層建築物の木造化促進に向…", "…木造化促進に向けた新たな技術開発を始め、一戸建て住宅など低層建築物の国産材使用率向上に向けた取組を促進すべきだと考えておりますが、まず、この…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/105", "sentence": []}]}]}]