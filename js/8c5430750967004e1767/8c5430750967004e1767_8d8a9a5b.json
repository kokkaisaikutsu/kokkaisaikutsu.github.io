[{"date": "2022-04-06", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/122", "sentence": ["…細かい話を今日は聞くんですけれども、兵庫県警と警視庁が捜査に基づいて認定をしている拉致事件というのがあります。いわゆる国の、政府の拉致被害者…", "…いる拉致事件というのがあります。いわゆる国の、政府の拉致被害者として認定されるのではない。埼玉県の渡辺秀子さんという方のお子さん二人が連れ去…", "…かったということなんですね。そういう中で、この二人のきょうだいの拉致認定も進まず、いろんな形での支援というような形というものがなかなか取られ…", "…形というものがなかなか取られていないんですが、これについて、なぜ拉致認定がなされていないのかということをもう一度改めてお聞きをして、どういう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/130", "sentence": []}]}]}]