[{"date": "2021-05-20", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/62", "sentence": ["…に集まり、そして、予約、管理、工事、監視も含めて、工事の監視ですね、効率よく工事のワンストップセンターで運営をされていました。無電柱化を推進…", "…、様々な埋設管渠等、そういったものがあります。この台湾台北市のような効率的な行政運営も参考にしていただきたいと思います。毎年七万本も増加し、…", "…と思います。防災、減災に資する無電柱化の取組に対して国の見解、防災大臣としての見解、また、災害復旧現場の効率化に対しての見解もお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404339X00620210520/68", "sentence": []}]}]}]