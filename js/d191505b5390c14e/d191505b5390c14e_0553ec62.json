[{"date": "2023-03-30", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/83", "sentence": ["…事情により帰国又は新在勤地への転勤を命じられたときということで、割と包括的な内容が書かれていて、省令でア、イを定めるという理解でございます。…", "…な離任、帰朝の場合に関してもやはり同じような救済措置を設ける、つまり包括的な規定を設ける、省令の中で設けていく必要があるんではないかと思いま…", "…職員の今後の勤務環境の改善のため、安心して在外で勤務できるためにこの包括規定を是非省令に設けていただきたいんですが、大臣、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/85", "sentence": ["○金子道仁君ありがとうございます。是非、包括規定を設けていただいて、安心して職員が在外勤務できるように、家族をそろって行けるように御配慮いた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00620230330/95", "sentence": []}]}]}]