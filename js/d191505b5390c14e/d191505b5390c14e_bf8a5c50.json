[{"date": "2023-06-08", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/95", "sentence": ["…船の取締りに資する施策を進めていただければと思っております。続けて、調停に関するシンガポール条約について御質問したいと思います。この条約に関…", "…るシンガポール条約について御質問したいと思います。この条約に関して、調停によって国際的な和解合意ができた、それに強制執行が行われるというのが…", "…国内法の整備もされたと理解していますが、ただし、条約の一条二で、離婚調停などの家族関係に関する和解、雇用関係に関する和解合意、こういったもの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/99", "sentence": ["○金子道仁君ありがとうございます。まとめて言うと、この上の部分、国際調停、条約実施法、括弧、新法の制定、これが今回の条約に合わせた国内法の整…", "…じことなのかとは思います。そして、このＡＤＲ法ができた由来、裁判外の調停をより促進していく、裁判所に行きにくいような方々が裁判所じゃないとこ…", "…ていく、裁判所に行きにくいような方々が裁判所じゃないところでも和解、調停が進むようにということでしていったわけですけれども、私も個人的に離婚…", "…が進むようにということでしていったわけですけれども、私も個人的に離婚調停とかの関わりをする中で、やはり結局、ＡＤＲの方に行ったとしても強制力…", "…ＤＲの利用が非常に少なかったと。今回、この条約法の制定に伴って、この調停による和解合意についても一部強制執行力が出たということは望ましいこと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/101", "sentence": ["…結婚、非常に広がっています。残念ですけれども、それに伴い国際的な離婚調停も非常に増加していて、親が海外に連れ帰ってしまって親権が混乱してしま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X02020230608/107", "sentence": []}]}, {"meeting_name": "参議院 財政金融委員会、外交防衛委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115372X00320230608/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00320230608/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00320230608/72", "sentence": []}, {"url": "https://kokkai.ndl.go.j