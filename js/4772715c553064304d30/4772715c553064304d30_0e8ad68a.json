[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015254X00920221202/7", "sentence": ["…ま議題となりました令和四年度第二次補正予算二案に対し、賛成の立場から討論を行います。それでは、本補正予算案に賛成する主な理由を申し述べます。…", "…な成立が不可欠でございまして、議員各位に本予算案への賛成をお願い申し上げまして、私の討論といたします。御清聴ありがとうございました。（拍手）"]}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/101", "sentence": []}]}]}]