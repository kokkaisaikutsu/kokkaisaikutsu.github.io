[{"date": "2022-06-03", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/11", "sentence": ["…ております。この間の日米首脳会談で、岸田総理はバイデン大統領に日本の防衛費の相当な増額を約束されました。この英語表現を私、官邸に伺ったところ…", "…ておられました。今の時点で、補正後でＳＡＣＯや米軍移転経費を入れれば防衛費は六・一兆円まで来ておりますから、これをサブスタンシャルインクリー…", "…ャルインクリース、バイデン大統領にストロングリーサポーティッドされたこの相当な防衛費の増額についての岸田総理の意気込みを伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X02020220603/19", "sentence": []}]}]}]