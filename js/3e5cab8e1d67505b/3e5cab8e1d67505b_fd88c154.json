[{"date": "2021-04-23", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/4", "sentence": ["…、ＥＵとの間で当局間の取決めを結んでおり、主に欧州から我が国への航空製品の輸入に際して検査等の重複が取り除かれてきたと承知しております。そし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/6", "sentence": ["○尾身委員ありがとうございました。引き続きお伺いします。民間航空製品の輸出入に際して相互に検査等の重複を省略することは、効率の面から考えれば…", "…協定によって、相互に検査や監督の簡略化が図られることになりますが、民間航空製品の安全性の確認は十分でしょうか。この点について御説明ください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120403968X01020210423/16", "sentence": []}]}]}]