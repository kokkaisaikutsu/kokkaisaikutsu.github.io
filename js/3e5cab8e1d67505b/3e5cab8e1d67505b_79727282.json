[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第四分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/128", "sentence": ["○尾身分科員大臣、ありがとうございました。次に、地域の中核、特色ある大学の振興について質問いたします。我が国の研究力が諸外国と比較して低迷し…", "…変革を牽引していくことが必要です。政府は今月のＣＳＴＩで、地域中核・特色ある研究大学総合振興パッケージを取りまとめました。しかしながら、大学…", "…んま未来イノベーション会議として相互理解に努めています。大学の強みや特色を伸ばす取組を強化すること、地域と大学をつなぐ仕組みの構築を行うこと…", "…きを活性化することができるものと考えます。そこで伺います。地方大学や特色ある大学の研究力を強化し、地域と一体となって活動できる体制をつくり上…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805270X00120220216/140", "sentence": []}]}]}]