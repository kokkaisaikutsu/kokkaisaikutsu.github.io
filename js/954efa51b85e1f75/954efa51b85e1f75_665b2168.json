[{"date": "2022-11-15", "meeting": [{"meeting_name": "衆議院 科学技術・イノベーション推進特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/32", "sentence": ["○井出副大臣ありがとうございます。まず、公立高等学校の配置につきましては、昭和三十六年にいわゆる高校標準化法という法律が制定をされまして、当…", "…す。近年は、先生御指摘のとおり、人口減少の中で、どうやって地域の高等学校教育を守っていくかという視点かと思います。その際には、生徒さんですと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/34", "sentence": ["…センター形式でやっているところもありますし、先生がおっしゃるように、学校間で連携している、やっているというようなところもございますが、先生も…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/38", "sentence": ["…として大事な、持ってきたことを変えるとなると、例えば、じゃ、前やった学校の再編はどうなるんだとか、いろいろな御議論があると思うんですよね。私…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/40", "sentence": ["○井出副大臣先生の御質問のとおり、昨日、中教審の中に高等学校教育の在り方ワーキンググループを設置をいたしまして、人口減少への対応ですとか、ま…", "…応等も背景に議論をしていこうということにしております。その中に、高等学校制度の望ましい在り方、全日制、定時制、通信制等、そうした高等学校の在…", "…中に、高等学校制度の望ましい在り方、全日制、定時制、通信制等、そうした高等学校の在り方についても一つ論点として議論する予定にはしております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003910X00320221115/147", "sentence": []}]}, {"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl