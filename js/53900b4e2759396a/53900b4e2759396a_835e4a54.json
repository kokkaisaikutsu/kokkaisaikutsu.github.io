[{"date": "2022-05-10", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/64", "sentence": ["…が、その人の趣味、嗜好というものが分かるということで、ターゲティング広告だとか政治上の広告だとか、様々なものが今どんどん広がっている。これに…", "…嗜好というものが分かるということで、ターゲティング広告だとか政治上の広告だとか、様々なものが今どんどん広がっている。これに対してどのように、…", "…アナリティカ事件を例に、今回、参考人の御意見の中でも、ターゲティング広告などの規制について、個人の内心に入り込むプロファイリングが使われない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/80", "sentence": []}]}]}, {"date": "2023-03-16", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104183X00320230316/17", "sentence": ["…めどに、必要な法制上の措置等を講ずるものとし、国民投票運動等のための広告放送及びインターネット等を利用する方法による有料広告の制限などを挙げ…", "…票運動等のための広告放送及びインターネット等を利用する方法による有料広告の制限などを挙げています。昨年六月二日に開催された当審査会では有識者…", "…と考えます。そのためにも、国民投票法におけるＣＭ規制やインターネット広告規制など、法制上の十分な措置がないままの憲法改正発議は当然あり得ない…"]}]}]}]