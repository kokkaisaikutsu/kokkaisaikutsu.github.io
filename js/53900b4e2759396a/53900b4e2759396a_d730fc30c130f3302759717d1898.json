[{"date": "2022-12-07", "meeting": [{"meeting_name": "衆議院 沖縄及び北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/81", "sentence": ["…いうことでございます。その後、二〇〇三年の、当時の小泉総理大臣とプーチン大統領の日ロ行動計画においては、両国は、日ソ共同宣言、東京宣言、イル…", "…おります。二〇一三年四月の日ロ首脳共同声明では、当時の安倍総理とプーチン大統領が、両首脳は、二〇〇三年の共同声明及び日ロ行動計画においても解…", "…以上残されてきた課題を次の世代に先送りすることなく、私と大統領、プーチン大統領の手で必ずや終止符を打つという強い意思を共有、一九五六年共同宣…", "…有、一九五六年共同宣言を基礎として平和条約交渉を加速させることをプーチン大統領と合意ということで、私は、これはいろいろな見方はあると思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121003895X00320221207/89", "sentence": []}]}]}, {"date": "2023-03-08", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X00720230308/20", "sentence": ["○道下委員まだまだ経済制裁は十分ではないと思います。プーチン大統領の周辺の人たちのオリガルヒへの影響も考えてと