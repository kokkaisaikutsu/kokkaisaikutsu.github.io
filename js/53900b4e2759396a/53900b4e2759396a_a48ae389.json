[{"date": "2023-06-07", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/62", "sentence": ["○道下委員今答弁で、あたかも誤解を与えるような内容ということだったんですけれども、本当に優秀な有識者の方々がこのワーキンググループのメンバー…", "…議論を重ねて、そしてまとめられた最終報告書ですよね。それを、あたかも誤解を招くようなものだった。金融庁の皆様も、中身を見ていて、これで出そう…", "…時の金融担当大臣が受け取らなかったことを後ろで支えるために、あたかも誤解を与える内容だったと言うこと、私は、これは言い過ぎというか、それまた…", "…を与える内容だったと言うこと、私は、これは言い過ぎというか、それまた誤解を与えるというか、本来政府としてやるべきことを私は十分に果たしていな…", "…に振り向けようとしているわけじゃないですか。そういうふうに考えれば、誤解を与えるような内容じゃなくて、私は、当時の報告書は的確な内容だという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/251", "sentence": []}]}]}]