[{"date": "2022-04-26", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/64", "sentence": ["○道下委員そこで、今、生計を一にするという言葉が出ましたけれども、この定義についても伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/66", "sentence": ["○道下委員ちょっと事前の質問通告はしていないんですけれども、この生計を一にするということで、これは今回、夫もＡさんもそれぞれ働いている、しか…", "…になっているんですね。こうした方が、二人が別居していて、離婚はしていないけれども別居している状況、これは生計を一にすると言えるのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/70", "sentence": ["…に関して、私の今までいただいたＡさんからの情報等によりますと、私は、生計を一にしているとは言えないし、また、それぞれがほぼ独立した収入があっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01420220426/92", "sentence": []}]}]}]