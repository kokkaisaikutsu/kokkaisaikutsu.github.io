[{"date": "2022-04-19", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/126", "sentence": ["…っていただくかということが非常に大事だと思うんですけれども、今後、政省令で定めていくというふうに聞いているんですけれども、この政省令の考え方…", "…今後、政省令で定めていくというふうに聞いているんですけれども、この政省令の考え方あるいは目標地図の考え方、これについてあらかじめ考え方をお伺…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/132", "sentence": ["…、動くようにお願いをしたいと思います。また、基盤法十九条の第四の二の省令についてなんですが、この省令で、集積、集団化の基準を定めるということ…", "…思います。また、基盤法十九条の第四の二の省令についてなんですが、この省令で、集積、集団化の基準を定めるということなんでしょうか。また、担い手…", "…基準を定めるということなんでしょうか。また、担い手への農地集積八割をこの省令にも反映させるということなのか、これをお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X01120220419/138", "sentence": ["…ございます。是非これからも丁寧にお話を聞いていただいて、あるいは、政省令等にも是非御反映をいただきたいと思います。本日は、どうもありがとうご…"]}]}]}]