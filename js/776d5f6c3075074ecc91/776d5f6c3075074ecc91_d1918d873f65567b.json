[{"date": "2020-11-18", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/41", "sentence": ["…員まさにそこが問題なわけでありまして、これは、少なくとも、やはり、金融政策決定会合は、その議事録も出ます、早い段階で要旨も出ます。それから、…", "…前に出てきてしっかりと会見をするということが大切なんですよ。これは金融政策じゃない、一般的な政策だということだけで片づけてしまってはいけない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/45", "sentence": ["…この金利で、少なくとも金利を動かすわけですから。金利政策じゃない、金融政策じゃないとおっしゃっているけれども、少なくとも金利の世界で勝負をさ…", "…から、度量の広い人ですから、野党の言い分でもぜひ聞いていただいて、金融政策決定会合に諮らなくたって、やはり出ていって、こういうときは、大事な…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00220201118/53", "sentence": []}]}]}]