[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/224", "sentence": ["○白石分科員もう一つの切り口というのは、離島活性化交付金。これは、離島の生活一般をお支えする、そこに地域の交通の維持、確保というのもあると思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/232", "sentence": ["…使いながら買物したり散策したりして戻ってくるということで、地域振興、活性化にも寄与しているわけですね。それで、これはほかの地域にも適用できる…", "…ェンジに戻って自分の目的地に行くということが可能になる、そのことによって地域も活性化されるというふうに思うんですけれども、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805273X00120220216/238", "sentence": []}]}]}, {"date": "2022-02-17", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00220220217/174", "sentence": []}, {"url": "https://kokkai.ndl.go.j