[{"date": "2023-04-13", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/87", "sentence": ["○串田誠一君冒頭、アニマルウエルフェアが投資にすごく強く関連しているという話をしたんですが、ＥＳＧ投資というのはどのようなものでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/89", "sentence": ["○串田誠一君今のＥＳＧ投資に関する全運用資産、そして全ての世界の投資に対するＥＳＧ投資の割合についてはいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/91", "sentence": ["…に換算すると四千五百兆円から五千兆円の間ぐらいになって、すごい金額がＥＳＧ投資として行われていて、今まではプロダクト、商品の良さだけだったの…", "…非常に目安になっていると言われているんですけれども、そういう意味で、ＥＳＧ投資というのにアニマルウエルフェアというのは非常に深く関わっていて…", "…深く関わっていて、ＮＨＫの番組でも取り上げられているんですけれども、ＥＳＧ投資にアニマルウエルフェアに取り組む企業が対象になっているという認…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00620230413/105", "sentence": []}]}]}]