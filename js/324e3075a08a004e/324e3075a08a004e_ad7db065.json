[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/299", "sentence": ["○串田誠一君日本維新の会の串田誠一です。日本維新の会は、男女差別あるいは多様性の差別、断じて許さない政党であるということを明言させていただい…", "○串田誠一君日本維新の会の串田誠一です。日本維新の会は、男女差別あるいは多様性の差別、断じて許さない政党であるということを明言させていただい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/303", "sentence": ["…に、コロナに関する就職氷河期に関して、昨日も大変議論がなされました。維新はこの点について雇用の流動化というものを一つの対策として主張させてい…", "…を一つの対策として主張させていただいているんですが、この雇用の流動化も含めて、維新と意見交換、総理、これから考えていただけませんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/305", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/310", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/320", "sentence": []}]}]}]