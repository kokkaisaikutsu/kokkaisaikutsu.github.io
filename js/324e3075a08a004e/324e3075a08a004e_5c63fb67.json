[{"date": "2023-05-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/75", "sentence": ["…構成要件上該当すると考えられるような場合、伝統行事であるということで捜査というものが逃れるというようなことがあるのかどうか、お聞きしたいと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/77", "sentence": ["○串田誠一君その場合、その行事を主催している人が捜査対象なのか、あるいは動物を操作している人が捜査対象なのか、警察庁の御意見を聞きたいと思い…", "…誠一君その場合、その行事を主催している人が捜査対象なのか、あるいは動物を操作している人が捜査対象なのか、警察庁の御意見を聞きたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/79", "sentence": ["○串田誠一君レクの段階でも動物を操作している人も捜査対象になるというお答えをいただいているんですが、間違いないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/81", "sentence": ["○串田誠一君当然、その動物を扱っている人も捜査対象にはならないと総合的な判断はできないだろうというふうに思うんですけれども。ところで、伝統行…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/95", "sentence": []}]}]}]