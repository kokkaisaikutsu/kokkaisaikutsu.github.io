[{"date": "2020-12-02", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/101", "sentence": ["…に関して大変貴重な発言になったのではないかと思います。残された時間は発議者にもお聞きをしたいと思うんですが、第三条の基本理念に、「生殖補助医…", "…殖補助医療として、不妊治療としてと限定する必要が果たしてあるんだろうかというのもちょっとあるんですけれども、発議者としてはいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/103", "sentence": ["…が適用できないというのはとても残念ではないかなと思うんですけれども、発議者として、この重要な法案を適用する幅を広めるためにも、このような今課…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/105", "sentence": ["…も、利用しないことに関しての偏見というものもこれはなくしていかなければならないと思うのですが、発議者としての御意見をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305206X00320201202/107", "sentence": []}]}]}]