[{"date": "2023-03-30", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/60", "sentence": ["…。それが五年後は変わるのか。それとも、それは変わらない中で日本の水産加工というのを何か発展させるには別の何か支援しなきゃいけないと思うんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/62", "sentence": ["…価しているわけですので、そういう意味で、世界がまねできないような水産加工というものを進めるということが、これは、その漁獲量とかそういったよう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00520230330/71", "sentence": ["…なものの技術開発みたいなので何か世界と対峙していただいて、そして水産加工が発展していってほしいなと思います。以上です。ありがとうございました…"]}]}]}]