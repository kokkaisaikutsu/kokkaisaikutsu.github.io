[{"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/58", "sentence": ["…いただいてありがとうございます。最初に、その動物用医薬品の中には抗生物質というのも入るわけでございますが、先ほどほかの方からの質問もございま…", "…わけでございますが、先ほどほかの方からの質問もございまして、この抗生物質を大量に使い続けると、薬剤耐性菌という、効かなくなってしまうというこ…", "…ふうに言われているんですけれども、問題は、この農水省が所管をする抗生物質の動物用の医薬品は治療に使うだけであるならこれ問題ないんですけれども…", "…れ問題ないんですけれども、成長促進あるいは生産量を増加するために抗生物質を使われているんではないかと思うんですが、日本はこれ禁止をしておりま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/60", "sentence": ["○串田誠一君抗生物質を成長促進に使うということを日本は全面的には禁止していないわけですけれども、ＥＵはこれ禁止しているんではないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/64", "sentence": ["…ら制限されるんですけれども、成長促進だとか生産量を増加するために抗生物質を使うというようなことになるともう切りがなくなってしまうというような…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00320221108/88", "sentence": []}]}]}]