[{"date": "2022-03-25", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/34", "sentence": ["…川でありますから、流出した場合、広範囲に有害物質が拡散し、因果関係の追及や原状回復の実施も困難になる、これは容易に想定されます。こうした事案…", "…、かなり悪質だと思いますよ、不法投棄を八年続けた、この事業者への責任追及及び原状回復の履行を求めるべきだと私は考えます。特に、今回、山梨県は…", "…逆性の高い不法投棄を行ったと思われる事業所に対して積極的にその責任を追及すべきだという意見も地元であります。この意見に対して、環境省の見解を…", "…、今回の山梨県の対応のように、都道府県が刑事告訴も含めた積極的な責任追及を行わない場合、環境省から、これは環境問題ですから、より強い指導を行…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00320220325/50", "sentence": []}]}]}]