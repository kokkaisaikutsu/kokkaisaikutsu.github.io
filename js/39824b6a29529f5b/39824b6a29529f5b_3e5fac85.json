[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/88", "sentence": ["…向けた検討の中で、戦車や戦闘機などの正面装備品の運用に不可欠な部品や弾薬が不足している実態が明らかになりました。部品等のサプライチェーンの再…", "…陸上輸送の主であります道路、鉄路上の長大トンネル内は安全性を考慮して弾薬の輸送を認めていないことであります。そのため、迂回ルートや積替えを余…", "…津軽海峡が他国によって海上封鎖されますと、民間フェリーによる各部隊や弾薬、装備品の輸送ルート確保は困難となります。こうした事態を含め様々な有…", "…であり、長大トンネル区間を有する青函トンネルや全国各地の道路、鉄路で弾薬など火薬類の輸送を、安全性を確保した上で輸送を可能とすべきであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/96", "sentence": []}]}]}]