[{"date": "2023-11-14", "meeting": [{"meeting_name": "衆議院 地域活性化・こども政策・デジタル社会形成に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/103", "sentence": ["○船橋大臣政務官お答えいたします。令和五年三月三日付で泉佐野市から総務省宛てに、熟成肉や精米に限って地場産品基準を改正した趣旨等について質問…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/108", "sentence": ["○船橋大臣政務官恐れ入ります。先ほど私、泉佐野市からの質問書の関係で御答弁をさせていただきましたときに、七月三日と答えるべきところを三月三日…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205367X00320231114/134", "sentence": []}]}]}, {"date": "2023-12-06", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121204080X00320231206/34", "sentence": ["○船橋大臣政務官お答えいたします。令和四年九月二十七日、泉佐野市から送付された資料についてでございますが、当時の基準における地場産品基準への…", "…討に当たりまして、参考とさせていただきました。熟成肉等については、泉佐野市から資料が送付される直前の令和四年九月二十二日の通知におきまして、…", "…やＱアンドＡの改正を行うことを検討することを旨として既にお示しをしていたことから、泉佐野市に対して特段回答は行っていないところでございます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121204080X00320231206/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204080X00320231206/38", "sentence": []}]}, {"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/112", "sentence": []}]}]}]