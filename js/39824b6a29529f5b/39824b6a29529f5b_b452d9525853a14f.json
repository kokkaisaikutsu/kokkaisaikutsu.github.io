[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/82", "sentence": ["…一・五％の賃上げで加点する優遇措置に加え、今年三月から国交省が発注労務単価を五％引上げをしたことは人材確保の観点から評価をいたします。しかし…", "…に実施されている一・五％の賃金アップと、今回の五％引上げされた発注労務単価の取扱いについて、分かりにくいとの声があります。五％の中には一・五…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/86", "sentence": ["…業務について伺います。資料を御覧ください。令和五年度の建築保全業務労務単価は、全国の全職種平均で令和四年度比プラス五％となりました。これは十…", "…経験も六年以上、指導監督などの総合的な技能を有する清掃員や警備員の労務単価が低く設定されているのは不合理であります。建築保全業務の適切な執行…", "…警備員の人材確保が前提となります。今後、清掃員、警備員の労務区分と労務単価、これは見直しをしていくべきと考えますが、見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/96", "sentence": []}]}]}]