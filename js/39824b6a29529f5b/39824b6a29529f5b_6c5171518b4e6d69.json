[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/82", "sentence": ["○船橋利実君次に、公共事業予算についてお尋ねをいたします。政府案の令和五年度公共事業予算は、国民生活、経済の安定と成長、大規模自然災害等から…", "…君次に、公共事業予算についてお尋ねをいたします。政府案の令和五年度公共事業予算は、国民生活、経済の安定と成長、大規模自然災害等から国民の命を…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/84", "sentence": ["…くように、丁寧な説明を今後もお願いをしたいと思います。次に、政府の公共事業予算案でありますけれども、これは当然必要額が盛り込まれていると思い…", "…業を進捗させる工事の事業量と委託業務の確保、適切な維持管理が必要とされます。提案されている公共事業予算に関する政府の見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/96", "sentence": []}]}]}]