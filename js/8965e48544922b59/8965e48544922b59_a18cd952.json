[{"date": "2022-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/327", "sentence": ["…ことが重要です。こうした観点から、御指摘の需要予測などの経済的効果や財務面の安定性については、認定のための審査基準等を定めたＩＲ整備のための…", "…の来訪者数、ＩＲの整備により見込まれる旅行消費額、これらの推計方法、財務面については、経営の安定性、それから業績が下振れした場合の対応等につ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/329", "sentence": ["…おります。国といたしましては、自治体から区域整備計画が申請された場合には、経済的効果や財務面の安定性についてしっかりと審査をしてまいります。"]}]}]}]