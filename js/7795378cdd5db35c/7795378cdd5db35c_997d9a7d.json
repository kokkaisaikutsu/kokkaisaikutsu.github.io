[{"date": "2022-06-15", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/6", "sentence": ["○委員長（長谷川岳君）継続調査要求に関する件についてお諮りいたします。農林水産に関する調査につきましては、閉会中もなお調査を継続することとし…", "…りいたします。農林水産に関する調査につきましては、閉会中もなお調査を継続することとし、本件の継続調査要求書を議長に提出いたしたいと存じますが…", "…関する調査につきましては、閉会中もなお調査を継続することとし、本件の継続調査要求書を議長に提出いたしたいと存じますが、御異議ございませんか。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/9", "sentence": []}]}]}, {"date": "2022-08-05", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/4", "sentence": ["○委員長（長谷川岳君）国政調査及び継続調査要求に関する件についてお諮りをいたします。本委員会は、従来どおり農林水産に関する調査を行うこととし…", "…会は、従来どおり農林水産に関する調査を行うこととし、今期国会閉会中も継続して調査を行うため、本件の継続調査要求書を議長に提出いたしたいと存じ…", "…る調査を行うこととし、今期国会閉会中も継続して調査を行うため、本件の継続調査要求書を議長に提出いたしたいと存じますが、御異議ございませんか。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915007X00120220805/8", "sentence": []}]}]}]