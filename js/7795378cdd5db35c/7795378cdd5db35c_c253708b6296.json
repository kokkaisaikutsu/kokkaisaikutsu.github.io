[{"date": "2022-06-15", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01620220615/9", "sentence": ["…営に当たり御協力をいただきまして、誠にありがとうございました。本年は参議院通常選挙が行われる年であります。選挙に臨まれる方々におかれましては…", "…産委員会に所属されて以来、理事、そして委員長、さらには農林水産大臣、参議院副議長を務めるなど、農林水産分野並びに議会政治の発展のために多大な…"]}]}]}]