[{"date": "2022-03-03", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/5", "sentence": ["…農林水産に関する調査を議題といたします。令和四年度の農林水産行政の基本施策について、農林水産大臣から所信を聴取いたします。金子農林水産大臣。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00120220303/7", "sentence": ["○委員長（長谷川岳君）以上で所信の聴取は終わりました。本件に対する質疑は後日に譲ることとし、本日はこれにて散会いたします。午後零時五分散会"]}]}]}]