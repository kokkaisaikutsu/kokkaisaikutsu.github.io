[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/141", "sentence": ["…険を伴うものというふうに心配をするところでございます。大病院における長期処方というものとよく比較されることがありますけれども、本来、大病院が…", "…処方というものとよく比較されることがありますけれども、本来、大病院が長期処方をするような患者さんを診ていること自体が問題があるのではないかと…", "…理解いただきたい。大病院では、専門医がその専門の単一疾患の治療として長期処方等をしているということが多いわけですけれども、かかりつけ医では、…", "…ということは、一見患者さんの利便が良いように見えますけれども、変化を長期にわたり放置されるということも危険が伴いますので、その点を十分御理解…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/151", "sentence": []}]}]}]