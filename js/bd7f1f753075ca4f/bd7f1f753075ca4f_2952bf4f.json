[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/141", "sentence": ["…が十分されないままこの投薬が繰り返されるということは、一見患者さんの利便が良いように見えますけれども、変化を長期にわたり放置されるということ…", "…いますので、その点を十分御理解いただいて、健康管理は大変重要であり、利便や安易な考えでリフィル処方が繰り返させないということが非常に大切であ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/143", "sentence": ["…でございますけれども、これは、新型コロナウイルス感染症ということで、利便性と、患者さんと医療者との接触を減らすという意味で、そういう目的でオ…", "…も、全ての疾患において対応可能なわけではないということに鑑みまして、利便性だけで活用とならないように努める必要があるというふうに考えておりま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/151", "sentence": []}]}]}]