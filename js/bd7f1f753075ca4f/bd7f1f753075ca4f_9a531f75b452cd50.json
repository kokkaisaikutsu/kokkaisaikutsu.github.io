[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/147", "sentence": ["…用の薬剤の開発ということに是非力を入れていただきたいということでございますので、是非、厚生労働大臣としてのお考えをよろしくお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00220220308/151", "sentence": []}]}]}, {"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/10", "sentence": ["…ございます。自由民主党の羽生田俊でございます。四月の二十五日に後藤厚生労働大臣にもいろいろと質問させていただいたんですけれども、二つほどもう…", "…ということがあったというふうに理解をしております。中医協というのは厚生労働大臣の重要な諮問機関でありますから、今後このようなことがないように…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/14", "sentence": []}]}]}, {"date": "2022-08-19", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/8", "sentence": ["○羽生田副大臣この度、厚生労働副大臣を拝命いたしました羽生田俊でございます。主として、労働、福祉、年金を担当するということになってございます…", "…の実現に向けて、様々な施策に誠心誠意、丁寧に取り組んでまいります。厚生労働委員会の皆様方の御理解と御協力を得ながら、伊佐副大臣、両大臣政務官…"]}]}]}]