[{"date": "2022-05-24", "meeting": [{"meeting_name": "衆議院 科学技術・イノベーション推進特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/5", "sentence": ["○手塚委員長以上で両大臣の所信表明は終わりました。次に、令和四年度科学技術関係予算の概要について説明を聴取いたします。小寺内閣府大臣政務官。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/7", "sentence": ["…員長以上で説明は終わりました。次に、赤池内閣府副大臣及び宮路内閣府大臣政務官から、それぞれ発言を求められておりますので、順次これを許します。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/9", "sentence": ["○手塚委員長次に、宮路内閣府大臣政務官。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00220220524/11", "sentence": []}]}]}]