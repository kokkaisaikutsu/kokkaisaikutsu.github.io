[{"date": "2022-02-18", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/104", "sentence": ["…ども、大学、あるいは企業の本社、あるいは中央省庁外局、こういった地方移転は力仕事です。担当大臣だけでは絶対にできません。大学はなかなか大変だ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/106", "sentence": ["…はり大学と企業本社の存在だと思うんですね。むしろ、地方に学部だけでも移転した方が私学助成上有利だというぐらいの財政上の仕組みをつくったらいか…", "…政上の仕組みをつくったらいかがでしょうかね。もっと言えば、企業本社の移転税制だってありますけれども、小出し、ちまちましていますよね。今年やら…", "…らいだね。この二十三区で転出超過に初めてなったんですよ、去年。このときを捉えて、企業本社の移転税制を大胆に仕組む、当然のことじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01620220218/133", "sentence": []}]}]}]