[{"date": "2023-03-09", "meeting": [{"meeting_name": "衆議院 安全保障委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/24", "sentence": ["…姿勢、基本的な考え方というものを伺いたいというふうに思います。重要な隣国である、こういうふうに政府は度々おっしゃっているわけでありますけれど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/26", "sentence": ["…務大臣、あるいは時々の総理で変わる面があると私は思っています。重要な隣国であることは多分どの政権でもほとんど変わらないのですけれども、人によ…", "…分どの政権でもほとんど変わらないのですけれども、人によっては、重要な隣国以上の存在だと考える政権もあれば、逆に、そうでないと本音ベースでは思…", "…べきくらいの国ではないか。要は、何が言いたいかというと、私は、重要な隣国以上の国という位置づけを私の中では実は持っているんですけれども、林外…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/28", "sentence": ["…は、日本として、一般論として申し上げれば、若干包容力を持って向き合う隣国なのかなと。やはり、可能な限り組み込んでいくことが、私たちが望む東ア…", "…国と向き合った方がいいと思います。ですから、冒頭申し上げた言葉で言えば、重要な隣国以上の存在だと思いますけれども、改めて問いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/30", "sentence": ["○玄葉委員もう一言。重要な隣国以上だというふうにお考えですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103815X00220230309/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103