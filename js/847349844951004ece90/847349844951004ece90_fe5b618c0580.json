[{"date": "2022-03-15", "meeting": [{"meeting_name": "衆議院 安全保障委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/209", "sentence": ["…げておきたいというふうに思います。自衛隊法八十四条の四の改正で、輸送対象者の範囲を拡大するということに今回はしております。邦人の配偶者及び子…", "…者及び子始め、現地に邦人がいない場合でも自衛隊を派遣できるように輸送対象者を追加するということでございますが、これはこれで私はいいと思います…", "…思いますが、外国人については、私などは、より柔軟性を発揮しながら輸送対象者に加えていく、広げていくということがあってよいのではないかというふ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/213", "sentence": ["…ども、自衛隊法、今回は八十四条の四が議題になっています。いわゆる輸送対象者を拡大するということになっているわけですけれども、その輸送対象者が…", "…輸送対象者を拡大するということになっているわけですけれども、その輸送対象者が外国人のみである、私は将来あり得ない話じゃないと思うんですけれど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803815X00320220315/223", "sentence": []}]}]}]