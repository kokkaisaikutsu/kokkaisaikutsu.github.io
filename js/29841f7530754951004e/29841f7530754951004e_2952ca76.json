[{"date": "2022-10-17", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/10", "sentence": ["…場は非常に厳しいです。現在の防衛調達では、かかった原価に対して、営業利益率が最大でも七％。国が中小企業の価格転嫁の旗を振っている中で、十分に…", "…さらに、実際には、財政当局、整備当局から査定をされ、五％にも満たない利益率になり、企業からすれば、先も見えない、稼げない事業として撤退をせざ…", "…つでも使える環境を整えることが私は急務だと思っていまして、調達契約の利益率の大幅改善など、国内防衛産業への抜本的な支援策を取るべきだと思いま…", "…と思います。装備移転を積極的に進めていくことも、有志国の安全保障上の利益になるだけでなく、国内防衛産業の基盤強化につながります。装備移転は、…", "…かがかなと思っています。国内防衛産業の基盤強化の観点から、調達契約の利益率の改善、日本版ＦＭＳ創設などの取組について、防衛大臣の見解を伺いた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/27", "sentence": []}]}]}, {"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/16", "sentence"