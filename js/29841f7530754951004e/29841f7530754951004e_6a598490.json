[{"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/6", "sentence": ["…せんでした。さて、私たち自由民主党が友党公明党の皆さんとともに政権を奪還して、十年がたちました。政権奪還前、私は浪人中でありましたけれども、…", "…党が友党公明党の皆さんとともに政権を奪還して、十年がたちました。政権奪還前、私は浪人中でありましたけれども、ここにいる自民党の多くの仲間も本…", "…さんいただいたと思います。そして、それを糧に、私たちは十年前、政権を奪還しました。しかし、一旦失われた信頼を取り戻すことはそう簡単なことでは…", "…で政権運営に当たっていた安倍元総理の言葉を思い出します。私たちは政権奪還の初心を決して忘れてはなりません。信なくば立たずであります。この十年…", "…果に静かな誇りを持ちながらも、おごることなく、次の十年に向けて、政権奪還の際の、強い日本を取り戻す、国民の皆さんとの約束を更に前進させていか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/31", "sentence": []}]}]}]