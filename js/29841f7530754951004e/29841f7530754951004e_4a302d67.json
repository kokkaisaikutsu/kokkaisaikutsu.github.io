[{"date": "2023-10-27", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/12", "sentence": ["…ートから出たら必ず見えるようにする。あるいは、カンボジアやラオスは、お札に日本のＯＤＡ事業の橋や道路をちゃんと造ってくれていますよ。ついでに…", "…の橋や道路をちゃんと造ってくれていますよ。ついでに申し上げれば、このお札そのものを日本で刷ってあげたらいいんですよ。造幣局は、外国からの依頼…", "…枚一枚が。したがって、言うならば、グローバルサウスの国で偽造されないお札を造りたいと思って日本に相談しても、高くて結局諦めちゃうんです。私は…", "…私は、これもＯＤＡでいいんじゃないんですか、日本で造った偽造されないお札をその国の国民が全員が使うって、こんないいＯＤＡはないんじゃないかと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00220231027/23", "sentence": []}]}]}]