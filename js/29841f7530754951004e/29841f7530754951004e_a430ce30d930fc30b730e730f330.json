[{"date": "2022-10-17", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/12", "sentence": ["…んでいます。米国においても、二〇一五年からＤＩＵ、ディフェンス・イノベーション・ユニットを創設し、シリコンバレーやボストンにオフィスをつくっ…", "…込みを積極的に行っています。こうしたデュアルユース技術こそが今やイノベーションの源泉だと思います。目まぐるしいスピードで進む軍事分野でのイノ…", "…ションの源泉だと思います。目まぐるしいスピードで進む軍事分野でのイノベーションに我が国も追いついていくためにも、もはや防衛省・自衛隊の内部の…", "…自衛隊の内部の研究だけでは限界です。外部から民間の技術、とりわけイノベーションの源泉であるスタートアップから技術をどんどん取り組んでいくとい…", "…求められていると考えます。今後五年間の防衛力抜本強化においては、イノベーションをこれまで以上に加速していくため、予算上も一定の数値目標を置き…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00220221017/27", "sentence": []}]}]}, {"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/14", "sentence": ["…割りの発想ではなくて、米国では、国防総省のＤＩＵ、ディフェンス・イノベーション・ユニットをつくりました。これを参考に、外部から民間技術を積極…", "…を