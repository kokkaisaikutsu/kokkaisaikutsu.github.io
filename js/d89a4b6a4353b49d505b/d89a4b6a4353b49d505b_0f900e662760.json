[{"date": "2021-04-14", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/103", "sentence": ["…定の審査に当たっては、なぜここが選ばれたのか明らかになるようにする、透明性は確保しなければならない、このように答弁をされています。ということ…", "…、今言ったように、一者のみしか応募がない、それで随契になったら、それも今どき透明性が図れないと思いますが、その点についてはどうお考えですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/107", "sentence": ["…は自治体の話です。自治体が、認定事業者がたった一者しか応募がなかったらそこに決まっちゃう、それで透明性が図れますかということを聞いています。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/109", "sentence": ["…たように、なぜここが選ばれたのかというところに疑問符がつくんですよ。透明性が図れないんだったら、何によってそれが正しいものなんだということを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01120210414/123", "sentence": []}]}]}]