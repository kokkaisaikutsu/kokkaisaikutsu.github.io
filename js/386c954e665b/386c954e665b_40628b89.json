[{"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/17", "sentence": ["…シングリンクの解消、早期整備が重要であると考えますが、国土交通省の御所見を伺います。また、暫定二車線区間の早期解消について、国土交通省では、…", "…などの通行止めも頻発しております。そこで、全国における暫定二車線の高速道路の四車線化についてどのようにお考えなのか、併せて御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/19", "sentence": ["…され、観光や経済面における効果が期待されることから、渋滞対策を推進していくことが重要であると考えておりますが、国土交通省の御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/25", "sentence": ["…の適用に関し、受注者負担分の緩和と手続の簡素化について国土交通省の御所見を伺います。また、民間工事については、契約後の工事費の増額は施主が応…", "…ております。そこで、民間工事においても価格高騰分について受注者負担が軽減されるような仕組みの構築が必要と考えますが、併せて御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/27", "sentence": ["…重要ではないかと考えます。そこで、担い手を確保するという観点で建設業界の活躍をしっかり広報すべきと考えますが、国土交通省の御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00320221108/29", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/133", "sentence": ["…は安定的な経営基盤の構築が不可欠でありますが、国交省として地域建設会社の持続的な経営環境の整備についてどのようにお考えか、御所見を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/137", "sentence": ["…る形で表れておりません。旅行業界完全復活のために更なる団体旅行の促進をしっかりとやっていくべきと考えますが、観光庁の御所見を併せて伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00320230309/147", "sentence": []}]}]}, {"dat