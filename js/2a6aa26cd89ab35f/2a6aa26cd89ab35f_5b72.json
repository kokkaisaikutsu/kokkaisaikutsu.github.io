[{"date": "2021-12-22", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/50", "sentence": ["…設備の負担が大きくなっているという声が多く聞かれます。例えば、岩手の肉牛農家が一軒当たり二十頭以上も飼育すればトラクターなどの大型機械が必要…", "…どの大型機械が必要になってきますが、八百万近いトラクターを導入すると、牛は四十頭ぐらいいないと経営が成り立ちません。しかし、畜産クラスター事…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/52", "sentence": ["…ど藤木委員からもありましたが、土地の面積に応じた頭数を導入することが、牛が草を食べ、そして牛からふんが出て、そして土に返るという自然サイクル…", "…ましたが、土地の面積に応じた頭数を導入することが、牛が草を食べ、そして牛からふんが出て、そして土に返るという自然サイクルが無理のない農業にな…", "…という自然サイクルが無理のない農業になると考えます。国の政策として今肉牛の頭数を進めている中で、必然と購入牧草や機械の大型化に頼らざるを得ず…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/69", "sentence": []}]}]}]