[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015254X00920221202/5", "sentence": ["…せんでした。九月には、大量に積み上げた予備費から支出し、住民税非課税世帯への給付金などを決定しましたが、いずれも不十分な内容にとどまっていま…", "…に、児童手当の特例給付に関わる所得制限によって特例給付を受けられない世帯に対して相当額を給付し、所得制限の実質的な撤廃を図る。第四に、家計の…"]}]}]}, {"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/145", "sentence": ["…の対応についてお伺いをしたいと思います。調査によりますと、二人以上の世帯の金融資産保有額の中央値は四百万円とのことです。貯蓄から投資に回す資…", "…産保有額の中央値は四百万円とのことです。貯蓄から投資に回す資金がある世帯は、今回のＮＩＳＡの拡大で恩恵が得られる。貯蓄する余裕がなく投資に回…", "…ＩＳＡの拡大で恩恵が得られる。貯蓄する余裕がなく投資に回す資金がない世帯は、預金なしの人、およそ三五・七％の世帯は恩恵が受けられない。今回の…", "…裕がなく投資に回す資金がない世帯は、預金なしの人、およそ三五・七％の世帯は恩恵が受けられない。今回の見直しは所得格差の拡大につながるのではな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00520230317/163