[{"date": "2020-12-25", "meeting": [{"meeting_name": "衆議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/2", "sentence": ["○高木委員長次に、御報告申し上げます。昨二十四日、議員安倍晋三君から、大島議長宛てに、本会議及び委員会において、内閣総理大臣として行った答弁…", "…における協議に基づき、本委員会で行うこととなりました。この際、議員安倍晋三君の発言を許可するに御異議ありませんか。〔「異議なし」と呼ぶ者あり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/3", "sentence": ["○高木委員長御異議なしと認めます。よって、そのように決定いたしました。安倍晋三君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304024X01120201225/78", "sentence": []}]}]}]