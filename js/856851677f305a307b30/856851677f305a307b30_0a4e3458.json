[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/145", "sentence": ["…だきたい、そのように思っております。続いては、大阪堂島商品取引所で本上場を目指していた米の先物取引についてです。今でこそ世界中で活況を呈する…", "…た。一度は途絶えましたこの日本の米先物取引を二〇一一年から、まあ試験上場ということで復活させてきまして、堂島の商取では二年の期間延長のたびに…", "…いうことで復活させてきまして、堂島の商取では二年の期間延長のたびに本上場への認可基準をクリアするべく努力を重ねてきました。認可基準は主に二つ…", "…長は、ゴールポストが動いていると大変憤慨なさっていました。その結果、上場を諦められたというふうに把握をしております。そこでお伺いしたいのです…", "…うに把握をしております。そこでお伺いしたいのですが、提示されていた本上場の条件、そして審査のときに言われていたことと最終的に今まで指摘されな…", "…査のときに言われていたことと最終的に今まで指摘されなかった点について上場不認可となった、こういった矛盾について農林水産省の見解をお伺いしたく…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00220220308/165", "sentence": []}]}]}]