[{"date": "2022-04-14", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/60", "sentence": ["…なんですね。そこで何やっているかというと、この豆かすと木材を合わせて堆肥を作っているんです。コーヒーチェーンの従業員さんでありながら、うちの…", "…もう半林半Ｘみたいなものですよね。で、コーヒーチェーンの方が、へえ、堆肥ってこういうふうに作れるんだというふうに知ってもらって、その堆肥を使…", "…え、堆肥ってこういうふうに作れるんだというふうに知ってもらって、その堆肥を使って苗木を作って、その苗木をまたこの河内の山に返していこうという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/72", "sentence": []}]}]}]