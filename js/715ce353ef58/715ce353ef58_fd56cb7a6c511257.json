[{"date": "2022-02-08", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01220220208/10", "sentence": ["…脈のダイナミックな地形と我が国最大級の原生的な自然が残されており、国立公園の候補地としてふさわしいと考えています。国立公園に指定されることで…", "…然が残されており、国立公園の候補地としてふさわしいと考えています。国立公園に指定されることで保護管理が充実する、国の管理になるわけですね、充…", "…のすばらしい自然が受け継がれるということを期待しています。さらに、国立公園化によってブランド力が強化されるということで、プロモーションができ…", "…います。それから、どの辺までいくかということについては、基本的に、国立公園としての指定に向けて、現在の国定公園の周辺にも重要な自然が広がって…", "…に調整してまいりたいと思います。関係機関あるいは地域との調整後に、国立公園の指定案についてパブリックコメントを求め、そしてまた中央環境審議会…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01220220208/12", "sentence": ["○山口国務大臣御指摘のとおり、国立公園の名称は、対象地域の自然を代表するとともに、地域や国内外の利用者の方々にも利用されやすいものである必要…", "…々にも利用されやすいものである必要があるというふうに考えています。国立公園に指定する際の名前については、こうした要件や地域関係者の御意見も踏…", "…踏まえて、環境省で名称案を整理していきたいと思っています。本地域の国立公園化によって、地域の関係者の方々と連携しつつ、我が国最大級の原生的な…"]}]}]}, {"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/2", "sentence": ["…意した二〇三〇年までの陸と海の三〇％以上の保全を目指します。また、国立公園等の区域拡張とその質や魅力の向上に加え、民間取組を促すための仕組み…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/8", "sentence": ["…大臣東先生のおっしゃられるとおり、この廃屋の問題というのが、立派な国立公園の中で、やはりそこは価値を損なうんじゃないかというところは非常に強…", "…損なうんじゃないかというところは非常に強く感じます。先月、阿寒摩周国立公園における廃屋対策の取組を視察してきました。先生のところは大雪山だと…", "…うんですけれども。北海道の世界に誇る大自然を目の当たりにして、その国立公園に魅力的な自然があっても、景観を阻害する廃屋があるということで、魅…", "…活用を前提とした廃屋撤去に取り組む場合の補助事業を実施しています。国立公園利用拠点滞在環境等上質化事業と言われるもので、二分の一の補助をさせ…", "…います。引き続き、関係省庁あるいは地域関係者の方々と連携しながら、国立公園内の廃屋撤去や跡地活用の取組を推進していかなければいけないと思って…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/12", "sentence": ["○山口国務大臣今おっしゃられるとおり、先ほどの国立公園利用拠点滞在環境等上質化事業というのは、令和四年度予算の中で十六・七億円お願いさせてい…", "…られたように、数億の話だと思います。したがって、この間の阿寒摩周の国立公園を見させていただいたとき、おっしゃられるとおり、自治体的には規模は…", "…。しかし、そこには当然、限度もあるわけですから、やはり国の管理する国立公園として、更にできることは増やしていかなければいけないなというふうに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/42", "