[{"date": "2021-04-16", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/23", "sentence": ["…ゃる方は多いと思うんです。なぜこれまでの政策がきちんと効果が出てきていないのか、限定的であるのか、この反省点、教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/25", "sentence": ["○田島麻衣子君政策のアピールではなくて反省点を伺いたかったんですけれども。例えば、首相のメッセージの発信力が弱い、また過去の医療崩壊の学びを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414024X02120210416/27", "sentence": []}]}]}, {"date": "2022-03-31", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/13", "sentence": ["…回、三月二十四日、北朝鮮が発射したＩＣＢＭから国民の命と安全を守るために政府が取った対応、自己評価、それから反省も含めて伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/17", "sentence": ["…行っていらっしゃいますね。本当に、海に出ていてどれだけの船がパソコンを持っているんでしょうか。これおかしくないですか。反省点になりませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/19", "sentence": ["…に落下地点に十隻前後の船舶が周辺いたのか、航行していたのか、この点も含めてしっかりと検証して反省点洗い出すべきだと思いますが、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00620220331/23", "sentence": []},