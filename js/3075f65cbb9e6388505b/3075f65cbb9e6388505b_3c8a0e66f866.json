[{"date": "2022-04-19", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/26", "sentence": ["…も、現在、この旧姓併記のパスポートで、海外用の新型コロナワクチン接種証明書アプリ、これというのは旧姓で証明書を取得することはできるんでしょう…", "…併記のパスポートで、海外用の新型コロナワクチン接種証明書アプリ、これというのは旧姓で証明書を取得することはできるんでしょうか。いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/28", "sentence": ["○田島麻衣子君これは、海外でワクチンを受けて接種証明書をもらおうと思っても、旧姓では証明書もらえないということなんですね。その男性なり女性な…", "…れは、海外でワクチンを受けて接種証明書をもらおうと思っても、旧姓では証明書もらえないということなんですね。その男性なり女性なりが旧姓でその会…", "…旧姓、パスポートも明記されているわけですから、海外用のこのコロナワクチン接種証明書アプリも旧姓併記していただけないでしょうか。いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01020220419/54", "sentence": []}]}]}]