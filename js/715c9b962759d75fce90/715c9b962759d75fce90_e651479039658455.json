[{"date": "2022-02-28", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/322", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/324", "sentence": ["○国務大臣（山際大志郎君）まず、今般の処遇改善の対象となる職種、これはおっしゃるように限られているんですが、しかし、その処遇改善のための収入…", "…なる職種、これはおっしゃるように限られているんですが、しかし、その処遇改善のための収入を活用して他の職種の処遇改善に充てる柔軟な運用、これを…", "…いるんですが、しかし、その処遇改善のための収入を活用して他の職種の処遇改善に充てる柔軟な運用、これを認めることとしております。そして、お尋ね…", "…柔軟な運用、これを認めることとしております。そして、お尋ねの今後の処遇改善の在り方につきましては、公的価格評価検討委員会の中間整理にこれまた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/475", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/477", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/479", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/483", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/485", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/487", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/489", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/491", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00420220228/509", "sentence": []}]}]}]