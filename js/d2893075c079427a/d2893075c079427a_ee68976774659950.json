[{"date": "2023-04-27", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/60", "sentence": ["…田大臣政務官森林環境譲与税については、主として山間部の市町村から、森林整備を一層推進する観点から、譲与基準を見直すべきだとの声があるところで…", "…「各地域における取組みの進展状況や地方公共団体の意見を考慮しつつ、森林整備をはじめとする必要な施策の推進につながる方策を検討する。」とされた…", "…見据えて、自治体の取組内容やニーズ等の分析を行い、譲与税がより一層森林整備を始めとする必要な施策の推進に活用されるよう、検討してまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00720230427/108", "sentence": []}]}]}]