[{"date": "2023-05-30", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/76", "sentence": ["…でありますけれども、日本は議長国として、各国の国益を懸けた闘いの中で合意に向けたリーダーシップを発揮できたと、そのように理解をしております。…", "…合では議長として取りまとめに奔走され、国際協調の土台となる共同声明の合意形成が図られたというふうに理解をしております。そこで、Ｇ７のエネルギ…", "…エネルギー分野における協議過程でどのような各国の利害がぶつかり合い、また日本の立場や考え方がどのように合意に反映されたか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/78", "sentence": ["…ンの強化が確認されました。今回のＩＰＥＦ閣僚会議にも、この点について合意できるかが焦点であったわけでありますけれども、西村大臣が議論を主導し…", "…いうふうに伺っております。どのような議論が行われたのか、そして今回の合意がエネルギー分野の協議にこれからどのような影響を与えるのか、その辺の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/92", "sentence": ["…れども、Ｇ７札幌会合では天然ガス分野への投資の必要性が確認されました。この合意は世界のエネルギー市場にどのような影響を及ぼすのか、伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01220230530/104", "sentence": []}]}]}]