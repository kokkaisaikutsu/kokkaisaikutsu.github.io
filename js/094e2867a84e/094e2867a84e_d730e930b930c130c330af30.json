[{"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/13", "sentence": ["…いたします。次に、今、海洋環境の保全の重大な脅威となっている海のプラスチックごみ対策について伺いたいと思います。三月の二日にナイロビで開催さ…", "…ナイロビで開催されていた第五回国連環境総会で、二〇二四年末までにプラスチックごみによる汚染に関して法的拘束力のある国際協定を制定するとの合意…", "…ども、カモが水草をついばむような、のどかな風景の横に、たくさんのプラスチックのかけらというか、発泡スチロールのかけらみたいなのがいっぱい流れ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00220220316/19", "sentence": []}]}]}]