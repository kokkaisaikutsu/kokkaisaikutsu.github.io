[{"date": "2022-02-17", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/201", "sentence": ["…ら先にコメントしてしまいます。長所の一点目、同等の消費水準には同等の税負担を求める水平的公平性に優れるというんだよね。とんでもない話。これが…", "…。こんな投網で魚を捕るような税金だもの、安定した税金が得られますよ。税負担が勤労世帯に偏らない。これもうそっぱちですよ。勤労世帯ほど、家庭を…", "…れども。それから、短所ですけれども、逆進性。低所得者ほど所得に占める税負担が重い。これはそのとおりかもしれません。加えて、今私が申し上げたよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00220220217/209", "sentence": []}]}]}]