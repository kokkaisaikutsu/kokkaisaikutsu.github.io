[{"date": "2022-03-10", "meeting": [{"meeting_name": "衆議院 地方創生に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/21", "sentence": ["…えておりましたが、デジタル基盤を整備すれば、人口減少、高齢化、産業の空洞化等、地域が抱える課題をデジタルの力で解消できる、こう若宮大臣は所信…", "…高齢化を止められるのか、止められない。少し止められるとすると、産業の空洞化は止められるかもしれません。ですから、そういう意味では、デジタルも…", "…は、残念ながらそれを止められません、幾らデジタルが普及しても。産業の空洞化は多少止めることもできると思います。ですから、そういう世の中の現象…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00320220310/29", "sentence": []}]}]}]