[{"date": "2021-08-05", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/86", "sentence": ["○浜口誠君たった四・一％なんですよね、まあ全体の病床数からするとですよ。これは、努力はされたかと思いますけれども、現実はまだその程度しか全体…", "…れは、努力はされたかと思いますけれども、現実はまだその程度しか全体の病床数からすると受入れのキャパはないということなんで、これ引き続き病床を…", "…の病床数からすると受入れのキャパはないということなんで、これ引き続き病床を確保していく努力というのは国挙げてやっていただく必要があるというふ…", "…、あるいは軽症の方の急変する方をしっかりと医療につなげていくためには病床数の拡大というのはこれからも取り組んでいく必要があると思いますけれど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/88", "sentence": ["…療関係者の皆さんの御協力もいただきながら、少しでも受け入れていただく病床数を拡充していただく取組、これはもう国挙げてしっかりと連携をしていた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/102", "sentence": []}]}]}]