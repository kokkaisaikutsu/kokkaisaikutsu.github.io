[{"date": "2022-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/250", "sentence": ["…れ見ていただくと、これ、ガソリンのレギュラー価格の直近の状況と過去の最高額を示しています。昨年の一月時点では、レギュラーガソリン百三十六・一…", "…に昨年の一月と比べると三十六・七円上がっています。さらに、これまでの最高額は二〇〇八年の八月、このときは最高のレギュラーガソリンの価格になっ…", "…がっています。さらに、これまでの最高額は二〇〇八年の八月、このときは最高のレギュラーガソリンの価格になったんですね。そのときが百八十五・一円…", "…きが百八十五・一円です。それで見ると、もう昨年の一月と比べると、過去最高のときとの比較では四十九円上がることになるんですね。更にこれ上がる可…", "…もう一バレル百十ドルを超えているという状況ですから、相当、今後、過去最高を上回るような状況にもなってくると思います。今政府がやろうとしている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/252", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/254", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/256", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/258", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/260", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/262", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00