[{"date": "2021-04-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/177", "sentence": ["…をキャリーオーバーさせないという観点からは、経済が落ち着いてきたら財政健全化もやっぱり同時に取り組んでいくことが必要だというふうに私自身は思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/181", "sentence": ["○浜口誠君ありがとうございます。是非、財政健全化の旗はずっと掲げていただいているというのは、将来世代にとっても大事なことだと私は思っておりま…", "…来世代にとっても大事なことだと私は思っておりますので、引き続きその財政健全化、二〇二五年に本当達成できれば一番いいんですけれども、今内閣府の…", "…その一方で、二〇〇八年のリーマン・ショックのときに、ＯＥＣＤ各国は財政健全化を図るために独立財政機関というのを、約八割のＯＥＣＤ諸国で財政機…", "…おりますので、我が日本においてもそういう独立財政機関を設置をして、財政健全化に対してしっかりと目を光らせていただくということも非常に重要では…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/191", "sentence": []}]}]}, {"date": "2021-12-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/114", "sentence": ["…銀でしっかり御検討いただきたいというふうに思っております。一方で、財政健全化についてはいろんな御意見あります。積極財政、ＭＭＴを主張される皆…", "…な動きもあります。そこで、黒田総裁にお伺いしますが、日銀総裁として財政健全化についてどのようなお考えをお持ちなのか、お伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/127", "sente