[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/107", "sentence": ["…でやはり国内販売を底支えしていくために、自動車の税制に関して引き続き減税対応等をお願いをしたいなと。今、自動車関係諸税の中のエコカー減税です…", "…続き減税対応等をお願いをしたいなと。今、自動車関係諸税の中のエコカー減税ですとか、あと環境性能割の一％の軽減措置、さらにはグリーン化特例、こ…", "…、あと環境性能割の一％の軽減措置、さらにはグリーン化特例、こういった減税措置が来年の三月若しくは四月末に終わるという今計画になっていますので…", "…で、年末にかけての来年度の税制改正の議論の中で、是非、自動車に関する減税措置、今の枠組みを来年以降も延長していただくことを強くお願いをしたい…", "…だくことを強くお願いをしたいというふうに思っております。この自動車に関する減税措置の延長に関して、赤羽大臣の御所見をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314319X00220201126/127", "sentence": []}]}]}]