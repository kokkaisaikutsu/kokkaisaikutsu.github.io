[{"date": "2022-04-26", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/53", "sentence": ["…の発電設備等を民間の事業者の方が整備する場合については、その土地の使用権の上限期限を、従来までは十年だったのを今回二十年に延長するということ…", "…は可能なのか、もう二十年来たらそこですぱっと民間事業者の方の土地の使用権限というのは終わらせないといけないのか、その辺りの対応についてお伺い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/55", "sentence": ["…ででも延長は可能だということなんですかね。どこかでやっぱり最終的な使用権限のエンドというか期限はあるのか、もうずっと認められれば半永久的にそ…", "…的な使用権限のエンドというか期限はあるのか、もうずっと認められれば半永久的にその使用権限というのは延長されるのか、その点はいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01020220426/77", "sentence": []}]}]}]