[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/47", "sentence": ["…ってから、主要国はインフレ抑制のために金利引締めに転じております。金融緩和を継続する日本との金利差は拡大をしているという状況です。為替市場で…", "…銀は九月の金融政策決定会合で、景気を下支えするため、現状の大規模な金融緩和策を維持するということを決めました。この円安、物価高騰の現状で金融…", "…模な金融緩和策を維持するということを決めました。この円安、物価高騰の現状で金融緩和策を継続する必要があるのかということをお聞きをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/63", "sentence": []}]}]}]