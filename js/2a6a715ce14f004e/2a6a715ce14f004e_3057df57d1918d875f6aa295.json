[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/53", "sentence": ["…に思います。金融庁に伺います。地方銀行あるいは信金、信組といった地域金融機関、これは、地域の中小企業に対して積極的に資金供給を行う、いわゆる…", "…度と、こうした特別付利を実施をしているところであります。そこで、地域金融機関の役割と今後の地域金融機関の経営基盤強化をどう進めていくのか、伺…", "…うした特別付利を実施をしているところであります。そこで、地域金融機関の役割と今後の地域金融機関の経営基盤強化をどう進めていくのか、伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/55", "sentence": ["○横山信一君予想しなかったコロナ禍という状況の下で、地域金融機関の経営基盤強化というのは非常に重要な今課題になってきておりますので、更にこの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/63", "sentence": []}]}]}]