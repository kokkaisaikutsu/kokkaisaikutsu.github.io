[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/49", "sentence": ["…いきたいんですけども、政府は、物価高克服・経済再生実現のための総合経済対策を講じることを発表いたしました。エネルギーや食料品の価格高騰に対す…", "…これからやっていきます。しかし、この現状の物価高騰に対するこうした経済対策と消費者物価の前年比上昇率二％の物価安定の目標、これは矛盾するんじ…", "…安定の目標、これは矛盾するんじゃないかという見方もあるわけですけれども、この政府の経済対策と金融政策との関係はどうなっているのか、伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00320221110/63", "sentence": []}]}]}]