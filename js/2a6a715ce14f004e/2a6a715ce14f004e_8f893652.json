[{"date": "2022-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/221", "sentence": ["…る厳しい法的管理など、先ほどの三浦議員の質問にもありましたが、様々な規制に苦労しているのが実情です。機構では、放射線科学に限らず、ドローンや…", "…るのが実情です。機構では、放射線科学に限らず、ドローンや空飛ぶ車など規制により研究が阻まれている分野では、個々の規制を関係機関に働きかけ、緩…", "…、ドローンや空飛ぶ車など規制により研究が阻まれている分野では、個々の規制を関係機関に働きかけ、緩和する努力が求められます。規制緩和は、福島国…", "…野では、個々の規制を関係機関に働きかけ、緩和する努力が求められます。規制緩和は、福島国際研究教育機構を中核拠点にするための鍵となります。その…", "…国際研究教育機構を中核拠点にするための鍵となります。そのため、機構に規制緩和のための専門のセクションをつくるべきと考えますが、復興大臣に伺い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/223", "sentence": ["…を専門とする研究者は多くありません。その理由は、先ほど申し上げた多重規制です。復興副大臣のときに東京大学のＲＩＣ、アイソトープ総合センターを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/239", "sentence": []}]}]}]