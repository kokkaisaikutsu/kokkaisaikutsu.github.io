[{"date": "2022-05-13", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/100", "sentence": ["…林業の再生に向けた取組を進めてきております。この中で、シイタケの原木生産、これは二十年、二十年から二十五年のサイクルというふうに聞いておりま…", "…りません。これらが使えないなら、来年からコナラを育てて二十年後の原木生産を目指さなければいけないわけですけれども、今後のこの二十年サイクルの…", "…二十年後の原木生産を目指さなければいけないわけですけれども、今後のこの二十年サイクルの原木生産の支援をどう考えているのか、林野庁に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00520220513/106", "sentence": []}]}]}]