[{"date": "2022-05-18", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/45", "sentence": ["○藤岡委員では、その後、補助者が五人から豊田船長だけになったときに、知床遊覧船から届出や連絡、また運輸局など国土交通省にはあったのでしょうか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/47", "sentence": ["…とをまず思います。そして、雇い止めになって、五人の補助者からいわゆる豊田船長だけになってしまったという中で、改善の、そこについて把握は、届出…", "…は、これは予見できたということに私は考えられると思います。ある意味、豊田船長だけが補助者になっていて、豊田船長が船に乗る、桂田氏が事務所にい…", "…は考えられると思います。ある意味、豊田船長だけが補助者になっていて、豊田船長が船に乗る、桂田氏が事務所にいるかというと、いろいろな、まあホテ…", "…現場を離れるという当然可能性も出てきますので、本来であれば、補助者が豊田船長だけになった段階で、非常時の連絡を確実に行える補助者の選任がなけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/65", "sentence": []}]}]}]