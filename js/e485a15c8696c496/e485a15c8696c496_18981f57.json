[{"date": "2022-03-30", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/109", "sentence": ["○藤岡委員先ほど、領土の保全という観点からというふうに内閣府の方から話がありましたが、国土交通省の地籍調査を担当する部局に対して内閣府の方か…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/111", "sentence": ["…非常にちょっと残念だったのが、地籍調査のためにということではなくて、領土の保全のために内閣府の方から国土交通省さんの方に積極的に情報提供を例…", "…ます。しかしながら、例えば、じゃ、地籍調査をやるときに、やはりこれは領土、領海の保全からここを優先してやろうという判断をしようと思っても、そ…", "…しようもない話でございます。地籍調査のためにというところではなくて、領土、領海の保全のために、どこにどういう情報を提供するのかというところを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/119", "sentence": ["○藤岡委員領土、領海の保全という視点で、本当に早急にこの対応を。法律が施行されていて、何だか放置されていて、いつも法務省が判断してもらうまで…", "…き、この負担金、これは少なくとも免除をするとか、大幅に減免するとか、領土、領海の保全という視点で、そういうふうな政令にしていただきたいなとい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/121", "sentence": ["…りになっている部分をきちっと内閣府さんの方で主導権を持って、積極的に領土、領海を守るという視点で働きかけていただく必要があると思うんですけれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00520220330/125", "sentence": ["○藤岡委員領土、領海をしっかり守るという姿勢でやはり臨んでいただきたいと思うんですよね。実質的公平性、それはそう、法務省さんのお答えとしたら…", "…分ももちろんあると思うんです。もうちょっと本当は内閣府の方でそれを、領土、領海を守るというこの目的に沿って制度の調整を行っていただくんだ、そ…", "…ので、これは