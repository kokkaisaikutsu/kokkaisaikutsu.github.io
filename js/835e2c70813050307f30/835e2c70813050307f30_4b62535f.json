[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/17", "sentence": ["…どうもありがとうございます。是非よろしくお願いいたします。次に、児童手当の所得制限についてお聞きします。最近、茂木幹事長も言及された児童手当…", "…手当の所得制限についてお聞きします。最近、茂木幹事長も言及された児童手当の所得制限の撤廃について、政府参考人にお聞きします。二〇二二年十月に…", "…制限の撤廃について、政府参考人にお聞きします。二〇二二年十月に、児童手当法が一部改正され、年収千二百万円以上の場合には児童手当が支給されなく…", "…二〇二二年十月に、児童手当法が一部改正され、年収千二百万円以上の場合には児童手当が支給されなくなりましたが、その趣旨と目的を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/19", "sentence": ["…結果として待機児童を解消できたことはとても良かったと思いますし、児童手当は、申出があれば保育料や給食費に振り替えることができる、父母が別居中…", "…と思います。ただ、もっと安心、安全な養育のために全ての子供たちに児童手当を給付してもらいたい、この点について小倉大臣に御意見をお聞きしたいと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/41", "sentence": []}]}]}]