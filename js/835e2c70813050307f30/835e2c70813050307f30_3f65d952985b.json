[{"date": "2023-04-06", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/11", "sentence": ["…す。カップルの間でなぜ暴力が起きるのかを学んで、予防をすることはとても良いことだと思います。その趣旨や思いを政務官にお聞きしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/18", "sentence": []}]}]}, {"date": "2023-04-19", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/24", "sentence": ["…い手不足は極めて深刻でございます。復興の観点から、今後の漁業、水産業の振興についていかに考えるか、復興大臣政務官のお考えをお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/26", "sentence": ["○広瀬めぐみ君中野政務官、力強い御答弁、誠にありがとうございました。頑張る養殖、頑張る漁業の復興事業ということで、新たなメニューも設けていた…", "…興と絡めて、内地から沿岸に、沿岸から内地に観光客を呼び込む努力をお願いしたいと思いますが、いかがでしょうか。これも中野政務官にお聞きします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/28", "sentence": ["○広瀬めぐみ君中野政務官、どうもありがとうございました。被災地の観光の重要性を認識していただいているということで、非常に有り難く思います。是…", "…域振興に役立てるべきと考えておりますが、復興庁はこのようなローカル線の活用についてどのようにお考えでしょうか。中野政務官にお聞きいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114858X00420230419/36", "sentence": []}]}]}]