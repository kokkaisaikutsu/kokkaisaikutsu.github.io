[{"date": "2023-12-06", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/30", "sentence": ["○森まさこ君原発被災地域について大臣から今御説明があり、令和三年から当面十年の令和十三年まで。しかし、大臣、この原発被災地域というのが一体ど…", "…あり、令和三年から当面十年の令和十三年まで。しかし、大臣、この原発被災地域というのが一体どこなのか、示されていないんです。大熊町と双葉町だけ…", "…河を中心とした森林組合の皆様が要望に来ましたけど、白河は一体、原発被災地域に入って令和十三年までに組み込まれるのか、それとも令和七年で終わる…", "…二期復興・創生期でしょうか。国は示しておりません。少なくとも、原発被災地域を抱える福島県全体は第二期後も国の支援が必要であることは誰も反対し…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/46", "sentence": []}]}]}]