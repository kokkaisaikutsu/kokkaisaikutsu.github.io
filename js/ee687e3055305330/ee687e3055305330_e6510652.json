[{"date": "2021-04-09", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/9", "sentence": ["…ではないということもおっしゃっていました。この五つの課題。一つ目は、処分について漁業者と福島県民と国民へ責任ある説明をしてほしいということで…", "…更にこの処理水ショックという新たな風評被害が出てきましたら、処理水の処分を実行するのが仮に今から二年後だとしても、風評被害自体の、発生してし…", "…害への万全な対応をしてほしいということです。三つ目は、処理水を安全に処分するということを実行できるのかという問題です。これは、後ほど東電さん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/15", "sentence": ["…防護対策に問題を起こしたばかりの東電でございますが、実際にこの処理水の対策が決まったときに安全に処理水を処分できるのか、答弁をお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/27", "sentence": []}]}]}]