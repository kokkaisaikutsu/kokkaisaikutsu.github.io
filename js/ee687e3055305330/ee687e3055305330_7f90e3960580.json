[{"date": "2023-12-06", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/32", "sentence": ["…票が大熊町ですか、石川県じゃなきゃ駄目ですよと言われてしまいました。避難者であるんですと説明し、財務局に問い合わせても駄目でした。そこで、私…", "…事故で福島県内の多くの人が県内外への避難を心ならずも強いられました。避難者は避難先の自治体から基本的な行政サービスさえ受けることが困難でした…", "…です。その二人が中心になって発案したことがきっかけの一つとなり、原発避難者特例法の制定につながりました。この法律により、避難者は住民票を移さ…", "…一つとなり、原発避難者特例法の制定につながりました。この法律により、避難者は住民票を移さなくても避難先の自治体から様々な行政サービスを受けら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121214858X00320231206/46", "sentence": []}]}]}]