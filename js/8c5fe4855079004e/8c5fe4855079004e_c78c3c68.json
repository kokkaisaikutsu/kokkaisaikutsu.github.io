[{"date": "2022-10-24", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/95", "sentence": ["…ればいいんでしょうか。これについては、先週、参議院でも議論があって、資格証明書というのを使ってやるというような答弁がありました。この資格証明…", "…て、資格証明書というのを使ってやるというような答弁がありました。この資格証明書というのは何かというと、保険料を納めていないような方が、お医者…", "…ありました。総理、保険証を廃止しちゃったら、その後、マイナンバーカードを取っていない人は、この資格証明書みたいに窓口全額負担になるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/97", "sentence": ["…いじゃないですか。保検証もやめて、マイナンバーカードを持っていない、資格証明書でもないんですか。じゃ、何か新しいのをつくるんだ、ばかばかしい…", "…。マイナンバーカードを進めていただいて大いに結構。保険証を廃止して、資格証明書で本当にやるんですか。やめましょうよ、保険証を維持しましょうよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/99", "sentence": ["○後藤（祐）委員そうすると、保険証は廃止、マイナンバーカードの人はそれでいいでしょう、資格証明書ではない第四の方法をつくるということですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/136", "