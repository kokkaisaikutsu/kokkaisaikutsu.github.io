[{"date": "2023-01-31", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/116", "sentence": ["…で、その後二割ぐらい下がって七千三百六円になるんですが、その後、今、料金認可申請、値上げ申請というのが来ていて、東京電力の場合二九％、北陸電…", "…は皆さん、ぬか喜びですから。これはこれでありがたいんですが、その後、料金認可申請、更にそれ以上上げる、つまり、二割下がって三割上がるというの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/120", "sentence": ["…たんですよ。燃料費調整制度という、為替と原油相場が上がったら自動的に料金を上げられる制度が、五割分しかできないので、上限に張りつく会社が二月…", "…の一ドルレートは大体百三十円ぐらいです。これは、燃料費が上がったから料金値上げなので、この査定の中で、為替だとか原油価格ですとか、ＬＮＧとか…", "…替だとか原油価格ですとか、ＬＮＧとかあるかもしれないけれども、それを踏まえた査定をすることで適切な電気料金ということにすべきじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00320230131/148", "sentence": []}]}]}]