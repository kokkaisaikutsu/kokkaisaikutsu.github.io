[{"date": "2022-03-18", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X00820220318/19", "sentence": ["…しながら、自衛隊は現在でも定員割れが続いています。この要因として、自衛隊員の給与体系、待遇、働く環境に課題があるのではないでしょうか。現行の…", "…遇、働く環境に課題があるのではないでしょうか。現行のシステムでは、自衛隊員の給与改定は他の公務員と同様に民間給与との比較に基づいた人事院勧告…", "…との比較に基づいた人事院勧告によって定められていますが、国防を担う自衛隊員の給与査定が、経済環境に大きく左右される民間給与に影響されることは…", "…を行っています。給与体系の見直し、十分な危険手当の付与等、抜本的な自衛隊員の待遇改善を行うべきと考えますが、防衛大臣の見解を伺います。自国の…"]}]}]}, {"date": "2022-04-05", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/99", "sentence": ["…長退席、理事宇都隆史君着席〕これ、一説によれば、この歴史的テーマ、自衛隊員の給与体系というのは、警察予備隊の創設時に警察に準じた給与制度に基…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00720220405/119", "sentence": []}]}]}]