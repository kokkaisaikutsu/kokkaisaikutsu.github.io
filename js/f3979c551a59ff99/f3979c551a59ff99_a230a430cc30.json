[{"date": "2021-03-23", "meeting": [{"meeting_name": "参議院 沖縄及び北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/77", "sentence": ["…うことを要望いたしたいと思います。次に、北方問題に関連いたしまして、アイヌ振興、北海道白老町にあります民族共生象徴空間、ウポポイについてお伺…", "…ポポイについてお伺いしたいと思います。民族共生象徴空間、ウポポイは、アイヌ文化を振興するための空間や施設であるだけではなく、我が国の貴重な文…", "…設であるだけではなく、我が国の貴重な文化でありながら存立の危機にあるアイヌ文化を復興、発展させる拠点として、昨年の七月に一般公開をされました…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/79", "sentence": ["…行けていないので、ホームページ等々にあるプログラム拝見いたしました。アイヌ民族に伝わる竹製のムックリの製作や演奏体験、調理体験など、提供され…", "…とになれば、今後当面の間はやはりウイズコロナ、アフターコロナに適したアイヌ文化の振興や普及啓発の方法、これやっぱり新たに方向転換を少しして、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/81", "sentence": ["…でそういったところを改善していただいて、少しでもこのウポポイの魅力、アイヌ文化の振興というのを広めていただきたいというふうに思います。今の話…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413895X00320210323/93", "sentence": []}]}, {"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00520210323/151", "sentence": []}, {"url": "https