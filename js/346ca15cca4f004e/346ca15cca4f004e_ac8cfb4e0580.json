[{"date": "2020-10-30", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315254X00320201030/21", "sentence": ["…ログに、内閣官房長官は政府のアイヌ政策推進本部長であり、アイヌ政策の責任者ですと記しています。その菅総理がアイヌ政策推進会議の座長として尽力…", "…利用されていようとしているのです。そこで、質問十一です。アイヌ政策の責任者だった菅総理、今度は国の責任者として、こうした民族の誇りを踏みにじ…", "…す。そこで、質問十一です。アイヌ政策の責任者だった菅総理、今度は国の責任者として、こうした民族の誇りを踏みにじる行為を止めるべきではないです…", "…ようとしました。ところが、あらかじめ連絡調整していたにもかかわらず、責任者である防衛局長は行方不明、次席の立場の職員は会いたくないと面会を拒…"]}]}]}, {"date": "2021-06-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/43", "sentence": ["…お持ちでないというふうに理解をせざるを得ないですね。そうすると、東京オリンピック・パラリンピックの真の責任者は一体どなたなんでしょう、総理。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/45", "sentence": ["…が起こったとしても、あるいは国の政治の中でどんなに無駄遣いが出ても、責任者がはっきりしていない、いつもうやむやになってしまう、そういうことが…", "…います。ですから、今回、オリンピック・パラリンピック、東京五輪の真の責任者はどなたであるのか、このことをはっきりしておかないと、国民の皆さん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/47", "sentence": ["…た中で人命を救うことができない、そういうような事態に起こったときも、責任者が誰かということがはっきりしていないとどうにもならないじゃないです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/49", "sentence": ["○水岡俊一君残念ですね。前提ばかりをおっしゃって、責任者は誰かが分からない。こういったことで進んでいくことに大変大きな危惧を感じます。感染を…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/56", "sentence": []}, {"url": "https://kokkai