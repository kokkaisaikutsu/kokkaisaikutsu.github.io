[{"date": "2021-06-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/30", "sentence": ["…と自覚をしながら心して質疑を行いたいと、こういうふうに思っております。菅総理始め閣僚の皆さん方には、委員に対してはもとよりでありますけれども…", "…りますけれども、その中にあってもオリンピック・パラリンピックを開催できると菅総理はお考えになっているんでしょうか、お聞きをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/39", "sentence": ["…の委員であるディック・パウンド氏が、先日こういう発言をされております。菅首相がオリンピック中止を求めても大会は開催される、つまり菅総理には中…", "…ております。菅首相がオリンピック中止を求めても大会は開催される、つまり菅総理には中止をする権限がないんだというふうにおっしゃっているように私…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/41", "sentence": ["○水岡俊一君もう一度お聞きしましょう。ＩＯＣの委員が、菅総理がオリンピック中止を求めてもそんなことは聞き入れられないよと、こういうふうにおっ…", "…ク中止を求めてもそんなことは聞き入れられないよと、こういうふうにおっしゃったというふうに聞いていますが、菅総理はどうお感じになっていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/53", "sentence": ["…きて、命を落とす方々が出てきているという現実じゃないですか。そういう中にあって、子供たちの観戦を進めていくという立場に菅政権はあるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00920210607/64", "sentence": ["…義を否定する、つまり