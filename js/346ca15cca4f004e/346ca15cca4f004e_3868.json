[{"date": "2022-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/55", "sentence": ["…のお話を先ほどいたしましたが、その決議の中で私たちは、プーチン大統領が核使用を前提とするかのような発言をしているのは言語道断である、唯一の被…", "…唯一の被爆国として非難をすると、こういうふうに訴えたところであります。核で脅されている中で、我が国が核の共有を議論するというようなことがもし…", "…、こういうふうに訴えたところであります。核で脅されている中で、我が国が核の共有を議論するというようなことがもしあったらば、私は、ウクライナの…", "…ようなことがもしあったらば、私は、ウクライナの人々に対して、あなた方は核を持っていないから攻め込まれても仕方がないんだというようなことを言わ…", "…を与えるというふうに思えてならないんですね。被爆国の政府として、絶対に核共有の議論をするということのないように強く求めて、私は次の質問に入り…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/79", "sentence": []}]}]}]