[{"date": "2024-06-11", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/26", "sentence": ["…。そして、その中には、動物として特記がしてあるんですね。オオワシ、オジロワシ、知床半島の海岸斜面等にはワシ類の利用できる森林が連続しており、…", "…斜面等にはワシ類の利用できる森林が連続しており、越冬期のオオワシ、オジロワシが常時利用する道内でも最も重要な環境となっている、また、知床半島…", "…が常時利用する道内でも最も重要な環境となっている、また、知床半島はオジロワシが高い密度で営巣、繁殖する重要な繁殖地にもなっているとまで書いて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/28", "sentence": ["…をしている、何の調査をしているかというと、今管理計画書で申し上げたオジロワシ等の調査をしていなかったから、委員会から指摘を受けて今調査をして…", "…僕は大臣の真意がよく分からないんですが、ちょっと問題整理しますね。オジロワシの調査が今進んでいる、そして今お話の中にあった最大の問題点は、大…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314006X01320240611/52", "sent