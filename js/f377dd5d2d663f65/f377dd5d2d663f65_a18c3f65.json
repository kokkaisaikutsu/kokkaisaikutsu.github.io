[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/81", "sentence": ["…それから、もう一点、総理にお伺いしたいと思います。今、党内には二つの財政政策に関する本部が立ち上がりまして、これから、来年の骨太方針だと思い…", "…ります。今総理おっしゃいました、コロナ禍を経まして、大きく世界経済、財政の考え方が変わってきております。一つは、やはり、大規模な財政政策を行…", "…界経済、財政の考え方が変わってきております。一つは、やはり、大規模な財政政策を行って、このコロナ禍から急速に経済を復元していこう、こういう大…", "…ました新しい資本主義というのを実現するためには、やはり、国が積極的に財政で経済を下支えして、民間の皆様の活性、活力を引き出す必要がある。そう…", "…二〇二五年のＰＢ黒字化目標というのは一旦凍結をする、そして、積極的な財政によって経済を拡大して、一気に日本経済を成長軌道、Ｖ字回復させるべき…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/104", "sentence": []}]}]}]