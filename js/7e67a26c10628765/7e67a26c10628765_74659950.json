[{"date": "2023-04-13", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/50", "sentence": ["…ようやく日本でも軟エックス線向けの次世代放射光施設であるナノテラスが整備されたと。ここは高く評価したいと思いますが、文科省に設置された有識者…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/52", "sentence": ["…出てしまっておりますので、ちょっと割愛します。次に、このナノテラスの整備費用は総額で約三百八十億円、そのうち国が二百億円の多額の国費を費やす…", "…思われますが、これらの既存の本法の対象施設の老朽化や高度化に伴う施設整備の計画と、それに伴う費用の見通しについてはどうなっているんでしょうか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00620230413/60", "sentence": []}]}]}]