[{"date": "2023-05-23", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/97", "sentence": ["…いしたいというふうに思います。時間がなくなってきたんですが、ちょっと孔子学院について伺います。三年ほど前にこの委員会でも、自民党の有村治子氏…", "…校に設置されているということであります。これまで、設置されてきて閉鎖された孔子学院というのは日本にあるんでしょうか。その理由は何でしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/101", "sentence": ["…収集、調査では、これ一番最後の質問に行きますが、日本で運営されている孔子学院には全く問題がない、全く問題がないということで文部省の見解、判断…", "…機関じゃないのかとか、そういう疑いが掛けられ、もうこれ閉鎖されている孔子学院が多いわけですね。私も、これだけ問題視されている孔子学院でありま…", "…鎖されている孔子学院が多いわけですね。私も、これだけ問題視されている孔子学院でありますから、そのような組織については今後情報公開を政令や通達…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/103", "sentence": ["○松沢成文君ちょっと質問戻りますけども、この十三校ありましたね、孔子学院、日本に。それで、その中で、この情報公開を要求したら、予算、決算まで…", "…院、日本に。それで、その中で、この情報公開を要求したら、予算、決算まで、お金の動きまで公開している孔子学院というのはどれぐらいあるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01320230523/111", "sentence": []