[{"date": "2021-03-15", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/310", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/318", "sentence": ["…に、今日は澤田社長に来ていただいています。澤田社長、今、ＮＴＴは国の特殊会社という立場です。国が三分の一を株を持ってもらう、しかし、国に監督…", "…ける、それから人事、役員の昇任、解任についてもこうやって指導を受ける。さあ、この特殊会社のメリット、デメリット、ＮＴＴはどう考えていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/320", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/322", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/324", "sentence": ["…沢成文君ソフトバンクはゼロ、ＫＤＤＩは一名ですね。さあ、総理、やはり特殊会社という形で国と密接な関係にある会社はこういう人事でもかなり交流が…", "…社をスイスに移しちゃうような企業も、いまだに三分の一国が株式を抱えて特殊会社にして、たばこ利権を守っているわけです。さあ、菅総理、規制改革、…", "…例踏襲をやらない、そして既得権を打破するというのであれば、この三つの特殊会社を完全民営化していきましょうよ。それぐらい大きな改革に挑戦したら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/326", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/328", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/331", "sentence": []}]}]}]