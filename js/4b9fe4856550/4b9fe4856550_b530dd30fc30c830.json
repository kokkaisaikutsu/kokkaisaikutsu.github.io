んだろうというふうに思っていま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X02120230602/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X02120230602/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X02120230602/142", "sentence": []}]}]}]