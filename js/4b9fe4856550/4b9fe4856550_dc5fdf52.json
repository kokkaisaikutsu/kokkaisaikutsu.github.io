[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/133", "sentence": ["…材を確保するという観点から、弁護士や司法書士等の民間法律実務家からの応募を推進していくということは重要だというふうに考えてはいるんですね。そ…", "…ましたほか、平成三十年以降は願書の受付期間を延長するなどして、何とか応募を広めようという取組を進めてきているところではあります。そして、令和…", "…年七月までの間に、法務省退職者、裁判所退職者以外の方から延べ十九名の応募がありましたが、結果として、先ほど事務的に答弁したように、七名を公証…", "…については多様で有為な人材を確保していきたいと思っているので、民間からの応募についての環境整備には努めていきたいと考えているところなんです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/182", "sentence": []}]}]}]