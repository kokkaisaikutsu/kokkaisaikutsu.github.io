[{"date": "2021-12-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/127", "sentence": ["…では、防衛大臣に伺いますけれども、今回の防衛予算に防衛装備品の安定な納入のための経費四千二百八十七億円というのが入っておりますけれども、これ…", "…経費でありますけれども、じゃ、この補正予算を計上することによって、この納入される時期というのは早まりますか。イエスかノーかでお答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/129", "sentence": ["…ては、早まらないんですよ。今、防衛大臣がお答えになったように、要は、納入の遅延リスクというものを回避するんだということでありますが、コロナ禍…", "…必要はないんじゃないですか。資金繰りを助けてやることが目的であって、納入時期が早まらないのであれば、補正予算に計上することは財政法二十九条に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/177", "sentence": []}]}]}]