[{"date": "2023-02-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/276", "sentence": ["…。そしてまた、北朝鮮のミサイル・核開発。これについても、アメリカとの同盟関係であるがゆえに言ってみれば抑止されているということについても説明…", "…ているということについても説明をしなければいけない。平時にアメリカと同盟関係であることについて、我々は恩恵を受けている。しかし、台湾に対して…", "…、台湾に対してアメリカが肩入れをして、そして結果として、日本が、日米同盟関係の中にある、しかも基地がある、近くにあるということで巻き込まれる…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/290", "sentence": []}]}]}, {"date": "2023-04-04", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105254X01520230404/23", "sentence": ["…理の見解を求めます。戦後、長期政権を担った自民党政治の問題の一つは、同盟国アメリカへの依存を強めることが現実的な防衛政策だと決めつけ、自らの…", "…、下院はどのような勢力構成か。アメリカの世論が日本に対して同情的か。同盟関係に絶対はないと私は考えますが、総理の考え方をお示しください。この…", "…私は考えますが、総理の考え方をお示しください。この防衛三文書は、日米同盟関係の維持強化とともに、自分の国を自分で守る能力を高めることになるの…"]}]}]}]