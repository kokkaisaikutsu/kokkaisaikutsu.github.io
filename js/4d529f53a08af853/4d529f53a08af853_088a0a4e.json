[{"date": "2021-02-26", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/274", "sentence": ["…ら、省エネを評価するグリーン住宅ポイント制度、これは一千九十四億円が計上されております。十年前、私も国交省にいたときにちょうどリーマン・ショ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/290", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/292", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/294", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404376X00720210226/296", "sentence": []}]}]}, {"date": "2021-12-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/127", "sentence": ["…る、こういうものが歳出化経費でありますけれども、じゃ、この補正予算を計上することによって、この納入される時期というのは早まりますか。イエスか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/129", "sentence": ["…うことなら資金繰りの支援をしたらいいわけで、別にこれは補正予算として計上する必要はないんじゃないですか。資金繰りを助けてやることが目的であっ…", "…か。資金繰りを助けてやることが目的であって、納入時期が早まらないのであれば、補正予算に計上することは財政法二十九条に反するんじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/131", "sentence": ["…くないんですね。もう一つお聞きします。普天間飛行場代替施設の建設、八百一億円と計上されていますね。これによって全体の工期は短くなるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/133", "sentence": ["○前原委員要は、工事が早く進んでいるから計上しましたということなんですが、防衛省からあらかじめ聞いておりますけれども、これは今埋め立てている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/177", "sentence": ["…どに四千二百八十七億円、普天間飛行場代替施設の建設に八百一億円などが計上されておりますが、こうした経費は、予算作成後に生じた事由に基づき特に…", "…成後に生じた事由に基づき特に緊要となった経費と言えるのか、当初予算に計上すべきではないかといった疑問が残ります。また、大学ファンドに六千百十…", "…十一億円、先端半導体の生産基盤整備のための基金創設に六千百七十億円が計上されるなど、基金への支出も膨らんでいます。特に後者は、海外の半導体メ…", "…事業関係費、国際分担金及び拠出金への支出など、本来であれば当初予算に計上し、十分な国会審議を尽くして必要性を精査すべき経費があり、我が会派で…", "…我が会派では、歳出の見直しを行い、令和四年度予算編成過程で再検討し、計上すべきと提案しております。以上のように、政府は、我が会派提出の組替え…"]}]}]}]