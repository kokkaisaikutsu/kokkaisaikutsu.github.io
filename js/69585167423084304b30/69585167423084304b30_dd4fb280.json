[{"date": "2021-05-12", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X02120210512/7", "sentence": ["…いる一千二百万円以上の御家庭の全員が恩恵を受けていません。幼児教育、保育の無償化の恩恵も受けられず、待機児童問題の当事者ではない世帯に対し、…", "…臣、お答えください。次に、子ども・子育て支援法の第六十六条の三です。保育所等の運営費に充てるための事業主拠出金ですが、経済界と協議の上、拠出…", "…金の引下げや廃止はあり得るのか、坂本大臣にお伺いをいたします。また、保育所不足の一番の原因は保育士不足で、その原因は給与水準が低いことです。…", "…るのか、坂本大臣にお伺いをいたします。また、保育所不足の一番の原因は保育士不足で、その原因は給与水準が低いことです。また、その原因は委託費の…", "…の私的流用を許してきました。結果として、補助金が多い都市部に進出し、保育士の賃金を抑えることで利益を出すことになり、国が公費を入れることで通…", "…、国が公費を入れることで通知をする公定人件費と実際の年収に、東京では保育士一人に年間二百万円近い差も出ています。坂本大臣の受け止めと是正の必…", "…正の必要性、お答えをください。大臣は、この通知改定によって自治体が各保育園の賃金水準を見る上での参考にでき、通知の金額と実際の金額の差につい…", "…差について説明を求めることができるようになったと言いますが、自治体が保育士の賃金が適正かどうかを判断する監査基準にはしないと強調しています。…", "…坂本大臣に理由をお伺いいたします。本当に少子化対策をするのであれば、保育の質を担保する上での保育士の確保に直結をするこの問題こそ、少子化担当…", "…たします。本当に少子化対策をするのであれば、保育の質を担保する上での保育士の確保に直結をするこの問題こそ、少子化担当大臣がリーダーシップを取…"]}]}, {"meeting_name": "参議院 資源エネルギーに関する調査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414396X00620210512/73", "sentence": []}]}]}, {"date": "2021-05-18", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X01920210518/22", "sentence": ["…ッケージという政策を提案をさせていただいております。それは、基本的に保育費を含めた教育費の負担を減らしていくということと、中学校などの給食の…", "…中から予算を付け回して、新たな予算を取るのではなくて、付け回して今回保育所の対応しているわけなんですが、私は、どちらかと、新たな予算で対応す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01920210518/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01920210518/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01920210518/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01920210518/36", "sentence": []}]}]}, {"date": "2021-05-20", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X02020210520/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02020210520/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02020210520/20",