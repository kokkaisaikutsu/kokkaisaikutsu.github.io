[{"date": "2022-06-02", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/31", "sentence": ["…決定の話ありました、十二月二十一日ですね、昨年の。そこ確認をすると、移管する法律として根拠として挙げられているのが、放課後児童クラブは根拠法…", "…を踏まえて考えれば、これを機会に、文科省からこども家庭庁に子供教室を移管して、両者を福祉もそして教育も併せ持った制度に再編するということも考…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/33", "sentence": ["…ですけれども、児童クラブの所管が厚労省から各省庁より一段高いところに移管されることで何が変わるのだろうかと。これまでも連携してきたにもかかわ…", "…児童クラブと子供教室の例に限らず、既に縦割りが生じている分野の一方が移管された場合、こども家庭庁はその弊害を解消するためにどのような役割を果…", "…家庭庁はその弊害を解消するためにどのような役割を果たしていくのかと。移管されても役所の名前が変わっただけで縦割りは縦割りのまま維持されること…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01920220602/55", "sentence": []}]}]}]