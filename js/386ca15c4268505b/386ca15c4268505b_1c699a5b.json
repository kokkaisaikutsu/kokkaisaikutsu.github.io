[{"date": "2023-03-03", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/34", "sentence": ["…永岡桂子君）お答え申し上げます。今回の訂正の多くは、索引の修正など、検定後の図書の校正として供給前に発行者が適切に行うべき訂正ですとか、また…", "…の図書の校正として供給前に発行者が適切に行うべき訂正ですとか、また、検定合格後の時点修正、先ほどキーウの話がございました。そういうものと承知…", "…うものと承知をしているところでございます。今回、発行者におきまして、検定後の校正が適切になされずにこのような事態になったこと、また、検定手続…", "…て、検定後の校正が適切になされずにこのような事態になったこと、また、検定手続の過程で一部の誤記等を指摘し切れなかったことはこれは大変遺憾であ…", "…て、審査体制を始めといたしまして、検査体制につきまして、検査、あっ、検定制度につきましても不断に改善を図りながら、適切な検定審査に努めてまい…", "…しまして、検査体制につきまして、検査、あっ、検定制度につきましても不断に改善を図りながら、適切な検定審査に努めてまいりたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/355", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00420230303/357", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/59", "senten