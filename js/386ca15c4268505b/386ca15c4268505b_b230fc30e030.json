[{"date": "2023-05-16", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/35", "sentence": ["○国務大臣（永岡桂子君）確かに、昔のゲーム、まだやりたいと時々思うこともございますよね。そのことに関しましては、文部科学省におきまして、これ…", "…しては、文部科学省におきまして、これまでも様々な施策を実施する中で、ゲーム業界の関係者の皆様とも意見交換等を行っております。その中で、例えば…", "…意見交換等を行っております。その中で、例えば、物の保存にとどめずに、ゲームを再現することによりましてその価値が生きるですとか、また過去のゲー…", "…ゲームを再現することによりましてその価値が生きるですとか、また過去のゲームもプレーできた方がよいため、それが実現できることが望ましいといった…", "…もプレーできた方がよいため、それが実現できることが望ましいといった、ゲームのプレーアブル保存、利活用についての御意見などもございました。今後…", "…の御意見などもございました。今後も関係者、関係機関等とも連携を図りながら、ゲームを含めた我が国のメディア芸術の振興、発展に努めてまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01220230516/127", "sente