kai.ndl.go.jp/txt/121115104X01020230427/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/94", "sentence": ["…国務大臣（永岡桂子君）お答え申し上げます。義務教育で使用する教科書の価格については、教科書無償措置法によりまして、これ児童生徒に無償給与を行…", "…教科書を安定的に供給する必要があることなどを勘案いたしまして、適正な価格を維持することが重要であると考えております。このため、前年度の価格を…", "…な価格を維持することが重要であると考えております。このため、前年度の価格をベースにいたしまして、毎年度、ごめんなさい、前年度の定価ですね、定…", "…ございます。今後とも、教科書が持ちます高い公共性を踏まえまして、適正な教科書価格となりますよう、しっかりと努めてまいりたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/116", "sentence": ["○国務大臣（永岡桂子君）教科書を安定的に供給するために、これ適正な価格を設定するということは大変重要だと思っております。そういうことも考えて…", "…おります。そういうことも考えて、今後も、毎年度、物価の変動等も踏まえまして、適正な教科書価格となりますよう努めてまいりたいと思っております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/120", "sentence": ["○国務大臣（永岡桂子君）これまでも、製造コストを価格に反映するために、毎年度の定価をベースに原価の増減状況というものを教科書発行者の損益計算…", "…算書を用いまして分析することで対応してきておりまして、引き続きまして適正なこれ教科書の価格となりますように努めてまいりたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X01020230427/129", "sentence": []}]}]}]