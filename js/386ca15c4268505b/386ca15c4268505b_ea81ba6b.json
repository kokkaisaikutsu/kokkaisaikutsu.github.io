[{"date": "2022-11-18", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015254X00720221118/11", "sentence": ["…定義が一般に定まっていませんが、教職員による不適切な指導等が不登校や自殺のきっかけになる場合もあることから、体罰や不適切な行動等は学校教育に…"]}]}]}, {"date": "2023-03-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/362", "sentence": ["…（永岡桂子君）文部科学省におきましては、昨年十月に閣議決定されました自殺総合対策大綱に基づきまして、命の大切さや尊さを実感できる教育やＳＯＳ…", "…の大切さや尊さを実感できる教育やＳＯＳの出し方に関する教育を含みます自殺予防教育の更なる推進、また、スクールカウンセラー、スクールソーシャル…", "…用いたしました相談体制の整備の推進、また、教職員を対象といたしました自殺予防研修会の実施などの取組を進めているところでございます。また、一人…", "…康観察に末端を活用して児童生徒のメンタルヘルスの変化を把握し、そして自殺等のリスクの早期把握、早期対応に取り組む自治体というのも複数出ている…", "…取組の支援や全国への横展開に取り組んでおります。引き続きまして、児童生徒の命を守るため、学校における自殺予防の取組、全力を挙げてまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/364", "sentence": ["…ので、訂正させていただきたいと思います。文部科学省といたしましては、自殺対策を所管している立場から、ＳＯＳの出し方教育を含みます自殺予防教育…", "…しては、自殺対策を所管している立場から、ＳＯＳの出し方教育を含みます自殺予防教育の推進、また一人一台端末等を活用した自殺のリスクの早期把握な…", "…出し方教育を含みます自殺予防教育の推進、また一人一台端末等を活用した自殺のリスクの早期把握など、学校における児童生徒の自殺対策に取り組んでい…", "…台端末等を活用した自殺のリスクの早期把握など、学校における児童生徒の自殺対策に取り組んでいるというところは今お話し申し上げました。一方で、児…", "…り組んでいるというところは今お話し申し上げました。一方で、児童生徒の自殺の背景というのは学校の問題だけではなくてそれ以外にも、家庭の問題です…", "…とか、また厚生労働省、そして警察庁など関係省庁と連携をいたしまして児童生徒の自殺予防に取り組むことが必要と、そう考えている次第でございます。"]}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00320230309/38", "sentence": []}, {"url": "https://kokkai.ndl.go.