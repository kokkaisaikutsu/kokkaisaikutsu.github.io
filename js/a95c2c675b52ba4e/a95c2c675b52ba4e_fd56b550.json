[{"date": "2023-05-30", "meeting": [{"meeting_name": "参議院 財政金融委員会、外交防衛委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/10", "sentence": ["…の元年予算ということで令和五年の予算を表しております。その中で、建設国債を使われたわけでありますが、これが四千三百四十三億円であります。これ…", "…四千三百四十三億円であります。これ、海上保安庁の巡視船の建造費に建設国債を充てられたということで、それは十分私も承知をしているところでありま…", "…ただいた結果だというふうに思います。じゃ、この四十三兆円の、今回建設国債を一部使われているんですけれども、四十三兆円の防衛予算の財源構成に対…", "…も、四十三兆円の防衛予算の財源構成に対しまして、どのような判断で今回国債を発行するようなことになったのか、基本的な認識を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115372X00120230530/20", "sentence": []}]}]}]