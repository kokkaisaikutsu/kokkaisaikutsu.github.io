[{"date": "2021-04-08", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/11", "sentence": ["…うな対応をされていくのか、さらには、今、先ほど答弁のあったように、外国船舶、外国人が船員が乗船する外国船舶の対応についてはどのように考えてい…", "…は、今、先ほど答弁のあったように、外国船舶、外国人が船員が乗船する外国船舶の対応についてはどのように考えているのか、お伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/13", "sentence": ["…断で入域をさせると聞いております。ただ、その漁具被害があった場合、外国船舶なので、補償、負担で大変、民間同士の話合いになってかなり補償の交渉…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X00920210408/24", "sentence": []}]}]}]