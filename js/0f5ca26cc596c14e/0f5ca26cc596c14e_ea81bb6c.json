[{"date": "2022-03-22", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X00920220322/22", "sentence": ["…本来目指すべき分権社会に向けた税源移譲がなされていないことです。分権自治を進める立場から、税源移譲を始めとする税の分権化が求められていますが…", "…もそも、固定資産税は市町村の基幹税であるにもかかわらず、税収減になる自治体への補填も不十分です。国の一存で決定することのないよう配慮をすべき…", "…院を始めとする公的病院の再編統合を前提とせず、地域医療の確保のための自治体の主体的な取組を十分に尊重するべきです。第六の理由は、森林環境譲与…", "…五四％が使われず、基金に積み立てられていたことが明らかになりました。自治体への配分基準で人口割が三割を占め、森林の少ない都市部が優遇されてい…", "…上で、税源移譲を中心とする地方税財政制度の改革はまだ道半ばです。分権自治の観点で日本社会の構造転換を図ろうという大きな視野での取組を強く求め…"]}]}, {"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00520220322/79", "sentence": []}]}]}, {"date": "2023-04-20", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/117", "sentence": ["…すけれど、私は一定評価をさせていただきたいと思います。もちろん、労使自治の下で賃上げ等の処遇については協議を図っていただくのは当然であります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/127", "sentence": []}]}]}]