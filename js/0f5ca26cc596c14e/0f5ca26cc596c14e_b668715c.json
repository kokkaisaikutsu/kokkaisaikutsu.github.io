[{"date": "2021-04-09", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/46", "sentence": ["○小沢雅仁君立憲民主・社民の小沢雅仁でございます。お忙しい中、梶山経産大臣にお越しいただきました。後ほど原発処理水についてお伺いをしたいと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/54", "sentence": ["…いというふうに思っているところでございます。さて、原発処理水について梶山経産大臣にお伺いをしたいというふうに思います。一番最初に森まさこ委員…", "…受けましたけれど、まさしくこの言葉のとおりだと思っております。まず、梶山大臣にお伺いをしたいんですが、一昨日、全漁連の岸会長と総理が、菅総理…", "…っていたというふうに思いますが、是非、同席されておりましたので、具体的にどのようなやり取りがあったのかを梶山大臣にお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414858X00420210409/70", "sentence": []}]}]}]