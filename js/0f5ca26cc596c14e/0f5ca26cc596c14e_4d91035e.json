[{"date": "2022-03-15", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/26", "sentence": ["…算委員会でも我が党の岸真紀子議員が、このＡＬＰＳ処理水のチラシ、学校配布のチラシについて取上げをさせていただきました。この配布の経緯と目的に…", "…のＡＬＰＳ処理水のチラシ、学校配布のチラシについて取上げをさせていただきました。この配布の経緯と目的について経産省にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/28", "sentence": ["…題があったんではないかなと思っています。岩手県宮古市の教育委員会は、配布済みの二校を除く小中学校に保管を指示をしたと。水産業が基幹産業であり…", "…要と判断したというコメントを出しています。また、釜石、大船渡両市も、配布済みを除いて学校に保管を指示。宮城県の教育長は、一律回収は考えていな…", "…を指示。宮城県の教育長は、一律回収は考えていないとしつつ、直接学校に配布され、現場に混乱を招いたことは問題だと指摘。福島県いわき市教育委員会…", "…ずれにしましても、経産省にお伺いをしたいんですが、教育委員会を、この配布についてですね、教育委員会を経由させなかった理由、それと、今申し上げ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00320220315/47", "sentence": []}]}]}]