[{"date": "2023-03-30", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/101", "sentence": ["○小沢雅仁君立憲民主・社民の小沢雅仁でございます。総務省を始め、稲葉会長、ＮＨＫの皆さん、どうぞよろしくお願いしたいと思います。まず、ＮＨＫ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/113", "sentence": ["…、それぞれ会議録も拝見をさせていただいたところでございます。そこで、稲葉会長にお伺いをしたいというふうに思いますが、その会議録の中で会長が使…", "…この改革を一定程度検証をされるということでありますけれど、この改革の検証と発展の具体的な考え方について、稲葉会長にお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/119", "sentence": ["…さんにひとしく公平に意見を吸い上げるとか聞いていただくような取組も併せてお願いをさせていただきたいと思いますが、稲葉会長、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/121", "sentence": ["…が、改めてお伺いしたいと思いますが、子会社にいわゆる天下りをさせないというこの方針は今後も堅持されるのか、稲葉会長にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/127", "sentence": ["…うに思います。是非、職員の命と健康を守るという経営責任をしっかりと果たしていただくため、稲葉会長のお受け止めと決意をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/246", "sentence": []}]}]}, {"date": "2023-06-13", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/9", "sentence": ["…手続に対して質疑を行いたいと思います。経営委員会の森下委員長、また、稲葉会長始め理事の皆さん、お越しいただきましてありがとうございます。早速…", "…だいた上で質問させていただきたいと思います。まず、今回の問題に対する稲葉会長の御見解を伺いたいというふうに思いますが、国民・視聴者の受信料か…", "…の費用を一部の役員のみの稟議書をもって執行しようとしたことについて、稲葉会長がどのように受け止められているのか、まずお伺いをしたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/19", "sentence": ["…は該当しなかったという認識なのか、理事会に諮らず一部役員の稟議だけで当該支出を決定をした理由について、稲葉会長からお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/23", "sentence": ["…ありますけれど、稟議書どおりの内容で予算が執行された場合、これは放送法に抵触したという認識はございますか。稲葉会長にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/31", "sentence": ["…問題について、関係者の責任の明確化と処分をどのように考えているのか、稲葉会長と、その見解を受けて森下経営委員長から、それぞれお受け止めをお伺…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/34", "sentence": ["…革を行うとしておりますが、いつまでに取りまとめられて国会又は私たち、国会や関係者に御報告をいただけるのか、稲葉会長にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01320230613/36", "sentence": ["…ところが一番だというふうに思います。是非真剣に受け止めていただいて、稲葉会長が先頭に立って理事会で実行していただくことを強く御要請申し上げま…"]}]}]}]