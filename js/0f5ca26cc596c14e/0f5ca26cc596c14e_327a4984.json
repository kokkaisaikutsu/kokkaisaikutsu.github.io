[{"date": "2023-03-30", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/101", "sentence": ["○小沢雅仁君立憲民主・社民の小沢雅仁でございます。総務省を始め、稲葉会長、ＮＨＫの皆さん、どうぞよろしくお願いしたいと思います。まず、ＮＨＫ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/113", "sentence": ["…、それぞれ会議録も拝見をさせていただいたところでございます。そこで、稲葉会長にお伺いをしたいというふうに思いますが、その会議録の中で会長が使…", "…この改革を一定程度検証をされるということでありますけれど、この改革の検証と発展の具体的な考え方について、稲葉会長にお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/119", "sentence": ["…さんにひとしく公平に意見を吸い上げるとか聞いていただくような取組も併せてお願いをさせていただきたいと思いますが、稲葉会長、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/121", "sentence": ["…が、改めてお伺いしたいと思いますが、子会社にいわゆる天下りをさせないというこの方針は今後も堅持されるのか、稲葉会長にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/127", "sentence": ["…うに思います。是非、職員の命と健康を守るという経営責任をしっかりと果たしていただくため、稲葉会長のお受け止めと決意をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00820230330/246", "sentence": []}]}]}]