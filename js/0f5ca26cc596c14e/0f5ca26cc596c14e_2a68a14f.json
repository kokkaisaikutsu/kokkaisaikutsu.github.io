[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/9", "sentence": ["…四日で丸五年を迎えました。その当日の新聞各社の評価は、「郵政失態続き株価低迷」、「期待を裏切った上場郵政の五年間」など、私にとっては憤りの見…", "…の株式売却について財務省にお伺いをしたいと思います。昨日の日本郵政の株価は八百六円、ゆうちょ銀行は八百八十八円、かんぽ生命は千八百円です。こ…", "…ちょ銀行は八百八十八円、かんぽ生命は千八百円です。この間の不祥事等で株価は大きく毀損し、日本郵政がゆうちょ銀行株式の約三兆円の減損損失を余儀…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/11", "sentence": ["…仁君ありがとうございます。残りの一・三兆円を確保するには、日本郵政の株価が千百三十円程度になる必要があると報じられております。この株価の観点…", "…郵政の株価が千百三十円程度になる必要があると報じられております。この株価の観点からも、日本郵政グループの信頼回復が急務であるということを強く…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/49", "sentence": []}]}]}]