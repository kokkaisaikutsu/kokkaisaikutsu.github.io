[{"date": "2022-04-13", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/230", "sentence": ["…十四日に陸上幕僚監部が総括文書管理者に第一報を行った際に用いられた、行政文書の情報公開請求に係る対応についてという資料にある「陸幕監理部とし…", "…求に係る対応についてという資料にある「陸幕監理部としての対応」には「行政文書を誤廃棄したものとして処置」と記載されております。修正前の資料に…", "…ります。修正前の資料については、陸上幕僚監部が、保存期間が一年未満の行政文書として認識して、既に廃棄しておりました。このため、令和三年七月二…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00920220413/246", "sentence": ["○鬼木副大臣そのとき使われた文書は、実際に使われた行政資料ですので、修正せず、そのまま存在しております。"]}]}]}]