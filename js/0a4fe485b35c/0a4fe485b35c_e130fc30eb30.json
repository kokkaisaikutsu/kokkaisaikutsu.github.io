[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/233", "sentence": ["…書によりますと、総務省は、令和三年、二〇二一年八月に国交省から新たなメールを受け取りました。資料一を御覧をいただきたいと思います。まず資料を…", "…下に説明書きがあります。新聞記者からの取材を受けたので相談したい旨のメールでした。この中には、ダブルカウント、つまり二重計上を指す文言もあり…", "…す文言もありました。資料二を御覧いただきたいと思います。これは、そのメールに添付されました、国交省が作成した会計検査院調査に国交省がどう対応…", "…身は見えません。総務省は淡々と対応すればいいと返事を返していたようです。金子大臣、この二〇二一年の八月の国交省のメールの実物、見ていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00220220308/244", "sentence": []}]}]}, {"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/333", "sentence": ["…どが書かれた、これマスキングが掛けられていて読めないものですが、このメールですね、二〇二一年八月、国交省から総務省へのメールについて、金子大…", "…いものですが、このメールですね、二〇二一年八月、国交省から総務省へのメールについて、金子大臣は八日の当委員会において実物を見ていないと答弁を…", "…日の当委員会において実物を見ていないと答弁をされました。しかし、このメールは非常に重要なものだと思うんです。国交省が会計検査院の調査にどう対…", "…たのか、それに対して総務省がどのように対応しようとしていたのか。このメールの全容が分からなければ、明らかにならずしては、国交省が書換え、合算…", "…その国交省の不正隠しの真相が究明できるわけがないからであります。大臣、二〇二一年八月の国交省からのメール、その後、メールの実物は見ましたか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/335", "sentence": ["○伊藤岳君今大臣も言われましたけど、二重計上という言葉があるメールだというのは分かっているわけですよね。これ、なぜ大臣見ないのか、よく分から…", "…んだから、検証委員会の後かどうとかじゃなくて、直ちに見るような重要なメールだと思いますよ。前回の委員会でも、大臣はタスクフォースの検証の中立…", "…たり前じゃないでしょうか。そして、統計不正の再発防止のためにも、これメール確認することが当たり前じゃないかと思うんです。メール見ずして、大臣…", "…、統計不正の再発防止のためにも、これメール確認することが当たり前じゃないかと思うんです。メール見ずして、大臣、どのように責任果たすんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/337", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/339", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/344", "sentence": ["○伊藤岳君まあ、なぜその重大なメールの実物をいまだに見ようとしないのか、私は分かりません。しかし、総務省の中にはこのメールの全文を読んでいる…", "…だに見ようとしないのか、私は分かりません。しかし、総務省の中にはこのメールの全文を読んでいる方はいますよね。総務省の中にいる、どういう地位に…", "…はこのメールの全文を読んでいる方はいますよね。総務省の中にいる、どういう地位にある方の誰と誰がメールの全文を読んだんですか。教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/346", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/348", "sentence": ["○伊藤岳君審議官が読んでいないって、私、信じられませんね。じゃ、メールを最初に受け取った統計委員会の担当者とは、どういう地位にある方ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/350", "sentence": ["○伊藤岳君課長級未満の職員がメールを最初に受け取った。そうなると、その受け取った課長級以下の職員は統計委員会室の上司に報告したと思いますが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/352", "sentence": ["○伊藤岳君メールを最初に受け取った職員が課長級の職員に報告をしたと。政策統括官はメールの実物見ていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/354", "sentence": ["○伊藤岳君じゃ、そのメールを最初に受け取った職員、そして上司である課長、このメールの実物を見た方は、大臣に対して、メールの実物を見る必要があ…", "…君じゃ、そのメールを最初に受け取った職員、そして上司である課長、このメールの実物を見た方は、大臣に対して、メールの実物を見る必要があるという…", "…員、そして上司である課長、このメールの実物を見た方は、大臣に対して、メールの実物を見る必要があるということを進言しなかったんですか、重大なメ…", "…る課長、このメールの実物を見た方は、大臣に対して、メールの実物を見る必要があるということを進言しなかったんですか、重大なメールの中身を見て。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/356", "sentence": ["…の必要がどこにあるのかと私は思います。先ほど来言いましたように、このメールの実物、全容が明らかにならなければ、二重計上という公的統計の不正を…", "…思うんです。八日の当委員会で、二〇二一年八月の国交省から総務省に来たメールについて、マスキングを掛けることを総務省の事務方が助言をしたとの答…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/358", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/360", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/362", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/364", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/366", "sentence": ["…、もうやっぱりこのマスキング掛けているような状況じゃ何も明らかになりません。大臣、メールの実物の公表を指示していただけませんか。どうですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/368", "sentence": ["…ょっとお願いですが、当委員会に、二〇二一年八月の国交省から総務省へのメールの実物の提出を求めていただきたい。お取り計りをいただきたいと思うん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/370", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/372", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/374", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/376", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/378", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/380", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/383", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/385", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/387", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/389", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/391", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/393", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/395", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/397", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/399", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/401", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/403", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/405", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/407", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/409", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00420220316/411", "sentence": []}]}]}, {"date": "2022-03-22", "meet