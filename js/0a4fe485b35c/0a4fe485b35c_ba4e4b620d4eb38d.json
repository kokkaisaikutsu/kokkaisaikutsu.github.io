[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/214", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/224", "sentence": ["…四日以内に送達に緩和します。総務省は、この改正案の背景に郵便事業の人手不足は深刻化していることがあるとしています。離職者も多く、有効求人倍率…", "…倍率も二〇一九年度が三・八〇倍、年度平均が一・五五倍で、二倍以上の人手不足になっているとしています。郵政職場にとって大事なことは、労働者を大…", "…していくことです。そのためには、給料を上げて、労働条件を改善して、人手不足も解消して、働きがいのある、先ほど増田社長も言われた幸せを感じられ…", "…だと思います。武田総務大臣にお聞きします。今回の法改正は、労働者の賃金や労働時間の改善、人手不足の解消につながるのでしょうか。いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/226", "sentence": ["…分業務が不要になる、こうしたことを通じて労働環境の改善につながる、人手不足の改善につながるという話がありました。衣川社長にお聞きします。今回…", "…ました。衣川社長にお聞きします。今回の法改正によって、労働者の賃金、労働時間の改善、人手不足の解消を具体的にはどのように行っていくんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/2