[{"date": "2021-03-12", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X00920210312/19", "sentence": ["…ないことも明るみに出てきました。総務大臣、副大臣、政務官の任にあった政治家が、在任中あるいは退任後に頻繁にＮＴＴからの接待を受けていたと報じ…", "…後に頻繁にＮＴＴからの接待を受けていたと報じられました。指摘を受けた政治家から、会食した事実、ＮＴＴ側に費用を負担してもらっていた事実を認め…"]}]}]}, {"date": "2021-03-26", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X01120210326/33", "sentence": ["…れても仕方ないではありませんか。さらに、ＮＴＴによる総務省幹部官僚、政治家への接待問題です。情報通信事業に対する認可権限などに関わる総務省の…", "…な接待が繰り返され、さらには、総務大臣を始め副大臣、政務官など多数の政治家がその在任中にもＮＴＴから高額接待を受けていた事実も明らかになりま…"]}]}, {"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X00820210326/55", "sentence": []}]}]}]