[{"date": "2022-04-14", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/79", "sentence": ["…を統計委員会評価分科会に承認されたかのように装うための国交省が企てた作戦だったということであります。金子大臣、本件合算処理を評価分科会に参考…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/91", "sentence": ["…ように、結果的には、国交省は資料を配付して、説明も許されて、国交省の作戦成功しちゃったんですよ、たくらみが。国交省のたくらみに総務省はまんま…", "…聞きます。合算処理が行われていることを統計委員会評価分科会に承認されたかのように装った国交省のこの極めてあくどい作戦、たくらみ、許せますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00720220414/98", "sentence": []}]}]}]