[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/167", "sentence": ["…杉田政務官は、政務官就任後の十月二十日、東京高裁において、ツイッター上での名誉毀損で有罪判決を受けられました。政務官、上告はされるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/173", "sentence": ["…関係ガイドラインは、法改正後随時更新をされています。杉田政務官の高裁判決では、事実認定として、積極的に名誉感情を害する意図でいいねを押してお…", "…り、限度を超えた侮辱行為で不法行為に当たるとされています。大臣、この判決が確定すれば、その判決が個票としてこのガイドラインに示されることにな…", "…為で不法行為に当たるとされています。大臣、この判決が確定すれば、その判決が個票としてこのガイドラインに示されることになります。総務行政に関す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/175", "sentence": ["…民の信頼はそれこそ一瞬にして消えてなくなるんではないかと思います。大臣、そう考えませんか。有罪判決が確定している、有罪判決が出ているんです。", "…民の信頼はそれこそ一瞬にして消えてなくなるんではないかと思います。大臣、そう考えませんか。有罪判決が確定している、有罪判決が出ているんです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/177", "sentence": ["○伊藤岳君高裁判決で事実認定が裁定されています。政務官の任命は八月でしたが、その後、十月二十日に高裁判決を受けた。人権侵害の加害者が総務行政…", "…定されています。政務官の任命は八月でしたが、その後、十月二十日に高裁判決を受けた。人権侵害の加害者が総務行政を担う政務官の職にあって国民の信…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/197", "sentence": []}