[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/153", "sentence": ["…思います。今日は資料をお配りいたしました。御覧ください。配偶者からの暴力の防止及び被害者の保護等に関する法律、いわゆるＤＶ法ですが、この前文…", "…れております。下線を引いてきました部分ですね。ところが、配偶者からの暴力は、犯罪となる行為をも含む重大な人権侵害であるにもかかわらず、被害者…", "…、被害者の救済が必ずしも十分に行われてこなかった。また、配偶者からの暴力の被害者は、多くの場合女性であり、経済的自立が困難である女性に対して…", "…は、多くの場合女性であり、経済的自立が困難である女性に対して配偶者が暴力を加えることは、個人の尊厳を害し、男女平等の実現の妨げになっている。…", "…状況を改善し、人権の擁護と男女平等の実現を図るためには、配偶者からの暴力を防止し、被害者を保護するための施策を講じることが必要である。この前…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/180", "sentence": []}]}]}]