[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/214", "sentence": ["○伊藤岳君日本郵政増田社長に聞きます。日本郵政グループの現職の方の自死者数について報告を受けていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/216", "sentence": ["…強い指示もありましたという社長への直々の訴えもあったじゃないですか。増田社長、ノルマ必達主義の在り方が日本郵政グループ全体に問われています。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/222", "sentence": ["…を伝えてきた幹部や管理職への厳しい処分は皆無に等しいじゃないですか。増田社長、あなたは社内向け雑誌、郵政十月号にメッセージを寄せられて、こう…", "…と何も変わっていない、今度こそ社員を大切にする会社に変わってほしいと訴えている。この願いを真摯に受け止めてほしい。増田社長、どう思いますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/224", "sentence": ["○伊藤岳君今の、増田社長は、かんぽ不正問題とさいたま新都心の自死事件の関連も言われました。先ほど、面会はされるというお話がありましたけれども…", "…げて、労働条件を改善して、人手不足も解消して、働きがいのある、先ほど増田社長も言われた幸せを感じられる展望ある職場づくりを進めることだと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00420201126/234", "sentence": []}, {"