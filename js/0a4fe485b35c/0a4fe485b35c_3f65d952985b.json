[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/167", "sentence": ["○伊藤岳君日本共産党の伊藤岳です。まず、杉田政務官に関する問題について聞きます。杉田政務官は、政務官就任後の十月二十日、東京高裁において、ツ…", "…産党の伊藤岳です。まず、杉田政務官に関する問題について聞きます。杉田政務官は、政務官就任後の十月二十日、東京高裁において、ツイッター上での名…", "…岳です。まず、杉田政務官に関する問題について聞きます。杉田政務官は、政務官就任後の十月二十日、東京高裁において、ツイッター上での名誉毀損で有…", "…杉田政務官は、政務官就任後の十月二十日、東京高裁において、ツイッター上での名誉毀損で有罪判決を受けられました。政務官、上告はされるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/169", "sentence": ["○伊藤岳君寺田大臣にお聞きします。杉田政務官は政務官の任に値するのでしょうか。インターネット上の悪質、不当な情報流布による人権侵害と被害者救…", "○伊藤岳君寺田大臣にお聞きします。杉田政務官は政務官の任に値するのでしょうか。インターネット上の悪質、不当な情報流布による人権侵害と被害者救…", "…な情報流布による人権侵害と被害者救済を重要施策として進めていく総務省政務官としてふさわしいのか。大臣、冷静に客観的に判断すべきではないかと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/171", "sentence": ["○伊藤岳君政務官の職責を果たしていただくようと言われますけれども、昨年の通常国会で改正プロバイダー責任制限法が成立して、総務省のインターネッ…", "…組を強化するとうたわれているんです。大臣、この施策を推進する総務省の政務官として杉田氏が適任だと思われますか。総務省の施策と矛盾することにな…", "…が適任だと思われますか。総務省の施策と矛盾することになるのではないですか。政務官を辞めさせるべきではないか。大臣の認識を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/173", "sentence": ["…、責任制限法関係ガイドラインは、法改正後随時更新をされています。杉田政務官の高裁判決では、事実認定として、積極的に名誉感情を害する意図でいい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/177", "sentence": ["○伊藤岳君高裁判決で事実認定が裁定されています。政務官の任命は八月でしたが、その後、十月二十日に高裁判決を受けた。人権侵害の加害者が総務行政…", "…の後、十月二十日に高裁判決を受けた。人権侵害の加害者が総務行政を担う政務官の職にあって国民の信頼と納得が得られるのか。私、これ冷静に、本当に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/179", "sentence": ["○伊藤岳君大臣、適任かどうか聞いているんです、政務官として。総務行政の推進に当たる政務官として適任ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/181", "sentence": ["○伊藤岳君適任かどうか、答えられませんね。杉田政務官は、政策パッケージに盛り込まれたＳＮＳ誹謗中傷対策キャンペーン、「ＮｏＨｅａｒｔＮｏＳＮ…", "…ＳＮＳ」について存じ上げませんと答弁されましたが、私は、そもそも杉田政務官は総務行政に対してノーハートなんではないかと思います。あなたには政…", "…務官は総務行政に対してノーハートなんではないかと思います。あなたには政務官務まりません。即刻辞めていただくべきだと私は思う。大臣、総理に対し…", "…りません。即刻辞めていただくべきだと私は思う。大臣、総理に対して杉田政務官の即刻辞任を求めるべきだというふうに強く言いたいと思います。続いて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00220221101/222", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/149", "sentence": []}, {"url": "https://kokkai.