[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/81", "sentence": ["…こととされています。郵便局長の発掘、育成スキームとしては、部会長及び地区会長は、提出された後継者候補者をそれぞれ人物調査及び面接を実施し、部…", "…提出された後継者候補者をそれぞれ人物調査及び面接を実施し、部会推薦、地区会推薦を総合判断する、配偶者がいる場合は配偶者も同席させて面接を実施…", "…実施し、本人及び配偶者が共に制度への理解と協力をする意思があること、地区会推薦を得た後継候補者は次の育成、後継者育成プロセスへ移行するなどと…", "…目の十行ぐらいからこう書かれています。まず妻も同席して面接に臨んだ。地区会長の局長は、奥さんにも選挙に協力してもらわないといけないと説明し、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X01120220607/100", "sentence": []}]}]}]