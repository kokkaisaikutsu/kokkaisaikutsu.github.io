[{"date": "2020-11-24", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/127", "sentence": ["…拡大の中で、学生や社会的弱者の生活を支えるライフラインである携帯電話の料金についてお聞きします。今、学生はリモート授業が続いていて、携帯料金…", "…話の料金についてお聞きします。今、学生はリモート授業が続いていて、携帯料金の負担がかさんでいます。学生が利用している携帯料金プランは一般的に…", "…業が続いていて、携帯料金の負担がかさんでいます。学生が利用している携帯料金プランは一般的には二ギガバイト等の低容量プランで、リモート授業によ…", "…ありますが、月々三千円以上、年間にすると四、五万円にもなるＷｉＦｉ使用料が掛かります。また、ＷｉＦｉ環境がない場合には、通信容量制限をオーバ…", "…Ｆｉ環境がない場合には、通信容量制限をオーバーしたギガの追加など、携帯料金は自己負担となります。こうした中で、毎日一食しか食べていないという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/131", "sentence": ["…者団体に対して、三月十九日に、新型コロナウイルス感染症の影響拡大に伴う料金支払延長等の実施に係る要請も発出しました。局長、この要請に基づいて…", "…ス感染症の影響拡大に伴う料金支払延長等の実施に係る要請も発出しました。局長、この要請に基づいて料金支払猶予を受けた実績件数を示してください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/133", "sentence": ["○伊藤岳君学生、社会的弱者を含むこれだけ多くの方が料金支払猶予を受けたということになります。しかし、その対応も既に終了しています。大臣と携帯…", "…既に終了しています。大臣と携帯電話利用者との意見交換会においても、携帯料金を支払えず携帯電話を手放すと、仕事探しもできず、生活基盤が脅かされ…", "…はならないと思います。大臣の認識はどうですか。猶予が終わって数か月分の料金支払が今迫られる方々についても関心を払う必要があるんではないでしょ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/141", "sentence": ["○伊藤岳君じゃ、お聞きしますが、デジタル・ガバメント閣僚会議などの資料等を見ますと、マイナンバーカードの紛失、盗難に対して検討したという資料…", "…料等を見ますと、マイナンバーカードの紛失、盗難に対して検討したという資料は見付かりませんでしたが、デジガバ閣僚会議では検討されているんですか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314601X00320201124/149", "sentence": []}]}]}, {"date": "2022-03-16"