[{"date": "2024-05-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/17", "sentence": ["…来生物に指定をされて、地球上最悪の侵略植物と言われておりますナガエツルノゲイトウであります。先生方のお手元にも資料をちょっとお配りをいただい…", "…力はもちろんなんですけれども、費用も相当掛かるということで、ナガエツルノゲイトウが繁殖をしております土地改良区さんはもう本当に苦労をしている…", "…非常に大変でした。少なからずそれを実感したわけでありますけれども、このナガエツルノゲイトウの分布状況について環境省にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/19", "sentence": ["…の取組についても触れていただいたわけでありますけれども、このナガエツルノゲイトウの対策、それから、これはやっぱり処理について相当費用も掛かる…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/22", "sentence": ["…ますので、是非よろしくお願いしたいと思います。電気料金もこのナガエツルノゲイトウも別に改良区が何かやったから悪いということではない、土地改良…", "…いという、費用が掛かってしまうということであります。例えば、ナガエツルノゲイトウなんかでは、多面でも取り組めるわけでありますし、やっていただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315007X01020240516/39", "sentence": []}]}]}]