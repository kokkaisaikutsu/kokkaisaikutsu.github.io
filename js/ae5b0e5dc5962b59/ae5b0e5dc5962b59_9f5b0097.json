[{"date": "2022-03-30", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/104", "sentence": ["…うに考えておるところでございます。このため、農林水産省では、生産者や実需者が参画する協議会で、どのような作目を、いつ、誰が、どのぐらい作るか…", "…すとか、個々の農業者の生産出荷計画をオンライン上で共有をいたしまして実需者と結びつけるマッチングサイトの構築をこれまで支援をしたところでござ…", "…うに、これまでのこういった取組でございますとか、有機農業に関わる生産者や実需者の御意向も踏まえながら、取組を進めていきたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/120", "sentence": []}]}]}]