[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/25", "sentence": ["…たな法規制が必要ということも考えられますが、そもそも観光船における安全対策、例えば監査や運航管理の規程、船体の検査、無線などの連絡体制等、こ…", "…理の規程、船体の検査、無線などの連絡体制等、これまでの観光船に対してどのような安全対策を取っていらっしゃるのか、お伺いいたしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/29", "sentence": ["○酒井庸行君今のお答えによると、いろんな安全対策を含めた改善の報告も受けて指導をしたということであります。にもかかわらずということは、こうい…", "…因の究明というのをしっかりと解明をすることはもちろんでありますし、安全対策ももちろんということであります。それから、船体の引揚げの話も出てき…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/41", "sentence": []}]}]}]