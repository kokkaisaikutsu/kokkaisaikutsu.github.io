[{"date": "2022-04-26", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/9", "sentence": ["…て、水なんですよ、まず。それから、二つ目は何かというと、あるとき、子供たちを呼んで自分の田んぼで田植をさせました。それで、もう約三十人ぐらい…", "…ん、やっさん、分からぬのだけど、多分こういうことだろうと。それだけ子供たちが中に、田んぼの中に入ってぐちゃぐちゃにしたわけ、ぐちゃぐちゃに。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01220220426/19", "sentence": []}]}]}]