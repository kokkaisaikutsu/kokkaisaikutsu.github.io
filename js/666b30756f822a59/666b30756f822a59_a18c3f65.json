[{"date": "2021-06-11", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/17", "sentence": ["…、政策評価審議会の提言を踏まえて取り組んでまいります。最後に、地方税財政の充実について御質問をいただきました。新型コロナ感染症の影響により、…", "…て御質問をいただきました。新型コロナ感染症の影響により、極めて厳しい財政状況の中にあって、地方団体は感染症対策や活力ある地域社会の実現に向け…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/26", "sentence": ["…効果が改めて確認されました。また、議員からお話ありました都道府県への財政措置については、現行の市町村に対する普通交付税措置を見直し、令和三年…", "…対する普通交付税措置を見直し、令和三年度からは、都道府県又は市町村の財政負担に対して特別交付税措置を講ずる等の対応を行うこととしております。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415254X03020210611/45", "sentence": []}]}]}]