[{"date": "2022-03-29", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/26", "sentence": ["…て認識したと思います。私は、例えば他の外国のＣＮＮやＢＢＣや様々なチャンネルが取り組んでいるように、ＮＨＫも例えば二十四時間の報道ニュースチ…", "…ネルが取り組んでいるように、ＮＨＫも例えば二十四時間の報道ニュースチャンネルを設けるというような取組など、報道の充実をもっともっと図っていく…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/30", "sentence": ["…おける情報発信の現実だと思います。私、ＮＨＫワールドについても必ずチャンネルを探すようにはしているんですけれども、残念ながら、多くが大分後ろ…", "…すようにはしているんですけれども、残念ながら、多くが大分後ろの方のチャンネルであるというのも現実です。それから、ＮＨＫワールドをつけてもニュ…", "…とか、これを英語で流している、これはあるんですけれども、ずっと他のチャンネルのようにニュースをどんどんどんどん流しているというものではない。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814601X00620220329/48", "sentence": []}]}]}]