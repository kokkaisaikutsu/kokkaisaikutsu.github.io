[{"date": "2023-05-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/28", "sentence": ["…またモニタリング検査で食品衛生法違反が確定した段階で既に流通、販売、全量消費されてしまっていて、主に、これ四ページ目、四枚目の資料を御覧いた…", "…した日になるんですけれども、このときには、措置状況を御覧いただくと、全量消費済み。中には、残留農薬違反、基準値の十倍を超えている違反というも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/30", "sentence": ["○徳永エリ君回収ということですけど、これもう全量消費済みということでありますし、その違反が分かった段階で回収できたことって過去にあるんですか…", "…全量消費済みということでありますし、その違反が分かった段階で回収できたことって過去にあるんですか、これ全部、全量消費済みになっていますけど。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00920230516/44", "sentence": []}]}]}]