[{"date": "2021-03-16", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/21", "sentence": ["…た家屋の解体の進捗状況といつまでに完了するのかということ、つまり避難指示解除の目標はいつなのか、お伺いしたいと思います。また、拠点区域は、帰…", "…、僅か八％と聞いております。拠点区域以外の帰還困難区域について、今後、除染や避難指示解除はどうするのかも併せてお答えいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/23", "sentence": ["…む、そんなところなんだと思います。非居住区域だからといって、また避難指示解除を急ぐ余りに除染をしないというのは、私は理解ができないんですね。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00220210316/49", "sentence": []}]}]}]