[{"date": "2020-11-19", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/34", "sentence": ["…に関しましては、太陽光、風力の発電量は常に変化しているという非常に不安定な状態で、その需給のバランスを調整して安定供給をしているという役割が…", "…変化しているという非常に不安定な状態で、その需給のバランスを調整して安定供給をしているという役割があります。北海道、私の地元も泊原発が止まっ…", "…ことも検討していただきたいと思いますし、それから、関係労働者の雇用の安定とか地域経済への影響とか、そういったこともしっかり考えていただいて、…", "…しゃる方もおられます。これまで再生可能エネルギーは発電コストや電力の安定供給という課題が掲げられておりました。しかし、この十年でこの分野、相…", "…れているんですね。風力も三分の一、蓄電池の値段も五分の一になったと。安定供給に支障を来すという問題も、いずれイノベーションで解決されるんだと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/52", "sentence": []}]}]}]