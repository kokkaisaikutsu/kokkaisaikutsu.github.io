[{"date": "2021-05-07", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X02020210507/6", "sentence": ["…心で、再エネ事業など担当する部署も専門家もおりません。ですから、策定義務のない市町村の地方公共団体実行計画の策定率は僅か約二五％にとどまって…", "…どういうメンバーかということが大変に重要です。法案では、協議会の設定義務もなく、また、住民その他利害関係者の意見も、反映されるために必要な措…", "…エネルギー庁作成の事業計画策定ガイドラインには、推奨される事項、努力義務ではありますが、環境保全、景観保全の観点から適切な土地の選定を行うこ…", "…境アセスメントの規模要件の緩和を年度内にやるように求められ、環境省は義務付けの対象となる出力規模の要件を一万キロワット以上から五万キロワット…", "…を決めました。そもそも、環境アセスメント制度については、必ずしも報告義務のない事後調査の結果や状況を確認して見直しを行おう、もっと厳しくした…"]}]}, {"meeting_name": "参議院 地方創生及び消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415328X00820210507/85", "sentence": []}]}]}]