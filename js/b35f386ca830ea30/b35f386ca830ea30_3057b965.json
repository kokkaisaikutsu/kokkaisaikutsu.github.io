[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/36", "sentence": ["…、警察庁生活安全局保安課長から各都道府県警察の長、各府県機関の長、各地方機関の長に、そして環境省からも各都道府県鳥獣行政担当部局長に通知が出…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/44", "sentence": []}]}]}, {"date": "2022-11-30", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/401", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/403", "sentence": ["○徳永エリ君やはり政策決定に影響があるんじゃないかとか、あるいは地方の条例、こういったところにも何か影響があってはならないと。これなかなか確…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/405", "sentence": ["○徳永エリ君ただ、自民党のガバナンスコードには地方議員のことは書かれていませんよね。統一教会の機関紙、世界日報は、全国の地方議会で、旧統一教…", "…員のことは書かれていませんよね。統一教会の機関紙、世界日報は、全国の地方議会で、旧統一教会と地方議員らとの関係の断絶や調査、追及を求める意見…", "…んよね。統一教会の機関紙、世界日報は、全国の地方議会で、旧統一教会と地方議員らとの関係の断絶や調査、追及を求める意見書が自民党議員らの反対多…", "…針、ガバナンスコードに新たに盛り込んだ、組織、団体との責任ある関係を地方に徹底することは容易ではなさそうだというふうに報じているんですよね。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/407", "sentence": ["○徳永エリ君ガバナンスコードにこの地方議員も追加するというお考えもありますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/409", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/412", "sentence": ["…エリ君まあ伝えているということでございますけれども、だったらどうして地方議会で自民党の地方議員が意見書を否決するんでしょうか。この否決するこ…", "…るということでございますけれども、だったらどうして地方議会で自民党の地方議員が意見書を否決するんでしょうか。この否決すること自体、旧統一教会…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/414", "sentence": ["…でも、自民党会派、北海道議会議員十二人、主要六市市議会議員二十七人の地方議員に関連団体のイベントや会合の出席、選挙支援が集中し、国会議員同様…", "…員同様に関係の深さが報じられているというのが現状です。自民党本部は、地方議員にも旧統一教会との関係を絶つように求めているということであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/416", "sentence": ["…らには、衆議院選挙も思ったより早くなるかもしれません。そういう中で、地方議員がしっかりと旧統一教会とのこの関係を切っておかないと、これ国政選…", "…家庭連合、旧統一教会の問題をめぐって、自民党が党内の接点調査の対象を地方議員にも広げるべきだと、こういう回答が七四・八％でした。また、十一月…", "…・八％でした。また、十一月十四日のＮＨＫの世論調査でも、旧統一教会と地方議員の関係も点検し、明らかにするべきだという意見が七一％です。こうい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/418", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/420", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/422", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/424", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/426", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/428", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/430", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/432", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/434", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/436", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00520221130/438", "sentence": []}, {"url": "https://ko