[{"date": "2021-05-25", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/13", "sentence": ["○赤池誠章君今、文化庁から蓋かぶせという言葉が出ました。一つの重要な言葉ということなんですが、なかなか国民の皆様方にとって、蓋かぶせと言って…", "…。一つの重要な言葉ということなんですが、なかなか国民の皆様方にとって、蓋かぶせと言っても、一体、うん、何を言っているのかとちょっと分かりにく…", "…いるのかとちょっと分かりにくいところがあるので、簡単で結構ですから、文化庁から蓋かぶせって具体的にどういうことか、御説明をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415104X01420210525/19", "sentence": []}]}]}]