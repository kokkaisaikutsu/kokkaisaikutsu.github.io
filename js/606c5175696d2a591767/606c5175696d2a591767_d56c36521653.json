[{"date": "2022-03-30", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/99", "sentence": ["…党の委員からも質問がありました。給食における有機農産物の活用に向けた法制化が必要であるのではないかというふうに私は考えます。大臣が答弁でよく…", "…思っておりますので、継続性がかなり必要だというふうに思っております。法制化による支援措置、恒久的な、恒久化を考えるのはこれから必要ではないか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/101", "sentence": ["…は皆さん共通の認識だというふうに思います。それで、先ほど大臣からも、法制化とか、そういうことにはなかなか踏み切る、また、市町村が頑張るべきだ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00720220330/107", "sentence": []}]}]}]