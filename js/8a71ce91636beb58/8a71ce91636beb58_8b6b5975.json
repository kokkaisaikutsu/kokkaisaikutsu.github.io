[{"date": "2022-04-07", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/71", "sentence": ["○熊野正士君ありがとうございます。今お話ございましたが、残留農薬が非常に大きな課題だというふうに聞いていまして、微量でも残留農薬が検出される…", "…が、残留農薬が非常に大きな課題だというふうに聞いていまして、微量でも残留農薬が検出されると全て返品されると、これ輸出の際の大きなリスクになっ…", "…ます。この有機ＪＡＳ制度をうまく活用して、輸出国との交渉においてこの残留農薬検査のこういったリスク回避ができないかというふうに思いますけれど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/73", "sentence": ["○熊野正士君分かりました。今のお話で、やっぱり農薬についての、残留農薬についての基準はあるという、残るということですので、そういった意味でい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/80", "sentence": []}]}]}]