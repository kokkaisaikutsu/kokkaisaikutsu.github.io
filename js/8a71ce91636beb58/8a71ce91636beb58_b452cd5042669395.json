[{"date": "2022-04-19", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/46", "sentence": ["○熊野正士君そうすると、次のページで、十アール当たりの労働時間はやっぱり有機の方が時間掛かっているとなると、何かそこがちょっと、何かどう理解…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/48", "sentence": ["…うことは、先生、この平成十年のデータでは、いわゆる十アール当たりの労働時間は、いわゆる環境保全型、有機を中心とする環境保全型の農業の方が時間…", "…方が時間は長くなっているんだけれども、でも実はそうではなくて、むしろ有機とかの方が実は労働時間も負担も減るという理解でよろしいんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01020220419/53", "sentence": []}]}]}]