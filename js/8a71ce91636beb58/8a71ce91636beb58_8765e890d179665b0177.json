[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/121", "sentence": ["…後、この感染症の専門医を養成する意味で感染症講座を各大学に設置するように文科省として働きかけるべきではないかと思いますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/123", "sentence": ["…イルス学あるいは免疫学、疫学といった感染症に関する基礎的な研究です。文科省としてこうした基礎的な研究者の育成にどのように取り組んでいくおつも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/125", "sentence": ["…迅速に収集をして、それを分析できる体制をつくる必要があります。緊急時にも対応できる研究体制の構築が急務と考えますが、文科省の見解を求めます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/131", "sentence": []}]}]}]