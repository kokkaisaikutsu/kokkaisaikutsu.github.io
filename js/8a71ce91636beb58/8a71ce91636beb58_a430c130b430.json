[{"date": "2022-04-07", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/77", "sentence": ["…に移りたいと思います。昨年、滋賀県の豊郷町というところに行きまして、イチゴ栽培をされている農家さんにお話を聞きました。家族経営の若手の方でし…", "…ら本当様々にアドバイスをもらい、とても感謝をされていました。加工品のイチゴバターの輸出が好調で、地元テレビ局からも取材もあって、自分で栽培を…", "…ターの輸出が好調で、地元テレビ局からも取材もあって、自分で栽培をしたイチゴが海外で食されているのを非常にやりがいがあると、達成感があるという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00720220407/80", "sentence": ["…た。輸出に取り組むことでブランド化されて、商品の付加価値も高まって、イチゴのパックが一パック当たり五十円高く売れるようになったというふうなお…"]}]}]}]