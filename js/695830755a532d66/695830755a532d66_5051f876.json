[{"date": "2023-04-06", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/94", "sentence": ["…でございまして、十分に進んでいない自治体もございます。児童福祉法では児相が必要と判断すれば保護者の同意なしで子供を一時保護できますけれども、…", "…止法では同意がないと子供の保護はできません。そこで、ＤＶ担当の職員と児相が様々な子供の事例を想定して更に連携強化への取組や子供への心理的援助…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/96", "sentence": ["…ども、子供を保護することができても、もう一つの、まあ関連してですね、児相によって子供を一時保護できたケースでも、同じように、配偶者などからＤ…", "…ちっと聞き取りをしてあげる、こういう丁寧なやはり対応が必要であると、このように思います。こうした児相との連携について見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00620230406/118", "sentence": []}]}]}]