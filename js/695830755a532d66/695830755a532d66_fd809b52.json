[{"date": "2020-12-01", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/199", "sentence": ["…ございますので、厚生労働省はこのピーク時までにＰＣＲ検査や抗原検査の能力を一日当たり五十四万件まで引き上げると、このように聞いておりますけれ…", "…の見込み件数を機械的に合計したものだというふうに伺っております。検査能力については、比較的精度の高いＰＣＲ検査と抗原定量検査で合計二十万件と…", "…ンフルエンザとの同時流行が懸念される冬に向けて全国の都道府県で十分な能力を整えることが迫られていると、こう思います。十分な検査能力の構築に向…", "…国の都道府県で十分な能力を整えることが迫られていると、こう思います。十分な検査能力の構築に向けて、厚労省の考えをお伺いいたしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/211", "sentence": []}]}]}]