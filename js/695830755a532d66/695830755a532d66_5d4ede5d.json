[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/58", "sentence": ["…も事前放流を行うとしておりますが、令和二年七月の豪雨では、七月四日に九州を襲った一連の豪雨で実施されず、下流域の堤防決壊や氾濫が相次ぎました…", "…が掛かるために三日前頃から事前放流が必要とされていますが、このときの九州は線状降水帯による豪雨が続いて、直前まで大雨の予測が困難であったため…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X01120220510/68", "sentence": []}]}]}]