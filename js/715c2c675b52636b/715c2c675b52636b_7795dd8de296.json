[{"date": "2022-04-22", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/128", "sentence": ["…ていただきたいというふうに思います。これは、この感じでは、残念ながら長距離交通機関には何の得にもならないわけでございますよね。今日の航空法に…", "…空業界の方たちもまさにそうでございます。でも、例えばその後に、やはり長距離交通機関が疲弊をしているという現状を考えたら、何かそれに対する対策…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/130", "sentence": ["…がってきた状況のときに、県民割とかそういうものはあるけれども、やはり長距離交通機関には何のインセンティブもないという状況では、更なる疲弊を増…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01120220422/146", "sentence": []}]}]}, {"date": "2023-03-28", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105254X01320230328/12", "sentence": ["…数の割引が政策的に導入されており、一定の効果が発現しています。一方、長距離の移動における利用者の料金負担を減少させることを一つの目的として、…", "…は、自宅や会社などにおける基礎充電や目的地での充電器の整備に加えて、長距離移動時における充電、いわゆる経路充電のための急速充電器の整備が重要…"]}]}]}]