[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/25", "sentence": ["…続してやっていきたいというふうに思います。次に、自衛隊の営舎における電気代の問題について取り上げます。平成十八年の決算検査報告において、会計…", "…を防衛省に求めていますけれども、これは営舎内に居住する自衛官の私用の電気代全てを当該自衛官に負担させようというものなのか、会計検査院に聞きま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/27", "sentence": ["○和田政宗君防衛省にお聞きします。自衛隊において、営内居住自衛官の私用電気代は何が対象で、どういうふうに算出しているのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/29", "sentence": ["…として営内に居住することが定められています。ポットや冷蔵庫といった生活必需品の電気代も負担すべきと会計検査院は考えているのか、答弁願います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/31", "sentence": ["…ように会計検査院が求めておりますのは、営内に居住する自衛官が私用する電気代、私で使う電気代についてはどこまでを防衛省が負担をするのか、線引き…", "…が求めておりますのは、営内に居住する自衛官が私用する電気代、私で使う電気代についてはどこまでを防衛省が負担をするのか、線引き、規程をしっかり…", "…や冷蔵庫、私、これは生活必需品と思いますが、こうしたポットや冷蔵庫の電気代、防衛省で負担すべきではないかと考えますが、大臣、いかがでしょうか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/39", "sentence": []}]}]}]