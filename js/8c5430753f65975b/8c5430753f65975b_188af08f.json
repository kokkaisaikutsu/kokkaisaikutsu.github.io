[{"date": "2023-04-03", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/45", "sentence": ["…南京入城後、非戦闘員の殺害があったことは否定できないと考えているとの記述があります。この記述と、根拠となる文書は外務省内に存在するんでしょう…", "…入城後、非戦闘員の殺害があったことは否定できないと考えているとの記述があります。この記述と、根拠となる文書は外務省内に存在するんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/47", "sentence": ["…、関連文書全部読みましたけれども、意図的に日本軍が殺害したとの明確な記述はない状況でありました。これ、外務省ともやり取りしていますけれども、…", "…ました。これ、外務省ともやり取りしていますけれども、より事実に即した記述に変えるべきだというふうに思いますので、引き続き検討して実施をお願い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/49", "sentence": []}]}]}, {"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/21", "sentence": ["…いただければというふうに思います。次に、南京戦の外務省ホームページの記述について聞きます。今月三日の当委員会で、私は、外務省のホームページの…", "…について聞きます。今月三日の当委員会で、私は、外務省のホームページの記述、日本政府としては、日本軍の南京入城後、非戦闘員の殺害があったことは…", "…南京入城後、非戦闘員の殺害があったことは否定できないと考えているとの記述について、根拠となる文書は外務省内に存在するのかを外務大臣に質問いた…", "…庁防衛研究所戦史室による戦史叢書「支那事変陸軍作戦」第一巻において該当する記述があると答弁していますが、該当する記述とはどの文言でしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/23", "sentence": ["…。そして、答弁の後段部分、たとえ少数であっても無辜の住民が殺傷されの記述ですけれども、これは日本軍が意図的に住民を殺害したという文脈で記され…", "…されているのではなく、非戦闘員や住民が巻き添えを食らって死亡したとの記述に続く文脈の中で記されているものです。さらに、たとえ少数であっても無…", "…画的組織的な虐殺とは言い難いというものです。この外務省ホームページの記述における政府資料としては唯一の根拠である戦史叢書「支那事変陸軍作戦」…", "…も含め、政府の公式文書からは日本軍の意図的な住民殺害についての明確な記述はありませんでした。ですから、この戦史叢書「支那事変陸軍作戦」におい…", "…「支那事変陸軍作戦」においても、住民が巻き添えを食らって死亡したとの記述になっているのです。私は、住民を戦闘に巻き込むことは避けなくてはなら…", "…な殺害について明確に記している政府の文書が明らかになれば、そのとおり記述することになると思いますが、現在そうした文書は存在しません。こうした…", "…書は存在しません。こうしたことから、政府見解や外務省のホームページの記述について、政府が保有する公式文書に記されているものを根拠に内容を修正…", "…ないかとの意見を前回の質疑の後、多くの方からいただきました。政府が保有する公式文書に記されている内容に即した形に記述を改めないのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/39", "sentence": []}]}]}]