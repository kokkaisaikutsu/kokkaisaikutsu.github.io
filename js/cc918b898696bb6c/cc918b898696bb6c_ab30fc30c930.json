[{"date": "2021-12-17", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/112", "sentence": ["…ていくと、この決意で進めていただきたいと思います。次に、マイナンバーカードの普及と利活用についてお伺いをいたします。一人最大二万円のマイナポ…", "…事業第二弾、これは、例えばこれまでも石川県加賀市などで、マイナンバーカードの普及率が大変高い自治体がございますが、そうしたポイント制度を活用…", "…事例からも相当の効果が期待できると考えております。現在のマイナンバーカードの普及率は全国で四割程度と伺っておりますけれども、今後どのぐらいの…", "…急に時期をお示しいただきたいと思います。総務大臣、今後のマイナンバーカードの普及に向けた見通し、スケジュールをお示しいただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/114", "sentence": ["…険証とデータ上連携できるようになった場合に、健康保険証とマイナンバーカードをひも付けできれば、より迅速、円滑な救急活動ができると、そういうお…", "…ざいます。このため、緊急、救急業務においても、救急隊員がマイナンバーカードから医療情報を確認できるような環境整備が重要だと思います。こうした…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/135", "sentence": []}]}]}]