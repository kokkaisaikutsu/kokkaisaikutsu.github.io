[{"date": "2021-12-17", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/108", "sentence": ["…おりますけれども、まだ解消されていない点がございます。給付を決定する基準日というのがありまして、今回の給付は今年の九月三十日とされています。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00220211217/135", "sentence": []}]}]}, {"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/187", "sentence": ["…踏まえまして、二〇一八年から二〇一九年にかけまして、規制料金の解除の基準について、有識者による審議会において検討を行いました。この結果、これ…", "…れら三点から総合的に判断するべきとされたものでございます。この三つの基準に照らしまして、二〇二〇年三月末の時点で同審議会において地域別の競争…", "…期的に競争状況の確認を行っておりますが、現在に至るまで規制料金の解除基準を達成する地域は出ておりません。引き続き、競争環境の整備に努めますと…", "…出ておりません。引き続き、競争環境の整備に努めますとともに、競争状況を注視し、基準を満たす地域があるかどうか、定期的に確認をしてまいります。"]}]}]}]