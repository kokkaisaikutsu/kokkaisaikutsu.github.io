[{"date": "2022-04-07", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/2", "sentence": ["…御出席いただいております参考人は、東京大学大学院法学政治学研究科教授藤田友敬君、一般社団法人関東交通犯罪遺族の会代表理事小沢樹里君及び自動車…", "…くお願いをいたします。次に、議事の進め方について申し上げます。まず、藤田参考人、小沢参考人、福田参考人の順にお一人十五分以内で御意見を述べて…", "…おりますので、御承知おきをください。なお、御発言は着席のままで結構でございます。それでは、まず藤田参考人からお願いをいたします。藤田参考人。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/25", "sentence": ["○委員長（斎藤嘉隆君）じゃ、藤田参考人、時間が来ておりますので、端的にお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/74", "sentence": ["○委員長（斎藤嘉隆君）藤田参考人、お願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00720220407/77", "sentence": []}]}]}]