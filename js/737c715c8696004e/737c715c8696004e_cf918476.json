[{"date": "2022-12-06", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/77", "sentence": ["…更は二、三年はないと踏み込まれましたよね。つまり、長短金利操作つきの量的・質的緩和は二、三年継続するということを織り込んで、物価上昇の推測を…", "…皆さんいらっしゃるけれども、政策委員の方は、総裁終わったら長短金利付量的・質的緩和は終わるから二％物価上昇はしないんだなと思って、一・六％っ…", "…じゃ、思われているんですか。総裁は、一体二年後に、この長短金利操作付量的・質的緩和を続けていったら、二年後、二％上がると思われているんですか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/81", "sentence": ["…、物価上昇率が一・六％のままで、春闘等々で賃金が三％上がったら、この量的・質的金融緩和はどうされるんですか。物価上昇率二％になっていないから…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/83", "sentence": ["…で賃金が三％上がりました、実質賃金が一・四％上がりました。このとき、量的・質的緩和は続けるんですか、続けないんですかという質問です。この質問…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/85", "sentence": ["…の安定的物価目標という達成できもしなかった目標に固執して、なおそれを、量的・質的緩和は続けると今おっしゃられたんですが、それでいいんですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004376X00420221206/87", "sentence": []}]}]}]