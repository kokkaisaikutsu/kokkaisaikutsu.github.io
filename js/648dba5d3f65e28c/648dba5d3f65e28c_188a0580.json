[{"date": "2020-11-27", "meeting": [{"meeting_name": "衆議院 安全保障委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/140", "sentence": ["○赤嶺委員私は、報道の記事を見て、両紙の取材担当記者にも確認をしましたが、外務省の担当者は記事のとおりＰＦＯＳを一部含むと説明していたと。今…", "…ＯＳを含むという答弁に聞こえましたけれども、今米軍が取りかえているのもＰＦＯＳを含む、だから地元紙の記者にそう答えたという理解でいいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120303815X00420201127/146", "sentence": []}]}]}, {"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/329", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/333", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/335", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/337", "sentence": ["…今でも、通知はなかった、知ったのは十二月だ、そういう認識ということですね。何で日本側にも落ち度があったみたいな記者会見になっていたんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/339", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/343", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/345", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/347", "sentence": ["…頃からずっとやり取りをしてまいりましたが、合同委員会では、朝日新聞の記者がフォーブスに書いた記事によると、アメリカ側はコロナ対策をめぐる国防…", "…で、出国前検査の免除と明言したわけではなかった、このように書いている記者がいらっしゃるんですね。合同