[{"date": "2021-06-09", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X02920210609/17", "sentence": []}]}, {"meeting_name": "両院 国家基本政策委員会合同審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/5", "sentence": ["…ロナ戦略というのは、要は、無症状の方も含めて検査を実施して、感染者を徹底して探すということになるわけでありますけど、御党では特措法の私権制限…", "…私も伺ってみたいというふうに思っていました。また、欧米諸国では検査を徹底しても感染拡大が止まらなかった。強制的に検査を行うことができない中で…", "…させていただきたいと思います。東京大会は、感染対策、水際対策、これを徹底して安全、安心なものにしなきゃならないと思います。海外から来る選手を…", "…報告を受けています。入国前に二回、入国時に一回、そしてその後に三回、徹底して検査をし、選手については期間中も毎日行う、その予定であります。ま…", "…ボールを拾って得点を上げておりました。非常に印象に残っています。また、底知れない人間の能力というものを感じましたあのマラソンのアベベ選手も非…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120424293X00120210609/36", "sentence": []}]}]}]