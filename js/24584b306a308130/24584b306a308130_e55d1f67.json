[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 経済産業委員会環境委員会原子力問題調査特別委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/89", "sentence": ["…上がればどんどん上がるということだと思います。四点目に、革新軽水炉の工期と建設コストについてお聞きします。革新軽水炉は、計画時よりも工期が何…", "…炉の工期と建設コストについてお聞きします。革新軽水炉は、計画時よりも工期が何年も延びたり、コストが何倍もかかってしまったというケースが多いと…", "…と聞いています。例えばフィンランド・オルキルオトの革新軽水炉の場合、工期について、計画時には三・九年とされていましたが、実際には十六・五年、…", "…七倍に膨らんだと聞いています。そこで、フランス・フラマンビルの革新軽水炉について、計画時から工期とコストがどう変わったのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/91", "sentence": ["…るはずだったのに、十六年たった現在でもまだ完成していない。すなわち、工期は確実に三倍を超えるということです。総費用の見込みは三十三億から百三…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105370X00120230419/105", "sentence": []}]}]}]