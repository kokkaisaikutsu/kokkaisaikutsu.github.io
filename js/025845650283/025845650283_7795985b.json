[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/8", "sentence": ["…な森林資源を今こそ活用し、国産材の安定的かつ持続的な供給体制を構築していく必要があるのではないかと思います。林野庁長官に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00220221101/16", "sentence": ["…故茂君ありがとうございました。時間が来ましたので終わりますが、水産庁長官、質問一つ余りましたので、残しましたので、次回に質問させていただきた…"]}]}]}]