[{"date": "2022-04-25", "meeting": [{"meeting_name": "参議院 行政監視委員会国と地方の行政の役割分担に関する小委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/11", "sentence": ["…本年三月には公立病院に関する国の方針が統廃合を含む再編から病院間の役割分担、連携強化へと大きく転換されました。まずはよかったなと思うわけであ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/13", "sentence": ["…、新型コロナウイルスへの対応については、国と地方自治体の間の連携、役割分担をめぐって様々な課題があることが議論されてきました。一回目と二回目…", "…のこの委員会や地方制度調査会の議論を踏まえ、国と都道府県、市町村、それぞれの連携、役割分担をどのように改善していくのか、伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/18", "sentence": []}]}]}]