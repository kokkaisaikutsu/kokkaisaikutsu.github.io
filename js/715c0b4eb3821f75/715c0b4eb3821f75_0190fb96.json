[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/124", "sentence": ["…だと思います。当面は太陽光発電と蓄電池を推進し、中長期的に洋上風力と送電線網の整備を行って再エネによる電力確保を行うと。おっしゃるように、い…", "…たいんですけれども、再生可能エネルギー、それから蓄電、それから地域間送電網の整備などに必要な二〇三五年までの累積設備投資額は三十八兆円という…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/126", "sentence": ["…にあると。だから、こういう太陽光の活用を大いに当面進めながら、今から送電網を整備して、五年後、十年後に向けて洋上風力の導入進めるのは可能だと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/132", "sentence": []}]}]}]