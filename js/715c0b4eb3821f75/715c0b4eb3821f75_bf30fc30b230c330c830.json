[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/120", "sentence": ["…冒頭述べられました。そこで、大臣、なぜＣＯＰ26では石炭火力をＣＯ２排出削減対策の中心的なターゲットにしたのか、御認識を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/124", "sentence": ["○山下芳生君私は石炭がなぜターゲットになったのかということを聞いているんですよ。各国の事情、日本の事情しか返ってこない。極めて残念なんです。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00320220324/132", "sentence": []}]}]}]