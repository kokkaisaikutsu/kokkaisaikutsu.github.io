[{"date": "2022-12-06", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/154", "sentence": ["…、一九七四年から二〇〇二年にかけて有機汚泥のしゅんせつを四百四十三万立米行い、舞洲と夢洲の二区、三区に投入しました。さらに、一九九七年から二…", "…一年にかけて木津川の一部区域のＰＣＢ含有土砂の除去対策として四十七万立米を行い、夢洲四区で埋立て、固化いたしました。それから、二〇〇六年から…", "…底質ダイオキシン類及びＰＣＢの除去を行っております。計画では九十二万立米を夢洲一区で処理することになっていますが、まだ途上であります。国交省…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/156", "sentence": ["…砂の埋立ては一九八七年に始まって、二〇二〇年までに約三千四百八十六万立米投入されました。しかし、その九割以上に当たる約三千二百万立米は二〇〇…", "…八十六万立米投入されました。しかし、その九割以上に当たる約三千二百万立米は二〇〇一年までに埋め立てられたものと、これ大阪市の埋立ての履歴の資…", "…業者から汚染土壌の対策を求められて、ＩＲ施設建設で発生する汚泥百十万立米の処理を検討していると聞いております。これ間違いないでしょうか。また…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00320221206/180", "sentence": []}]}]}]