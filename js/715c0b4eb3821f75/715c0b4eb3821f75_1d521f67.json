[{"date": "2022-05-24", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/86", "sentence": ["…抑えるこの排出経路、排出曲線が、こうしてスキーのジャンプ台のように、初期に急降下し、やがて緩やかに降下する線を描くのはどうしてなのか、御説明…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/88", "sentence": ["…ます。私なりに、四点考えることがあるんじゃないかと。一点目は、やはり初期に急な排出削減をするほど累積排出量を抑えることができ、一・五度に抑え…", "…と、その分非常に巨大なコストが掛かってしまうことになると。三点目に、初期に急な排出削減を行うことは不可能ではないと先ほど御答弁もありました。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00820220524/100", "sentence": []}]}]}]