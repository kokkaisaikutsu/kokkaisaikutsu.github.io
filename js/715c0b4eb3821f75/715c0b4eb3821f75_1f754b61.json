[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/107", "sentence": ["…もたらし、人類が存続していく上で不可欠のものであります。具体的には、生態系サービスという言葉で理解されています。環境省、生態系サービスとは具…", "…ります。具体的には、生態系サービスという言葉で理解されています。環境省、生態系サービスとは具体的にどういうことか、簡潔に説明いただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/113", "sentence": ["…関する条例や、滋賀県外来種リスト、生物多様性しが戦略を制定するなど、生態系の保護、外来生物対策では先進県の一つであります。長年、名物のフナず…", "…た。国としても、琵琶湖再生保全法で、多数の固有種が存在するなど豊かな生態系を有する国民的資産として琵琶湖を特別に位置付けております。その琵琶…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/127", "sentence": []}]}]}]