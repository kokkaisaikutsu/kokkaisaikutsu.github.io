[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/119", "sentence": ["○山下芳生君今回の法改正によって、国の、自治体の責務が明記されました。当然それに対応する予算などの財政的支援が強化されるべきですが、環境省に…", "…財政的支援が強化されるべきですが、環境省にまずその点で伺いたいのは、法改正の案で、国の責務として、生物の多様性の確保上重要と認められる地域に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/121", "sentence": ["…ました。私は、これらの方々の労苦に報いる必要があると思います。今回の法改正を機に、自治体から出ている財政支援の拡充強化の要望に全面的に応える…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/127", "sentence": []}]}]}]