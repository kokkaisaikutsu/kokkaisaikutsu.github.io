[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/115", "sentence": ["…常に厄介なんですね。資料六を見ていただきたいんですけれども、やっぱり機械力を利用した大規模な防除とともに人力による防除がどうしても必要という…", "…ですね。現在の管理可能な状態を維持するためにも、今年も七月から八月に機械力と人力による防除が必要とのことでありました。防除しなければ現状を維…", "…囲の広域化、それから、ヨシ帯や石組み護岸の間に根を下ろした群落など、機械駆除困難群落での防除手法開発が必要としています。そのためにも、提案、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814006X00520220510/127", "sentence": []}]}]}]