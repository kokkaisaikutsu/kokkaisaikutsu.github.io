[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/151", "sentence": ["…。資料五にあるように、夢洲は一区から四区の工区に分けられ、一区は一般廃棄物、産業廃棄物、二区、三区は大阪湾や河川のしゅんせつ土砂や建設残土、…", "…るように、夢洲は一区から四区の工区に分けられ、一区は一般廃棄物、産業廃棄物、二区、三区は大阪湾や河川のしゅんせつ土砂や建設残土、そして四区は…", "…予定されております。環境省、夢洲が大阪湾のしゅんせつ土砂や建設残土、廃棄物の処分場として埋め立てられた場所だということは間違いありませんね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014006X00220221101/170", "sentence": []}]}]}]