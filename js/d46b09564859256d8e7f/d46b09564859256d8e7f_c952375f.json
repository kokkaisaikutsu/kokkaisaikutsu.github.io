[{"date": "2022-03-25", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/15", "sentence": ["…。乳がんの治療薬ハラヴェンなども海洋生物からできております。いろいろ勉強してきた中で、これからいろんな物質を探すのに海の中が一番可能性が高い…"]}]}]}, {"date": "2022-06-02", "meeting": [{"meeting_name": "参議院 内閣委員会、厚生労働委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/4", "sentence": ["…見てまいりました。そして、お母様方も、やっぱり若年のお母さん多くて、勉強をしなくてはいけないという子供の姿を見て、自分もそう感じて、手に職を…", "…子供の姿を見て、自分もそう感じて、手に職を付けるということで一生懸命勉強してライセンスを取られているお母さん方もいました。沖縄の取組について…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/13", "sentence": []}]}]}]