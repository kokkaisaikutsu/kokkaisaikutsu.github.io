[{"date": "2020-12-03", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/85", "sentence": ["…いて、あしなが育英会の子供も親も旅行に行く余裕なんかありません、一日一食取れるかどうかというときもあります、旅行に行ける家庭に税金を使うので…", "…由記述には、子供の教育費と生活費について毎日悩んでいます、自分のものや食べ物などを我慢して子供に回して生活しています、五十代母親。子供は育ち…", "…などを我慢して子供に回して生活しています、五十代母親。子供は育ち盛りで食費はこれ以上削れません、私は八十八円のふりかけで御飯を食べたり、農家…", "…供は育ち盛りで食費はこれ以上削れません、私は八十八円のふりかけで御飯を食べたり、農家の人から出荷できない野菜を廃棄する袋ごともらい、虫だらけ…", "…きない野菜を廃棄する袋ごともらい、虫だらけ、溶けて腐ったレタスの中から食べられる僅かな部分を探しながら涙が出ました、四十代母親。とにかくお金…", "…また家計を助けることもできなくて、おなかがすいている、たまにはお菓子も食べたい、高校二年生。就職して母を助けたい、コロナの影響でバイトしたい…", "…トしたいけど雇ってくれるところがない、高校二年生。アルバイトがないので食費を削っている、土日は寮で御飯も出ないため、友人からもらった乾パンで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/111", "senten