[{"date": "2022-06-02", "meeting": [{"meeting_name": "参議院 内閣委員会、厚生労働委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/30", "sentence": ["…いと。幼稚園や保育所とは別に、児童発達支援事業所などに通って専門的な療育を受ける、そのためにはお子さんたちの送迎で親が付き添う必要がある。た…", "…う必要がある。ただ、経済的理由によって就労を優先せざるを得ない場合は療育を断念せざるを得ないということもあるそうです。親の就労も子供の療育も…", "…場合は療育を断念せざるを得ないということもあるそうです。親の就労も子供の療育も、どちらも保障する必要があると思うんですが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/32", "sentence": ["…君是非よろしくお願いします。もう現状はなかなか、親、特に母親が就労か療育かを、その選択に迫られる状況にあると聞いています。母親の就労を保障す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814894X00120220602/42", "sentence": []}]}]}]