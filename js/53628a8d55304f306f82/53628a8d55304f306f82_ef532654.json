[{"date": "2021-06-01", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/104", "sentence": ["…の順番を変えさせていただきます。感染症の動向も踏まえ、オリパラ開催の可否については日本として判断する必要があります。尾身茂氏は、オリパラを仮…", "…きだと述べています。せめて、アドバイザリーボードなどにオリパラ開催をする場合の条件や可否について諮問すべきだと思いますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/106", "sentence": ["…から、そこにいらっしゃる専門家の皆さんにオリンピック開催をする場合の条件、可否について改めて諮問するべきだと思いますが、改めてお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02120210601/110", "sentence": []}]}]}, {"date": "2021-06-03", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/25", "sentence": ["…だ、五輪を優先させることはないとおっしゃいました。しかし、オリパラの可否につき、感染症の状況を踏まえ判断すべきではないか、アドバイザリーボー…", "…症の状況を踏まえ判断すべきではないか、アドバイザリーボードや分科会に可否や開催の条件につき諮問すべきではないかと質問を私、三回重ねましたけれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/27", "sentence": ["…、調整することであり、あくまでも開催を前提としたものです。オリパラの可否を判断するものではないことから、総理の答弁には強い違和感を抱かざるを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/29", "sentence": ["…あるいは厚生労働省の方から、そうしたオリパラに関連して感染についてのリスク評価、そして開催の可否について諮問は受けていないということですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/31", "sentence": ["…するのが義務だとおっしゃいました。なかなか権限がないということではありましたけれども、開催の可否について改めて教えていただけないでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/251", "sentence": []}]}]}]