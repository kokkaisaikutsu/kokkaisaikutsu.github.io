[{"date": "2022-03-18", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/90", "sentence": ["○松野国務大臣お答えをさせていただきます。発災当時、私、議員宿舎の方で休んでおりましたが、発災から二十分前後ぐらいで官邸の方に入ったものと思…", "…させていただきます。発災当時、私、議員宿舎の方で休んでおりましたが、発災から二十分前後ぐらいで官邸の方に入ったものと思います。先ほど先生から…", "…先ほど先生からお話をいただいたとおり、総理は今公邸にお住まいでありますから、総理は迅速にこの発災に関して対応されたものと承知をしております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/92", "sentence": ["…だきます。特に、私自身としては通常と同様の対応だと思っておりますが、発災直後の緊急時でございまして、各種情報が飛び交っている中での対応であり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01020220318/142", "sentence": []}]}, {"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X00820220318/25", "sentence": []}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01520220318/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01520220318/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01520220318/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01520220318/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01520