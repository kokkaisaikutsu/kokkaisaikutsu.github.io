[{"date": "2022-11-04", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/166", "sentence": ["…時説明してきているところでありますが、引き続き、閣議決定の前後を問わず、その時点での議論の推移に応じて丁寧な説明に努めていく考えであります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/168", "sentence": ["…も国会における質疑にお答えする形で随時説明してきているところでありますが、引き続き、議論の推移に応じて丁寧な説明に努めていく考えであります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/172", "sentence": ["…で随時説明をしてきているところでありますので、閣議の決定の前後を問わず、その時点での議論の推移に応じて丁寧に説明を進めていく考えであります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/174", "sentence": ["…と考えており、政府としては、引き続き、閣議決定の前後を問わず、そのとき、その時点での議論の推移に応じて丁寧な説明に努めていく考えであります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00520221104/218", "sentence": []}]}]}]