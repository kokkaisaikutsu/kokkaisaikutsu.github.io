": [{"meeting_name": "еҸӮиӯ°йҷў еҶ…й–Је§”е“Ўдјҡ", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00220230307/2", "sentence": ["вҖҰиҮӘз”ұгҒ§й–ӢгҒӢгӮҢгҒҹгӮӨгғігғүеӨӘе№іжҙӢгҒ®е®ҹзҸҫгҒ®гҒҹгӮҒгҒ®иіӘгҒ®й«ҳгҒ„гӮӨгғігғ•гғ©ж•ҙеӮҷгҒ®жҺЁйҖІгҖҒпј§пј—еәғеі¶гӮөгғҹгғғгғҲзӯүгӮӮиҰӢжҚ®гҒҲгҒҹгҖҢдё–з•ҢдёҖе®үе…ЁгҒӘж—Ҙжң¬гҖҚеүөйҖ жҲҰз•ҘдәҢгҖҮдәҢдәҢгҒ«еҹәгҒҘгҒ„вҖҰ"]}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "еҸӮиӯ°йҷў еҶ…й–Је§”е“Ўдјҡ", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/5", "sentence": ["вҖҰгӮҜгғ©гӮӨгғҠдҫөз•ҘгӮ’еҸ—гҒ‘гҖҒжӯҙеҸІзҡ„гҒӘи»ўжҸӣжңҹгҒ«гҒӮгӮҠгҒҫгҒҷгҖӮгҒ“гҒҶгҒ—гҒҹдёӯгҒ§й–ӢеӮ¬гҒ•гӮҢгӮӢпј§пј—еәғеі¶гӮөгғҹгғғгғҲгҒ§гҒҜгҖҒеҠӣгҒ«гӮҲгӮӢдёҖж–№зҡ„гҒӘзҸҫзҠ¶еӨүжӣҙгҒ®и©ҰгҒҝгӮ„гҖҒгғӯгӮ·гӮўгҒҢиЎҢгҒЈгҒҰгҒ„вҖҰ", "вҖҰгҒӘгӮүгҒӘгҒ„гҒЁж–ӯеӣәгҒЁгҒ—гҒҰжӢ’еҗҰгҒ—гҖҒжі•гҒ®ж”Ҝй…ҚгҒ«еҹәгҒҘгҒҸеӣҪйҡӣз§©еәҸгӮ’е®ҲгӮҠжҠңгҒҸгҒЁгҒ„гҒҶпј§пј—гҒ®еј·гҒ„ж„ҸжҖқгӮ’еҠӣеј·гҒҸдё–з•ҢгҒ«зӨәгҒ—гҒҹгҒ„гҒЁиҖғгҒҲгҒҰгҒҠгӮҠгҒҫгҒҷгҖӮеҗҢжҷӮгҒ«гҖҒгӮЁгғҚгғ«гӮ®гғјвҖҰ"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/7", "sentence": ["вҖҰеӨүжӣҙгҒ®и©ҰгҒҝгӮ’ж–ӯеӣәгҒЁгҒ—гҒҰжӢ’еҗҰгҒ—гҖҒжі•гҒ®ж”Ҝй…ҚгҒ«еҹәгҒҘгҒҸеӣҪйҡӣз§©еәҸгӮ’е®ҲгӮҠжҠңгҒҸгҒЁгҖҒпј§пј—гҒ®еј·гҒ„ж„ҸжҖқгӮ’еҠӣеј·гҒҸдё–з•ҢгҒ«зӨәгҒҷгҒЁгҒ„гҒҶгҒ“гҒЁгҒҜгҖҒгҒҫгҒ•гҒ«е§”е“ЎеҫЎжҢҮж‘ҳгҒ®пј§пј—иӯ°й•·вҖҰ", "вҖҰгҒЁгҖҒпј§пј—гҒ®еј·гҒ„ж„ҸжҖқгӮ’еҠӣеј·гҒҸдё–з•ҢгҒ«зӨәгҒҷгҒЁгҒ„гҒҶгҒ“гҒЁгҒҜгҖҒгҒҫгҒ•гҒ«е§”е“ЎеҫЎжҢҮж‘ҳгҒ®пј§пј—иӯ°й•·еӣҪгҒЁгҒ—гҒҰдё»дҪ“зҡ„гҒ«еӣҪйҡӣе№іе’ҢгҒ«иІўзҢ®гҒ—гӮҲгҒҶгҒЁгҒ„гҒҶеҸ–зө„гҒ®дёҖз’°гҒ§гҒӮгӮҠгҒҫгҒҷгҖӮвҖҰ", "вҖҰиӯ°й•·еӣҪгҒЁгҒ—гҒҰдё»дҪ“зҡ„гҒ«еӣҪйҡӣе№іе’ҢгҒ«иІўзҢ®гҒ—гӮҲгҒҶгҒЁгҒ„гҒҶеҸ–зө„гҒ®дёҖз’°гҒ§гҒӮгӮҠгҒҫгҒҷгҖӮпј§пј—еәғеі¶гӮөгғҹгғғгғҲгҒ§гҒҜгҖҒгӮҰгӮҜгғ©гӮӨгғҠгҖҒж ёи»Қзё®гғ»дёҚжӢЎж•ЈгҖҒзөҢжёҲе®үе…ЁдҝқйҡңгҒЁгҒ„гҒЈгҒҹиӘІвҖҰ", "вҖҰгҒҰиӯ°и«–гӮ’гҒ—гҒҹгҒ„гҒЁиҖғгҒҲгҒҰгҒҠгӮҠгҒҫгҒҷгҖӮгҒҫгҒҹгҖҒеәғеі¶гӮөгғҹгғғгғҲгҒҜгӮўгӮёгӮўгҒ§й–ӢеӮ¬гҒҷгӮӢпј§пј—гӮөгғҹгғғгғҲгҒ§гҒӮгӮӢгҒ“гҒЁгҒӢгӮүгҖҒиҮӘз”ұгҒ§й–ӢгҒӢгӮҢгҒҹгӮӨгғігғүеӨӘе№іжҙӢгҒ«й–ўгҒҷгӮӢпј§пј—гҒ®йҖЈжҗәвҖҰ", "вҖҰгҒ§й–ӢеӮ¬гҒҷгӮӢпј§пј—гӮөгғҹгғғгғҲгҒ§гҒӮгӮӢгҒ“гҒЁгҒӢгӮүгҖҒиҮӘз”