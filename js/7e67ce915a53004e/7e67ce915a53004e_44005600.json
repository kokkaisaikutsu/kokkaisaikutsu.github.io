[{"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00220220404/199", "sentence": ["…準ずる心身に有害な影響を及ぼす言動と定義をされています。御指摘の虚偽ＤＶによって長期間子供と引き離されることについては、ケース・バイ・ケース…", "…と考えております。現在、内閣府では、配偶者暴力防止法の見直しを含めたＤＶ対策の抜本的強化に向けて検討しており、その中で子供と離れて暮らす父母…", "…も踏まえつつ、様々な状況で配偶者からの暴力に苦しむ方をきめ細かく支援できるよう、ＤＶ対策の抜本的強化に向けて検討を進めていく考えであります。"]}]}]}]