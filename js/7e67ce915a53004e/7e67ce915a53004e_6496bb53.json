[{"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/37", "sentence": ["…宅や学校で囲まれ、世界で最も危険と言われている普天間飛行場の危険性の除去と返還にあるかと思います。普天間飛行場が固定化をされ、危険なまま置き…", "…識であるかと思います。日米同盟の抑止力の維持と普天間飛行場の危険性の除去を考え合わせたときに、辺野古移設が唯一の解決策であり、この方針に基づ…", "…に基づいて着実に工事を進めていくことこそが普天間飛行場の一日も早い全面返還を実現し、その危険性を除去することにつながるものと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01620220517/127", "sentence": []}]}]}]