[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/197", "sentence": ["…きたいと思っております。次に、総理に伺います。国家安全保障戦略を防衛大綱と中期防と一体となってこの一年以内に見直しをするということは表明をさ…", "…てＯＤＡ政策がありますけれども、ＯＤＡ政策の根幹となるのが、開発協力大綱というものがございます。この開発協力大綱というのは二〇一五年に策定さ…", "…策の根幹となるのが、開発協力大綱というものがございます。この開発協力大綱というのは二〇一五年に策定されております。その策定した後に何が起きて…", "…がいまして、今回、国家安全保障戦略を改定する際に、新しくこの開発協力大綱も一体となって見直しをしていくべきではないかと。その中に人間の安全保…", "…しをしていくべきではないかと。その中に人間の安全保障に基づく開発協力大綱を作り、来年はＧ７、我が国開催しますし、ＳＤＧｓ達成のための中間年な…", "…の議論に厚みを増すことも可能だと思っております。是非この新たな開発協力大綱を策定していただきたいと思いますが、いかがでございますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/213", "sentence": []}]}]}]