[{"date": "2021-04-20", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/43", "sentence": ["○谷合正明君公明党の谷合です。この通常国会では、行政のデジタル化を進めていくことは政権の柱ともなっております。そこで、不動産登記制度の見直し…", "…政権の柱ともなっております。そこで、不動産登記制度の見直しと行政のデジタル化につきまして質問をいたします。不動産登記につきまして、オンライン…", "…申請に関する運用上の問題点と、不動産登記法の改正を踏まえた今後の法務省における行政のデジタル化への取組や意気込みについて伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00920210420/65", "sentence": []}]}]}, {"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01420220517/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01420220517/38", "sentence": ["…いても笠原参考人にお伺いします。農業委員会の負担軽減であったりとかデジタル化について伺いたいと思います。目標地図の素案を農業委員会が作成する…", "…減の在り方について御所見を伺いたいのと、特に負担軽減となると、特にデジタル化というのがよく耳にするわけですが、極めて重要な取組であるという認…", "…は、すぐに導入が円滑に進むものではないという声もあったりして、このデジタル化についての今後浸透していく上での課題であったり、そういうことにつ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01420220517/40", "sentence": ["…明君ありがとうございます。稲垣参考人にお伺いしたいと思います。今、デジタル化の話がありましたけれども、予算上は、国の予算上は最適化委員二人に…", "…大事だと思いますが、この農業委員会の事務負担の軽減の在り方として、デジタル化を進めていく上で、その意義だとか、またその課題についてどのように…"]}, {"url": "