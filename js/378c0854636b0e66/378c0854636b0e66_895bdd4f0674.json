[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/199", "sentence": ["…のはよく、不完全だけども不可欠な組織とよく言われます。そこで、国連の安保理改革について伺いたいと思います。これまで安保理改革は、常任理事国の…", "…れます。そこで、国連の安保理改革について伺いたいと思います。これまで安保理改革は、常任理事国の拒否権の問題もありましてなかなかこれ難しくて、…", "…そして、先週は、ゼレンスキー大統領が、日本に期待するということでこの安保理改革をおっしゃっていただいたわけであります。今、先ほど私、頓挫と言…", "…あります。今、先ほど私、頓挫と言いましたけれども、いろんなグループが安保理改革の案を持っております。日本も持っております。この日本の役割とし…", "…るような、そういう役割も私はあるのではないかなと思っております。この安保理改革、大変難しい課題だと思いますが、あえてこの度総理が国際秩序の再…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/213", "sentence": []}]}]}]