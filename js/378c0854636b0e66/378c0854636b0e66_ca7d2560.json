[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/201", "sentence": ["…そういう責務があると思っております。公明党は、先週、国民生活総点検・緊急対策本部というものを立ち上げました。また、各県本部にもその対策本部を…", "…府にも伝えていきたいと思っております。本日、決算委員会の後にも、早速緊急提言の申入れもさせていただきたいと思っております。総理にまず伺いたい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/203", "sentence": ["…君その中でも原油価格高騰対策でございまして、三月上旬に政府としてこの緊急対策を決定しております。この措置につきましては、既に報道でも出されて…", "…というふうに思っております。改めまして、この原油価格高騰対策について緊急対策を延長、拡充すべきでありますし、また、トリガー条項につきましては…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/213", "sentence": []}]}]}]