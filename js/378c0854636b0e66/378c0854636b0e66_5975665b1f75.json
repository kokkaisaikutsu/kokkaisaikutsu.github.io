[{"date": "2021-04-08", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/52", "sentence": ["…お願いしたいと思います。それでは、難民について質問をいたします。先に留学生の受入れのところから聞きます。お手元に、皆さんに資料を配付させてい…", "…れております。そこで、私が思いましたのは、この統計表に、シリア難民の留学生を今政府は受け入れておりますけれども、それが記載されていないので、…", "…〇一五年にシリア難民キャンプを訪れまして、そのときに、やはり、例えば留学生として受け入れるという形を取るということがあり得るのではないかと。…", "…おりますけれども、グテーレスさんとも意見交換を重ねまして、是非日本で留学生の形として受入れをやってほしいという話がありました。そこで、私もＰ…", "…を安倍総理にさせていただきまして、二〇一六年に安倍総理がシリア難民の留学生を五年間で百五十名という形で受け入れるということを発表して、二〇一…", "…て、今、日本にいるのはたしかレバノンだとかヨルダンにいるシリア難民の留学生が来ているんですけれども、家族とも一緒に来ているんですね。ですから…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415206X00620210408/56", "sentence": []}]}]}, {"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/193", "sentence": ["…点。そして二点目は、六年前にシリア危機を迎えたときに、シリアの難民の留学生を日本として受け入れるということを始めました。これはＧ７の場でも表…", "…ろでございます。今回、ウクライナ危機を迎えまして、例えばウクライナの留学生を受け入れるということを通じて、日本に親族や身内がいない場合であっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/201", "sentence": []}, 