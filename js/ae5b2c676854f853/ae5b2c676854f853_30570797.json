[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/20", "sentence": ["…ていく、このことを強くお願いをしたいと思います。今月十六日に福島県沖地震が発生をいたしました。お亡くなりになられた方々の御冥福を衷心よりお祈…", "…ざいますが、令和元年には東日本台風、そして昨年、令和三年には福島県沖地震が発生をいたしまして、この同じ地域が二度、三度と被災をしております。…", "…の期待が高まった、そんな頃がこの十六日だったと思いますが、再び大きな地震がこの地域を襲い、それぞれがまた大きな被害に遭ったところでございます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/33", "sentence": []}]}]}]