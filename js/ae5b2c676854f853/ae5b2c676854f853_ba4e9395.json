[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/30", "sentence": ["…あると思っております。そして、あわせて、二年前から、食文化の分野から人間国宝を認定しようという、その追加に対する準備が始まっています。この二…", "…ユネスコ登録、ここに合わせて、例えば酒造りであったり食の達人、これの人間国宝への追加認定、これも機運を高める相乗効果があると思っております。…", "…は、ユネスコの登録に向けての覚悟と取組、またその先の戦略を総理に、そして人間国宝の追加認定、これに関しては末松文科大臣にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/33", "sentence": []}]}]}]