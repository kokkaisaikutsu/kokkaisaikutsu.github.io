[{"date": "2021-05-27", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/16", "sentence": ["…その意味におきまして、世界的にも今議論の一つになっておりますが、石炭火力、これも我が国にとっては現状では重要な選択肢だと思っています。一方で…", "…も我が国にとっては現状では重要な選択肢だと思っています。一方で、石炭火力は、設計時の発電方式によりまして効率が異なります。これを現行のエネル…", "…すが、一方で、設備更新などの事業者の努力によって高効率化している石炭火力というものは多く確認できていますし、国内でもこれらはしっかりと活用す…", "…ていますし、国内でもこれらはしっかりと活用するべきだと思っています。火力もフル稼働しながらバックアップ電源の務めを果たす。ただ、その中で停止…", "…しなければいけない。そういったことも鑑みまして、今後この高効率の石炭火力をいかに整理をして、そして今後制度として措置をしていくか、このことが…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00620210527/30", "sentence": []}]}]}]