[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/26", "sentence": ["…推進していく、未来への投資としてこのことを意見をしたいと思いますが、末松文科大臣、今決断をしていただくべきだと考えますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/30", "sentence": ["…力強く進めていかなければいけないと思っております。最後に、総理とまた末松大臣の方にお伺いをいたします。昨年、ようやく農林水産品、食品の輸出額…", "…は、ユネスコの登録に向けての覚悟と取組、またその先の戦略を総理に、そして人間国宝の追加認定、これに関しては末松文科大臣にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/33", "sentence": []}]}]}]