[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第一分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/166", "sentence": ["…ますので、どうぞよろしくお願いをいたします。私の選挙区は、栃木二区、日光市に代表される選挙区であります。県議時代は栃木県の人口の比較的多いと…", "…た小山市、野木町には観光産業というものがほとんどありませんでしたが、日光市の世界遺産二社一寺に代表されるように、新たな選挙区では、まさに観光…", "…す。そういう中にありまして、今回のデジタル田園都市国家構想、まさに、日光市そして私の栃木二区にとっても、起死回生、人口減少からいま一度地方が…", "…なってほしいという大きな期待を感じているところでございます。私の地元日光市、かつては国際観光都市とも言われた時代がありましたけれども、今回の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/168", "sentence": ["…。来年、我が国でもＧ７サミットが予定をされておりますが、栃木県そして日光市は、その際の閣僚級会議の誘致に手も挙げてございます。そういうものを…", "…るところが非常に増えてきていることを実感いたしますが、同時に、地元の日光市を始め地方では遅れているというのを率直に感じております。政府として…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/180", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/105", "sentence": []}]}]}]