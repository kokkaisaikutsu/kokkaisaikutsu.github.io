[{"date": "2024-02-08", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/13", "sentence": ["…が国のタクシー事業は、国民に安全かつ安心な輸送サービスを提供する地域公共交通機関として、二種免許制度や車両の運行整備管理、アルコールチェック…", "…。こうした中におきましても、タクシー事業者は、国民生活に不可欠な地域公共交通機関としての社会的責任を果たすため、努力を続けていただいておりま…", "…、安易な参入障壁の引下げ、新規参入の増加は、かえって安全、安心な地域公共交通機関としてのタクシーサービスを毀損しかねないということであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/15", "sentence": ["…行います。全国のタクシー運転手や利用者はもちろん、タクシー以外の地域公共交通機関、交通問題など、様々なところに影響を及ぼす可能性もあります。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00620240208/27", "sentence": []}]}]}]