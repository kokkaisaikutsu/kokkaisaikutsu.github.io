[{"date": "2023-02-02", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/141", "sentence": ["…すけれども、まず、少子化担当大臣の小倉大臣に伺いたいと思います。二〇二三年に向けた骨太方針、どのようなタイムスケジュールでお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/143", "sentence": ["…。私、今、小倉大臣の話を伺いながら、遅いなという感じがするんですね。骨太方針ということで、相当な期待が高まっているわけなんですけれども、私、…", "…当な期待が高まっているわけなんですけれども、私、改めて見てみました。骨太方針は二〇二一年もできていました。そして、二〇二〇年もありました。今…", "…るんですね。あれっと思いました。今回、三月に意見を取りまとめ、六月に骨太方針として出る、来年の、二〇二三年の予算に反映されるんだということで…", "…。こども家庭庁、これだけはできた。それ以外って何か。小倉大臣、二〇二〇年、二〇二一年、そして今回取りまとめる骨太方針、何が違うんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/167", "sentence": ["…なりたいと思っているはずです。異次元の少子化対策、そして、思い切った骨太方針。小倉大臣、岸田総理もそして小倉大臣もここは賛成の立場でいらっし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00520230202/173", "sentence": []}]}]}]