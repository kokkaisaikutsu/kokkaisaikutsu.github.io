[{"date": "2022-04-15", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/184", "sentence": ["○山田（勝）委員長期化している原因は、難しい事件が増えているという指摘も一方であります。今回の期間限定裁判には、難しい事件にはそもそも使えな…", "…いただきます。その上で、裁判の迅速化については、原因の調査と、裁判官の増員など基盤整備、証拠、資料などの収集手続などの手続の整備、運用の改善…", "…ている内容を引用させていただきます。私は、二〇〇三年に日弁連で裁判官の増員について意見書をまとめたときの座長です、いろいろ調べましたが、少な…", "…化を図る上で、問題の本質は期間限定裁判ではなく、裁判官の処遇改善、定員増こそが本質の課題であり、期間限定裁判でないことは明らかです。司法改革…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00920220415/200", "sentence": []}]}]}, {"date": "2023-05-11", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/43", "sentence": ["○山田（勝）委員ありがとうございます。みどりの食料戦略同様、海の森を増やしていくことは、当然、政府が掲げているＣＯ2排出ゼロのカーボンニュー…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X009202305