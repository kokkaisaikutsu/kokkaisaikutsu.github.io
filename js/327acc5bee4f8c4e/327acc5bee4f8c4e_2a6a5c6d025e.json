[{"date": "2022-03-09", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/6", "sentence": ["…認をしてまいりたいと思います。まず、この参加者についてでございます。横浜市が作った、二〇二七年横浜国際園芸博覧会計画案、二〇二一年三月には、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/10", "sentence": ["…ってのネックでございまして、今回、二〇二七年に開催するに当たっては、横浜市と地元の業者との様々な行き来、やり取りがあったと聞いております。一…", "…を造らなければ、その一千万人も運べないということだったかと思います。横浜市が横浜シーサイドライン社に対して、事業参加、新たな交通機関を造ると…", "…したのが去年の九月、そして、十一月にその横浜シーサイドライン、これは横浜市が六割出資している第三セクターです、そこがこれを断っているのが十一…", "…、しかし、十一月にその横浜シーサイドラインは断っているということで、横浜市自体も、この花博までに、瀬谷駅から会場までの二・二キロの鉄道建設と…", "…が十二月と理解をしております。理由は、このシーサイドラインによれば、横浜市から提示された来園者の予想値、交通分担率などが大きく変動する可能性…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00320220309/32", "sentence": []}]}]}]