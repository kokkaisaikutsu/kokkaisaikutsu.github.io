[{"date": "2023-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/66", "sentence": ["…私は、婚姻というものは、家族を成立させる基礎的な組織として国が法的な承認を与える手続であり、夫婦とはその基礎的組織であるというふうに考えます…", "…まして、ＬＧＢＴを夫婦として認めるということは、それに対して国が法的承認をするということです。確かに、ＬＧＢＴが法的に夫婦として認められない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/68", "sentence": ["○古庄玄知君どのようなカップルに国が夫婦としての法的承認を与えるかは、その国の歴史、時代の推移、国民の意識、価値観、慣習、それを求める人や反…", "…は考えておりますが、この点について、国はどのような観点からカップルに婚姻を認め、夫婦として承認するのか、政府の見解をお尋ねしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00920230314/90", "sentence": []}]}]}]