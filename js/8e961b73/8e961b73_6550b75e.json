[{"date": "2022-12-08", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004183X00620221208/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004183X00620221208/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004183X00620221208/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004183X00620221208/22", "sentence": ["…うな趣旨のお話であったと思います。それから、知る権利、あるいは情報的健康ですか、こうしたものについては、どういうやり方、憲法で手当てするのか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004183X00620221208/24", "sentence": ["…ますけれども、我々の知る権利という文脈は、今おっしゃったような情報的健康を維持するための文脈だけではなくて、政府に対して正しい情報を開示させ…"]}]}]}]