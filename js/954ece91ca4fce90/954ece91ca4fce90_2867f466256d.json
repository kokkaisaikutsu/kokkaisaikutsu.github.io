[{"date": "2023-04-26", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/36", "sentence": ["…輸送ヘリコプター群や第一〇二飛行隊所属の各種航空機による輸送支援を得て、木更津駐屯地から南西地域に機動展開する際の要領を訓練をいたしました。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/38", "sentence": ["…の各種航空機による輸送支援を得て、水陸機動団や第一空挺団などの部隊が木更津駐屯地から南西地域に機動展開する要領を訓練をいたしました。その上で…", "…には、令和元年十一月十一日から二十一日にかけて、第一ヘリコプター団が木更津駐屯地から高遊原分屯地、日出生台演習場、那覇基地、与那国駐屯地、宮…", "…日から十五日にかけて、統合特殊作戦訓練の一環として、第一〇二飛行隊が木更津駐屯地から奄美駐屯地、奄美基地、那覇基地などの南西地域に向けて飛行…", "…ら二十一日にかけて、第一ヘリコプター団が水陸両用作戦訓練の一環として、木更津駐屯地から種子島などの南西地域に向けて飛行する訓練を行いました。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00920230426/50", "sentence": []}]}]}]