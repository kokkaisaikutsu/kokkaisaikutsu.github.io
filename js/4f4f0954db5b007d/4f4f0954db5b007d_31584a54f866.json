[{"date": "2023-06-07", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/132", "sentence": ["…せていただきます。どうぞよろしくお願いいたします。まず最初に、四半期報告書制度廃止についてお伺いいたします。今回の改正案において、上場企業の…", "…て、上場企業の第一と第三・四半期については、金融商品取引法上の四半期報告書を廃止し、そして、取引所規則に基づく四半期決算短信に一本化すること…", "…則に基づく四半期決算短信に一本化することが定められております。四半期報告書と四半期決算短信には重複が見られ、民間の経済団体の方のお話を伺って…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/136", "sentence": ["…と思います。四半期決算短信に一本化されることにより、廃止される四半期報告書でのみ開示が求められている事項が開示されないということになります。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X02120230607/253", "sentence": []}]}]}]