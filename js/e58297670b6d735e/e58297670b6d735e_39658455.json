[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/46", "sentence": ["…で、質問を続けさせていただきます。令和五年度の予算案にも自衛官の処遇改善が掲げられておるかと思いますが、どのような処遇改善を考えられているの…", "…予算案にも自衛官の処遇改善が掲げられておるかと思いますが、どのような処遇改善を考えられているのでしょうか、お聞かせをいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/48", "sentence": ["…衛官の士気に関わる、最も関わる制服や施設、営舎、そして宿舎、食事等、いま一度具体的な改善の計画が言える範囲でお聞かせいただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/51", "sentence": ["…答弁をありがとうございました。今回の予算案では退職自衛官に対する処遇改善までは組み込んでいただけませんで、組み込んでいただけませんでしたが、…", "…いただけませんで、組み込んでいただけませんでしたが、退職自衛官の処遇改善や業績に対する表彰についてどうお考えかを御見解いただきたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/73", "sentence": []}]}]}]