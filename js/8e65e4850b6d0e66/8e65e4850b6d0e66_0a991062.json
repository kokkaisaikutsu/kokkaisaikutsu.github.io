[{"date": "2024-02-27", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/13", "sentence": ["…）分科員是非よろしくお願いします。次、ちょっと視点を変えまして、医師養成課程に関連してお尋ねいたします。というのは、今、我が新潟県も医師不足…", "…いたします。というのは、今、我が新潟県も医師不足県でありまして、医師養成課程のそもそも在り方の議論をしたりですとか、あるいは地域枠を通じて、…", "…いうことで努力を重ねております。国公立であっても私立であっても、医師養成課程にはかなり税金が投入されております。一方で、卒業して医師免許を取…", "…しいのではないかと考えられる分野もございます、税金投入というのは医師養成に関してですが。そこで、とはいえ、現実にニーズがあることもございます…", "…ーズが存在すること、それから医師にも職業選択の自由があること等と医師養成課程に税金投入していることとのバランスを取る上で、保険適用外の診療を…", "…用外の診療を行う医療機関への課税をしっかり強化をしていただいて、医師養成に税金が使われていることとのバランスを図るべきではないかと考えており…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/15", "sentence": ["…います。現に稼いでおられるところからはしっかりいただいて、それを医師養成課程に投入していくような発想を引き続き取っていただきたいというふうに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305268X00120240227/25", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第五分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305267X00120240227/174", "sentence": []}, {"url": "https://kokkai.