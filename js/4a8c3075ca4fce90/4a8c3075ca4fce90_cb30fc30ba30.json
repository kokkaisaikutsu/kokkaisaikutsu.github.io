[{"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/17", "sentence": ["…進めておりますが、この十か年計画も後半に差しかかってきた今日、国民のニーズに沿った地図整備が実現されているか改めて見直し、前に進める必要があ…", "…は、法務局でなければ整備できない大都市部や著しい地図混乱地域といったニーズ、緊急性が高いものから優先順位を付けて進めなければならないと考えて…", "…の大都市部、二つ目として人口集中地域の中でも防災・減災の観点から特にニーズの高い地域など、法務局による地図作成が急がれる地域が多々ございます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/33", "sentence": []}]}]}]