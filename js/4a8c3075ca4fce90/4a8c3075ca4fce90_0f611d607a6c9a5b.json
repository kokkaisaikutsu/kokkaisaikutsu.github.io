[{"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/29", "sentence": ["…に憂慮されるのは、所有者不明、管理不全が進行していくと区分所有者の意思決定が阻害されるおそれがあることであります。現行の区分所有法ですが、区…", "…ることであります。現行の区分所有法ですが、区分所有者の、所有者間の意思決定、これは集会において多数決で決議をすることにより行われております。…", "…なっているため、そのような者が多いと多数決に必要な賛成が得られず、意思決定を行うことが困難な状況になります。この状況を放置すると、建物をきち…", "…と管理しようとする区分所有者がいても、必要な賛成が得られないために意思決定をすることができず、建物が管理不全になっていくことになりかねません…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/33", "sentence": []}]}]}]