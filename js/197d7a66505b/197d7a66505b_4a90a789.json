[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/207", "sentence": ["…の方々の一日も早い救助を心から願っております。海難事故を起こした知床遊覧船は、五月二日に業務上過失致死容疑で家宅捜査を受けました。同社の運航…", "…携帯電話の件です。この件について国土交通省から説明を受けました。知床遊覧船は、四月二十日に中間検査を受けた際に、船長から携帯電話に変更したい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/209", "sentence": ["…だと思うんですね。それで、ちょっと委員長にお願いなんですけども、知床遊覧船の安全管理規程、それからＪＣＩが携帯電話を認めた内規の提出を求めた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/211", "sentence": ["○紙智子君で、遊覧船の安全管理規程を届ければ事実上は事業者任せと。ＪＣＩは、携帯電話の電波がつながらないエリアがあっても認めるというんですね…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/229", "sentence": []}]}]}]