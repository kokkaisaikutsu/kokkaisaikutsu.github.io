[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/213", "sentence": ["…、今後の工期の柔軟化を検討するように求めているわけですけれども、この完成時期を遅らせることで工事費を抑えることができれば一つの選択肢という意…", "…という意見もあったようなんですね。そこで、国土交通大臣にお聞きするんですけれども、国土交通省として完成時期を含めてこれ検討するのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/215", "sentence": ["○紙智子君今のお答えは、完成ありきということではなくて、必要なことをやるということだと思うんですね。それで、新函館北斗から札幌間の地方負担分…", "…、六年間でトータルすると五百五十六億円の赤字なんですね。二〇三〇年の完成を目指しているんだけれども、今後赤字がどこまで膨らむのか、で、この赤…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/219", "sentence": ["…一億円です。二〇二〇年度の予算は七億円で、測量や地質調査、設計費だと聞いています。このアクセス道は何年までの完成を目指しているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/229", "sentence": []}]}]}, {"date": "2023-05-10", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510