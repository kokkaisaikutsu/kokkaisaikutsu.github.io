[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/99", "sentence": ["○紙智子君公的なものから民間にだんだんこう流れが変わっていったら、やっぱり経費に占める種苗のコストというのは増加するんじゃないかというふうに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/193", "sentence": []}]}]}, {"date": "2020-12-01", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00520201201/161", "sentence": ["…業採種の種苗を保存、利用、交換、販売する権利ということがうたわれています。今回の改正は、こういう流れに逆行するものになるんじゃありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/tx