[{"date": "2022-03-25", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00520220325/51", "sentence": []}]}, {"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/200", "sentence": ["…沖地震と、様々な困難を強いられています。今回の大地震を受けて、まず、二之湯大臣は、国としてできる限りのことをしたいと言われました。激甚災害に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/208", "sentence": ["…思うんです。住宅の応急修理制度や被災者生活再建支援制度の適用条件の緩和を検討すべきではないかと思いますけれども、二之湯大臣、どうでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/210", "sentence": ["…従来の枠を超えた支援を拡大していくように検討をお願いしておきたいと思います。それで、二之湯大臣はここまでで結構です。ありがとうございました。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/214", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/228", "sentence": []}]}]}]