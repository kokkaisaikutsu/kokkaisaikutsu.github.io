[{"date": "2022-04-14", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/96", "sentence": ["…は基本方針を定めることになっています。この基本方針というのは、生物の多様性の保全を図るための施策に関する国の計画と調和が保たれたものでなけれ…", "…こで、今日、環境省来ていただいているんですけど、環境省にお聞きしますが、ゲノム技術で開発した植物などが生物の多様性に影響を与えるでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/98", "sentence": ["…たりもして、ちょっと農水省にも聞きたいんですけど、ゲノム作物が生物の多様性に影響を与えるということになったら、これ有機農家というのは困るんじ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00920220414/103", "sentence": ["…要だと。しかし、ゲノム作物が新たな不安を広げていることになれば、生物多様性とか生態系から見ても環境と調和の取れたシステムにならないと思います…"]}]}]}]