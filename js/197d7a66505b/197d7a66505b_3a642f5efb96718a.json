[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/207", "sentence": ["…航は届出どおりであるかどうかのチェックをしているかどうか。二つ目は携帯電話の件です。この件について国土交通省から説明を受けました。知床遊覧船…", "…けました。知床遊覧船は、四月二十日に中間検査を受けた際に、船長から携帯電話に変更したいと申請があったと。そのときに、日本小型船舶検査機構、Ｊ…", "…たいと申請があったと。そのときに、日本小型船舶検査機構、ＪＣＩは、携帯電話がつながる範囲外であってもつながることがあるので認めたというんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/209", "sentence": ["…ね。それで、ちょっと委員長にお願いなんですけども、知床遊覧船の安全管理規程、それからＪＣＩが携帯電話を認めた内規の提出を求めたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/211", "sentence": ["…で、遊覧船の安全管理規程を届ければ事実上は事業者任せと。ＪＣＩは、携帯電話の電波がつながらないエリアがあっても認めるというんですね。安全運航…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/229", "sentence": []}]}]}]