[{"date": "2021-03-25", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/109", "sentence": ["…かというのがよく分からないままで来ているんですけど。これまで、苗木の新芽を例えば鹿に食べられる、それで木が育たない、だから造林が進まないとい…", "…問題もありました。北海道もエゾシカがすごく増えているというのもあって、芽も食べるし皮も食べちゃうんですけど、林野庁からはエリートツリーは成長…", "…エリートツリーは通常の苗木よりも一・五倍以上成長が早いといっても、鹿は芽を食べるのをやめるわけじゃないわけですよね、生きていくために必死です…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00520210325/122", "sentence": []}]}]}]