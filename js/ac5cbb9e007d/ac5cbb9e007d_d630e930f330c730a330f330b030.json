[{"date": "2022-03-23", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/76", "sentence": ["…になっていくのではないかと思います。そうしますと、登録制度自体がブランディングされていく必要があるのではないでしょうか。それぞれの博物館であ…", "…うか。それぞれの博物館であったり美術館、また動物園は、いろいろなブランディングにも努めているとは思うんですけれども、制度自体でブランディング…", "…なブランディングにも努めているとは思うんですけれども、制度自体でブランディングをしていく。登録をすることによって得られる信用度、また認知度と…", "…と思うんですけれども、この辺りの好循環をつくっていくということに関して、ブランディング、どのように大臣、お考えでいらっしゃいますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X00420220323/88", "sentence": []}]}]}]