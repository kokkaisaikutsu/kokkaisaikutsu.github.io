[{"date": "2022-03-29", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/60", "sentence": ["…Ａに関する改正案は、ＩＤＡの増資に対して政府が約四千二百六億円の追加出資を行うことを規定する法案でございます。過去、日本が世界銀行などから受…", "…いうものの、国民の皆様から集めた税金で行うことであるがゆえに、今回の出資に関して国民の皆様から御理解をいただく必要があると考えております。そ…", "…で、財務省国際局にお聞きします。今回のようなＩＤＡなどへの途上国への出資をする理由、出資によって将来得られるものなどについて御説明いただきた…", "…局にお聞きします。今回のようなＩＤＡなどへの途上国への出資をする理由、出資によって将来得られるものなどについて御説明いただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/62", "sentence": ["…リスはＧＤＰ比でいうと圧倒的に大きな負担をしております。ただ、今回の出資割合として、今回、第二十次だと、出資割合としてアメリカが大幅に増やし…", "…負担をしております。ただ、今回の出資割合として、今回、第二十次だと、出資割合としてアメリカが大幅に増やしてイギリスは減らしたと承知をしており…", "…幅に増やしてイギリスは減らしたと承知をしております。ここで、ある国の出資比率について注目しておきたいことがありまして、それは中国になります。…", "…て、それは中国になります。中国は、日本の約三倍のＧＤＰを誇りながら、出資比率としては日本の約三分の一であることについて、物足りないように感じ…", "…ついて、物足りないように感じます。そこで、国際局にお聞きします。中国の出資比率が小さいことについて、御見解をお聞かせいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00820220329/73", "sentence": []}]}]}, {"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00520230317/205", "sentence": []}, {"url"