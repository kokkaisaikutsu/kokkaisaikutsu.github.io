[{"date": "2022-03-11", "meeting": [{"meeting_name": "参議院 北朝鮮による拉致問題等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815253X00320220311/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815253X00320220311/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815253X00320220311/178", "sentence": ["…朝鮮学校の教育内容に関する話題となります。二〇一六年九月に、東京都の小池百合子知事が、朝鮮学校が朝鮮総連の強い影響下にあると結論付けた平成二…", "…いうことについて、私は理解し難いものがあります。今回紹介した報告書を小池都知事が再掲載したことは、拉致問題解決に向けた自治体からの働きかけと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815253X00320220311/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815253X00320220311/182", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/189", "sentence": ["…出された住民監査請求について再調査などが勧告されており、これを受けて小池百合子東京都知事が令和五年二月二十八日に講じた措置というのが公表され…", "…ございます。本件の背景として、幾つか問題点を挙げさせていただきます。小池都知事と東京都議会の一大勢力である都民ファーストの会がこの件に関して…", "…ストの会とされております。今回、東京都福祉保健局のこの局長の人事には小池百合子氏が介入していることが、報道であったり、上田令子東京都議にも指…", "…がっている状況だと思います。そこで、再調査結果についてお聞きします。小池都知事は、三月三日の都の記者会見において、そもそもこの事業は国の事業…", "…もは委託を受けているということですと発言をされておられます。つまり、小池都知事は、若年被害女性等支援事業を、国の事業であって東京都は委託を受…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320