[{"date": "2023-04-14", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/62", "sentence": ["…え申し上げます。まず、投票率につきましては、今も四十一道府県議会議員選挙四一・八五％という数字をお示しいただきました。二・一七ポイント前回よ…", "…ます。先ほども、私、石川県の出身と申しましたが、石川県の県議会議員の選挙の投票率は四六・三六％ということで、前回を一・六四ポイント上回りまし…", "…前回を一・六四ポイント上回りました。これは、投票率というものはやはり選挙の争点とかあるいは競争の激しさとか様々な事情により上下するものである…", "…々な事情により上下するものであると思いますけれども、一般論としては、選挙は民主主義の根幹であり、できるだけ多くの有権者に投票に参画していただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/114", "sentence": []}]}]}]