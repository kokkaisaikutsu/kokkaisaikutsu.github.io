[{"date": "2022-11-17", "meeting": [{"meeting_name": "衆議院 地方創生に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/31", "sentence": ["…らは、地方の発意に根差した提案募集方式を導入して、国から地方への権限移譲を含む地方分権改革の取組を進めております。令和三年までの八年間で、地…", "…ついて趣旨を踏まえた対応を行っておりまして、特に、国から地方への権限移譲については、平成二十六年以降、地方分権一括法において、農地転用許可権…", "…いては、平成二十六年以降、地方分権一括法において、農地転用許可権限の移譲や地方版ハローワークの創設を始めとして五十を超える法律を改正するなど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/113", "sentence": []}]}]}, {"date": "2023-04-14", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/20", "sentence": ["…革推進委員会からの勧告に基づき、国主導による集中的な取組を行い、権限移譲や義務付け、枠付けの見直しなどを推進して、延べ三百六十七本という法律…", "…域の実情に応じた主体的な土地利用を可能とするための農地転用許可権限の移譲や、地方版ハローワークの創設による就労支援の充実などが挙げられるかと…", "…られるかと考えております。近年は、地方から寄せられる提案のうち、権限移譲を求めるものは比較的少なく、九割超が地方に対する義務付け、枠付けの見…", "…団体の職員数も減少傾向にあり、地方公共団体の業務の増加につながる権限移譲を求める機運が余り高まっていないことも一因かなと考えております。一方…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X0062