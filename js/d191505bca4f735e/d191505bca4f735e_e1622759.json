[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/4", "sentence": ["…たいと思います。今回の法改正、一番の大きな目玉というのは、支援範囲を拡大をしていただく。本当にありがたい。そして、七月にさかのぼってやってい…", "…御決定をいただいておりますけれども、そのとき、まだ適用範囲に関しては拡大をしておりませんでした。大きな災害が多発している近年、このことに関し…", "…かと思われますけれども、なぜ平成十九年の前回から十三年たった今、適用範囲の拡大に至ったかもあわせて御見解をいただければというふうに思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/22", "sentence": []}]}]}]