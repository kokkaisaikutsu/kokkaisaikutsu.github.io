[{"date": "2024-02-14", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/376", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/378", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/380", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/382", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/384", "sentence": ["…確認させていただきました。先日の報道ですが、二階議員の政治資金団体が書籍の購入として三千五百万円の修正申告をされているということです。ここで…", "…ことです。ここで、財務大臣に質問です。個人事業主が確定申告をする際、書籍を経費として認めてもらうにはどんな基準を設けておられるか、どんなケー…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/386", "sentence": ["○林（佑）委員当然、書籍の目的に応じ、その確証、領収書の提出であるとか、漫画の本や趣味の本など仕事とは関係のない本は認めないなど、合理性まで…", "…ないなど、合理性まで問うことと思います。それでは、政治資金団体が購入する書籍代を経費とみなす際、何を確認されるのでしょうか。お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/388", "sentence": ["○林（佑）委員ありがとうございます。国民が確定申告をする際に書籍を経費算入するには、書籍の中身を含め、国税の厳しいチェックが入るケースもある…", "…りがとうございます。国民が確定申告をする際に書籍を経費算入するには、書籍の中身を含め、国税の厳しいチェックが入るケースもあるように、政治資金…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/390", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/392", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/394", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/396", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/398", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00920240214/400", "sentence": []}]}]}]