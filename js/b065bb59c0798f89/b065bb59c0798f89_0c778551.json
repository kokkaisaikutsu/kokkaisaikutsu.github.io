[{"date": "2020-11-24", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/89", "sentence": ["…また情報支援について、これ経産省さんにお伺いをしたいと思います。愛知県内にある、ある航空機部品の組立てを行う会社では、仕事量が急激に減ってし…", "…立てを行う会社では、仕事量が急激に減ってしまって、余ってしまった人を県内の自動車産業に一時的に出向させることによって雇用の維持が何とかできた…", "…るんですけれども、日本の航空業界は大体そういう状況です。今回訪問した県内の別の企業からは、エアバスのようなこれまで余りつながりがなかったよう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314080X00220201124/110", "sentence": []}]}]}]