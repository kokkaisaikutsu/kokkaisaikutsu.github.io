[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/53", "sentence": ["…思います。次に、二〇三〇年までに陸と海の三〇％を保全するサーティー・バイ・サーティーの実現について、これ環境省の政府参考人に伺います。この生…", "…物多様性回復に向けて鍵となる取組が、その先ほどありましたサーティー・バイ・サーティーです。この目標の実現に向けて、国立公園、国定公園などの保…", "…、生命の誕生が集中するような領域もあります。よって、このサーティー・バイ・サーティー、この三〇％の保全については、陸域、海域、それぞれトータ…", "…全の観点から細かく評価をしていくべきと考えます。さらに、サーティー・バイ・サーティーの実現に向けて切り札になるのではないかと議論されています…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114006X00220230309/71", "sentence": []}]}]}]