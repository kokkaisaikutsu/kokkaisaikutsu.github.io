[{"date": "2023-06-12", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/99", "sentence": ["…きます。次に、薬剤耐性について伺います。薬剤耐性とは、抗生物質などの抗菌薬に対して病原菌などの細菌が耐性、耐える性質を獲得してしまった状態の…", "…るということであります。ここで鍵となるのが薬剤耐性に効果がある新しい抗菌薬の開発なのでありますが、これはとても開発が難しくて、掛けたお金が回…", "…が相次いでいます。これではいけないと、各国の政府は相次いでこの新しい抗菌薬の開発を積極的に支援をするようになっております。我が党においても、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/103", "sentence": ["…ているのがカルバペネム耐性菌という厄介な細菌でありまして、切り札的な抗菌薬であるカルバペネム系抗菌薬に対して耐性を獲得をしてしまって、切り札…", "…菌という厄介な細菌でありまして、切り札的な抗菌薬であるカルバペネム系抗菌薬に対して耐性を獲得をしてしまって、切り札が効かないという状況になっ…", "…わけであります。これに効果が見込めるのが、現在我が国の企業が開発中の抗菌薬であります。既にＧ７では日本、カナダ以外の五か国で薬事当局の承認が…", "…ここで、仮にこの薬に承認が下りた場合、先ほど秋野財務副大臣からもありました政府の抗菌薬確保支援事業の対象になるとの理解でよろしいでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X01020230612/115", "sentence": []}]}]}]