[{"date": "2021-03-05", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404319X00120210305/4", "sentence": []}]}, {"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/311", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/566", "sentence": ["…や港湾の今後の在り方につきましては、必要に応じ、関係省庁、また地元の沖縄県などの自治体や利用者始め関係者の意見を聞きながら適切に検討してまい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/570", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/579", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/583", "sentence": ["…う話があれば対応したいと思いますし、この空港、県管理でありますから、当然のことながら沖縄県も交えなければいけないというふうに思っております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/585", "sentence": ["…赤羽一嘉君）これも、先島諸島の港湾、全て県管理の港湾でありますので、沖縄県と検討しながら、これ災害対応のときの必要なライフラインだというふう…"]}]}]}]