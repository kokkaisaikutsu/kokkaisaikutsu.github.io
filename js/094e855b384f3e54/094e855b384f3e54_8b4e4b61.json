[{"date": "2021-03-16", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/19", "sentence": ["○三宅伸吾君続けて、岸防衛大臣にお聞きをいたします。台湾での有事は、我が国にとって存立危機事態に該当いたしますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/21", "sentence": ["…点も考慮いたしまして、あってはならないことではございますけれども、万が一このような事態が起こった場合、日本としてはどのように対応されますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/23", "sentence": ["…います。今私が申し上げました四つのポイントも考慮しまして、このような事態が起こった場合、日本としてはどのように対応されるでしょうか。また、問…", "…応されるでしょうか。また、問題は、海上保安庁の管轄範疇にとどまるのでしょうか。それとも、海上自衛隊が指揮を執るような事態になるのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00220210316/31", "sentence": []}]}]}]