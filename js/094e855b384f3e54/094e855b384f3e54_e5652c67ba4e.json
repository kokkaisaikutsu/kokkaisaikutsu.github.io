[{"date": "2023-05-22", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/65", "sentence": ["…制度を抜本的に変更するとした場合には、やはり労働者でございますので、日本人にない規制を外国人だけに厳格に適用するのはやはり妥当ではないと考え…", "…しますけれども、労働力確保という一本に絞って制度を見直すのであれば、日本人に対して規制を掛けていない分野について外国人にだけ掛けるというのは…", "…はなかなか国際的には通用しないんだと思います。理念といたしましては、日本人労働者と同等の扱い、又はそれに近い扱いをするのが多分国際標準だろう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/71", "sentence": ["…外国人の入超分がほぼ続くであろうという推計でやれば、五十年後に、二〇七〇年に日本人の人口のうち一割が外国人になるという理解でよろしいですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00920230522/83", "sentence": []}]}]}]