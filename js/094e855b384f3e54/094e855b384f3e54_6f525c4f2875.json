[{"date": "2023-05-10", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/6", "sentence": ["…を継続するのが基本だとおっしゃられました。そして、様々な政策の効果と副作用のバランスを間違えないように常に注意深く分析し、できる限り情報発信…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/8", "sentence": ["…。その一方で、光強ければ影深しという言葉がございますように、やっぱり副作用もあるんだろうと思います。様々な識者が多くの副作用について論文書か…", "…すように、やっぱり副作用もあるんだろうと思います。様々な識者が多くの副作用について論文書かれておられますけれども、私が考えるに、最大の副作用…", "…の副作用について論文書かれておられますけれども、私が考えるに、最大の副作用は、証券市場の株価形成機能を私は損なったんではないかと深く憂慮をい…", "…私は、日本銀行の利潤を目的としない大量の長期の証券の保有は、その点で私は副作用があったと考えておりますけれども、植田総裁、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/32", "sentence": []}]}]}]