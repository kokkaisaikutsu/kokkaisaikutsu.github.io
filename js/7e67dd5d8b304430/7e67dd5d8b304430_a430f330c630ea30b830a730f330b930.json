[{"date": "2022-03-10", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/76", "sentence": ["…てお伺いします。今回のウクライナに対する侵略、非常にＳＮＳとかインテリジェンスといった情報戦が役割を果たしているという気がいたします。長期化…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/78", "sentence": ["…ありがとうございました。また、同じく情報戦という意味でいくと、インテリジェンスが非常に重要だと思います。日本のような平和的な、防御的な国こそ…", "…が非常に重要だと思います。日本のような平和的な、防御的な国こそインテリジェンスの力が必要でありまして、先に、先手を見越すことができれば事前に…", "…ば事前に手を打ち問題回避ができます。しかし、日本には、もちろんインテリジェンス機能は各省に、必要なところにあるといえばあるんですけれども、Ｃ…", "…Ｓのような統合された対外情報機関はございません。私は、この際、インテリジェンス機関の設置を含め、インテリジェンス機能を日本、高めることについ…", "…ございません。私は、この際、インテリジェンス機関の設置を含め、インテリジェンス機能を日本、高めることについて真剣に検討すべきだと思いますが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/95", "sentence": []}]}]}]