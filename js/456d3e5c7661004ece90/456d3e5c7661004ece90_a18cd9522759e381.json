[{"date": "2022-11-17", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/11", "sentence": ["…らいいのかなというふうに思います。もう一つ、これは是非、今日は鈴木財務大臣に、お越しでいらっしゃるんで、是非御検討いただきたいことがあるんで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/13", "sentence": ["…高い給与になっているということでありまして、例えばこの、まあこれは財務大臣の所管ではありませんけど、労働市場をもう少し市場を反映させるような…", "…みというのはつくれないんじゃないかなというふうに思いますので、是非財務大臣は、その要求するのは別の役所だと思いますけれども、そういう要求が来…", "…ので、是非そういったこともお願いしていきたいと思います。あわせて、財務大臣の所掌の中でできることだと思いますけれども、例えば今会社の中にいら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/15", "sentence": ["…きるような、そんな環境をまずつくっていただきたいと思いますし、まず財務大臣に、そういった環境ができた、つくっていただけるように、これは政府と…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00420221117/19", "sentence": []}]}]}, {"date": "2023-03-14", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/5", "sentence": ["○浅尾慶一郎君自由民主党の浅尾慶一郎です。冒頭、鈴木財務大臣が金融担当大臣も兼務されておりますので、ちょっと、昨日の質疑通告ではなくて、急遽…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/7", "sentence": ["…し、納税者が理解しやすいものとするということだというふうに理解しておりますが、そうした理解でよろしいかどうか、財務大臣、御答弁お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/13", "sentence": ["…いう考え方もあるんではないかなというふうに思っておりますが、こうした活力という考え方について財務大臣はどのように考えておられますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/15", "sentence": ["…の費用の分を何倍かに引いていくというような考え方、こういうことについてはどのように考えておられるか、財務大臣、御答弁お願いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/19", "sentence": []}, {"url": "https://kokkai.ndl