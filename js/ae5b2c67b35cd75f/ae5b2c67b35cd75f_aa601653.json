[{"date": "2023-05-16", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/128", "sentence": ["○宮本（岳）委員経営の悪化が見込まれないとできない制度だったんですね。そんな計画を立てれば、あの放送局は経営危機らしいということになりますの…", "…改正では、経営の状況にかかわらず認定できることといたしました。経営の悪化とか収益性の向上などにかかわらず、これで全ての放送時間帯で同一放送番…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/130", "sentence": ["…のニーズに応えられない可能性が出てくると考えられる、その結果、収益の悪化を招き、ひいては地域情報発信の量、質共に著しく低下するおそれがあると…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X01320230516/147", "sentence": ["…盤強化計画を改め、制度利用について収益性の向上の規定を廃止し、経営の悪化が見込まれなくても、特定放送番組同一化実施方針の認定によって、特段の…", "…放送の魅力が失われれば、結果的に、視聴者や地元企業の放送離れ、経営の悪化を招くことになります。また、総務省は、将来にわたる放送事業の確保を名…"]}]}]}]