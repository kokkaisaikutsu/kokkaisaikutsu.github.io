[{"date": "2022-04-07", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/107", "sentence": ["…結果で、男性職員の育休の取得率は何％でございましょうか。また、今日は人事院にも来ていただいております。人事院に、国家公務員全体の男性職員の取…", "…得率は何％でございましょうか。また、今日は人事院にも来ていただいております。人事院に、国家公務員全体の男性職員の取得率をお答えいただきたい。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/114", "sentence": ["…般職では超えている、国はよくやっていると思ってしまいましたけれども。人事院にも同じように聞こうと思います。資料二を見ていただきたい。育児休業…", "…、二週間以上一か月以下五〇・六％の合計七二・五％、男性は。これも大きな違いなんですね。人事院の次長に聞きます。この違いはどこにあるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01020220407/124", "sentence": []}]}]}]