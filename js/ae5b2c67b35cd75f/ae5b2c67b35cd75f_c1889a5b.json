[{"date": "2023-04-14", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X01120230414/4", "sentence": []}]}, {"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/93", "sentence": ["…が党も、今回の改正は、基本的に賛成です。権利者側からは、今回の新たな裁定制度が権利の切下げにつながるのではないかとの危惧も出されておりますの…", "…で、まず、幾つか確認しておきたいと思います。今回の法改正にある新たな裁定制度は、利用許諾を確認できなければ利用できないというこれまでの一般原…", "…めの措置を取ったにもかかわらず、確認ができない場合には、文化庁長官の裁定を受け、補償金を供託することにより、裁定において定める期間に限り、当…", "…きない場合には、文化庁長官の裁定を受け、補償金を供託することにより、裁定において定める期間に限り、当該未管理公表著作物等を利用することができ…", "…未管理公表著作物等を利用することができる、こうなっております。現行の裁定制度よりも簡易に迅速に使えるようにしようというのは一定理解するものの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X00820230414/125", "sentence": []}]}]}]