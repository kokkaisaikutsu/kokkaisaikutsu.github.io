[{"date": "2022-04-19", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/190", "sentence": ["…得ないわけであります。続いて、受信契約の締結に応じない者を対象とする割増金制度について聞きたいと思います。受信料契約は、受益者負担の原則とは…", "…民の理解なしには成り立たない制度、これが受信料だと思います。しかし、割増金で本当に正しく制度が理解されていくのか、極めて疑問であります。そも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/192", "sentence": ["…強引な営業を行って、こじれたというケースも私は耳にするんですね。この割増金、つまり、鉄道のきせると同じ通常料金の三倍程度というものを想定して…", "…めることにならないんじゃないか。理解を求めていかないといけないときに割増金をちらつかせれば、強制してくるのがＮＨＫだと理解されてしまう。これ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01320220419/215", "sentence": ["…であり、極めて重大です。第二に、受信料契約の締結に応じない者を対象に割増金制度を導入することです。鉄道の不正乗車を参考に約三倍の額が想定され…"]}]}]}, {"date": "2023-03-16", "meeting": [{"meeting_name"