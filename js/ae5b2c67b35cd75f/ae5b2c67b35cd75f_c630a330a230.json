[{"date": "2023-05-10", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/172", "sentence": ["…とについても聞きたいと思います。日本語教室は、教える人の多くがボランティアによって担われている。支援者の高齢化や次世代の担い手不足により、継…", "…いて、日本語教師数は二〇二一年度で何人おられるか。そして、勤務形態別に、常勤、非常勤、ボランティア、それぞれどういう比率になっておりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/174", "sentence": ["…の内訳は、常勤が一五・七％となっておりまして、非常勤が四割弱、ボランティアが半分弱、これが現状なんですね。こうなってくると、ボランティアです…", "…ボランティアが半分弱、これが現状なんですね。こうなってくると、ボランティアですから、収入は本当に限られているわけですよ。そうなりますと、当然…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105124X01220230510/193", "sentence": []}]}]}]