[{"date": "2022-05-18", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/232", "sentence": ["…しょうか。一九九八年には建築基準法が改正され、住宅の質に関する検査も民間任せにしたことから、耐震偽装などの問題が発生しました。民間任せで住宅…", "…する検査も民間任せにしたことから、耐震偽装などの問題が発生しました。民間任せで住宅の新築の量ばかりを重視する政策は、とっくの昔にそのひずみを…", "…家を政府が財政支援をして改修する、これもやっていただきたい。これまで民間任せで、量重視で走ってきた住宅政策は、質重視へと抜本的な方向転換が必…", "…いと考えます。住まいは権利です。この福祉政策を、多少の補助金をつけて民間事業者に任すのではなくて、責任ある国家として施策を講じていただきたい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01320220518/240", "sentence": []}]}]}]