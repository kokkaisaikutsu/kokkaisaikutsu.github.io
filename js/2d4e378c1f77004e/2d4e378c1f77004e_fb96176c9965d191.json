[{"date": "2022-10-26", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/131", "sentence": ["…は現在検討中でございまして、電力料金請求システムを活用して、毎月の電気料金請求において直接的かつ実感できる形で負担軽減策を講ずる考えでありま…", "…あります。支援の幅につきましては、家庭については来年春に想定される電気料金の上昇による平均的な負担額に対応する額といたしまして、また、時期に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004080X00220221026/145", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/26", "sentence": []}]}, {"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/246", "sentence": ["○副大臣（中谷真一君）電気料金の改定申請につきましては、先般の総理の御指示を踏まえまして、為替や燃料価格が変動している中、燃料費をどのように…", "…正かつ丁寧に審査を行っていきたいというふうに考えております。また、電気料金の負担軽減については、総合経済対策に基づきまして、二月の申請分から…", "…府に提言するよう御指示されたことを踏まえ、与党とも連携をしながら、今後の電気料金の支援について検討してまいりたいというふうに考えております。"]}]}]}]