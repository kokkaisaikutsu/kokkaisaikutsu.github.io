[{"date": "2022-06-07", "meeting": [{"meeting_name": "衆議院 科学技術・イノベーション推進特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/39", "sentence": ["…究データに限らず産業データも同じだと思っていて、よく、データのプラットフォームをつくるというのは、言うのは簡単ですけれども、当然、多分、デー…", "…ン基本計画におきまして、今、政府としては、研究データの中核的なプラットフォームや検索体制の構築をして、産学官における幅広い利活用を進めていま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/41", "sentence": ["…・イノベーション分野におきましても、先ほども申し上げた中核的なプラットフォームですとか、また、それに加えて、材料分野あるいはライフサイエンス…", "…えて、材料分野あるいはライフサイエンス、こうした研究分野ごとのプラットフォーム、この構築というものを通じて、研究データを保存し、共有し、また…", "…組というものを先行的に行ってきているところであります。こうしたプラットフォームの構築に当たりましては、最新の知見を活用して、より効果的に研究…", "…とをしっかりと考えていきたいと思いますし、より信頼性の高い、強固なプラットフォームの形成にこれからもしっかりと取り組んでいきたいと考えます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803910X00320220607/77", 