[{"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/67", "sentence": ["…ただきたいと思います。飼料等の価格高騰を受けまして、とりわけ酪農家の営農の危機が叫ばれ続けております。地元の愛知県豊橋市の畜産・酪農農家の皆…", "…ございますが、改めて、酪農家を守り、酪農産業を維持していくためにも、営農継続に向けた支援をお願いしたいというふうに思います。また、実際、私も…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/69", "sentence": ["…ませんけれども、酪農というインフラというべき産業を維持していくために、中長期的な営農支援の視点も重要と考えます。野村大臣の御答弁を求めます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X00320230317/83", "sentence": []}]}]}]