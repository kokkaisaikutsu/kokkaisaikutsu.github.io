[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/5", "sentence": ["…検討を進め、早急に結論を得ると明記されています。この一年半でどのような進捗があり、いかなる結論を日本政府として出されたのか、御答弁ください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/7", "sentence": ["…提案し、当時の大臣からもその意義を明確に支持する答弁をいただきました。あれから半年がたちます。この間の日本政府の進捗状況をお尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014889X00420221110/18", "sentence": []}]}]}]