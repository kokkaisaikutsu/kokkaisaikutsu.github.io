[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/11", "sentence": ["…うことになりました。ちょっと時間の関係でそこは飛ばして、その上で、今金融庁で、僕はすごく努力されていると思うんですが、この資料をちょっと、お…", "…方ですかね、損しているということになっているんです。預金から投資へと金融庁はよく言っていますが、投資してみてこれだけ損が出るようなところにど…", "…ことなんじゃないかなと思っていて、私はこの情報公開すごく評価しているんです。どうして金融庁はこういった情報を公開しようと思ったんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01320220510/22", "sentence": []}]}]}]