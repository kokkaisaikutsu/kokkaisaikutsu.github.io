[{"date": "2022-12-06", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/109", "sentence": ["…を使っていると思うんですが、他方で、防衛装備移転三原則では、その運用指針の中で、紛争当事国への輸出は禁止となっているんですが、ロシアと実質的…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/113", "sentence": ["…にも署名をしていない国に防衛装備を移転する場合の目的は、いわゆる運用指針の１の運用装備の海外移転を認め得る案件の（２）、イの（エ）にあるよう…", "…ると承知をしています。したがって、今回ウクライナに防衛装備品を供与したというのは、この指針を変更若しくは追加したという理解でよろしいですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00820221206/121", "sentence": []}]}]}]