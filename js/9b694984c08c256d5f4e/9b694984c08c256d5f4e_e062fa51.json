[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/184", "sentence": ["…七九年に始まった日本のＯＤＡ、二〇二二年、四十二年間行われて、まあ二〇二二年に終了しましたが、この対中国のＯＤＡ、拠出総額は幾らでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/186", "sentence": ["○榛葉賀津也君これだけ拠出して、今の中国見てみると、結果として、台湾がのみ込まれ、チベットやウイグルでの人権弾圧は更に激しさを増し、台湾有事…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/191", "sentence": []}]}]}, {"date": "2022-11-08", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/151", "sentence": ["…ッジした金額だと思うんですけれども、この国際緊急アピールに、国連の緊急アピールに対して実際に拠出した割合というのはどれぐらいなんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/153", "sentence": ["○榛葉賀津也君結局、数字は勇ましいんですけれども、実際拠出されているのは二割ないということです。日本、真面目でして、約束した金額は必ず出すと…", "…すけれども、中国、この一億六千万ドルのうち、これ借款はあるんでしょうか、それと、どれぐらい実際拠出されていますか。もし分かったらで結構です。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00420221108/161", "sentence": []}]}]}]