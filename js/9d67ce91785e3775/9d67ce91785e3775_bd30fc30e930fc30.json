[{"date": "2023-02-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/80", "sentence": ["…に思っています。御指摘のとおり、森林面積が大きいということで、メガソーラーをやろうと思ったら、それは不利かもしれません。それから、遠浅の海が…", "…大型の洋上風力をやるためには、それは不利かもしれません。でも、メガソーラーも大型の洋上風力も再生可能エネルギーの中ではごく一部ですし、そして…", "…地かもしれないけれども、そうしたところについては、農業と両立させたソーラーシェアリングの議論は、我が党からもいろいろ申し上げていますが、全然…", "…それから、森林が多くて急峻な地形が多いというのは、これは確かにメガソーラーには不利かもしれません。そして、我が国は、実は再生可能エネルギーと…", "…散化された再生可能エネルギーが、適地があまたあるのに、大規模なメガソーラーとか大規模洋上風力に目が行っているというこの感覚が再生可能エネルギ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/82", "sentence": ["…も、利用のために利用期間を延長するということはやりながら、もちろんソーラーシェアリングなどに壁があるのは、困難があるのはよく分かっていますよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01120230215/102", "sentence