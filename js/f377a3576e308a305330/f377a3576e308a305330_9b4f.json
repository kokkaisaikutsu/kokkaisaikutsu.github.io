[{"date": "2022-03-25", "meeting": [{"meeting_name": "参議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/71", "sentence": ["…、これ一部抜粋しますけど、電気工作物は、その電気工作物が発電事業の用に供される場合にあっては、これに作用する地震力による損壊により一般送電事…", "…にあっては、これに作用する地震力による損壊により一般送電事業者の電気の供給に著しい支障を及ぼすことがないよう耐震性を有するものでなければなら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814858X00420220325/75", "sentence": ["…不安も感じます。是非とも、ちょっと本当に、皆さんの生活に支障がない安定供給をいかに、もう火力発電所が地震の被害にできるだけ耐え得るような設備…", "…に今この渦中にあるわけでございます。原発再稼働を掲げる前に、電力の安定供給のためにやるべきこと、できることがもっともっとあるのではないかと。…", "…くて、まずは来るべきもう大きな災害に備えてできる対策を、今日は特に電力供給に関してのお話をこの場では申し上げましたけれども、しっかりとすべき…"]}]}]}]