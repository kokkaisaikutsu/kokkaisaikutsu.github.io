[{"date": "2020-12-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/29", "sentence": ["…長もされていたわけですけれども、鶏卵、鶏肉業界から農水省に寄せられた要望書があるかと思います。この中にアニマルウエルフェアに関する要望という…", "…れども、鶏卵、鶏肉業界から農水省に寄せられた要望書があるかと思います。この中にアニマルウエルフェアに関する要望というのはあったんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/31", "sentence": ["…こ君既に資料要求も先週からさせていただいております。まだ確認ができていないということですけど、そもそも鶏卵、養鶏業界の要望書はございますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/38", "sentence": ["…のが誠意のある対応ではないかと思います。引き続き、では、なるべく早く要望書の存在含めて、アニマルウエルフェアに関する記述もそうですけれども、…", "…では、なるべく早く要望書の存在含めて、アニマルウエルフェアに関する記述もそうですけれども、養鶏業界からの要望書を資料としての提出を求めます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/40", "sentence": ["…ということなんですけれども、ちなみに、この業界団体などから受け取った要望書、確認に随分時間が掛かるということで、ちゃんと整理がされているのか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/42", "sentence": ["…な今お話だったと思いますけれども、各業界団体の素直な思いが込められた要望書ですから、さすがに、仮に行政文書に当たらないという判断をされたとし…", "…管理がなされていないということもあり得ないと思いますので、先ほどの、要望いたしましたけれども、しっかりとこの鶏卵、養鶏業界からどのような要望…", "…要望いたしましたけれども、しっかりとこの鶏卵、養鶏業界からどのような要望が寄せられているのか確認して、御報告いただきたいと思います。では、ち…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00120201208/63", "sentence": []}]}]}]