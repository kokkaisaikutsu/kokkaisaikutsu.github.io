[{"date": "2022-03-29", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/72", "sentence": ["○石垣のりこ君賃金を得て生計を立てている労働者が失業した場合の生活の安定を図る制度として雇用保険制度があるわけですけれども、今のお話の前提で…", "…用保険制度があるわけですけれども、今のお話の前提ですと、自らの労働で生計を維持している人で、失業したときの再就職を図るために、四十時間、二十…", "…きの再就職を図るために、四十時間、二十時間以上の働きがある人が主たる生計を担っていると、それ以外の二十時間未満だとそうではないという考え方が…", "…かもしれませんが、二十時間未満だから家計を維持しているとは言えない、生計を維持しているとは言えないとかそういうことも、今この時代の多様な働き…", "…方で全体として豊かになっていない現状があるわけですから、一人の稼ぎで生計を立てているわけではなく、複数の稼ぎの中で生計を立てている家計という…", "…ですから、一人の稼ぎで生計を立てているわけではなく、複数の稼ぎの中で生計を立てている家計というのは結構あるわけですよね。そうした実態はもっと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/78", "sentence": ["…ておりますけれども、六十五歳以上のやっぱり高齢者だけじゃなくて、今、生計を成り立たせるために、一か所で二十時間以上働けない、逆にセーブされて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00620220329/94", "sentence": []},