[{"date": "2022-04-07", "meeting": [{"meeting_name": "衆議院 原子力問題調査特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/31", "sentence": ["…員ありがとうございました。次に、カーボンニュートラル政策下における原子力発電の位置づけについてお伺いをさせていただきます。菅内閣は、三百八十…", "…かなり細かく詳しく書かれておりましたが、私から見て、残念なことに、原子力発電というものについての考え方を私自身が見つけ出すことができませんで…", "…で、ＥＵタクソノミーにおきましては、持続可能な経済活動の観点から、原子力発電と天然ガス、これらがＥＵタクソノミーに該当するとされて、現在欧州…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/33", "sentence": ["…来て明らかになっていると思います。エネルギーの安定供給の面からも、原子力発電を有効に活用していくことこそが国民生活と日本経済にとって必要であ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804194X00220220407/43", "sentence": []}]}]}]