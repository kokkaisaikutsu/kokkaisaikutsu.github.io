[{"date": "2022-11-08", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005254X00720221108/10", "sentence": ["…どの程度把握しているのか、お答えください。さらに、本法案における電子決済手段、いわゆるステーブルコインとは具体的にどの決済がこれに該当するの…", "…本法案における電子決済手段、いわゆるステーブルコインとは具体的にどの決済がこれに該当するのか、お答えください。そして、ステーブルコインの取引…", "…に対して有効な手段として制度設計することが可能です。現在、オンライン決済における匿名性とマネロン対策及びテロ資金供与対策への対応に不可欠な取…", "…、日本銀行が技術的な観点から調査研究を進めています。また、オフライン決済についても、求められるセキュリティーレベルを調整することで、セキュリ…"]}]}]}, {"date": "2022-11-09", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X00620221109/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004889X