[{"date": "2022-04-22", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/14", "sentence": ["…うに果たしてこの省令がなるのかどうかが問題です。実は、既に、指定国立大学法人、これは国立大学の中でも傑出した立場を持つ大学法人、これが十ある…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/16", "sentence": ["…れとあと、論文数も含めて、世界的にトップレベルである、これは指定国立大学法人も、優れた研究開発ができるということで重なる部分もあるということ…", "…ちなみに、この法案からは離れるんですけれども、私が大臣時代に指定国立大学法人として認めることにさせていただいた一橋大学が、その後、思うような…", "…思うような成果を上げていないという情報を得ています。今後、この一橋大学については、指定国立大学法人との関係ではどのようにされるのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01020220422/28", "sentence": []}]}]}]