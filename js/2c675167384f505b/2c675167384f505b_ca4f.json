[{"date": "2022-10-28", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/137", "sentence": ["…れども、法務行政と統一協会の問題についてお伺いをしたいと思います。井野俊郎防衛副大臣が法務大臣政務官だった二〇一六年に、統一協会関係者を法務…", "…ございます。記事によれば、自民党関係者の証言として、二〇一六年十一月、俊世会の一行の十数人が法務省を見学した、法務史料展示会などを見学し、井…", "…どを見学し、井野議員は政務官室にも案内をしていると報じております。井野副大臣は、俊世会の人たちを法務大臣政務官室に案内したことはありますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/139", "sentence": ["○本村委員済みません、二〇一六年十一月、俊世会の方々を招き入れたか、その点、御確認お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/146", "sentence": ["○本村委員その俊世会なんですけれども、俊世会の俊という字は井野俊郎防衛副大臣の俊を取って、そして、世は世界平和統一家庭連合から取ったというふ…", "○本村委員その俊世会なんですけれども、俊世会の俊という字は井野俊郎防衛副大臣の俊を取って、そして、世は世界平和統一家庭連合から取ったというふ…", "…員その俊世会なんですけれども、俊世会の俊という字は井野俊郎防衛副大臣の俊を取って、そして、世は世界平和統一家庭連合から取ったというふうに聞い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/148", "sentence": ["○本村委員この俊世会というのは今もあるでしょうか。俊世会、今もあるかどうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00320221028/152", "sentence": []}]}]}, {"date": "2022-11-02", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005206X00420221102/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00420221102/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00420221102/149", "sentence": ["…も、井野防衛副大臣が法務大臣政務官時代に、統一協会関係者が中心となった俊世会の人たちを法務大臣政務官室に案内したという報道に関し、確認すると…", "…たという報道に関し、確認すると先回お約束をいただきました。斉藤県議及び俊世会の中心人物から聞き取りを行ってくださったと思うんですけれ