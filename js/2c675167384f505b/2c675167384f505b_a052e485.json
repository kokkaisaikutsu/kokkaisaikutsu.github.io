[{"date": "2023-02-03", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/313", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/315", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/317", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/319", "sentence": ["…いますけれども、低次元過ぎるんです。子供ファーストじゃなくて、ワーストになっております。この低次元の状況を加藤大臣はどう考えるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/321", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/323", "sentence": ["…、そういう思いで保育士の方々は日々保育に向き合っているわけです。保育士の方々が、もう一人保育士を、こう思うのは当然じゃないですか、加藤大臣。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/325", "sentence": ["…いるというふうに思います。この十年以内の間でも確実に仕事は増えているというふうに思いますけれども、加藤大臣、お答えをいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/327", "sentence": ["…っしゃいました。この当事者の声に基づいた政策なんです。是非これは実現をしていただきたいと思いますけれども、加藤大臣、お願いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/329", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/331", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00620230203/333", "sentence": []}]}]}]