[{"date": "2021-03-19", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/8", "sentence": ["…師と環境省が幅広く連携並びに協力し、しっかりとした取組、施策をしていただきたいと思いますが、いかがでしょうか。堀内副大臣にお尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/10", "sentence": ["○畦元委員堀内副大臣、ありがとうございました。正直言いまして、二、三か所、十か所もまだ実質上はできていないようなので、できるだけ全国的に広げ…", "…ます。調査開始から十年経過しましたが、これまでの調査の進捗状況や出された成果についてお尋ねいたします。堀内副大臣、よろしくお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/17", "sentence": []}]}]}]