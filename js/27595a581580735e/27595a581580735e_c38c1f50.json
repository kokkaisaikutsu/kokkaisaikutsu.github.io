[{"date": "2022-03-30", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/96", "sentence": ["…くれている資料集の中に、防衛省の返還予定米軍基地、区域の最近五年間の賃借料及び所有者数という、こういう資料もあるんです。令和二年度直近のデー…", "…和二年度直近のデータですと、所有者の方は一万四千二百八十八人、年間の賃借料が二百五十億五千七百万円と、まあ随分大きな金額のような気がするんで…", "…一人当たりに直すと百七十五万円ぐらいなんですね。せっかくの機会なのでお伺いしたかったのは、この賃借料は所有者に対して誰が払っているんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/98", "sentence": ["…じゃないところ、つまり、当分返ってきそうにないと、そういうエリアの所有者に対しても賃借料というのは払われているという理解でいいんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00620220330/104", "sentence": []}]}]}]