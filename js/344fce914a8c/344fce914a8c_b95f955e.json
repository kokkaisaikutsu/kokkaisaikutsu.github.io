[{"date": "2022-10-28", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/78", "sentence": ["…で、是非そうしていただきたい。やはり、今の時代、デジタル化ですので、徹底的に効率性を上げて、紙と鉛筆、ファクスからどんどんデジタル化していた…", "…は、私はもっとシンプルに考えていいと思うんですよ。とりわけ安全教育の徹底、これはもう抜本的に見直してください。正直に言って、多分、安全教育の…", "…監視システムをやるということらしいですが、この業界全体、上から下まで徹底的にこの際やっていただいて、ちょっとＳＦチックになっちゃいますけれど…", "…直言って命の保証がない期間というのが出てきたとするならば、ここはもう徹底的に国交省の方で運航を止める。もっと言うなら、それをやったところで、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004319X00220221028/82", "sentence": []}]}]}, {"date": "2023-04-12", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/73", "sentence": ["…は言いませんし、鉄道も重大事故をやっています。だから、こういうことを徹底して、場合によっては、重大事故をやっちゃった分だけ、こういうところが…", "…いらっしゃるところだと思いますが、私は、一度国交省を挙げて安全教育を徹底されたらどうかと思います。絶対に損はないと思いますし、私自身も若いと…", "…とがなかなか経費の方が出せない、だったら公が出していいじゃないですか。徹底的にこれを大臣のときに先鞭をつけていただけませんか、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104319X00920230412/77", "sentence": []}