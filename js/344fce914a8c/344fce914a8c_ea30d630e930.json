[{"date": "2022-05-13", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/38", "sentence": ["…思います。先ほど来から言葉の中にも出てきていますけれども、いわゆる旧リブラ構想、フェイスブックによる旧リブラ構想というのがあったかと思います…", "…出てきていますけれども、いわゆる旧リブラ構想、フェイスブックによる旧リブラ構想というのがあったかと思いますが、これは今、金融庁としてはどうい…", "…題意識の中で今回も法案化されたと思いますけれども、まず、その辺りから、旧リブラ構想というのはどう捉えて、どう対応してきたか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/44", "sentence": ["…お伺いしたいと思いますが、この辺り、どう捉えていらっしゃいますか。先ほど、旧リブラ構想に端を発したという話もありましたが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01820220513/58", "sentence": []}]}]}]