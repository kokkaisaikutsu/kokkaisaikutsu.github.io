[{"date": "2022-04-06", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/84", "sentence": ["○太委員今、国連憲章では、ロシアは常任理事国に名前がありません。ソビエト社会主義共和国連邦というふうに明記されております。そういった意味で、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/86", "sentence": ["…おりますし、もちろん国連の中でもこれは承認手続は取られていない。国連憲章も、もちろんロシアが今常任理事国だというふうには明記されていない状況…", "…されていない状況だと思っております。そういった意味で、もちろん、国連憲章を変えるとか、なかなかこれは難しいことだと思うんですが、やはり私は、…", "…は、やはり、ロシアは我が国の隣国です。同じように、東アジアでも、国連憲章を無視して領土拡張とか他国への軍事侵略という、これは私、あり得ると思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00820220406/110", "sentence": []}]}]}]