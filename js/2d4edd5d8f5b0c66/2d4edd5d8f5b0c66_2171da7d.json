[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/295", "sentence": ["…したいと思います。よろしくお願いを申し上げます。続きまして、防災行政無線についてお伺いをしてまいります。二〇一九年の台風十九号、私の出身の長…", "…の日ですとか、また、場所によっては建物に遮られまして、地域の防災行政無線が聞こえないという声を多くお聞きをいたします。地域住民にとりましては…", "…を多くお聞きをいたします。地域住民にとりましては、行政からの防災行政無線が聞こえないということはやはり不安だと思います。そこで、まず、防災行…", "…聞こえないということはやはり不安だと思います。そこで、まず、防災行政無線について、現在の課題をどのように認識をしているのか、お伺いをいたしま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/299", "sentence": ["…、新しい技術を大いに取り入れまして、住民の安心、安全のための防災行政無線の確立を是非していただきますようお願いを申し上げたいと思います。デジ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/301", "sentence": []}]}]}, {"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/191", "sentence": ["…員よろしくお願いいたします。次に、大雪や災害に大きく関連する防災行政無線についてお伺いをします。近年の台風災害ですとか豪雨災害で被災された方…", "…災された方からよくお聞きしたことは、大雨にかき消されまして、防災行政無線が聞こえづらい、何を言っているのか聞こえないということでありました。…", "…点につきまして私も質問させていただきましたが、その時点では、防災行政無線を整備している市区町村のうち八八％で、屋外スピーカーからの声が聞き取…", "…導入がされているとのことでありました。また、消防庁としても、防災行政無線の機能強化、戸別受信機の配備促進、また、災害情報伝達手段の多重化を促…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/195", "sentence": ["…是非ともお願いしたいというふうに思っております。それで、この防災行政無線も導入されてから相当期間がたちまして、施設が老朽化している地方自治体…", "…は財源を捻出するのが大変だと言われております。この地方の老朽化した防災行政無線の高度化、また財政面での支援についてお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/197", "sentence": ["…重く受け止め、今しっかりと検証していただいていると思いますけれども、防災行政無線とＪアラートの連携について、お取組をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/211", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第四分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00120230220/