[{"date": "2021-04-07", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/205", "sentence": ["○井上（英）委員是非、水をためる取組として、緑地の有する機能というのをうまく利用していくことも必要だというふうに思います。災害防止の観点から…", "…く利用していくことも必要だというふうに思います。災害防止の観点から、緑地などのオープンスペースというのは、これまでは、一時的な避難場所として…", "…避難場所としての役割を主に担ってまいりました。一方で、これに加えて、緑地の持つ雨水の貯留浸透機能というのに着目をして、豪雨対策に資するグリー…", "…浸透機能というのに着目をして、豪雨対策に資するグリーンインフラとして緑地の保全を積極的に進めているという自治体も見られるようになっています。…", "…は榊都市局長にお伺いをしたいと思います。浸水被害の軽減に資する都市部の緑地の保全についてどのようにお考えか、お聞かせいただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404319X01020210407/217", "sentence": []}]}]}]