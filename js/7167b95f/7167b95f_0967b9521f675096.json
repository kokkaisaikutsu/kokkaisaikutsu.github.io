[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/147", "sentence": ["…ず最初に、ワクチンから質問させていただきたいと思います。ワクチンの有効期限についてでありますけれども、公的接種に使われていますファイザー製の…", "…ファイザー製のワクチンでありますが、これ、ファイザー製のワクチンの有効期限というのは製造年月日から半年ということになっております。六か月なわ…", "…種を終える目標となっている、これ七月末が目標となっているわけでありますが、有効期限の切れるもの、どれぐらいあるのか、お伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/149", "sentence": ["…ね。運んでいるワクチンが、大体どのワクチン、最初に運んだワクチン、有効期限どれぐらいかというのは厚生労働省としては把握していると思うんですね…", "…それが、在庫がなくなっていっている、完全になくなっていれば、それで有効期限のうちにもう全て接種されたんだなとか、そういうことが分かると思うん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/171", "sentence": []}]}]}]