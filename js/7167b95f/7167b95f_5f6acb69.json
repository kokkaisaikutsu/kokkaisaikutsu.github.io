[{"date": "2021-06-03", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/147", "sentence": ["…の分科会の尾身茂会長が理事長を務めている独立行政法人地域医療機能推進機構の医薬品発注に関して、スズケンなど医薬品卸の間で談合がこれ長年行われ…", "…ズケンなど医薬品卸の間で談合がこれ長年行われていたということで、この機構の入札というのは二〇〇八年からこれ繰り返し行われていたということです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/149", "sentence": ["…でいくということが非常に大事だというふうに思います。この談合によって機構がどれだけ損失を被ったのか実態を把握した上で、機構への指導を行って再…", "…。この談合によって機構がどれだけ損失を被ったのか実態を把握した上で、機構への指導を行って再発防止策や業者への賠償請求などを行うべきと考えます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02220210603/157", "sentence": []}]}]}]