[{"date": "2022-05-24", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/169", "sentence": ["…せていただきますが、民法第七百五十四条があることで、夫婦である期間に離婚後の子供の親権をどちらの親が持つかを夫婦間で決めたとしても、これを取…", "…意味がなくなってしまうわけです。今、結婚する前にですね、結婚する前に離婚後のことを決めておく婚前契約書を結ぶよう勧めている団体もこれあるわけ…", "…を結ぶよう勧めている団体もこれあるわけなんですね。我が国として、これ離婚後も共同親権を認めていればこういったことが必要なくなるわけであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01420220524/186", "sentence": []}]}]}]