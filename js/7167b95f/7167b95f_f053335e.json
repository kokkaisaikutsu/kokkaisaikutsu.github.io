[{"date": "2020-12-01", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/214", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/216", "sentence": ["…のことについて質問させていただきますが、先日も参考人質疑等で接触者の台帳のことがいろいろと話題に出ておりました。市町村が用意する接種台帳です…", "…者の台帳のことがいろいろと話題に出ておりました。市町村が用意する接種台帳ですね、接種台帳についてでありますけれども、これ、やはり誰がいつどの…", "…いろいろと話題に出ておりました。市町村が用意する接種台帳ですね、接種台帳についてでありますけれども、これ、やはり誰がいつどのワクチンを一回接…", "…クチンを一回接触したのか、二回接触したのか、こういったことがきちっと台帳でやっぱり管理されていくということがやっぱり非常に大事だというふうに…", "…ね。まずは、やっぱりそういった把握をしていくためにも、そういった接種台帳のやっぱりデジタル化というのは非常に大事だと思います。今、政府を挙げ…", "…げてデジタル化の推進ということをやっておられますので、そういった接種台帳というものがデジタル化したものを厚生労働省として市町村に用意をして、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00620201201/244", "sentence": []}]}]}]