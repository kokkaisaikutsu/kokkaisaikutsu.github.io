[{"date": "2020-09-18", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/1", "sentence": ["…が一名欠員となっております。その補欠選任につきましては、先例により、委員長において指名するに御異議ありませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/2", "sentence": ["○大口委員長御異議なしと認めます。よって、そのように決しました。それでは、理事に小倉將信君を指名いたします。――――◇―――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120204601X00120200918/7", "sentence": []}]}]}]