[{"date": "2020-11-24", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/48", "sentence": ["…もなくなってきましたので、最後に、中央銀行発行デジタル通貨とデジタル人民元についてお尋ねをしたいと思います。デジタル通貨、今いろいろ言われて…", "…ｃａですとかさまざまな電子マネーというのが広がっております。デジタル人民元がなぜ広がっているかというと、取引実態が非常に広がっていること、こ…", "…このことが大事ではないかというふうに考えております。他方で、デジタル人民元はもう一つ別の側面があって、ドルを中心とした金融覇権、これに対する…", "…と思っております。大臣もＧ７等でさまざま御発言をされていたと思いますが、デジタル人民元の評価について最後にお聞かせをいただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304376X00320201124/51", "sentence": []}]}]}]