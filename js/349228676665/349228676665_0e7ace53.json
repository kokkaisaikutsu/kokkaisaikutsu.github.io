[{"date": "2022-02-14", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/365", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/367", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/369", "sentence": ["○鈴木（敦）委員これは、税収に関してだけですよね。過去にガソリンの暫定税率が失効した際、流通が混乱したということをよくおっしゃいますけれども…", "…疑的にならざるを得ません。しかし、特に、今は総予算の審査中ですから、税収が下がるということについて認めるのが難しいことは重々よく分かります。…", "…いことは重々よく分かります。では、トリガー条項が仮に発動された場合の税収のマイナス、今御説明をいただきましたけれども、もちろん検討されている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/371", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/373", "sentence": ["…らゆる方法を検討される、これはもちろん正しい方法だと思います。ただ、税収面で一・六兆円の財政赤字が生じるということですけれども、これは税制だ…", "…したいんです。民間の試算では、シンクタンクの計算では、一年目は確かに税収減、一・六兆円程度減収をするというものの、二年目以降、消費税やあるい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/375", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/377", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/379", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/381", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/383", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/385", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/387", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/389", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/391", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/393", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01520220214/395", "sentence": []}]}]}]