[{"date": "2022-03-16", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/169", "sentence": ["…、そして、二〇二五年の二年後には、私、神奈川県ですけれども、横浜では園芸博覧会も開催が予定されております。この園芸博覧会と国際博覧会、実は違…", "…川県ですけれども、横浜では園芸博覧会も開催が予定されております。この園芸博覧会と国際博覧会、実は違いがございまして、国際博覧会というのは五年…", "…いがございまして、国際博覧会というのは五年に一度開かれるもの、そして園芸博覧会については、その五年間の間に一度だけ開くことができる、こういう…", "…ございます。それを申し上げた上で、近現代において、国際博覧会と認定の園芸博覧会を連続して開催することができた、こんな幸運な国は我が国しかあり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803968X00520220316/187", "sentence": []}]}]}]