[{"date": "2023-05-25", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/106", "sentence": ["…敦）委員鈴木敦でございます。今日も議論を聞かせていただきまして、災害対策ということでいろいろお話をさせていただいていると思いますが、災害対策…", "…対策ということでいろいろお話をさせていただいていると思いますが、災害対策ということは、やはり、防災、減災だけではなくて、その後のことも考えな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/116", "sentence": ["…でいただきたいということなんですよ。政務官、いかがですか。この地図と写真を御覧いただいて、取組を加速するために、何か方策、思いつきませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104339X00420230525/122", "sentence": ["…っとこの樋管から水が出ていましたので、是非そういった面も含めて、事前に対応できる策、広報の方法も検討していただきたいと思います。終わります。"]}]}]}]