[{"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/18", "sentence": ["…、週休二日、罰則規定が二〇二四年四月から適用されます。そうすると、労務単価が高くなるということ、そして工期に余裕をもっと持たせなければなりま…", "…ういうことを発注者がもっと理解をしていかなければいけません。適切な労務単価と工期について、民間建設工事の標準契約約款、この中に反映をさせ、そ…", "…しく指導すべきだと考えます。こうした建設業界の、とりわけ民民工事契約において、工期や労務単価が適正に反映されるための国交省の取組を伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114319X00420230317/25", "sentence": []}]}]}]