[{"date": "2023-04-14", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/27", "sentence": ["…いただければと思います。次に、交通安全計画及び実施計画の作成に係る努力義務規定の見直しについて伺います。今、交通事故は、十六年連続で、事故件…", "…月一日からは、道交法の改正により、自転車に乗る人のヘルメット着用が努力義務化されました。地方自治体でも、交通安全対策というのは最も重要な政策…", "…画、実施計画の作成について、県の計画と重複することが多いため、作成努力義務をできる規定に緩和するということですが、このようにやっぱり年々重要…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00620230414/33", "sentence": []}]}]}]