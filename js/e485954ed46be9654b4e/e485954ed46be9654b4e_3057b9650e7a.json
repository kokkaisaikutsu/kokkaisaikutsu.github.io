[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/247", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/249", "sentence": ["…じゃないかということもお問合せをさせていただいた思い出がございます。地方税法が改正されて、地場産品基準が設けられて今に至るというところでござ…", "…。これは本当に地元の誇りになることです。ふるさと納税について、結局は地方税全体のパイは変わらない、奪い合いじゃないか、また、返礼品競争が問題…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/251", "sentence": ["…す。ですから、本来はこれは税源の偏在是正に役立つ、そしてまた、本当は地方税の税源、全体が広がればいいのではないかと思いますが、そこはいろいろ…"]}]}]}]