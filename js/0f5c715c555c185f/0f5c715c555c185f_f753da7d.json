[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第一分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/234", "sentence": ["…ら質問をさせていただきたいと思いますが、静岡県内を通る国道三百六十二号線という、災害時の第二次緊急輸送路に指定されている道路がございます。た…", "…道路幅が狭く、整備が進んではおりません。一方で、新東名ができ、国道一号線も四車線化が進み、大変当時とは道路状況が変わってはまいりましたが、か…", "…道路日本坂トンネル事故があった際には、迂回路としてこの国道三百六十二号線に車両が集中して、トラックが立ち往生しちゃったというようなこともござ…", "…原発もありますけれども、様々なリスクがある中で、内陸を通る三百六十二号線というのは非常に重要な道路であると思っておりますが、この三百六十二号…", "…六十二号線というのは非常に重要な道路であると思っておりますが、この三百六十二号線の現在の整備状況、今後の整備方針についてお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805266X00120220216/251", "sentence": []}]}]}, {"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105268X00220230221/36", "sentence": ["○小山分科員国交省さんにもう一問、国道一号線掛川バイパスの四車線化についてお尋ねしたいと思います。民主党政権下では、国道一号線の天竜川橋の八…", "…スの四車線化についてお尋ねしたいと思います。民主党政権下では、国道一号線の天竜川橋の八車線化、磐田バイパスの四車線化、袋