[{"date": "2022-05-10", "meeting": [{"meeting_name": "衆議院 内閣委員会厚生労働委員会連合審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/89", "sentence": ["…います。子供の生活環境という点で今問題になっていることに、いわゆる共同親権という問題があります。ただ、共同親権という言葉が、人によっても使い…", "…題になっていることに、いわゆる共同親権という問題があります。ただ、共同親権という言葉が、人によっても使い方が違いますし、そして、使われる局面…", "…と考えております。そこで、まず、津島副大臣にお伺いしたいんですが、共同親権という言葉について、法務省としては今どのような定義をしているのか。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/91", "sentence": ["○吉田（統）委員副大臣、その後の共同親権というものの定義、共同親権という言葉の法務省としての定義を教えていただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/93", "sentence": ["○吉田（統）委員そうすると、共同親権という言葉は法務省内で定義づけはされていないという理解なんですかね、副大臣。ちょっとそこ、大事なことなの…", "…はされていないという理解なんですかね、副大臣。ちょっとそこ、大事なことなのでお答えいただけますか。共同親権という言葉がないんですかね、まだ。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804920X00120220510/104", "sentence": []}]}]}]