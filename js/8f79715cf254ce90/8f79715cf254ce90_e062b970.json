[{"date": "2023-04-25", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/82", "sentence": ["…いうふうに思います。ありがとうございます。ジブチにある自衛隊初の海外拠点というのは、ソマリア沖やアデン湾において当時頻発していた海賊被害に対…", "…アデン湾において当時頻発していた海賊被害に対応するために二〇一一年に拠点を設置しまして、実は民主党政権でございました。当時、今日いらっしゃい…", "…民主党政権でございました。当時、今日いらっしゃいます榛葉防衛副大臣が拠点整備の事前の調整なり場所の確保なりに御奮闘いただきました。もう御勇退…", "…。小川副大臣から行ってきたよという報告を受けたことがありまして、この拠点が今回の邦人救出に一定の役割を果たしたことは非常によかったなというふ…", "…というふうに思っておりますし、国家安全保障戦略の中にも、このジブチの拠点を邦人救助の際に活用するということを安全保障戦略の中にも明記をいただ…", "…としても一定評価をさせていただいておりますし、今回迅速にこのジブチの拠点を使って救助に当たっていただいたことについても感謝と御慰労をさせてい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/84", "sentence": ["…とは共有していくべきだと私はずっと申し上げているので、本当にジブチの拠点が有効に使われたことについては有り難く思っております。ＲＡＡの前に、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X01020230425/105", "sentence": []}]}]}]