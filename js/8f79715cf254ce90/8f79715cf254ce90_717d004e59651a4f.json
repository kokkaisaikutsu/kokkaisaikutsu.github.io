[{"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/46", "sentence": ["…ないと言われているんですね。どうなんだ、これはと。加えて言えば、旧統一教会問題に抱き付かれてしまい、解決に取り組まなければならず、私の顔も幾…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/52", "sentence": ["…にあらずだと思いますので、本当に即刻お辞めいただきたい。ましてや、統一教会の問題、二世の救済どうするか、これ与野党で今協議しています。それか…", "…というのは非常に重要なのに、この人は、テレビの露出が増えるとか、旧統一教会問題に抱き付かれてしまいみたいな話で、嫌々やるなら本当に、何度も言…", "…ただきたいというふうに思っております。もう一点、山田外務副大臣の旧統一教会関連団体のことについてお伺いします。我が党の小西議員がずっと質疑を…", "…、質疑をさせていただかざるを得ないなというふうに思います。小西議員も聞かれていますが、この旧統一教会関連団体とのお付き合いはいつからですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00520221110/81", "sen