[{"date": "2023-02-08", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00520230208/10", "sentence": ["…先生とともに賜りますことは、身に余る光栄であり、望外の喜びであります。心から御礼を申し上げます。ありがとうございます。また、関口昌一自民党参…", "…重ねて、尾辻議長を始め同僚議員の先生方にも、このような機会をいただき、心から感謝を申し上げます。ありがとうございます。私が高校一年のとき、父…", "…峨野高校に入学。二度目の高一でした。とても自由な校風で、貧乏な私にも居心地の良い空間でした。リベラルな政治信条はこの頃培われたのかもしれませ…", "…が日本の底力だったのではないでしょうか。社会全体に人を応援する優しさや心の余裕があったように思います。残念ながら、今の日本は、自己責任の濫用…", "…をひたすら目指してきました。また、ライフワークである地球温暖化問題を中心に、長く環境委員会に属しました。そして、二〇〇九年の政権交代。あのと…", "…か月での下野となり、未熟であったこと、国民の期待を裏切ったことなど、内心じくじたる思いでいっぱいであり、痛恨、無念の極みです。しかしながら、…", "…対に忘れてはならない二〇一一年三月十一日、東日本大震災。被災地の皆様に心よりお見舞いを申し上げます。原発事故担当として福島と向き合う日々でし…", "…。当院では、江田五月先生、鴻池祥肇先生、数え上げれば切りがありません。心から感謝を申し上げます。自ら二十五年を振り返ったとき、一体何を実現し…", "…の皆様に深く謝意をささげます。今日は、このような機会をいただいたことに心から感謝を申し上げ、終わりとしたいと思います。誠にありがとうございま…"]}]}, {"meeting_name": "参議院 国民生活・経済及び地方に関する調査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/1211153