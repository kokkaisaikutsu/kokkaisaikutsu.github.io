[{"date": "2020-10-29", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315254X00220201029/2", "sentence": ["…かがでしょうか。総理の見解を求めます。公共交通や物流は、国民生活や経済活動等を支える重要な社会インフラであり、緊急事態宣言下においても、大き…", "…ているのでしょうか。お聞かせください。安倍前総理は、ロシアとの共同経済活動を進めつつ、日ソ共同宣言をベースに二島先行返還を実現するという姿勢…"]}]}]}, {"date": "2022-03-22", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/20", "sentence": ["…シア外務省から、平和条約交渉や領土交渉についてやらないと、で、共同経済活動からの撤退ということも発表がありました。このことについて、日本国総…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/28", "sentence": ["○福山哲郎君日本との共同経済活動からの撤退と向こうが明確に言っているんですよ。よく分からないんですね。今、そんなに、まあ多少遠慮されているの…", "…なのか、配慮されているのかは分かりませんが、少なくとも、相手が共同経済活動からの撤退と言っているんだから、経済協力担当大臣は要らないはずです…", "…、在留ロシア、ロシア在留の邦人には帰ってこいと言っているんですよ。経済活動なんかできるわけないじゃないですか。帰ってこいって外務省は指示して…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01620220322/50", "sentence": []}, {