[{"date": "2023-02-08", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00520230208/10", "sentence": ["…都に向かいました。夜逃げ同然でした。生活費を稼ぎながら、翌年、府立嵯峨野高校に入学。二度目の高一でした。とても自由な校風で、貧乏な私にも居心…", "…場のキャディー、バイトばかりの高校生活でした。そんな折、学問の神様、北野天満宮が創設した奨学金制度で月一万円をいただくことになり、これをきっ…", "…うという高揚感は言葉では言い尽くせません。結果として、三年三か月での下野となり、未熟であったこと、国民の期待を裏切ったことなど、内心じくじた…", "…未来への責任と使命だと考えています。そして、二〇一七年総選挙直前に、枝野幸男衆議院議員とともに立憲民主党の結党に参画。告示十日前だったにもか…", "…、この参議院でも一人一人と仲間が増え、今では四十名の会派となりました。野党第一党の幹事長としての四年二か月は、真っ当な政治、差別のない、誰一…", "…た。党派を超えた多くの政治家との出会いが今の私を形作っています。晩年の野中広務先生には温かい御指導を賜り、京都府障害者団体連合会会長を引き継…"]}]}, {"meeting_name": "参議院 国民生活・経済及び地方に関する調査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115363X00120230208/57", "sentence": []}, {"url": "https://kokkai.ndl