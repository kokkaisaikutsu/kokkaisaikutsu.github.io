[{"date": "2022-03-15", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/21", "sentence": ["…けれども、とにかくこのままでは財政破綻が起こると言っているんですけれども、財政破綻起きるんですか。これ、事務方からちょっと説明してください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/35", "sentence": []}]}]}, {"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/8", "sentence": ["…ちょっと順番変えます、そちらに話が行くんでしたら。それで、これ、じゃ事務方にちょっと聞きますが、要するに、今のような話で、大臣がおっしゃった…", "…しなきゃならないと言うんですけど、要するに通貨の受取を拒否する事態があるというふうに思っているのか、ちょっと財務省の事務方から聞きたいです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/10", "sentence": ["…ら取引、経済取引するのをですよ、円をやめてドルでやりますと、こういうことがあり得るのかということですよ。まあ、じゃ、事務方、言ってください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/12", "sentence": ["…さに日銀券そのものなんだから。それは法律上拒否できないんですよ。それ分かっているでしょう。拒否できるんですか。財務省、事務方、答えなさいよ。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/16", "sentence": ["…年償還ルールを採用しているからなんですが、まず、この六十年償還ルールを採用している国がほかにあるのかと、このことをちょっと事務方に聞きます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/18", "sentence": ["…、私、今一応述べたけれども、述べましたけれども、それでいいんだったらそのとおりだと言ってくれたらいいし、簡潔に述べてください、事務方の方で。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/22", "sentence": ["…ころが、現実には転嫁されているんですよね。そのことをちょっと財務省の事務方に聞きたい。結局は外税方式が実態的にはほとんどのために転嫁が一〇〇…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/24", "sentence": ["…組みになっているんです。そこで、その実態がどうかということを財務省の事務方に聞きますが、要するにこれ、自民の税調の中でも私がこれ指摘したんで…", "…は法人じゃなくて個人でしょう、結局。そうすると、個人が負担している税金が税全体の六割ということになるんだが、これは、事務方、どうなんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00220230309/30", "sentence": []}]}]}]