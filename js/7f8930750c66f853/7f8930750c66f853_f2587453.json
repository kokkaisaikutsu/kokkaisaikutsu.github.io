[{"date": "2023-05-25", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/13", "sentence": ["…とだと思うんですけれども。それから、まだ、大手町プレイス、国有財産の売却で四千億円程度見込んでおられますが、そもそも、このほかに財源確保する…", "…億円程度見込んでおられますが、そもそも、このほかに財源確保するために売却できるような資産があるのかと、こういうことも我が党の特命委員会の中で…", "…した。そうした結果、資産は見当たらなかったということだと思うんですけれども、改めて、売却可能な資産があるのか、そこもお尋ねしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/15", "sentence": ["…余金やそういうものをかき集めてくると。売れる国有財産があったらそれを売却しますと。足らず前は増税だというような形なんですけれども、まだその法…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/48", "sentence": []}]}]}]