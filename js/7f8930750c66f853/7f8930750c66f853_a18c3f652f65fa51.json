[{"date": "2022-03-15", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/13", "sentence": ["…う仕訳になるわけですね。そして、二番目の財政出動。ここは、政府側は財政支出を何かしますと、そのことによって政府預金が出るわけですね、日銀当座…", "…どうなるかというと、政府側まとめると、日銀当座預金対国債、それから財政支出対日銀当座預金という仕訳になり、民間側は、先ほど言ったように、預金…", "…というのは、それぞれ。これ相殺をしていると、政府部門で行うものは、財政支出、そして国債というこの取引が残るだけであります。それから、民間の方…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00320220315/35", "sentence": []}]}]}]