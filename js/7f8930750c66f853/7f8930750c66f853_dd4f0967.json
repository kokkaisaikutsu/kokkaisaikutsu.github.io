[{"date": "2022-11-22", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015254X00820221122/11", "sentence": ["…払い費は政府の負担でありますが、現在、国債残高の半分近くは日本銀行が保有していますから、利払い費の半分は日銀に支払われることになります。日銀…", "…りは国庫に納入することになっています。このことから、少なくとも日銀が保有する国債については、国債の償還も利払いも事実上国庫に影響を与えていな…"]}]}]}, {"date": "2024-05-27", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/28", "sentence": ["…これもまたすごいこと書いているんですね。これには、将来世代のうち国債保有層は償還等を受けられる一方で、それ以外の国民は社会保障関係費等の抑制…", "…負担を被ることになりかねないと書いているんですね。これ、一体この国債保有層とは誰のことなんですか。国民で国債をそんなたくさん私持っているとい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/30", "sentence": ["○西田昌司君いやいや、それじゃ、もう一つ聞いてから進みましょう。じゃ、国債保有層以外とは具体的に、じゃ、誰なんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/32", "sentence": ["…あなたの今の話を総合すると、要するに、銀行にお金を預けている人は国債保有層だと、銀行に預金のない人は国債保有層以外ということになりますよ。そ…", "…合すると、要するに、銀行にお金を預けている人は国債保有層だと、銀行に預金のない人は国債保有層以外ということになりますよ。そういう意味ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00820240527/34", "sentence": ["…んですよ。現実なら、あなたの話を聞いていたら、預金持っている人が国債保有層だと、それで、預金持っていない人が国債保有層じゃないということにな…", "…、預金持っている人が国債保有層だと、それで、預金持っていない人が国債保有層じゃないということになっちゃって、預金も、まあ預金の多寡はあります…"]}, {"url": "https://kokkai.ndl.go.jp/t