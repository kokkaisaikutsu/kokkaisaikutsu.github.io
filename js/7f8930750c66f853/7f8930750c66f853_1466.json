[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/11", "sentence": ["…資は削減され続けて、しかも、そもそも、国土計画、国土開発計画がですよ、昔は十年ごとに書き換えてやってきたんですが、それなくなっているんですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/19", "sentence": ["…と当然企業の利益が増えます。企業の利益が増えるんだけれど、そのときに、昔は所得税が最高税率が非常に高かったわけですね、まあ九割近く、住民税を…", "…も、これ元々実効税率は、法人税は五〇％以上、五四、五％ありましたかね、昔は、住民税合わせると。ところが、今はもう完全に三割切っているわけです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/23", "sentence": ["…ですよ。私、税理士ずっとやっていましたから分かるんですけど、要するに、昔、実効税率が五割以上あると、一億円利益出たら五千万払わなあかんわけで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014370X00220221101/27", "sentence": []}]}]}]