[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/8", "sentence": ["…いてお伺いをしたいと思います。ここ数年、コロナ対策のために地方創生臨時交付金とか、物価高騰、電力、ガス、食料品等の重点支援が図られてきました…", "…が違いますから、自治体のしっかりとした現場の配慮に基づいて地方創生臨時交付金を活用していただいて、例えば、食材が上がっているんで給食費の補助…", "…、合わせて一兆四千億円の物価対策施していますが、まず内閣府に、この臨時交付金一・四兆円の現在の活用状況について事実関係を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/10", "sentence": ["…いうことが大事でありますし、予備費まだ五兆円あるという中において、臨時交付金などの措置を速やかに追加で検討していただくということが大事だと思…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00320230309/26", "sentence": []}]}]}]