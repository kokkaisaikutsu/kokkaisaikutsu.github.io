[{"date": "2023-04-24", "meeting": [{"meeting_name": "衆議院 決算行政監視委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/41", "sentence": ["○城井分科員今、授業準備にかかる時間について聞いたわけですが、この授業準備というのは校務なんですか、校務じゃないんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/43", "sentence": ["○城井分科員では、校務を自発的な業務として片づけてしまってもよろしいんですか。そういう国の見解なんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/45", "sentence": ["○城井分科員自発的業務で校務をやらせるということですか。校長が命じなければ、校務であっても自発的な仕事で片づけて、時間外労働としては認めない…", "…科員自発的業務で校務をやらせるということですか。校長が命じなければ、校務であっても自発的な仕事で片づけて、時間外労働としては認めない、こうい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/57", "sentence": ["○城井分科員勤務時間に数えないけれども校務という、このゆがんだ状況を何とかしたいのでこの話を聞いているわけですが、もう一つだけ伺いますね。児…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/59", "sentence": ["…しゃったように、勤務時間としては計算ができる仕組みにはなっていないが校務だというお話でしたよね。これはこのまま放置していいんだろうかというの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/69", "sentence": []}, {"url": "https://kokkai