[{"date": "2021-12-15", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/65", "sentence": ["…お願いしたいと思います。続きまして、賃上げ税制について、総理並びに財務大臣にお伺いいたします。長らく続いた実質賃金の上がらない状況を打破する…", "…ます。この一部社員だけの給与大幅引上げで、継続して雇用する人の給与総額の要件をクリアする場合は、対象に入れますか。財務大臣、お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/67", "sentence": ["○城井委員財務大臣の認識は少し甘いと思っています。経営者の方々の方がシビアに見ていると思います。ほとんどの社員の給与を上げない形でもしメリッ…", "…い、でも賃上げ税制のメリットは得られると考えるんじゃないか。この指摘に政府がどう答えるか。このやり方を見逃すのか。財務大臣、お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/69", "sentence": ["…そうな業務を非正規従業員に切り替えていくことで達成できると考える経営者の可能性を政府がちゃんと考えてくれているか、財務大臣、お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/71", "sentence": ["○城井委員財務大臣、内製化した場合に、超えてくるケースは全くないとお考えですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/77", "sentence": ["…増えるということ、この可能性を考慮すべきじゃないか。このやり方、政府として認めるんでしょうか。これ、ありでしょうか。財務大臣、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00420211215/83", "sentence": []}]}]}, {"date": "2022-02-10", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805