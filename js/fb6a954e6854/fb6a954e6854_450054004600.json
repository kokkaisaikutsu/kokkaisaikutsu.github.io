[{"date": "2022-02-04", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/57", "sentence": ["…、こういった副作用も予算委員会の中で指摘をされてまいりました。また、ＥＴＦの購入など、本来中央銀行がやるべきことではないだろう、世界でも例を…", "…きた。ただ、これも昨年については随分減らしてきて、私もこの委員会で、ＥＴＦはやり過ぎでしょうということを申し上げて、それを聞いてくださったか…", "…えを変えてくれたのかなというふうに思っていたら、今年に入ってからまたＥＴＦの購入がちょっと増えて、ペースが上がったりというようなことで、やは…", "…辺については、なかなか外に向かって発信すると委員会で答弁するというのは難しいと思いますが、ＥＴＦの購入、もうやめませんか。いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00220220204/67", "sentence": []}]}]}]