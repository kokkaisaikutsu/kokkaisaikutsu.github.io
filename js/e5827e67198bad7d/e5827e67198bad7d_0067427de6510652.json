[{"date": "2022-04-06", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/143", "sentence": ["…けれども、あくまでもこの福島県内の除去土壌、これが三十年以内に県外最終処分ということが法律で明記されております。ところが、もう既に十年たって…", "…然やっぱりできるものはどんどんどんどんやっていただくと、これ、県外最終処分も含めてですね。そういうことで、取組として、環境省内にもありますし…", "…非それも検討していただきたいんですけれども。是非、この三十年の県外最終処分、これを施行して、是非、現在の取組状況、いわゆる県外への最終処分に…", "…れども。是非、この三十年の県外最終処分、これを施行して、是非、現在の取組状況、いわゆる県外への最終処分についての取組状況をお尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00320220406/161", "sentence": []}]}]}]