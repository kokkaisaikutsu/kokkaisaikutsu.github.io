[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/89", "sentence": ["…平和と持続的な発展に向けた対話の場所として、国際平和文化都市広島から力強い平和のメッセージを世界中に発信する必要があります。また、世界中から…", "…摘しています。昨年七月の安倍元総理銃撃事件を受けて、要人警護体制、これ強化していたにもかかわらず、同様の演説会場での犯行を妨げなかったこと、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/91", "sentence": ["…結び付ける観点から、核兵器国と非核兵器国が共に参加するＮＰＴ体制の維持強化を図りまして、その下で核軍縮を進めていくことが重要である、この旨を…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/93", "sentence": ["…わせてＧＤＰ比二％に達する予算を確保しました。それ以降も、防衛力を維持強化していくために増税により財源を確保するという意向です。広島サミット…", "…復興を遂げた広島を世界に発信することで、平和が大切だということを改めて強調すべき場所です。にもかかわらず、岸田政権では、国民の理解を得ないま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/103", "sentence": ["○三上えり君その防衛費ですけれども、増額するために一兆円強の増税を行う方針ということです。朝日新聞社が今年一月に全国世論調査を行いました。賛…", "…、いずれも反対が大多数という結果でした。この世論調査の結果から、防衛力強化の内容、予算、財源についての国民の理解、これ、まだ得られていないの…", "…ついての国民の理解、これ、まだ得られていないのではないかと思われますけれども、防衛力強化を推し進めるのはどうでしょうか。御見解お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/119", "sentence": []}, {"