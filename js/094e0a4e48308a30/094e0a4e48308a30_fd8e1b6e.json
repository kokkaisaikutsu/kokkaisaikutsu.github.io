[{"date": "2022-11-15", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/11", "sentence": ["…以上の待遇が求められることもあり、経済的負担が大きくなる傾向にあるかと思いますが、こうした負担の軽減に向けての具体的な取組を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014319X00520221115/21", "sentence": []}]}]}, {"date": "2023-04-12", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X01420230412/4", "sentence": ["…て、国は、自治体や交通事業者の立場に寄り添い、財政的負担や人的負担の軽減のため十分な措置を講じることが大変重要と考えます。国の財政支援に関し…", "…再構築に当たっては、自治体を始め地域の財政的、人的負担等を可能な限り軽減するといった観点に特に留意し、法律、予算、税のあらゆる政策ツールを総…"]}]}]}]