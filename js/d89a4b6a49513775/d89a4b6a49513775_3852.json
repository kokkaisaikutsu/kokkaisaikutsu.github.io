[{"date": "2020-11-24", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/52", "sentence": ["…お伺いします。二十一日、先週の土曜日でございます、菅総理は、急遽、食事券の新規発行の一時停止やポイント利用を控えるよう都道府県に検討を要請し…", "…府県に検討を要請しましたが、現場の混乱は必至かと思われます。特に、食事券の発行停止はいつまでなのか分からないのであれば、一月末までと今なって…", "…寧な説明をお願いしたいと思います。また、ＧｏＴｏイート登録飲食店が食事券を回収し現金化するためには、都道府県ごとに扱いは多少異なりますけれど…", "…多少異なりますけれども、大体申込みは月一回のみ、受付には一回当たり食事券二十枚以上が必要といったような形になっています。今回の一時停止が各地…", "…な現金化の妨げとならないよう、換金申込回数や換金に必要な一回ごとの食事券数の下限などにつきましては柔軟に御対応いただきたいと思います。続いて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00320201124/56", "sentence": []}]}]}, {"date": "2021-03-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/81", "sentence": ["…ていきたいと思います。まず、緊急事態宣言が解除された都府県における食事券の販売再開についてでございます。国は、宣言を発出したときには一時停止…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/85", "sentence": ["○高橋光男君まさに食事券等の利用を控えるよう利用者に呼びかけている期間中であっても食事券を利用してテークアウト、デリバリーを積極的に進めてい…", "…に食事券等の利用を控えるよう利用者に呼びかけている期間中であっても食事券を利用してテークアウト、デリバリーを積極的に進めているということです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/95", "sentence": []}, {"url"