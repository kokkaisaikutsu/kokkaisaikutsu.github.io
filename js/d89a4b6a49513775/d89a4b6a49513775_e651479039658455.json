[{"date": "2022-01-25", "meeting": [{"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814024X00520220125/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X00520220125/20", "sentence": ["…の医療提供確保計画の中にも入っているようなところなんですね。今回の処遇改善が原因で協力病院が減ることになれば、私は本末転倒だというふうに思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814024X00520220125/22", "sentence": []}]}]}, {"date": "2023-05-15", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/102", "sentence": ["…士や作業療法士の方々の存在は欠かせません。しかし、そうした方々への処遇改善が一向に進んでいない実態がございます。資料二を御覧ください。これは…", "…の福祉職と比べても大きな差がございます。昨年十月、国は、看護職職員処遇改善評価料というものを新設されましたけれども、この対象医療機関というも…", "…には届いていないというお声も聞いております。そもそも、看護職等への処遇改善の対象は、年間二百件以上のコロナ患者を救急搬送する医療機関に限定さ…", "…で実態の見える化、基準の見直し等を行っていただき、理学療法士等も含め処遇改善が行き届くようにしていただきたいと考えますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00820230515/118", "sentence": []}]}]}]