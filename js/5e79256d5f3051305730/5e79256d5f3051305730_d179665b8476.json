[{"date": "2023-04-07", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/95", "sentence": ["○神津委員運転期間を延長するところについての科学的根拠というものがあるのかどうか、まずは経産大臣からお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/97", "sentence": ["…がたいんですが、私、三十分しかないので、少し短めでお願いします。今の科学的根拠のところなんですが、四十年まではあるというふうにこれまで発言さ…", "…で発言されていると思うんですが、五十年、六十年、それ以上を運転していくことに対して、科学的根拠はあるのでしょうか。山中委員長にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/99", "sentence": ["…運転期限の延長を撤廃しよう、そうしたらば、それはもう規制委側としては認めていくということなんでしょうか。そこに科学的根拠はあるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104080X00920230407/127", "sentence": []}]}]}]