[{"date": "2022-05-20", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/30", "sentence": ["○神津委員省エネを推進するという意味は分かるんですが、今、状況は変わっていると思っております。本日、配付資料、資料一を御覧ください。一九九〇…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/36", "sentence": ["…断熱性能等級四が義務化されることになります。断熱性能等級四というのは省エネ基準とも別名では言われています。この適合義務化の時期、それから、昨…", "…それから、昨年度、当該基準に適合して建てられた住宅の割合、また、現行省エネ基準での義務化によって、建築物分野の二〇三〇年までの温室効果ガス排…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/44", "sentence": ["…に、資料三を御覧ください。鳥取県は、独自の方策によって、住宅における省エネの促進を図っています。鳥取の最高レベル、この一番右端の縦の部分です…", "…いても研究し、周知していく必要があると思います。国交省としては、こうした省エネ性能の副次的効果の研究に予算を充当する予定があるのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X01420220520/53", "sentence": []}]}]}]