[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/16", "sentence": ["…事、つまり中台有事を想定した発言をすることや、日本政府が中台有事への備えを進めることというのは、中国の内政に対する干渉だとお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/18", "sentence": ["…ております。仮に、仮にですが、中台有事と言われる事態が発生した場合に備え、内閣は、先島諸島などにお住まいの皆様の安全を確保するということに加…", "…ついてもあらかじめ検討をしておかなければなりません。総理は、現在の自衛隊法は在外邦人救出を行う上で十分な内容を備えているとお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/33", "sentence": []}]}]}]