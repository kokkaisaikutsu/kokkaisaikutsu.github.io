[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/8", "sentence": ["…権公約ではコロナでお困りの皆様への経済的支援としていたことから、所得制限を設けるべきだというのが自民党としての見解でございました。他方、公明…", "…項だということで、自公両党の幹事長が会談をされました。その結果、所得制限は設けることになったものの、給付には児童手当の仕組みが活用されること…", "…世帯合算に見直しをするべきではないかと考えております。世帯合算の所得制限を設けている制度は多く、例えば不妊治療に対する助成、保育料、高等学校…", "…ございますが、世帯の働き方による不公平を解消するための児童手当の収入制限の在り方、また十八歳以下に支給対象を拡充するなど、少子化対策全体の中…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/33", "sentence": []}]}]}]