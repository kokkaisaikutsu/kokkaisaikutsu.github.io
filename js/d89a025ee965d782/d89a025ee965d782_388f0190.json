[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/20", "sentence": ["…ついて検討を指示したとおっしゃいましたが、八十四条の四は在外邦人等の輸送を任務とするものでございます。今年の八月、アフガニスタン、まさにこの…", "…ガニスタン、まさにこの八十四条の四によって自衛隊が派遣されましたが、輸送業務ですから、自衛隊は現地の空港から外には出られません。派遣された自…", "…衛隊員は武器を携行しておりましたけれども、自力で逃げてきた方を安全に輸送機に導くということ、また、ハイジャックなどから機体を守る、人を守る、…", "…邦人等の保護措置を認めていますので、大使館などに集合した邦人等を陸上輸送し、この保護任務の実施を妨害する行為を排除するための武器使用というの…", "…、もう既に政権が機能しておりませんでしたから、この三要件を満たさず、輸送を任務とする八十四条の四に基づく派遣しかできなかったということについ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/33", "sentence": []}]}]}]