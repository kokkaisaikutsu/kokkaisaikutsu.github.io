[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/18", "sentence": ["…ついてもあらかじめ検討をしておかなければなりません。総理は、現在の自衛隊法は在外邦人救出を行う上で十分な内容を備えているとお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/20", "sentence": ["…十四条の四について検討を指示したとおっしゃいましたが、八十四条の四は在外邦人等の輸送を任務とするものでございます。今年の八月、アフガニスタン…", "…法制の一部として追加した自衛隊法第八十四条の三に基づく派遣でしたら、在外邦人等の保護措置を認めていますので、大使館などに集合した邦人等を陸上…", "…態を想定して、いま一度、自衛隊法第八十四条の三の三要件を見直すなど、在外邦人などの保護措置を実効性のある内容に改正していくという御意思はあり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/33", "sentence": []}]}]}]