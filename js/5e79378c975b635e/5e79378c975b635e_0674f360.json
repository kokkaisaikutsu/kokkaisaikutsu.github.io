[{"date": "2023-05-25", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/225", "sentence": ["…思いますが、百年後の今は世界はそのように変わってきています。あるべき理想を訴えることはすばらしいことで、今回、核の廃絶と核なき世界ということ…", "…とを前提に、ただ、総理も本会議でおっしゃっていましたけれども、現実と理想が程遠いんですね。なので、今回のＧ７サミットでも、各国首脳は核なき世…", "…〇％が自前の核保有を支持しているとの報道もあります。核なき世界という理想と核の抑止力が有効だという現実のはざまで防衛力の抜本的強化を目指す我…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/229", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X01020230525/237", "sentence": []}]}]}]