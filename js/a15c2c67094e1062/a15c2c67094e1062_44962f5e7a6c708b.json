[{"date": "2022-03-11", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/39", "sentence": ["…議いただいた際に、本委員会におきまして、先ほど御紹介いただきました附帯決議を決めていただきました。我が国といたしましても、国際貢献機会を拡大…", "…送り込んでいくというのは非常に重要だというふうに思っています。この附帯決議を踏まえまして、日本人職員数及び日本人幹部の増加に向けて、具体的に…", "…めとする世銀幹部に対する働きかけなどに取り組んでまいりました。この附帯決議をいただきました以前から取り組んでまいりましたので、実は昨年末、二…", "…足下、若干その伸びが鈍化しておりますけれども、更に努力を重ねまして、附帯決議の趣旨に沿いまして努力を重ねていきたいというふうに考えています。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/63", "sentence": []}]}, {"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/187", "sentence": []}]}]}]