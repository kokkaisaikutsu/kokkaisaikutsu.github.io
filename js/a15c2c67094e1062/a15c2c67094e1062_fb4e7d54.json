[{"date": "2022-03-11", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X01020220311/63", "sentence": []}]}, {"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/177", "sentence": ["○岡本副大臣お答え申し上げます。今委員言及をいただきました旧日銀法の任命委員の任命基準は、各業界の有識者であることを要件としておりましたが、…", "…臣お答え申し上げます。今委員言及をいただきました旧日銀法の任命委員の任命基準は、各業界の有識者であることを要件としておりましたが、平成九年の…", "…有する者その他の学識経験のある者のうちから、両議院の同意を得て内閣が任命するとされました。今回のこの審議委員の候補者につきましても、こうした…", "…をされております。したがいまして、今回の場合もそうですが、審議委員に任命された時点で、過去に金融機関に仮に所属されていた方が審議委員を務めら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/179", "sentence": ["…経済、金融に関して高い見識を有する者の中から内閣が両議院の同意を得て任命するとなっておりますので、この法律に沿った形で皆様に御提案させていた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00820220311/187", "sentence": []}]}]}]