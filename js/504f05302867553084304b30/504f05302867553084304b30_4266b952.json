[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015206X00320221101/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00320221101/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00320221101/62", "sentence": ["…ていただければなと思っています。それから、もう一つですけれども、公訴時効の見直し、これも重要な課題であります。これは、試案ですと、現行の公訴…", "…の見直し、これも重要な課題であります。これは、試案ですと、現行の公訴時効の期間にそれぞれ五年延長をするということで、具体的には、強制性交等で…", "…、強制性交等であれば十五年、強制わいせつなどであれば十二年という公訴時効はいかがかと。それに加えて、被害者が十八歳未満、未成年者である場合に…", "…被害者が十八歳未満、未成年者である場合には、十八歳に達するまでの間は時効にならないということですかね、端的に言うと。ですから、十八歳になって…", "…、十八歳になって、更にそこから先ほど申し上げた十五年とか十二年とかの時効の期間は訴えができるということであります。これも、これまでの現行に比…", "…あるのかなと。そう考えると、そういった観点から、十八歳、未成年の間は時効にならないと、成人になってからということ、それにプラス時効期間を足す…", "…成年の間は時効にならないと、成人になってからということ、それにプラス時効期間を足すことによって一定程度の社会的経験ということにもなるのかもし…", "…なると、二十歳プラス強制わいせつだったら十二年ですから、三十二歳まで時効が完成しないということになります。でも、十八歳成人だから三十歳、二年…", "…人だから三十歳、二年少ない。例えば、ドイツの場合なんかは、三十歳まで時効が完成しなくて、そこから公訴提起にいろいろ時間掛かりますので、プラス…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00320221101/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00320221101/66", "sentence": []}]}]}, {"date": "2023-05-11", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/49", "sentence": ["…っておりまして、御存じのとおり、民法の債権法が改正をされまして、消滅時効というのは、基本的には権利を行使、基本的には五年ということですね。そ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01320230511/63", "sentence": []}]}]}, {"date": "2023-