[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/117", "sentence": ["…いただきたいわけですけれども、何せ忙しいという、この教員の多忙化、働き方改革ということ、これがもう本当に重大な課題でございまして、ここを根本…", "…化とともに人手不足ということが言われておりますけれども、この教員の働き方改革、また優秀な教員の確保という問題、非常に重要だけれども難しい、な…", "…な問題でございますので、この法改正も踏まえまして、大臣はこの教員の働き方改革、そして優秀な教員の確保という問題についてどのようにお考えになっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/119", "sentence": ["…っと持ったままこのやりがいを感じて働いていただけるような、そうした働き方改革、是非文科省としても頑張って引き続きいただきたいというふうに思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/137", "sentence": []}]}]}]