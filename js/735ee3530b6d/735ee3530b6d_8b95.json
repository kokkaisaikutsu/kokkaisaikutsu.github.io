[{"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/1", "sentence": ["○平口委員長これより会議を開きます。農林水産関係の基本施策に関する件について調査を進めます。この際、お諮りいたします。本件調査のため、本日、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/78", "sentence": ["○平口委員長この際、暫時休憩いたします。午前十時四十八分休憩――――◇―――――午前十一時三分開議"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/79", "sentence": ["○平口委員長休憩前に引き続き会議を開きます。質疑を続行いたします。金子恵美君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/128", "sentence": ["○平口委員長午後一時から委員会を再開することとし、この際、休憩いたします。午後零時四分休憩――――◇―――――午後一時開議"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/129", "sentence": ["○平口委員長休憩前に引き続き会議を開きます。質疑を続行いたします。神谷裕君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00220220302/245", "sentence": []}]}]}]