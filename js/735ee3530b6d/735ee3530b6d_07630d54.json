[{"date": "2021-11-12", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/2", "sentence": ["…の員数は、議院運営委員会決定の基準に従いまして八名とし、先例により、委員長において指名するに御異議ありませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/3", "sentence": ["…て、委員長は今枝宗一郎君齋藤健君野中厚君宮下一郎君大串博志君佐藤公治君空本誠喜君稲津久君をそれぞれ理事に指名いたします。――――◇―――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120605007X00120211112/8", "sentence": []}]}]}, {"date": "2021-12-21", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/2", "sentence": ["…が四名欠員となっております。その補欠選任につきましては、先例により、委員長において指名するに御異議ありませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/3", "sentence": ["…なしと認めます。よって、そのように決しました。それでは、理事に江藤拓君高鳥修一君簗和生君及び金子恵美君を指名いたします。――――◇―――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705007X00120211221/8", "sentence": []}]}]}, {"date": "2022-03-01", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/2", "sentence": ["…します。ただいまの理事辞任に伴う補欠選任につきましては、先例により、委員長において指名するに御異議ありませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/3", "sentence": ["○平口委員長御異議なしと認めます。よって、そのように決しました。それでは、理事に緑川貴士君を指名いたします。――――◇―――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00120220301/10", "sentence": []}]}]}]