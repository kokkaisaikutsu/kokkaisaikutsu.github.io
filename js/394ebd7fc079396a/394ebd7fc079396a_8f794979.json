[{"date": "2022-05-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/272", "sentence": ["○丹羽議員お答えいたします。児童福祉法第三条の二におきまして、児童が家庭において心身共に健やかに養育されるよう、児童の保護者を支援しなければ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/276", "sentence": ["…条約の前文におきまして、同様の記述がございます。家族が児童の成長及び福祉のための自然な環境であるということにされておりまして、児童は家庭環境…", "…ある雰囲気の中で成長すべきであるとされております。御質問の中の、児童の権利に関する条約及び児童福祉法と同様の考えということで考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/284", "sentence": []}]}]}]