[{"date": "2022-04-27", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/261", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/267", "sentence": ["…えば保育の重要性、あるいは学校の重要性、地域の重要性、様々あって、社会全体で子供をとにかく守るんだというのが、今の恐らく野田大臣の姿勢である…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/269", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02220220427/277", "sentence": ["…なくて、一番困っているのは子供。この子供に対してどれだけ守れるか。社会全体で、私たち日本という国は、どんな家庭の状況であっても一人一人の子供…", "…違います。そして家庭もまた一つ一つ全然違います。その子なりの成長を社会全体でサポートをしていく、そして、時代の要請に合わせて現場の課題を解決…"]}]}]}]