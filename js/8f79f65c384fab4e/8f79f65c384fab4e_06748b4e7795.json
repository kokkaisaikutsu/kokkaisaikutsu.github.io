[{"date": "2022-05-10", "meeting": [{"meeting_name": "衆議院 東日本大震災復興特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/104", "sentence": ["…、それが大事だと思うんです。もう一つ大事なのは、やはりトップですよ、理事長です。この委員会でも何度も問題になっておりました。このＯＩＳＴ法の…", "…とが第一の条件なんですよ。でも、この法案の百二条第一項第一号に掲げる理事長及び理事の要件は、機構が行う事務及び事業に関して高度な知識、経験を…", "…高度な知識及び経験を有する者というのは、官僚ですよ。これから見たら、理事長は天下りなんじゃないかとも思えるんですけれども、法律の条文が違うん…", "…文が違うんですよ、沖縄と明確に。違うということは、違うようなタイプの理事長を想定しているとしか思えないんですけれども、具体的にどういう方を想…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/106", "sentence": ["…、機構が行う事務及び事業を適正かつ効率的に運営することができる者」も理事長ができるんですよ。これは一号と何が違うかといったら、高度な知識や経…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804858X00620220510/124", "sentence": []}]}]}]