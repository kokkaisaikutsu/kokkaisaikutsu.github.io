[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/10", "sentence": ["…について報告します。戦没者遺骨収集事業において、日本人ではない遺骨が収容された可能性が指摘されながら、長年にわたり適切な対応が行われてこなか…", "…あり、引き続き鑑定体制の強化を図っていくこととしています。また、遺骨収容のプロセスに関しては、日本人の遺骨である蓋然性が高い場合に、ＤＮＡ鑑…", "…ることはできませんでしたが、硫黄島や沖縄県等において百五柱の御遺骨を収容しました。御遺骨については、身元特定のためのＤＮＡ鑑定を実施しており…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X02320210608/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260