[{"date": "2022-05-24", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/21", "sentence": ["…ことで大きく利便性が向上するということも期待されておりますが、このプッシュ型というのは非常に重要だということを山田政務官、まだもちろん政務官…", "…に重要だということを山田政務官、まだもちろん政務官になる前からこのプッシュ型、自分でリーチアウトしなくても物が手元に来る、ここに対するこだわ…", "…る、ここに対するこだわりが大変大きくあると思うんですが、是非、このプッシュ型の情報提供についてどういうお考えで進めていこうとされているのか、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/23", "sentence": ["…が、ここすっごく難しいことにこれからなってくるんだろうと思います。プッシュ型で何かをやるということであると、例えば、よく今総務省から勧告が来…", "…いるところがあるし、していないところもあるんですね。ですから、このプッシュ型で物が届くためには、縦割り、横割り、年代割りの打破といって今まで…", "…ちの横割りの壁が物すごくはだかる話を、ある意味行政的に整理しないとプッシュ型の通知はできないはずですので、ここは腰を据えて、仕組みをつくると…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01820220524/37", "sentence": []}]}]}]