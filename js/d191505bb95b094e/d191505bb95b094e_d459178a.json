[{"date": "2024-04-26", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/18", "sentence": ["○金子（容）委員ありがとうございます。業務を委託する指定法人についてもう少し現状をお伺いしたいと思うんですけれども、現状は、どういった法人何…", "…ども、現状は、どういった法人何者に対しまして、具体的にどのような業務委託を行っているのかというところをちょっと教えていただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/20", "sentence": ["…門性に応じて複数の、五者というふうな話がありましたけれども、事業者に委託していたということだと思いますけれども、一者の指定法人にその業務を集…", "…た、新たに指定する指定法人からも、その業務の一部をまた別の事業者に再委託するというふうな形で業務の一部をまた委託するのか、そういったちょっと…", "…務の一部をまた別の事業者に再委託するというふうな形で業務の一部をまた委託するのか、そういったちょっと業務遂行上のスキームについて教えていただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/22", "sentence": ["…していただくということに加えまして、また、その指定法人が別の業者に再委託するというふうなことになりますと、その指定法人が取り扱う機密情報の取…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01020240426/30", "sentence": []}]}]}]