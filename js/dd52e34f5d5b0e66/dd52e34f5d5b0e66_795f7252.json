[{"date": "2022-04-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/19", "sentence": ["…ばならない中で、我が国は間接金融の文化でありますので、地域金融機関の役割というのが非常に私は大切であるというふうに思います。いわゆる日本の金…", "…術を発掘して、地域と結びつけて事業化していくのはまさに地域金融機関の役割であり、それを本機構が呼び水として先頭に立っていかなければ私は意味が…", "…要視する金融機関としては融資に一層慎重になる、この点で本機構の大きな役割があるんじゃないかというふうに述べておりました。まさにそのとおりだと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/23", "sentence": []}]}]}]