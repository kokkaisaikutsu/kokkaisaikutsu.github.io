[{"date": "2022-04-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/17", "sentence": ["…うふうに思います。であるならば、我が国の地形に適した太陽光パネルを技術革新によって造ることは、こうした課題解決に私はつながってくるのではない…", "…ば、太陽光パネル百枚で年間発電量が三万キロワットアワーだとすると、技術革新で交換効率を十倍にできたとします、そうすると、単純に、同じ年間発電…", "…、こういった技術開発も行われております。こうした太陽光パネルの発電技術革新を徹底的に進めて、我が国の国土に適した利用ができるようにしていくこ…", "…このように、まさに前例に乏しく、認知度が低く、リスクは高いけれども技術革新が期待できる事業に投資をしていくことが大変重要なことであるというふ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/23", "sentence": []}]}]}]