[{"date": "2022-04-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/13", "sentence": ["…かなければならないというふうに思うんですね。例えば、森林法の林地開発許可にしても、宅地造成法にしても、全ての法規制が今、開発事業を行うための…", "…の法規制が今、開発事業を行うための法律になっているんですね。林地開発許可に至っては、都道府県知事は申請が、まさに、災害の防止、水害の防止、水…", "…防止、水の確保、環境の保全の四つの要件を満たしていると認めるときには許可しなければならないとされているんですね。開発行為を行う者の権利の方に…", "…うな気がします。林発においては、今、林野庁が太陽光発電に係る林地開発許可基準に関する検討会などを開いていただいて議論が進んでいるようでござい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00620220405/23", "sentence": []}]}]}]