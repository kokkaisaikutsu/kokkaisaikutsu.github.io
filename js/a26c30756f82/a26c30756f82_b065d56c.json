[{"date": "2022-12-07", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/356", "sentence": ["…れるまでの慌ただしさにかなり違和感を覚えました。本日議題になっている新法は、大きな注目を浴び、今も苦しんでいる被害者の皆様を早く救出したい、…", "…いで済まそうとしていたのではないかと感じてしまいますし、この時点で、新法は作らない、又は来年の通常国会に先送りしようという意図を感じずにはい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/358", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/360", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/362", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/364", "sentence": ["…少し時間、戻りますが、十一月十五日に消費者契約法等改正案、十八日には新法の概要が示されましたが、内容についてはまだまだ議論の余地は大いにある…", "…り容易に訴えられるという内容のものであり、行政措置や刑事罰につながる新法の適用拡大を求める弁護団や我々の要望には必ずしも応えられていないと思…", "…処分や刑事罰のない配慮義務規定違反の方に宗教法人が逃げ込んでしまい、新法が骨抜きになることを懸念しております。一方で、自民党の茂木幹事長は、…", "…も、でき得るものは全て取り入れたと会見でおっしゃっていました。今回の新法が審議されるまでの与野党におけるプロセスは、ここ最近では余り見たこと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/366", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/368", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/370", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/372", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/374", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/376", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/378", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00520221207/380", "sentence": []}]}]}, {"date": "2023-04-04", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104536X00420230404/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00420230404/108", "sentence": ["…ない問題、こういったことも出てくることを想定した上で、将来的に法改正や新法での対応、こういったものも考えていらっしゃるのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00420