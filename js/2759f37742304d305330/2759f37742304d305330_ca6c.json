[{"date": "2023-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会公聴会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/101", "sentence": ["…くないんだということを知っていただきたいなと思って、そういう観点から前泊博盛教授にお伺いしたいと思っています。棄民政策と私は冒頭言いましたが…", "…るんだという立場からは、国の安全保障の前提となるものをかえって脅かすのではないかと考えるんですけれども、前泊教授のお考えをお伺いしたいです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/103", "sentence": ["○大石委員ありがとうございます。前泊教授にもう少しお伺いしたいと思うんですね。れいわ新選組は、積極財政ということで、国債を発行して介護とか保…", "…、さきの大戦の教訓でもあったかと思います。アメリカの事情にもお詳しい前泊教授にお伺いしたいですけれども、アメリカは軍産複合体が国の経済に浸透…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105262X00120230216/205", "sentence": []}]}]}]