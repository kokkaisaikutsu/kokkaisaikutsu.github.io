[{"date": "2023-03-30", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105254X01420230330/23", "sentence": []}]}, {"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/31", "sentence": ["…ような食事の提供の事業、これは、規模、営業形態、様々でございますし、原材料の調達経路、これも非常に多様でございます。また、提供される商品も様…", "…達経路、これも非常に多様でございます。また、提供される商品も様々で、原材料が頻繁に変わる。あるいは、厨房で、コンタミというんでしょうか、混ざ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/51", "sentence": ["…分迷惑をしているところでございますが。コオロギの記載でございますが、原材料としてコオロギを含む食品、これがどれだけあるのか私は承知をしており…", "…そうした具体的な事例がないものですから、コオロギについて、特に現行の原材料表示ルール以上の表示の義務づけを行う必要は現時点でないというふうに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/55", "sentence": ["…つきましては、輸入品を除く全ての加工食品について、重量割合上位一位の原材料に、生鮮食品の場合は原産地、加工食品の場合は製造地の表示をそれぞれ…", "…表示をそれぞれ義務づけております。製造地表示につきましては、中間加工原材料を使用している場合、当該原材料の原料の調達先が変わることや、生鮮原…", "…す。製造地表示につきましては、中間加工原材料を使用している場合、当該原材料の原料の調達先が変わることや、生鮮原材料まで遡って産地を特定するこ…", "…材料を使用している場合、当該原材料の原料の調達先が変わることや、生鮮原材料まで遡って産地を特定することが困難なことから、こうした表示を認めて…", "…ことが困難なことから、こうした表示を認めております。ただし、中間加工原材料の原料の原産地が生鮮原材料の状態まで遡って判明をしており、客観的に…", "…した表示を認めております。ただし、中間加工原材料の原料の原産地が生鮮原材料の状態まで遡って判明をしており、客観的に確認できる場合には、製造地…", "…明をしており、客観的に確認できる場合には、製造地の表示に代えて当該生鮮原材料名とともにその原産地を表示することができるようになっております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104536X00320230330/131", "sentence": []}]}]}]