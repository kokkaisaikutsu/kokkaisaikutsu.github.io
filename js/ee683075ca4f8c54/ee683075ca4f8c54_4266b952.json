[{"date": "2022-04-15", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/72", "sentence": ["…に熱心に、それからずっと、情報提供、あるいはいろいろな啓発、あるいは時効の撤廃等含めていろいろな活動をされていらっしゃいまして、先日も、四月…", "…自動車運転過失致死としての捜査が継続されていたんですが、これが十年の時効を迎える直前に危険運転致死罪に変更されているということで、十年だった…", "…危険運転致死罪に変更されているということで、十年だったものを二十年の時効という扱いに、罪名変更をして、捜査期間を十年から二十年に延長して、引…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/80", "sentence": ["…したいんですけれども、殺人罪とか強盗殺人罪については、平成二十二年に時効が撤廃されているということもあります。やはり、ひき逃げのことについて…", "…の取り方が、捜査の環境が変わってくるということもありますので、是非、時効の撤廃についても御検討いただきたいということで、先ほどの、お母様に賛…", "…ても御検討いただきたいということで、先ほどの、お母様に賛同する、その時効撤廃のことも含めて、オンラインの署名が八万九千四百十七集まっていて、…", "…賛同されているという、非常に重い、皆さんの気持ちがこういうところに入っておりますので、是非、時効のことについても御所見を伺えればと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/98", "sentence": []}]}]}]