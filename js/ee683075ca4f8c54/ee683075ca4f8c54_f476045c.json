[{"date": "2023-04-07", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/35", "sentence": ["…、何が大事かというと、日光を中に入れない。日光が中に入ってしまうと、直射熱、輻射熱が中で気温を上げてしまうということがありますので、日光をい…", "…光が入るんですけれども、冬はこう入るわけですよね。ですから、冬は中に直射日光が入って夏だと入らないという角度を計算してこういう設計をしたんで…", "…かるとかということもあります。いずれにしても、いろいろな優遇の中に、直射日光を入れない、外部で直射日光を遮断するという考え方を取り入れるべき…", "…す。いずれにしても、いろいろな優遇の中に、直射日光を入れない、外部で直射日光を遮断するという考え方を取り入れるべきかなと思いますが、こちらに…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104006X00420230407/135", "sentence": []}]}]}]