[{"date": "2023-06-19", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/128", "sentence": ["…な措置を講ずるべきである。一、人間の安全保障の理念に基づく開発協力の推進平成十五年のＯＤＡ大綱改定の際に掲げられた「人間の安全保障」の理念は…", "…諸条約に基づく基本的人権の尊重、貧困や飢餓の解消、ジェンダー主流化を推進するとともに、増大する難民や避難民の保護、子どもや女性、障害者や少数…", "…協力を実施すべきである。二、多国間主義と共創の精神に基づく開発協力の推進国際社会が分断の危機を克服していくためには、多国間主義を尊重しつつ、…", "…直面し、紛争が依然として飢餓の最大の要因である中、多国間主義の尊重と推進の精神に基づき、人道・開発・平和の分野横断的な連携を伴った包括的かつ…", "…国民に「自分たちのＯＤＡ」との意識を持ってもらうためにも、開発教育の推進によって、国民一人ひとりが世界の開発課題の主人公であるとの意識を涵養…", "…治体、大学・研究機関等から幅広く参加を得て、可能な限り開かれた議論を推進すべきである。また、我が国の開発協力の担い手となる優秀な人材を集め、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115359X00720230619/131", "sentence": []}]}]}]