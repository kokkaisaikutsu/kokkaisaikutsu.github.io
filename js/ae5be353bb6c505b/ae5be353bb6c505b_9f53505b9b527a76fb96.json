[{"date": "2022-04-27", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X02020220427/8", "sentence": ["…ーへの転換に強くかじを切るべきではないでしょうか。東京電力福島第一原子力発電所の事故から我々が学んだように、原子力発電は、一度事故が起きれば…", "…ょうか。東京電力福島第一原子力発電所の事故から我々が学んだように、原子力発電は、一度事故が起きれば、地域やそこに暮らす人々への被害はもちろん…", "…て大きく、また現時点で使用済核燃料の処分方法も定まっていないなど、原子力発電の負の側面を克服できるほどの技術や地理的側面も含めた環境が整って…", "…整っているとは思えません。加えて、ロシアのウクライナ侵略によって、原子力発電所が安全保障上の重大なリスクになり得ることを改めて認識させられま…", "…ら、エネルギー安全保障にも寄与できるものです。今すぐは難しくても、原子力発電への依存を減らしていき、二〇五〇年には再生可能エネルギーからの供…"]}]}]}, {"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/60", "sentence": ["…においても経済産業省が試算を行っているかと思いますが、太陽光発電、風力発電、火力発電、原子力発電のコストについて、試算結果を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814080X00720220510/70", "sentence": []}]}]}]