[{"date": "2022-10-27", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/69", "sentence": ["○宮口治子君それぞれの教科書の占有率は何％となっているでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/71", "sentence": ["○宮口治子君近年では、ヘルプマークについて教科書にもそうして採用されていることが増え、子供たちが学ぶ機会が増えていることは非常にいいことだと…", "…にいいことだと思います。一方で、学ぶ学年がばらばらであったり、全ての教科書には採用されていないこともあったり、まだ全ての子供たちにこのヘルプ…", "…う、文科省として取組をしていただきたいと思います。もちろん、制度上、教科書に載せるよう指導ができないことは承知しておりますが、事務連絡とか、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/92", "sentence": []}]}]}]