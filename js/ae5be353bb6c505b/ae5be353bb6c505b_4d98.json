[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/26", "sentence": ["…教えてください。また、初期投資や運営経費が示す具体的な内容、一校当たりの支援額、当面のというのが何年程度を指すのかについても教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/28", "sentence": ["○宮口治子君一校当たりの支援額が、今、およそ数億円から二十億円程度ということを今聞きましたが、結構、非常に大きな額でございます。大学において…", "…そ数億円から二十億円程度ということを今聞きましたが、結構、非常に大きな額でございます。大学において適切に資金が使用されたかどうか、機構は十分…", "…ることが求められます。これら資金の使用の適切性の調査、検証及び学校の選定、金額の決定に関して、今の機構の体制は十分であるとお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/36", "sentence": []}]}]}]