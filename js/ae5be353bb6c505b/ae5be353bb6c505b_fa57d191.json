[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/22", "sentence": ["…の課題、承知いたしました。既に自らの費用負担により新規開設した大学と基金の支援を受けて今後新たに設置する大学との間に、その公平性についてはど…", "…のように考えていらっしゃいますでしょうか。既設の大学であっても追加投資など別の形で何か基金の利用ができるのであれば、具体的に教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/24", "sentence": ["…防衛大学校のような大学以外の高等教育段階での学習に対する学位授与となっておりますが、今般の基金の設置先をこの機構にした理由を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/26", "sentence": ["○宮口治子君基金が支援する対象経費は、文部科学省が作成した本法律案の概要によると、学部、学科再編、定員変更等に要する初期投資や当面の運営経費…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00420221202/36", "sentence": []}]}]}]