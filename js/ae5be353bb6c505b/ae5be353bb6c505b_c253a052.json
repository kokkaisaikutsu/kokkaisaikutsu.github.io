[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/88", "sentence": ["…は、公共科目に期待される役割のうち、特にこの投票率に表れるような社会参加を促す役割に期待しております。近年、国内の選挙における投票率の低下が…", "…てはいないと考えられます。今回導入される公共科目では、この政治や社会参加への関心の低下、そもそもの政治が関わるシステムへの不理解といった状況…", "…導入する狙い及び狙いを達成するための科目内での内容、構成上の要点、特に投票率などに現れる社会参加を促す部分についてお伺いできますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00220220308/92", "sentence": []}]}]}]