[{"date": "2023-12-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/7", "sentence": ["○伊藤国務大臣お答え申し上げます。原子力災害時の避難経路となる道路整備を始めとする避難の円滑化、これは地域住民の皆様の安心、安全の観点から大…", "…お答え申し上げます。原子力災害時の避難経路となる道路整備を始めとする避難の円滑化、これは地域住民の皆様の安心、安全の観点から大変重要だと考え…", "…の安心、安全の観点から大変重要だと考えております。内閣府では、緊急時避難円滑化事業等により、福井県内の避難道路の拡幅、のり面の整備等を支援し…", "…考えております。内閣府では、緊急時避難円滑化事業等により、福井県内の避難道路の拡幅、のり面の整備等を支援してございます。引き続き、この事業を…", "…声をしっかりお聞きしてまいります。住民の皆様の安心、安全を第一として避難道路の整備が促進されるよう、関係省庁と連携し、継続的に取り組んでまい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204006X00320231205/113", "se