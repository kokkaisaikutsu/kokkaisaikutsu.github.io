[{"date": "2022-04-15", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/56", "sentence": ["…まうんだろうということで、次のテーマであります自動配送ロボット、遠隔操作型小型車に関してお聞きしていきたいというふうに思います。これは、今の…", "…これをつけるということなんですけれども、警察庁、お聞きいたします、ロボットの緊急停止スイッチを操作できる者は、法律上、誰を想定していますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/58", "sentence": ["…しがつかないわけでございます。そこで、この緊急停止、警察官以外の者が操作をするという場合について、あらかじめ整理をしておく必要があると思いま…", "…要があると思います。警察庁、お聞きいたします。居合わせた方、第三者が操作した場合にどういうふうな扱いになるのか、政令等で定める予定はあります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/213", "sentence": ["…通事故情報等を収集・分析し、交通安全の更なる向上に努めること。三遠隔操作型小型車（以下「自動配送ロボット等」という。）が歩行者の安全を脅かす…"]}]}]}]