[{"date": "2022-03-03", "meeting": [{"meeting_name": "衆議院 沖縄及び北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/16", "sentence": ["…部、展望を申し上げる状況じゃないという、この一言なんですね。平和条約交渉もこの言い方、ビザなし交流もこの言い方、墓参も自由訪問もこの言い方だ…", "…完全に全て同列で考えるというのは私は少し違うんじゃないのかな、政府間交渉の様々な話合いと人道的な対応というものに対して少しは、そこは決して全…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/34", "sentence": ["…委員予断を持って言えないということでありますから、是非そこはしっかり交渉してもらって、移設したけれども、その先でフリーハンドで訓練ができると…", "…訓練ができるということでは、これは負担軽減に逆行すると思いますから、責任ある交渉をお願いして、私の質疑を終わります。ありがとうございました。"]}]}]}]