[{"date": "2022-03-03", "meeting": [{"meeting_name": "衆議院 沖縄及び北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/28", "sentence": ["…この五月十五日の日付を冠した外交文書があるわけですけれども、五・一五メモと呼ばれています。在沖米軍基地の取扱いについて一九七二年五月十五日に…", "…月十五日に日米間で合意した協定でありますけれども、昨今、この五・一五メモが取り上げられることが増えていますのが、那覇軍港での米軍の訓練をめぐ…", "…、これは港湾と貯油、油をためるということが本来の主目的とこの五・一五メモで書いていますけれども、今回の米軍による航空機等を用いた大規模な訓練…", "…いますけれども、今回の米軍による航空機等を用いた大規模な訓練というものは、この五・一五メモに規定をした主目的に違反するものではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/30", "sentence": ["…。これは今のお話どおりですと、移設後の代替施設においても今の五・一五メモの合意の枠組み、つまり、主目的は港湾と貯油であるというこの枠組みが移…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/32", "sentence": ["…覇軍港でできているような訓練というのは、浦添に移転した後もできる、やることができる、これは、五・一五メモの解釈上はそういうことになりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120803895X00320220303/34", "sentence": []}]}]}]