[{"date": "2022-04-15", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/56", "sentence": ["…ぐな制度になってしまうんだろうということで、次のテーマであります自動配送ロボット、遠隔操作型小型車に関してお聞きしていきたいというふうに思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/213", "sentence": ["…し、交通安全の更なる向上に努めること。三遠隔操作型小型車（以下「自動配送ロボット等」という。）が歩行者の安全を脅かすことのないよう、悪質な使…", "…が安心して歩道を通行することができるよう、電動キックボード等及び自動配送ロボット等の歩道走行の在り方について検討した上で、必要な措置を講ずる…", "…観表示の在り方について検討した上で、必要な措置を講ずること。十二自動配送ロボット等については、事故や非常停止が生じた場合の対応を速やかに行う…", "…事故や非常停止が生じた場合の対応を速やかに行うことができるよう、自動配送ロボット等の使用者による対応方法等を検討した上で、必要な措置を講ずる…"]}]}]}]