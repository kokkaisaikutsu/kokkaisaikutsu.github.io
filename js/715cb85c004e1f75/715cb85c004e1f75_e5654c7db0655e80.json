[{"date": "2022-03-30", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/4", "sentence": ["…なった防衛装備庁の調達に関する新しい基準、この基準をスクープをした日経新聞二〇一九年六月二十一日付の記事、これは先般大串議員が質問いたしまし…", "…ているとも言い換えていいと思うんですが、なので、お聞きしますけれども、防衛省、この記事について日経新聞に訂正の申入れをしたことはありますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/6", "sentence": ["○山岸委員つまり、誤報を放置をしている。私は、日経新聞さんに問合せいたしました。防衛省が国会答弁で事実上誤報だというふうに言っているんだけれ…", "…、一体どっちが正しいんだと、私、必死で考えました。防衛省の御答弁も日経新聞さんの取材も矛盾しない場合が三つだけあると考えています。一つは、記…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01320220330/26", "sentence": []}]}]}]