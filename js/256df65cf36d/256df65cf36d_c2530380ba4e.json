[{"date": "2023-04-21", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104376X01520230421/11", "sentence": ["○津島委員自由民主党の津島淳でございます。四名の参考人の先生方には、大変示唆に富む、そして貴重な、それぞれのお立場からの御意見の開陳をいただ…", "…論をまさに行っている、そのように考えています。そういった中で、今日の参考人の皆様への質疑で一体どのような質疑を行えばいいのかというのは、非常…", "…いるんですが、まず、この定義というのは、認識は間違いないかどうか、そこをお伺いしたいと思います。まず、土居参考人、金子参考人、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X01520230421/14", "sentence": ["…だと思っております。そこで、リスクということで、この点について、末澤参考人、柳澤参考人、お二方から、それぞれの立場からの御意見の開陳があって…", "…ります。そこで、リスクということで、この点について、末澤参考人、柳澤参考人、お二方から、それぞれの立場からの御意見の開陳があって、少し補完的…", "…いし、そこでも財政負担というのは生じる。以上の私の考え方について、末澤参考人それから柳澤参考人から、それぞれ御見解をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X01520230421/17", "sentence": ["○津島委員ありがとうございます。末澤参考人から、次元の異なるワイズスペンディングということが大事であると。ということは、きちっとリスクに対応…", "…やはり大事なことである。そして、そういう御指摘があって、それから柳澤参考人から、その事態に至らしめないための外交努力、これはもちろん私はすご…", "…そもそもの話として、税によって賄われるべきだという私の考え方について、これは土居参考人、そして末澤参考人、お二人にお聞きをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X01520230421/20", "sentence": ["…に今我々はいるのだということを再認識いたします。そしてもう一つ、土居参考人からお話があった国債、特例公債について、これについて少し、あと五分…", "…、特例公債について、これについて少し、あと五分ですので、これは全ての参考人の皆様にお聞きをしたいと思っております。防衛予算に特例公債を充てる…", "…う考え方でおるんです。この点について、最後に、多分これで最後の質疑になると思いますので、各参考人の先生方から御見解をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104376X01520230421/26", "sentence": []}]}]}, {"date": "2023-11-08", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121204376X00220231108/1", "sentence": ["…いて調査を進めます。この際、お諮りいたします。両件調査のため、本日、参考人として日本銀行総裁植田和男君の出席を求め、意見を聴取することとし、…", "…本銀行総裁植田和男君の出席を求め、意見を聴取することとし、また、政府参考人として内閣府大臣官房審議官茂呂賢吾君、公正取引委員会事務総局経済取…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121204376X00220231108/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204376X00220231108/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204376X00220231108/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204376X002202