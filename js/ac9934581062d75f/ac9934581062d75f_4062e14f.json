[{"date": "2022-03-03", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/4", "sentence": ["○委員長（馬場成志君）外交、防衛等に関する調査を議題といたします。まず、外務大臣から外交の基本方針について所信を聴取いたします。林外務大臣。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/6", "sentence": ["○委員長（馬場成志君）次に、防衛大臣から国の防衛の基本方針について所信を聴取いたします。なお、今期国会の本委員会における岸防衛大臣の御発言及…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/8", "sentence": ["○委員長（馬場成志君）以上で所信の聴取は終了いたしました。本件に対する質疑は後日に譲ることといたします。この際、副大臣及び大臣政務官から発言…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00120220303/24", "sentence": []}]}]}]