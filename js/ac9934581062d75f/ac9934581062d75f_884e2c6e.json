[{"date": "2021-04-27", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/12", "sentence": ["…で避難が円滑にできなかった要因の大きな一つとして、線状降水帯の発達が予測できなかったとの指摘があります。これは本当に難しいことだと思いますが…", "…く、近年、毎年のように線状降水帯によって被害が発生しております。その予測精度を上げることが住民の的確な避難のために必要であるというふうに思い…", "…な避難のために必要であるというふうに思いますが、線状降水帯による豪雨の予測精度の向上について、今どのような取組をされておるか、お伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/14", "sentence": ["…場成志君難しいこととは思いますが、御努力に期待をさせていただきます。予測精度を上げる一方で、またその危険性が市町村や住民に伝わることが重要で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414319X01320210427/24", "sentence": []}]}]}]