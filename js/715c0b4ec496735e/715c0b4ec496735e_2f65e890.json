[{"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/9", "sentence": ["○山下雄平君地裁の本庁は対応済みで、支部はこれからということだと思いますけれども、これは、ありていに言えば、本庁のある県庁所在地など比較的人…", "…、本庁のある県庁所在地など比較的人口の多いところが先で、人口の少ない支部はもう少し待ってくださいということが実態であろうかというふうに思いま…", "…で導入する時期に差が生まれてくるのでしょうか。公判前整理手続のように本庁が先で支部は後といったような形になるんでしょうか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X01020220510/23", "sentence": []}]}]}]