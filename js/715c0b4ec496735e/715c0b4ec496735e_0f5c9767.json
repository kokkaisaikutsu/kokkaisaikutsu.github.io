[{"date": "2023-06-01", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/2", "sentence": ["…合連合会常務理事齊藤良樹君、静岡県立農林環境専門職大学短期大学部教授小林信一君、酪農家金谷雅史君及び東京農工大学大学院農学研究院教授新村毅君…", "…たします。次に、議事の進め方について申し上げます。まず、齊藤参考人、小林参考人、金谷参考人、新村参考人の順にお一人十五分程度で御意見をお述べ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/6", "sentence": ["○委員長（山下雄平君）ありがとうございました。次に、小林参考人、お願いいたします。小林参考人。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/8", "sentence": ["○委員長（山下雄平君）小林参考人、時間が来ておりますので、御意見をおまとめください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115007X01320230601/121", "sentence": []}]}]}]