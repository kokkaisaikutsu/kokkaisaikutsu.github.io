[{"date": "2022-03-16", "meeting": [{"meeting_name": "衆議院 地方創生に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804773X00420220316/115", "sentence": []}]}, {"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/141", "sentence": ["…も園において実施される実地調査は、認定こども園法第十九条に基づく指導監査通知により、保育所等の児童福祉施設が原則として一年に一度以上実地調査…", "…す。参考までに、通知であっても、幼保連携型認定こども園というのは実地監査の実施率というのは実は保育所より上回っているということで、必ずしも通…", "…きたいということで、今、厚生労働省とも連携しつつ、都道府県の適切な指導監査、そういうことを、質の確保を取り組んでいるということでございます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/143", "sentence": ["…けて、厚生労働省において、繰り返しになりますけど、児童福祉施設の指導監査の在り方について検討が行われている、そういうことであります。保育所や…", "…われている、そういうことであります。保育所や認定こども園に対する指導監査は、御指摘のように、子供の安全確保や教育、保育の質の確保の観点から大…", "…ですが、厚生労働省の研究会の報告書、ここでは、保育所等においては指導監査はあくまでも実地によることが原則であるとして、例外的に実地によらない…"]}]}]}]