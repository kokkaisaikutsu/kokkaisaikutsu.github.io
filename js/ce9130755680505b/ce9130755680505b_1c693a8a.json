[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/73", "sentence": ["…（野田聖子君）今厚労省からも説明がありましたけれども、全般的ながんの検診を受けない人、見ているんですけれども、やっぱり受ける時間がないからと…", "…るからというような順番になっているそうです。御指摘のとおり、私も今年検診を受けてきましたけれども、いつも痛いです。まあこれは、もう息子のため…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/75", "sentence": ["…して答弁しているんですけれども、ずっとライフワークで乳がん・子宮がん検診促進議員連盟の会長というお仕事をいただいていて、まさに問題意識は共有…", "…診ですね、及び乳房エックス線検査、これマンモグラフィー、による乳がん検診を推奨しているものと承知しています。乳がん検診の方法としては、問診、…", "…ラフィー、による乳がん検診を推奨しているものと承知しています。乳がん検診の方法としては、問診、マンモグラフィーのほか、視触診、超音波検査、Ｍ…", "…、マンモとこの超音波エコーを人間ドックでやっているところです。乳がん検診については、科学的根拠の観点から、厚生労働省における専門家の議論、こ…", "…現時点では問診と乳房エックス線検査、マンモグラフィーが指針に基づく唯一の検診方法として推奨されている、そういうふうに理解しているところです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/171", "sentence": 