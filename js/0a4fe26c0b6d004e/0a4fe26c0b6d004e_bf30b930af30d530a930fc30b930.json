[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/138", "sentence": ["○伊波洋一君米国では、国防総省が二〇一九年七月にＰＦＡＳタスクフォースを設立して、全ての米軍基地に共通する、解決を要する国家的な課題としてＰ…", "…課題としてＰＦＡＳ汚染の問題に取り組んでいます。国防総省のＰＦＡＳタスクフォースの進捗、ＰＦＡＳ対処の状況について防衛省は把握していますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/142", "sentence": ["○伊波洋一君米国が、国家的解決を要する、国家的な課題としてタスクフォースを行い、そして調査をして、七百近く調査しているのに、まあ沖縄、日本に…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/151", "sentence": []}]}]}]