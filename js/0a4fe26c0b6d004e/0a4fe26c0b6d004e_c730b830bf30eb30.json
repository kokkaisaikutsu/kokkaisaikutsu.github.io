[{"date": "2021-06-01", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/162", "sentence": ["…ういうこの論文の形を見ますと、論文の図三は、委員会資料の基になったデジタルデータがあって初めて加工、作成できたものではないでしょうか。防衛省…", "…タルデータがあって初めて加工、作成できたものではないでしょうか。防衛省は論文の著者に何らかの生のデジタルデータを提供したのではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/166", "sentence": ["…ております。一方、これには何も書いていないんですね。何らかの意味でデジタルデータを入手してその加工を行ったものと思われます。一方、防衛省に、…", "…手してその加工を行ったものと思われます。一方、防衛省に、防衛局にはデジタルデータは行きませんよね。報告書としてのＰＤＦしか行かないはずです。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X01520210601/172", "sentence": []}]}]}]