[{"date": "2020-12-03", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/231", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/243", "sentence": ["…には、固定翼機が使用する滑走路の両端から約九百メートル外側までの間の区域については、飛行の安全と地上における人の安全確保の観点から、土地の使…", "…行の安全と地上における人の安全確保の観点から、土地の使用が制限される区域としてクリアゾーンが指定されていると答弁いただきました。そこで、質問…", "…間飛行場について、「基地外まで伸びるクリアゾーンは、基地外にある居住区域や商業区域といった適合的でない地域も含んでいるようである。」、「全て…", "…ついて、「基地外まで伸びるクリアゾーンは、基地外にある居住区域や商業区域といった適合的でない地域も含んでいるようである。」、「全ての固定翼の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/247", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/249", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/251", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/253", "sentence": ["…日米環境原則に関する共同発表では、日米両政府の共通の目的は、施設及び区域に隣接する地域住民並びに在日米軍関係者及びその家族の健康及び安全を確…", "…に、日米地位協定の第三条三項でも、「合衆国軍隊が使用している施設及び区域における作業は、公共の安全に妥当な考慮を払つて行なわなければならない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/255", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00620201203/257", "sentence": []}]}]}, {"date": "2021-03-26", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120413950X00520210326/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X00520210326/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120413950X005202103