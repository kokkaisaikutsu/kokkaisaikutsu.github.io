[{"date": "2022-04-27", "meeting": [{"meeting_name": "参議院 政府開発援助等及び沖縄・北方問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/123", "sentence": ["…や子供の貧困が問題になっています。沖縄では、基地は県経済の最大の阻害要因とする認識が広く県民に共有されています。これまで沖縄振興政策に問題が…", "…阻害していると言わざるを得ません。日本政府も、基地は県経済最大の阻害要因という認識に立って、沖縄振興に向けた更なる取組をお願いしたいと思いま…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815359X00820220427/127", "sentence": []}]}]}, {"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/146", "sentence": ["…の子供の相対的貧困率の問題などを抱えています。基地は県経済最大の阻害要因との認識が県民の間でも広く共有されており、基地の存在そのものが問題の…", "…識が県民の間でも広く共有されており、基地の存在そのものが問題の一つの要因であることは間違いありません。一九四五年の米軍による占領、一九五二年…", "…音、米軍犯罪、環境汚染など、県民の暮らしに犠牲を強いて、県経済の阻害要因になっているだけではありません。有事には軍事目標としての攻撃対象とな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/159", "sentence": []}]}]}]