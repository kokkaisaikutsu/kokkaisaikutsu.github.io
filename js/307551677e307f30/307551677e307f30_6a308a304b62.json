[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/152", "sentence": ["…いうのが現実というのは皆さんも周知の事実だと思います。所管が分かれてなり手不足に拍車も掛かるんじゃないかというような懸念もありますので、そも…", "…んじゃないかというような懸念もありますので、そもそも、この民生委員のなり手不足に対しての課題、そして、それがひいては、その民生委員を選んでい…", "…題として上がっていますが、現状、厚生労働省として、自治会長そのもののなり手不足や地域の福祉に関係する人々のなり手不足についての課題認識、そし…", "…働省として、自治会長そのもののなり手不足や地域の福祉に関係する人々のなり手不足についての課題認識、そして、今どのようにお考えになっているか、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/154", "sentence": ["…きには、逆に、分ける方がもしかしたら、少しの時間対応するということでなり手が増えていくという可能性もゼロではないというふうに思いますので、新…", "…に思いますので、新たな民生委員、児童委員の在り方ということだったり、なり手不足をもっと広範囲に考えていくという視点でも、是非今後検討していた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/166", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X018202206