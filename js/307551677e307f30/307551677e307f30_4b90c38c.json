[{"date": "2022-03-01", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/100", "sentence": ["…たいと思います。先ほど来、森屋委員も質問されましたけれども、標準的な運賃、これと実勢価格が低いままだというのが現状の、現場の認識なんですよね…", "…と実勢価格が低いままだというのが現状の、現場の認識なんですよね。標準運賃出したということですけど、今の実勢運賃が低いという認識は国交省にあり…", "…格が低いままだというのが現状の、現場の認識なんですよね。標準運賃出したということですけど、今の実勢運賃が低いという認識は国交省にありますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/102", "sentence": ["…これトラック業界、最下位、今十六位ずっと続いているんですよね。全く今の取組効いていないと思います。標準的な運賃の決め方、まず教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/104", "sentence": ["○田村まみ君例えば、運輸の中でも貸切りバス事業であれば下限運賃を設定しています。トラック運送業でもこうした制度、導入されませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/106", "sentence": ["○田村まみ君バス事業者では下限運賃を設定しています。この下限運賃の制度、どうでしょう。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/108", "sentence": ["○田村まみ君環境では長年のこの難題が突破できていないので、下限運賃など具体的な対応が必要だという御提案です。是非検討いただきたいです。そうい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00520220301/118", "sentence": []}]}]}]