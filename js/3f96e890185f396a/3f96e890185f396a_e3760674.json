[{"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/304", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/306", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/310", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/312", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/320", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/322", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/324", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/326", "sentence": ["○阿部（弘）委員では、新しく、仮放免制度に代わって、監理措置制度が二つにわたってあるわけなんですね、出国命令が出る前と出国命令が出た後の。僕…", "…と不思議だったんですが、四十四条の八では退去強制令書が発付された者は監理措置は行えないというふうに書いてあって、その次の号で、五十二条の二で…", "…えないというふうに書いてあって、その次の号で、五十二条の二では新たに監理措置について新法ではうたってあるんです。ちょっと分かりにくいですよね…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/328", "sentence": ["…弘）委員私なんか法律が所管外なものですから、四十四条の八で停止される監理措置と五十二条の二で停止される監理措置というのが同じものかと思ってお…", "…ですから、四十四条の八で停止される監理措置と五十二条の二で停止される監理措置というのが同じものかと思っておりました。じゃ、この監理措置につい…", "…十二条の二で停止される監理措置というのが同じものかと思っておりました。じゃ、この監理措置についてお伺いします。監理措置とはどんな制度ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/330", "sentence": ["○阿部（弘）委員では、この監理人というのが置かれなければ収容を続けるわけでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/332", "sentence": ["○阿部（弘）委員ですから、監理人がそもそも見つからなかった場合や、監理人が国外退去になった場合とかということもあり得るわけですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/334", "sentence": ["○阿部（弘）委員それじゃ、監理措置が置かれることで、果たして送還忌避問題