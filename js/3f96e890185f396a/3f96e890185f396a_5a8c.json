[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/145", "sentence": ["…がありますが、最近、日本脳炎はいかがですか。日本脳炎というのは、宿主は豚でございます。私も県庁におりましたときには、熊本県庁ではサーベイラン…", "…庁におりましたときには、熊本県庁ではサーベイランスを行っておりまして、豚の感染率を調べておりましたが、やはり陽性は時期が遅れて参るわけであり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/147", "sentence": ["…ということを思っております。それは、農水省の、あるいは厚労省の取組で、豚の免疫を調べることで予防に従事することができる。しかし一方で、デング…", "…種類の熱、日本脳炎に似たような脳炎、熱が東京なんかではやっております。豚とは余り関係ないようなところでございますが、デング熱はいかがでござい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/163", "sentence": []}]}]}]