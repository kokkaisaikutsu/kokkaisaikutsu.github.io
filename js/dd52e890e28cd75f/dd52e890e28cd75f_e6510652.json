[{"date": "2020-12-01", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/55", "sentence": ["…た。これを受けて金融庁では、昨日、東証などに対して業務改善命令の行政処分を行ったと承知をしております。原因と影響について、まずはどのように把…", "…しております。原因と影響について、まずはどのように把握をされているのか、そして処分の概要と再発防止策についてお示しをいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314370X00420201201/61", "sentence": []}]}]}, {"date": "2021-05-17", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00620210517/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00620210517/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00620210517/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00620210517/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00620210517/101", "sentence": ["…にもお越しいただいておりますので、核のごみ、高レベル放射性廃棄物最終処分の問題についてお伺いをいたしたいというふうに思います。核のごみの最終…", "…の問題についてお伺いをいたしたいというふうに思います。核のごみの最終処分問題については、その問題をめぐって北海道の寿都町、神恵内村で処分地選…", "…最終処分問題については、その問題をめぐって北海道の寿都町、神恵内村で処分地選定に向けた全国初の文献調査がスタートしております。四月の十四日に…", "…初の文献調査がスタートしております。四月の十四日には、寿都町で住民と処分事業者を担うＮＵＭＯ側との対話の場が持たれましたが、冒頭から紛糾する…", "…というふうに思います。皆様にもお手元に資料を配らせていただきました。処分地選定プロセスという資料がございますので、ちょっと参考のために見てい…"]},