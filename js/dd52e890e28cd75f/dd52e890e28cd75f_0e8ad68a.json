[{"date": "2021-03-26", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X01120210326/52", "sentence": ["…の一部を改正する法律案、これら二法案につきまして、共に反対の立場から討論いたします。新型コロナウイルス感染症が世界に猛威を振るい、一年以上が…", "…ように、所得税法等改正案及び公債特例法案の二法案につきまして反対の意思を表明し、私の討論を終わります。御清聴ありがとうございました。（拍手）"]}]}]}, {"date": "2022-03-22", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00620220322/53", "sentence": ["…会派を代表し、所得税法の一部を改正する法律案について、反対の立場から討論を行います。本法案に反対する最大の理由は、現在の税制に課せられた最重…", "…ません。その他、反対理由として指摘しなければならない点はたくさんありますが、持ち時間の関係上、以上、最大の反対理由を述べ、討論といたします。"]}]}]}]