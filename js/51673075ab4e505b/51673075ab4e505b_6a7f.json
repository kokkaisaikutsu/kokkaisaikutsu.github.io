[{"date": "2023-04-28", "meeting": [{"meeting_name": "参議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/46", "sentence": ["…誤認や有利誤認と認定されて措置命令や課徴金納付命令の対象となる事案というものが、この第四十八条の犯罪構成要件を満たすことになるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/48", "sentence": ["…きましたが、消費者庁として調査をしていく中で、これはもう第四十八条の犯罪構成要件を満たす事案を把握した場合、やはり警察や検察へ告発していくこ…", "…っぱり被害届を警察に提出しようと警察署に持っていっても、なかなかその犯罪構成要件を満たしているかはっきりしないということであったり、なかなか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/52", "sentence": ["…四十八条のお話をお聞きしましたが、次、今回のこの第四十八条の直罰と詐欺罪との関係についてもちょっとお聞きをしておきたいと思います。刑法二百四…", "…ついてもちょっとお聞きをしておきたいと思います。刑法二百四十六条の詐欺罪においては、「人を欺いて財物を交付させた者は、十年以下の懲役に処する…", "…る。」というふうにございますけれども、一般論として、この現行法上の詐欺罪との線引きというものがどんなふうに想定しているのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/54", "sentence": ["…事案に、今回、直罰が導入されることで、一つの事案で本法律案の第四十八条と詐欺罪というのが同時に成立することも考えていらっしゃるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114536X00620230428/62", "sentence": []}]}]}]