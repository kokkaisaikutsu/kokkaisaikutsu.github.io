[{"date": "2021-04-07", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/95", "sentence": ["…すので、引き続きよろしくお願いいたします。東日本大震災直後について、節電というものが呼びかけられました。私も北海道に住んでいますが、すごい、…", "…けられました。私も北海道に住んでいますが、すごい、北海道でもみんなが節電に向かっていたんですね、当時。ですが、残念ながら、十年たったら全国的…", "…向かっていたんですね、当時。ですが、残念ながら、十年たったら全国的に節電とか省エネという観点が少し失われて、少しというか大分失われてきている…", "…ませんが、やっぱり消費者とか事業者としての機運というのが、省エネとか節電への機運というのが薄れていると感じるんですが、大臣におかれましては、…", "…ています。今は環境省としてこの省エネに向かっていると思うんですが、この節電と省エネについて、改めて小泉大臣のお考えをお聞かせいただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414103X00220210407/103", "sentence": []}]}]}]