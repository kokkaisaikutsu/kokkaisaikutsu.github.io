[{"date": "2022-03-10", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/46", "sentence": ["…た、コロナで顕在化したものがあります。まず、女性労働者に占める非正規労働者の割合と、非正規労働者に占める女性の割合を厚労大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/48", "sentence": ["…う非正規労働者であるという実態が浮かび上がっています。この非正規労働者の問題、処遇改善について、厚労大臣、今後どう実現するか、お伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/50", "sentence": ["○岸真紀子君厚労大臣に今御説明いただいたお話はどれも重要だと思うので、それも引き続き進めていただきたいです。大臣がおっしゃっていた中には、正…", "…いった福祉職場、そういった職場は賃金が低く抑えられているのが実態です。厚労大臣は、女性が多く働く産業ではなぜ賃金が安く抑えられているとお考え…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/52", "sentence": ["…金にも影響していると私は考えます。この性別役割分業意識を政府としてどう変えていくのか、厚生労働大臣、そして内閣府特命担当大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01120220310/61", "sentence": []}]}]}]