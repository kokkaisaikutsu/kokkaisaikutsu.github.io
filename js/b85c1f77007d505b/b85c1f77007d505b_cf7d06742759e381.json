[{"date": "2022-12-01", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/21", "sentence": ["○岸真紀子君岸田総理も来年度の交付税増額に言及されていたと思いますので、当然、法定率の引上げなのかなと期待していたところなんです。是非、引き…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014601X00520221201/28", "sentence": []}]}]}, {"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/44", "sentence": ["…帰のこの政府の考えは到底受け入れられないとおっしゃっていました。岸田総理、福島の方々、そして原発に不安を感じる国民に思いをはせているのか、最…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/50", "sentence": ["…というのは、国から話を持っていくのではなくて、地域が自分で考えて、国は地域の支援に徹するべきです。この点について岸田総理にお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/52", "sentence": ["○岸真紀子君総理にも答えていただけたらよかったんですが、今、西村大臣からは丁寧な地元での説明と言っていますが、全然丁寧になっていないし、結局…", "…対話の場を設けるなど様々な方法を活用して丁寧に進めなければなりません。最後にこの点について、原発問題の最後に岸田総理のお考えをお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/54", "sentence": ["○岸真紀子君総理、問題がもう一つあって、この原発の政策を転換するようなことなんですが、選挙でこれ諮ったかどうかということなんです。これは、選…", "…案が昨日閣議決定されましたので、その懸念点を質問させていただきます。総理はこれまでの予算委員会で、入信当初に不安をあおられるなどで困惑し、そ…", "…受けていて合理的な判断が付かない場合や、信心している状態が分からない状態での献金についての取消しはできるのか、総理の答弁をお願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/56", "sentence": ["…気付いて後から取消ししたいと思ったときに、念書の効力はなくなるのでしょうか。そして、取消しができるのか。その辺も、総理、改めてお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/59", "sentence": ["○岸真紀子君本当は総理にお答えをというか、総理に要求をしていたものでございました。次に、旧統一教会の勧誘行為というのは、例えばですが、環境問…", "○岸真紀子君本当は総理にお答えをというか、総理に要求をしていたものでございました。次に、旧統一教会の勧誘行為というのは、例えばですが、環境問…", "…要で、これでは救えないのではないかといった懸念があります。教会が政府の考えている法案を逆手に取って抜け道とならないのか、総理にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/61", "sentence": ["○岸真紀子君岸田総理にこの被害者の救済への思いがあるのであれば、今お話ししていただいたような、例えば配慮義務に、その明確化できないものを配慮…", "…。きちんと条文化することを、まだこれからも議論続くと思いますが、是非総理の決断でしていただきたいということをお願いいたします。それで、次の質…", "…第八波という今後の感染拡大、さらには季節性インフルエンザとの同時流行の現時点での見通しをどのように想定し、対策するのか、総理にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/69", "sentence": []}]}]}, {"date": "2023-03-16", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/27", "sentence": ["…条第一項に関する政治介入問題について伺います。この問題は、礒崎陽輔元総理補佐官が議員個人の行動とはならない立場であることを重く考えなければな…", "…ばなりません。公開された七十八枚に及ぶ総務省の公文書を読むと、礒崎元総理補佐官が執拗に総務省職員へ迫っていたことが記されており、総務省職員に…", "…執拗に総務省職員へ迫っていたことが記されており、総務省職員にとっては総理の意向と捉えなければならず、相当なプレッシャーを受けていた背景をも読…", "…せていただきます。まず、これ、平成二十六年十一月二十六日水曜日、礒崎総理補佐官付きから放送政策課に電話で連絡。内容は以下のとおり。放送法に規…", "…礒崎補佐官レク。更に前向きに検討するよう指示。括弧、補佐官は年明けに総理に説明した上で国会で質問したいとのこと、括弧閉じ。平成二十七年一月九…", "…七日火曜日、二十四日火曜日、礒崎補佐官レクが続きます。三月二日、山田総理秘書官レク、状況説明。三月五日、礒崎補佐官から安倍総理に説明。括弧、…", "…三月二日、山田総理秘書官レク、状況説明。三月五日、礒崎補佐官から安倍総理に説明。括弧、今井、山田総理秘書官同席、括弧閉じ。三月九日月曜日、平…", "…、状況説明。三月五日、礒崎補佐官から安倍総理に説明。括弧、今井、山田総理秘書官同席、括弧閉じ。三月九日月曜日、平川参事官から安藤局長に連絡。…", "…弧閉じ。三月九日月曜日、平川参事官から安藤局長に連絡。高市大臣と安倍総理の電話会談結果。十三日金曜日、山田総理秘書官から安藤局長に連絡。括弧…", "…安藤局長に連絡。高市大臣と安倍総理の電話会談結果。十三日金曜日、山田総理秘書官から安藤局長に連絡。括弧、高市大臣と安倍総理の電話会談結果、括…", "…十三日金曜日、山田総理秘書官から安藤局長に連絡。括弧、高市大臣と安倍総理の電話会談結果、括弧閉じ。四月一日水曜日から四月七日火曜日までは、答…", "…れを今日は問いただしたかったというところです。この闇深い問題として、総理補佐官、背景にある総理の意向に沿う内容とするよう自民党議員に、あろう…", "…かったというところです。この闇深い問題として、総理補佐官、背景にある総理の意向に沿う内容とするよう自民党議員に、あろうことかこの参議院の総務…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230