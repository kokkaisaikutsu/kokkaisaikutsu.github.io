[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第四分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/2", "sentence": ["…この笹山笠が山笠の原型というふうに言われております。福岡県からの聞き取りや私の手元にあります文献からは、明治三十九年以前までは全てこの笹山笠…", "…言いましたとおり、現在も黒崎祇園山笠はこの形式を承継しまして、お汐井取りといって、神事の当日には、笹山笠を海水で清めて、実際にこの笹山笠の形…", "…さんの装飾を施した山笠は、この笹山笠の運行を行った後に、この笹山笠を取り外して派手な装飾を施して、もう一度黒崎祇園山笠として町の中を運行して…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/8", "sentence": ["…りまして、感謝を申し上げたいと思っています。実際に福岡県の方がお汐井取りの神事のときに調査に来られたときに、私も立ち会わせていただきました。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105270X00220230221/22", "sentence": []}]}]}]