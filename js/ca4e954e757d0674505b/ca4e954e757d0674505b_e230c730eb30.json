[{"date": "2022-04-25", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/21", "sentence": ["…進されることを期待しています。政府は、これまでも、聴覚障害児支援中核モデル事業として児童発達支援センターと特別支援学校の連携を模索されてきま…", "…、特別支援学校の敷地内に児童発達支援センターを設置し、協力、連携するモデルがあります。専門人材の有効的な活用ができ、かつ、児童に対して適切な…", "…効的な活用ができ、かつ、児童に対して適切な支援ができるこの一体型の中核モデルの実現を一層推進すべきだと考えますが、御見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/29", "sentence": []}]}]}]