[{"date": "2022-04-25", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/15", "sentence": ["…加算、特定処遇改善加算、処遇改善特別加算などがありますが、加算の対象職種や条件が異なるなど複雑な仕組みとなっているんですね。法人内では、加算…", "…っているんですね。法人内では、加算の対象が限定されることにより職員の職種によって不公平が生じるなど、とても使いにくい仕組みだという声も聞こえ…", "…るため、処遇改善加算のこの仕組みというものを簡素化するとともに、対象職種を全職種に拡大することが必要だと考えますが、御見解をお聞かせください…", "…ため、処遇改善加算のこの仕組みというものを簡素化するとともに、対象職種を全職種に拡大することが必要だと考えますが、御見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/29", "sentence": []}]}]}]