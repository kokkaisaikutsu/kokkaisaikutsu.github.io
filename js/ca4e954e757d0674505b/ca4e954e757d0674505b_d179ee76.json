[{"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/10", "sentence": ["…もうそれから約十年ぐらいたっています。この十年間で、やはりこのダンス科目の導入から十年たった今、実施状況を踏まえたこの検証と、また課題解決の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/12", "sentence": ["…たちもいます。このような民間の人材やノウハウを活用することで、ダンス科目が一層効果的で充実したものになると考えています。現在、国としてダンス…", "…が一層効果的で充実したものになると考えています。現在、国としてダンス科目における外部人材の活用に資する予算は、令和五年度の予算案には、多様な…", "…の状況を正確に把握することができないと思います。そこで、現在のダンス科目の実施状況を調査するとともに、外部人材の活用を積極的に推進すべきだと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/14", "sentence": ["…、実現などを検討していただきたいと思っております。ところで、特別支援学校におけるダンス科目の実施状況について教えていただけませんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/26", "sentence": []}]}]}]