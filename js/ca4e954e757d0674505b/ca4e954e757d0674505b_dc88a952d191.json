[{"date": "2022-04-25", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/23", "sentence": ["…所であれば保育が行われているものとみなされ、利用者がいる場合と同等の補助金が支給されていましたが、一昨年から減額されることとなりました。当日…", "…減額されることとなりました。当日の利用キャンセルについては従来どおり補助金が支払われるとのことですが、利用者の都合により利用者がゼロの場合で…", "…、保育以外にも環境整備や事務などの業務は行わなければならないことから補助金の減額は適当ではないと考えておりますが、御見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/25", "sentence": ["○今井絵理子君当日のキャンセルについては補助金は減額されないということなんですけれども、では、二日前、三日前、急に子供が熱を出したりする可能…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/29", "sentence": []}]}]}]