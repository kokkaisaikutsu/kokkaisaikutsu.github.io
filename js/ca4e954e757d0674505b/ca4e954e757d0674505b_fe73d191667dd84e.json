[{"date": "2023-03-13", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/20", "sentence": ["…がありました。政府におかれましても、その声を基に、児童一人当たりの現金給付を、二年前の春と昨年の春、二回実施していただきました。これについて…", "…末、私たち参議院自民党は、困窮子育て世帯への子供一人当たり五万円の現金給付の実現を求める緊急提言をまとめました。近々、正式に要請したいと考え…", "…いと考えております。是非とも総理にはこの困窮子育て世帯への子供一人当たり五万円の現金給付の実現をしてほしいと思いますが、見解をお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00820230313/36", "sentence": []}]}]}]