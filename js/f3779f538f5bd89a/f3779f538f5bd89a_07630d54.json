[{"date": "2020-11-10", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/3", "sentence": ["…が五名欠員となっております。その補欠選任につきましては、先例により、委員長において指名するに御異議ありませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/4", "sentence": ["…よって、そのように決しました。それでは、理事に菅家一郎君土屋品子君牧原秀樹君生方幸夫君及び源馬謙太郎君を指名いたします。――――◇―――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304006X00120201110/19", "sentence": []}]}]}]