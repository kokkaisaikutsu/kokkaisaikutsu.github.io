[{"date": "2021-03-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00220210316/235", "sentence": ["○副大臣（宮内秀樹君）お答えをいたします。有機質資源を原料とした堆肥等の利用は、持続的な農業生産活動のための土づくり、あるいは地域資源の循環…", "…ます。そこで、農水省におきましては、堆肥等の利用の促進を図るために、良質な堆肥の供給能力の拡大や地域の未利用資源の利用拡大に向けましての農業…", "…三つ目、家畜排せつ物を堆肥として土づくりに有効利用するための堆肥の高品質化やペレット化に資する施設等の整備への支援も行っているところでござい…"]}]}]}]