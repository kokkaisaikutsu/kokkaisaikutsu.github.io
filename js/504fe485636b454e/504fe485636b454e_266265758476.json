[{"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/9", "sentence": ["…と平和、そして繁栄です。まさに独立と平和、繁栄、そのために国際協力を戦略的に行う、そういう意味で、国家安全保障戦略にも実は国際協力の部分が結…", "…も実は国際協力の部分が結構盛り込まれております。そういう意味で、この国際協力を戦略的に使うということは重要だと考えますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/18", "sentence": ["…、またＯＤＡ予算をめぐって無用な労力を使うことになりますから、ここは戦略的に是非お願いしたいと思います。ここまででＯＤＡの開発協力大綱の議論…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01220220517/26", "sentence": []}]}]}]