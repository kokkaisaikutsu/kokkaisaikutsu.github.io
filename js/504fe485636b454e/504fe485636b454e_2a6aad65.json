[{"date": "2022-11-01", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/251", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/253", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/255", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/257", "sentence": ["…Ｉもロボットも非常に防衛の方が少ない。やはり総理が言われるように省庁横断でやらないといけないというふうに言えると思います。さらに、防衛省が今…", "…えないと駄目だと思います。まさに、今回のこの議論、省庁を、壁を破って横断的に将来しっかり守るための議論というものをやって、これはまさにＣＳＴ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/259", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/261", "sentence": ["…場合によっては防衛省だけではなく、ＮＳＳもかむような形で、省庁、本当横断的にやってもらわなければ無理ですから。ここはしっかり、私は第二筑波学…", "…に防衛力の抜本的強化をやるのであれば、真に使える公共インフラ、これを省庁横断的にやるべきだと思いますけれども、国交副大臣のお考えを伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/269", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00320221101/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013