[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/205", "sentence": ["…の航空会社、欧州の航空会社の飛行ルートがこの黄色い線です。今、ロシア上空通れないために、日本の航空会社もヨーロッパの航空会社も、北回りあるい…", "…の領空を避けて飛んでいます。では、国土交通省にお伺いします。今、日本や欧州の航空会社でロシア上空を通過している旅客とかカーゴとかありますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/207", "sentence": ["○佐藤正久君大臣、今言ったように、今、欧州便も日本便も既にロシアの上空は通過していないんですよ。モスクワ便も、今予約も停止しているんですよ。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00220220308/221", "sentence": []}]}]}]