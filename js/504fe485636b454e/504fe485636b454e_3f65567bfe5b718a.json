[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/21", "sentence": ["…に繰り返し述べています。でも今回は、取下げではなく、中断という形で政策対話を始めるというふうになっていますけれども、中断と取下げでは全く外交…", "…違います。なぜ今回、今までの答弁のように、取下げということで初めて政策対話が始まることを、それをやめて、中断で政策対話を始めるというふうに変…", "…今までの答弁のように、取下げということで初めて政策対話が始まることを、それをやめて、中断で政策対話を始めるというふうに変節したんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/23", "sentence": ["…にやっぱり見えてしまいますし、しかも、その二国間の協議ということと政策対話は全く違いますから、なぜここで協議という言葉を使っているのかと。日…", "…韓国側も、輸出管理についてはそれぞれの主権に基づいて対話を行うと、政策対話と言っているのに、なぜここで協議という言葉を使うのかと、協議と対話…", "…れ、半導体の三品目であれ、これは協議を行う対象ではないと、しっかり政策対話を行うと言っているにかかわらず、この発表文の方ではなぜこういう協議…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/25", "sentence": ["…るを得ません。しかも、ＷＴＯの紛争手続というものを中断をしなければ政策対話をしないと言っているんであれば、一番最初に、このＷＴＯの紛争解決手…", "…書きした方がいいですよ、しっかりと。ＷＴＯの中断と書いて、その上で政策対話の部分とあるいはそのＷＴＯの協議の部分と分けないと、譲っているよう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121113950X00320230309/37", "sentence": []}, {"url": "