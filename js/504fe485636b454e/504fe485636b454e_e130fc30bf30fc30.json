[{"date": "2020-11-19", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/21", "sentence": ["…なこういう大きなもの、これをＳＰＹ７型に小さくすると。大体一辺が五メーターぐらいのものがＳＰＹ７です。小さくする。小さくすると能力は当然小さ…", "…。素子が少なくなりますから、大きさ小さくすれば。ＳＰＹ６は一辺が四メーター。こういうものを洋上でやっぱり比較しないといけない。洋上の場合、仮…", "…やっぱり比較しないといけない。洋上の場合、仮に船に載っける場合、五メーターを載っけるのと四メーターを載っけるのでは船の大きさが違ってくるんで…", "…ない。洋上の場合、仮に船に載っける場合、五メーターを載っけるのと四メーターを載っけるのでは船の大きさが違ってくるんですよ。当然、大きなものを…", "…分かる話で。そういう、実際に洋上に載っけたときに、今の陸上のこの五メーター、五メーターのものをそのまま載っけるのか、あるいは若干小さくしてＳ…", "…そういう、実際に洋上に載っけたときに、今の陸上のこの五メーター、五メーターのものをそのまま載っけるのか、あるいは若干小さくしてＳＰＹ６のよう…", "…のをそのまま載っけるのか、あるいは若干小さくしてＳＰＹ６のように四メーター、四メーター、アメリカ海軍のイージス艦のように載っけるのか、これに…", "…載っけるのか、あるいは若干小さくしてＳＰＹ６のように四メーター、四メーター、アメリカ海軍のイージス艦のように載っけるのか、これによっても能力…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120313950X00220201119/35", "sentence": []}, {"url