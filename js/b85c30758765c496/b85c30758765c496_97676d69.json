[{"date": "2022-06-01", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/13", "sentence": ["○岸田内閣総理大臣まず、林業経営については、関係者の皆様方が、生産性の向上ですとか、あるいは規模拡大ですとか、様々な御努力をいただいてはおり…", "…、依然、委員御指摘のように、大変厳しい状況にあると認識をしています。林業が地域経済を支え、そして国土の保全、水源の涵養、地球温暖化の防止など…", "…温暖化の防止など多面的機能を発揮している、こうしたことを考えますと、林業の持続的な発展、これは極めて重要であると考えます。そして、特にいわゆ…", "…て重要であると考えます。そして、特にいわゆるウッドショックに対して、林業が国内資源を活用して木材需要に的確に対応していけるよう、路網整備、木…", "…ていかなければならない、このように思います。そして、将来を見据えて、林業者の所得向上を図り、切って、使って、植える、こうした循環利用を確立す…", "…は人材確保、こうしたものに努め、またデジタル技術等を活用したスマート林業への総合的な支援、こうしたものを推進していきます。こうした様々な政策…", "…政策を重層的に政府としてもしっかり用意することによって、現場で大切な林業を守っている皆さんたちをしっかりと支えていかなければならない、このよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02120220601/53", "sentence": []}, 