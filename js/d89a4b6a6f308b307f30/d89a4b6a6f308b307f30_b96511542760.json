[{"date": "2021-06-03", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/9", "sentence": ["…あります。コロナ禍の現状、またその先を見通して、企業への雇用支援政策をどのような方向性で展開をしていかれるのか、厚労省にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/11", "sentence": ["…で、二〇二一年の今日における国際、国内環境に対する現状認識と、それを踏まえての日本国の産業競争力強化政策の方向性について伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/23", "sentence": ["…は大変重要であります。こうした観点から、今回の法改正によって措置された政策を含め、今後の地域密着型中小企業支援策の方向性を伺ってまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00820210603/30", "sentence": []}]}]}]