[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/80", "sentence": ["…況も踏まえて、ＪＴはどのような対応をお取りになるんでしょうか。これは、国、財務大臣が筆頭株主でもございますので、財務省にお尋ねをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/82", "sentence": ["…、先週の二十三日には株主総会もＪＴは行っております。この株主総会で、筆頭株主である財務大臣、どのような意見を申し上げられたのか、お尋ねをいた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/84", "sentence": ["○古賀之士君財務大臣が筆頭株主ですが、特段の御意見はなかったということを伺いまして、確認をさせていただきました。一方で、この大規模な希望退職…", "…まして、配当性向は実に七五％弱に達する見込みでございます。財務大臣が筆頭株主であり、経営陣にも実は多くの官僚が天下りをしている実態もあるＪＴ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/86", "sentence": ["…た。特に私の方から申し上げたいのは、このＪＴという、言ってみれば、今筆頭株主、再三申し上げているように財務大臣です。そして、それが、筆頭株主…", "…、今筆頭株主、再三申し上げているように財務大臣です。そして、それが、筆頭株主の割合、株主の割合からすると三割以上を占めているという圧倒的な筆…", "…頭株主の割合、株主の割合からすると三割以上を占めているという圧倒的な筆頭株主なんですね。ですから、そういったことも踏まえて、配当を決める、あ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/108", "sentence": []}]}]