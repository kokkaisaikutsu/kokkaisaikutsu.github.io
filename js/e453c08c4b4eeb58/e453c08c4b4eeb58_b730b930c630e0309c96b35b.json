[{"date": "2021-03-22", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/40", "sentence": ["…くお願いをいたします。それでは、次の質問、移らせていただきます。システム障害についてですが、時間がなくなってまいりましたので、金融庁の参考人…", "…ので、金融庁の参考人に、まず、この過去五年間に発生した金融機関のシステム障害についての件数、それから、次の質問も合わせ技で伺いますが、ＡＰＩ…", "…ン・プログラミング・インターフェース、このＡＰＩの開放と関連するシステム障害があるのかないのか、済みません、まとめてお答えいただけますでしょ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414370X00420210322/43", "sentence": ["…そして、昨今、みずほ銀行などの、名前を出して申し訳ありませんが、システム障害が大きな問題にもなっております。これにつきましてはまた、時間が来…"]}]}]}]