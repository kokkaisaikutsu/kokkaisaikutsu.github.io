[{"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/34", "sentence": ["…調査をお尋ねする際に、今からの質問の際に参考にと思いまして、交通政策基本法の第十六条から十八条でございます。これはどのような意味を持つ条項で…", "…省の参考人にお尋ねいたします。また、地域公共交通の確保とどのような関係にこの交通政策基本法の第十六条から十八条はあるのか、お尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/36", "sentence": ["…。今回の実態調査の結果からして、今参考人から答弁ありました、交通政策基本法が定めるいわゆる重大な、重要な基本理念が確保されているかどうか、総…", "…考人から答弁ありました、交通政策基本法が定めるいわゆる重大な、重要な基本理念が確保されているかどうか、総務大臣は今どのようにお考えでしょうか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/46", "sentence": []}]}]}]