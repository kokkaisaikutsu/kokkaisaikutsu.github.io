[{"date": "2022-04-19", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/24", "sentence": ["…た、ウクライナのシュミハリ首相も参加と報じられておりますが、日本の財務大臣として会談を行う予定はございますでしょうか。お答えをお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/26", "sentence": ["○古賀之士君ありがとうございます。少なくとも財務大臣は、ウクライナの参加がもしかなった場合は個別の会談をしたいと思っていらっしゃいますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/28", "sentence": ["○古賀之士君その会談がもし調整が付けば、どのようなことを重点的にお話合いをするおつもりでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/30", "sentence": ["…けれども、直接またお会いできる機会もめったにないと思いますので、もし会談がかなった場合は、是非、日本の総括的なウクライナに対する支援をしっか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/32", "sentence": ["○古賀之士君お忙しい中、スケジュール調整大変かと思いますが、是非、会談が実現いたしまして、日本政府の意思が、為替についても、そしてウクライナ…", "…の意思が、為替についても、そしてウクライナの平和についても、実のある会談になることを祈っております、願っております。どうぞよろしくお願いいた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/52", "sentence": []}, {"url": "https://kokkai.nd