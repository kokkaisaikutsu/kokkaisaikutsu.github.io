[{"date": "2022-03-28", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/78", "sentence": ["…る方、そういったそのロシア側の資産の凍結やあるいは民間企業をそのまま接収しようという動きを察知する、そういったことも考えられるんですが、なら…", "…ったことも考えられるんですが、ならば、現実にそういったその民間企業や接収されたり資産が凍結された場合のことを考えて、例えば、財務大臣にお尋ね…", "…て、例えば、財務大臣にお尋ねします、日銀が持つこのロシアの外貨準備を、これ、こちら側も対抗措置として接収するということは可能なんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/80", "sentence": ["○古賀之士君ならば、接収ができる規定なりを設けていき、そして、もしロシア側が強硬な態度を取った際にきちんと速やかに、スピーディーに対抗措置が…", "…おります。この点、例えばフィリップ・モリスなど世界の大手の部分はもう接収を検討し始めているという報道も一部ございます。こういったそのロシアで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00120220328/108", "sentence": []}]}]}]