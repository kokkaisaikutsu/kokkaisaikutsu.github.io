[{"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/38", "sentence": ["…二を、お手元の資料を御覧ください。こちらは、地域公共交通の活性化及び再生に関する法律という形で、国の様々な、それから各自治体との連携、それか…", "…法律という形で、国の様々な、それから各自治体との連携、それから活性、再生といったものに関する条項でございますが、法律でございますが、この今回…", "…律でございますが、この今回の調査結果からして、この地域公共交通活性化再生法の第四条が定める国の努力義務について、どのようにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/46", "sentence": []}]}]}]