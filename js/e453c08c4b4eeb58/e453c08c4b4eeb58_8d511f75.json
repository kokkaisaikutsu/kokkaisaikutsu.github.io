[{"date": "2022-04-04", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/38", "sentence": ["…二を、お手元の資料を御覧ください。こちらは、地域公共交通の活性化及び再生に関する法律という形で、国の様々な、それから各自治体との連携、それか…", "…法律という形で、国の様々な、それから各自治体との連携、それから活性、再生といったものに関する条項でございますが、法律でございますが、この今回…", "…律でございますが、この今回の調査結果からして、この地域公共交通活性化再生法の第四条が定める国の努力義務について、どのようにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814281X00220220404/46", "sentence": []}]}]}, {"date": "2023-06-02", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X02820230602/16", "sentence": ["…ける審査の経過と結果を御報告申し上げます。本法律案は、福島の復興及び再生を一層推進するため、市町村による特定帰還居住区域復興再生計画の作成及…", "…島の復興及び再生を一層推進するため、市町村による特定帰還居住区域復興再生計画の作成及びその内閣総理大臣による認定、当該認定を受けた同計画に基…"]}]}]}]