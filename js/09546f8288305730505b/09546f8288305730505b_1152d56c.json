[{"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/257", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/260", "sentence": ["…、そうやって証拠をそろえるのが困難なのが性暴力被害であり、また、現行刑法では同意のない性行為そのものが犯罪行為だと明確に禁止されていないわけ…", "…あるわけです。そして、これらの課題は、被害当事者団体や日本学術会議、刑法改正市民プロジェクトなど様々な団体から指摘され、法改正が求められてい…", "…摘され、法改正が求められているところですが、法務大臣に伺います。この刑法百七十六条、百七十七条に規定されている暴行又は脅迫や抗拒不能要件、こ…", "…拒不能要件、これをなくして同意要件を新設するなど、同意のない性行為が犯罪であると刑法に明確に示すべきではないかと思いますが、いかがでしょう。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/262", "sentence": ["…も、こうした力関係、地位、関係性を背景にした性暴力も犯罪であるということを刑法に明示すべきではないかと思いますが、法務大臣、いかがでしょう。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/264", "sentence": ["…性を利用した性暴力も含めた同意のない性行為をこれを犯罪として明示する刑法改正、本当に急ぐべきであるということを重ねて訴えておきたいと思うわけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/282", "sentence": []}]}]}]