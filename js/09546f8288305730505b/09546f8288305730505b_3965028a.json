[{"date": "2022-04-25", "meeting": [{"meeting_name": "参議院 行政監視委員会国と地方の行政の役割分担に関する小委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815352X00220220425/103", "sentence": []}]}, {"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/222", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/224", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/226", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/228", "sentence": ["○吉良よし子君適切な対応じゃなくて、このマネジメント、手引き、改訂するべきではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/230", "sentence": ["○吉良よし子君いや、事前のレクでは改訂作業中だというお話ありましたけど、作業もされてないということなんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/232", "sentence": ["○吉良よし子君科学的知見を集積して改訂と、遅過ぎるんですよ。筋痛性脳脊髄炎の会の皆さん、ＭＥ／ＣＦＳの会の皆さんは、もうこの手引きが発表され…", "…者がいることが詳しく説明されていないことなどを問題点として、手引きの改訂、早くから求めているんです。それから既に四か月、まだ改訂されていない…", "…て、手引きの改訂、早くから求めているんです。それから既に四か月、まだ改訂されていない。今もこうやって私が伺っても改訂するとお答えにならない。…", "…それから既に四か月、まだ改訂されていない。今もこうやって私が伺っても改訂するとお答えにならない。どうなんですか、やっぱりすぐにでもこの問題点…", "…訂するとお答えにならない。どうなんですか、やっぱりすぐにでもこの問題点見直して改訂するべきじゃないですか。もう一度、厚労大臣、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00620220425/238", "sentence": []}]}]}]