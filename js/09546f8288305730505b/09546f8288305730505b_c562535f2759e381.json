[{"date": "2023-03-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/420", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/422", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/424", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/426", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/428", "sentence": ["…、子育て支援の観点からこの医療費助成を実施しているんだと思うんですが、そういう重視の表れだと思いますが、少子化担当大臣、これどう思いますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/430", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/432", "sentence": ["…いう悲鳴もありました。この自治体によるばらつき、少子化対策進めるためにも一刻も早く解消すべきと思いませんか。少子化担当大臣、いかがでしょう。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/434", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/436", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/438", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/440", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/442", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/444", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/446", "sentence": ["…で述べられているわけで、異次元の少子化対策というならば、この医療費、子供の医療費無料を実現すべきと思いますが、少子化担当大臣、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/448", "sentence": ["…と、そういう声が出ているわけです。やはり、この声にちゃんと応えるべきではありませんか。厚労大臣、少子化担当大臣、それぞれどうぞお願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01120230320/451", "sentence": []}]}]}]