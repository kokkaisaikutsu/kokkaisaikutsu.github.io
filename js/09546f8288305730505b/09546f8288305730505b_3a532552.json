[{"date": "2022-04-20", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X01820220420/17", "sentence": ["…事評価の面談と同じタイミングでの指導、助言は、本当に人事評価と明確に区別される、区別できるというのでしょうか。人事評価の面談の場で研修受講の…", "…と同じタイミングでの指導、助言は、本当に人事評価と明確に区別される、区別できるというのでしょうか。人事評価の面談の場で研修受講の有無などを確…"]}]}]}, {"date": "2022-04-28", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/65", "sentence": ["…省は答弁しているわけですが、この人事評価の面談の場での指導助言というのは、本当に人事評価と明確に区別して行うことができるものなのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00720220428/77", "sentence": []}]}]}, {"date": "2022-05-10", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/229", "sentence": ["…評価と異なる趣旨だっておっしゃいますけど、同じ場でやったらどこでどう区別を付けるのかというのは現場の校長また教員にとってはかなり困難だと思う…", "…かというのは現場の校長また教員にとってはかなり困難だと思うんですが、実際にどうやってこの明確に区別をするんですか、その人事評価と指導助言と。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/231", "sentence": ["○吉良よし子君趣旨と目的が異なるから区別されるんだという御答弁だったと思うんですけど、現場でやられている教員が明確にそれを区別して考えられる…", "…う御答弁だったと思うんですけど、現場でやられている教員が明確にそれを区別して考えられるのかと。人事評価を受ける面談の場で、これの研修、受けて…", "…じゃないかと恐れるのは当然じゃないかと思うんですね。それをどう明確に区別付けるのかということを申し上げているんです。その評価の対象にはしない…", "…考人質疑、先日の参考人質疑でも、校長経験のある戸ヶ崎参考人ですらこの区別についてなかなか難しいことだろうと答弁されているわけで、難しいんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/233", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00820220510/280", "sentence": []}]}]}]