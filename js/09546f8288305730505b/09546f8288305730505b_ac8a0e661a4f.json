[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/281", "sentence": ["…川市など周辺の八市は国の責任で住民に対して丁寧な説明を行うように繰り返し求めているわけですが、この住民に対する説明会というのはやりましたか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/283", "sentence": ["…住民の不安を一層高めるものと考えますと、この不安を伝えているわけです。防衛大臣、国の責任で住民への説明会、ちゃんとやるべきではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/285", "sentence": ["○吉良よし子君住民への説明会ちゃんと行わないで、どうやって不安に応えるというのでしょうか。地元自治体への説明も私は十分だとは思えないと思うん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/299", "sentence": []}]}]}]