[{"date": "2022-10-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/466", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/468", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/470", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/472", "sentence": ["…れた政策も施し、お恵みという温情主義的なものでした。例えば五万円の現金給付、非課税世帯にほぼ限定した形で行われます。困っているとうるさいから…", "…生活困窮していますから絶対的に給付が必要ですが、それ以外の人々にも必要です。現金給付の幅を今よりも拡大してください。総理、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/474", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/476", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/478", "sentence": ["…ません。少なくとも物価が上がる分は全て国が吸収する必要があります。現金給付は、悪い物価高が収まるまで、季節ごとに一律十万円給付するべきと考え…", "…一人の購買力を上げて需要を喚起、景気回復を促す政策として、まずは消費税減税と一律現金給付を併せてやるべきと考えます。総理、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/481", "sentence": ["○天畠大輔君残念です。消費税減税も一律現金給付もしない。温情主義から脱せないのですね。質疑時間がもったいないので、次に行きます。代読お願いし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/483", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/485", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/487", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/491", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/494", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/497", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/500", "sentence": []}]}]}]