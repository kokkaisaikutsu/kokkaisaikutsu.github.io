[{"date": "2022-03-04", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/58", "sentence": ["…ちなヤングケアラーを早期に発見することが重要であるとされています。関係機関の連携は、ヤングケアラーへの支援を進める上で欠かせないものだと思い…", "…ます。自治体として戸惑いの大きい部分でもあるかと思いますが、国として関係機関の連携をどのように支援していかれるのか、見解をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/60", "sentence": ["…の経費を計上しております。その中で、モデル事業として、地方自治体に関係機関や民間支援団体とのパイプ役となるヤングケアラーコーディネーターの配…", "…な方を置くことを想定しているのでしょうか。単なる飾りではなく、真の関係機関の連携を進められるような仕組みとなるよう工夫を凝らしていただきたい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X00320220304/74", "sentence": []}]}]}]