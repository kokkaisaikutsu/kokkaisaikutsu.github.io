[{"date": "2021-05-20", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/79", "sentence": ["…ことでお話がありました。最近の状況でいきますと、電気自動車に乗られて高速道路を使って移動される方が、それこそサービスエリア、パーキングエリア…", "…とが実際に起きています。特に地域でいきますと、東北方面なんというのは高速道路の設置数がやはり少なくて、そもそもそちらの方に足を伸ばしにくいよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/81", "sentence": ["…ね、数万円のレベルで設置できますから。ただ、急いで充電したいところ、高速道路の途中のパーキングなんというところはやっぱり急速充電を入れていた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00520210520/90", "sentence": []}]}]}]