[{"date": "2022-04-13", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X01620220413/17", "sentence": []}]}, {"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/99", "sentence": ["…とが言われていました。国と地方との役割を見直し、国から地方への権限の移譲、そして地方税財源の充実強化等地方公共団体の自主性、自律性の強化を図…", "…りました。そうしますと、今この国会の決議の中にあった文章のその権限の移譲と税財源の充実強化というその観点で、じゃ、税の収入、支出という観点で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/103", "sentence": ["…き続き、引き続き国が多くなり地方が少なくなるとしたならば、幾ら権限を移譲されても地方は動けなくなりますよね。ますます地方交付税という金額を大…", "…やっぱり大臣に聞きたくなりました。なので、やはりこの権限をしっかりと移譲するということと財源もしっかりとそこに手当てをしていくということが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815360X00620220413/107", "sentence": []}]}]}]