[{"date": "2022-12-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/15", "sentence": ["○国務大臣（加藤勝信君）メディカルジェットのお話がありました。メディカルジェットによる患者輸送を行う場合、これはメディカルジェットだけにかか…", "…大臣（加藤勝信君）メディカルジェットのお話がありました。メディカルジェットによる患者輸送を行う場合、これはメディカルジェットだけにかかわらず…", "…した。メディカルジェットによる患者輸送を行う場合、これはメディカルジェットだけにかかわらず、飛行計画を事前に空港事務所に通報するということが…", "…が求められております。要請から出動まで一定の時間を要するメディカルジェットよりは、ドクターヘリ等、緊急に対応し得る他の搬送手段によって搬送さ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/17", "sentence": ["○国務大臣（加藤勝信君）へき地患者輸送航空機、メディカルジェット運送支援事業は、安心安全な医療へのアクセスを確保することを目的とし、無医地区…", "…っておりまして、等による搬送の費用については支援をしております。そして、この等の中にはメディカルジェットが含まれるものと解釈をしております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/300", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/353", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/355", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/371", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/373", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00720221202/377", "sentence": []}]}]}]