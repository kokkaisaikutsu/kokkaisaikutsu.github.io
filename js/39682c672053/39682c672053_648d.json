[{"date": "2022-11-25", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/3", "sentence": ["○根本委員長質疑の申出がありますので、順次これを許します。赤澤亮正君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/19", "sentence": ["○根本委員長この際、若宮健嗣君から関連質疑の申出があります。赤澤君の持ち時間の範囲内でこれを許します。若宮健嗣君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/35", "sentence": ["○根本委員長この際、越智隆雄君から関連質疑の申出があります。赤澤君の持ち時間の範囲内でこれを許します。越智隆雄君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/47", "sentence": ["○根本委員長この際、岩田和親君から関連質疑の申出があります。赤澤君の持ち時間の範囲内でこれを許します。岩田和親君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/59", "sentence": ["○根本委員長この際、中川郁子君から関連質疑の申出があります。赤澤君の持ち時間の範囲内でこれを許します。中川郁子君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/73", "sentence": ["○根本委員長これにて赤澤君、若宮君、越智君、岩田君、中川君の質疑は終了いたしました。次に、赤羽一嘉君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/90", "sentence": ["○根本委員長この際、中野洋昌君から関連質疑の申出があります。赤羽君の持ち時間の範囲内でこれを許します。中野洋昌君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/100", "sentence": ["○根本委員長これにて赤羽君、中野君の質疑は終了いたしました。午後一時から委員会を再開することとし、この際、休憩いたします。正午休憩――――◇…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00620221125/163", 