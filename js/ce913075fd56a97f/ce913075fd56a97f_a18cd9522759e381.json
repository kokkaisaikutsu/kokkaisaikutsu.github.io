[{"date": "2023-05-10", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/44", "sentence": ["…の現在の財政状況ですね、国及び地方の長期債務残高、このことについて財務大臣にお聞きしたいと思います。本当は財務大臣じゃなくて使われる大臣の方…", "…債務残高、このことについて財務大臣にお聞きしたいと思います。本当は財務大臣じゃなくて使われる大臣の方がいいのかなと、お使いになるですね、しか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/48", "sentence": ["…そのように思うことを指摘をさせていただきたいと思います。それから、財務大臣の方にお聞きしたいと思いますが、いわゆる予備費でございますが、予備…", "…民に対していまだなされていないと考えているわけでありますけれども、財務大臣、この辺りのところ、いかがでしょうか、もっと説明ができないものかと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/50", "sentence": ["…の現状は憲法の趣旨に反するのではないかと考えますが、予備費に係る財政統制の在り方について、もう一度財務大臣の御所見をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00720230510/66", "sentence": []}]}]}]