[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第七分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/179", "sentence": ["…ネルギーの有効利用に向けて、スーパーキャパシタの更なる開発に国内でも期待が寄せられておりますが、ヘンプ繊維を原料としたカーボンナノシートがス…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/181", "sentence": ["…田分科員日本国内でも、若いベンチャー企業など、産業用ヘンプの利活用に期待を寄せている企業も少なくありません。先日、一般社団法人麻産業創造開発…", "…内外のニーズと政府の認識に乖離があるように感じるのですが、その辺り、若いベンチャー企業の期待なんかはどのように考えていらっしゃるでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/183", "sentence": ["…ィー等に使われている、カーボンニュートラルを見据えればヘンプの活用が期待される、耕作者が未来を描けるように、農業、産業振興の観点からも、政治…", "…ニュートラルを見据えた国内ヘンプ産業の振興に誇りを持って取り組んでいただけることを期待を申し上げ、質疑を終わります。ありがとうございました。"]}]}]}]