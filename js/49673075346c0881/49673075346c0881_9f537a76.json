[{"date": "2022-03-23", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/31", "sentence": ["…治区における人権問題の観点からも強い懸念がございます。ヨーロッパでは原発の積極利用を求める声が拡大し、フランスを中心に、チェコ、フィンランド…", "…める声が拡大し、フランスを中心に、チェコ、フィンランドなどの十か国は原発をグリーンの投資先に加えるよう共同声明で欧州委員会に訴え、昨年、ブリ…", "…後の記者会見で欧州委員会の委員長は、我々は安定的なエネルギー源である原発が必要だと述べました。化石燃料を持たない日本にとってエネルギー自給率…", "…、稼働の有無によってそのリスクは変わらないと思うのですけれども、経済安全保障の観点から、原発の再稼働について政府の御認識をお尋ねいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/33", "sentence": ["…からの発表のコメント欄とかを見ておりますと、もうほとんどの方が、早く原発を再稼働してほしい、それを進めてほしいというコメントで埋め尽くされて…", "…本当に命に関わります。国民の命を守るためにも、国民の声に応えて早期に原発を稼働させていただいて、電力の安定供給をよろしくお願いをいたします。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01120220323/45", "sentence": []}]}]}, {"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第七分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/163", "sentence": ["○杉田分科員それでは、今後、政府としてどのように原発の再稼働を進めていくのかについても教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/165", "sentence": ["…分科員ありがとうございます。先日の予算委員会で、野党の質疑において、原発反対派は必ず高レベル放射性廃棄物の最終処分場が決まっていないことを指…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105271X00220230221/167", "sentence": []}, {"url": "https://