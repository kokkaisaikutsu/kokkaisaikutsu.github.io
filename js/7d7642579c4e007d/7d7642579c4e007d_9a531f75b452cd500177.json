[{"date": "2024-03-11", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/41", "sentence": ["…福祉サービスの施設整備については補助金制度があると聞いておりますが、その内容について厚生労働省から分かりやすく御紹介いただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/45", "sentence": ["…からは、加算請求を簡単に行うことができる全国共通のソフトを開発し、厚生労働省から配布してほしいという声もありました。事業者の方々の事務作業の…", "…声もありました。事業者の方々の事務作業の負担軽減のためにもこうした対応ができるのではないかと考えますが、厚生労働省の見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/47", "sentence": ["…独自の基準を定め、地域の実情により即した別枠の制度を設けることも検討に値するのではないかと考えますが、厚生労働省の御見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00820240311/83", "sentence": []}]}]}, {"date": "2024-05-13", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/11", "sentence": ["…続き必要と考えております。重層的支援体制整備事業を更に推進するため今後どのような取組を実施していくのか、厚生労働省にお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/13", "sentence": ["…とが重要と考えております。重層的支援体制整備事業の実施状況に関する厚生労働省の調査結果によれば、多くの地方自治体から、ほかの地域の取組事例に…", "…進するに当たって、地方自治体に充実した支援を行っていく必要性や重要性に関する認識を、もう少し詳しく厚生労働省に御説明いただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314281X00420240513/21", "sentence": []}]}]}]