[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/4", "sentence": ["…、質問に入らせていただきたいと思います。まず、孤独・孤立対策について野田大臣に御質問させていただきたいと思います。党で孤独・孤立対策の特命委…", "…もおります。今国会でまた質問するチャンスもあると思っておりますので、野田大臣には大枠の質問だけ二つさせていただきたいと思います。デジタル化と…", "…、実態調査をやっているということで、初めての調査をやっておりますが、野田大臣は我が国における孤独、孤立の現状をどんなふうに捉えておられるかと…", "…会こそ一番重要だと思って、それこそが究極の役割じゃないかと思っておりますが、この点につきまして野田大臣の見解を教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/8", "sentence": ["…はちょっと御要望ということにしておきたいというふうに思います。委員長、野田大臣と問い一に関係する皆さん方は御退席いただいて結構でございます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00220220308/22", "sentence": []}]}]}, {"date": "2022-05-19", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/9", "sentence": ["…良祐君いよいよ今国会でも大変重要な法案の審議に入ることになりました。野田大臣には先ほど提案理由説明いただきましたけれども、大変思いのこもった…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01720220519/21", "sentence": []}, {"u