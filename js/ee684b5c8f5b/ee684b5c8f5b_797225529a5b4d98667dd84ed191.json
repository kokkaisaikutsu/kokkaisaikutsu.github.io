[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/9", "sentence": ["…いて少しお聞きをしていきたいというふうに思います。二〇二〇年から特別定額給付金でありましたり、一人親の世帯臨時特別給付金、そして子育て世代へ…", "…うふうに思います。特に、二〇二〇年、最初に、四月に実施されました特別定額給付金、全国民に十万円を配るということでございました。その多くが、あ…", "…要なことではなかろうかというふうに思います。そこでまず、今回の給付の効果、この特別定額給付金について財務省の見解をお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X00220220308/23", "sentence": []}]}]}]