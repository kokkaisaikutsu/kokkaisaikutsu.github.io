[{"date": "2022-11-28", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/305", "sentence": ["…しても、この二十五条を改正するか、あるいは、自衛隊八十条に基づく、防衛大臣による海上保安庁の統制要領を少なくともきちんと定めておくことが必要…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/307", "sentence": ["…めていただきたいと思います。一方で、現場で海保と海自の共同訓練は、防衛大臣、まだやっていないんですよね、国交大臣でもいいんですけれども。一回…", "…はり海自と海保がやるということは、是非これはやっていただきたいなと思いますけれども、防衛大臣、まだ一回もやっていませんものね。あるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/309", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/311", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/313", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/315", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/317", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/321", "sentence": []}]}]}]