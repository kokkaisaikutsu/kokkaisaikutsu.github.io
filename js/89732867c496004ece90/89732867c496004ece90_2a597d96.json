[{"date": "2021-01-21", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405254X00320210121/14", "sentence": ["…見解を伺います。国民民主党は、昨年の四月から、いわば北風である罰則と太陽である万全の補償をセットで盛り込む特措法改正案を一貫して訴え続けてき…"]}]}]}, {"date": "2021-01-26", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/257", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/259", "sentence": ["…種の道具、武器を持たなければいけない。この予算委員会でも、私はあえて太陽と北風という言葉を使って何度も申し上げたと思います。今の特措法には太…", "…陽と北風という言葉を使って何度も申し上げたと思います。今の特措法には太陽政策も北風政策もない、つまり、何かにやっていただいたらしっかりとした…", "…てください。私も、私ども国民民主党も去年から、先ほど申し上げた北風と太陽がセットになった実効力のある法改正にすべきだということを申し上げてき…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/262", "sentence": ["…とになろうかと思います。もう一つ、今度は補償について聞きます。北風と太陽と、セットだと思います、私は。補償とそして罰則は必ずセットです。補償…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120405261X00320210126/283", "sentence": []}]}]}]