[{"date": "2022-11-28", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/305", "sentence": ["…上保安庁の予算にちょっと絞って考えたいと思うんですが、いわゆる沿岸警備隊、コーストガードみたいなことも入り得るんですが、その他の軍も含む場合…", "…があるとしています。ただ、その場合の国防費は、軍事戦術の訓練を受け、軍隊としての装備を保有し、作戦展開の際に軍の直接指揮下で行動できるととも…", "…二十五条です。何て書いているかというと、海保については、「その職員が軍隊として組織され、訓練され、又は軍隊の機能を営むことを認めるものとこれ…", "…うと、海保については、「その職員が軍隊として組織され、訓練され、又は軍隊の機能を営むことを認めるものとこれを解釈してはならない。」とされてい…", "…これを解釈してはならない。」とされています。これは、制定の背景は、自衛隊よりも早い、一九四八年に海上保安庁が発足するときに、当時のソ連や中国…", "…うことを仮に概念するにしても、この二十五条を改正するか、あるいは、自衛隊八十条に基づく、防衛大臣による海上保安庁の統制要領を少なくともきちん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/309", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/311", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/313", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/315", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/317", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/321", "sentence": []}]}]}]