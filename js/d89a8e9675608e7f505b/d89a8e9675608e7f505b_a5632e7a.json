[{"date": "2022-10-26", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/4", "sentence": ["…れで清潔が保たれているのか。あるいは、これからも三か月ごとにワクチン接種するのか。あれこれと疑問が湧くのだけれども、最近は話題にする機会が減…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/8", "sentence": ["○高階委員続けさせていただきます。年少児への接種勧奨に伴って、コールセンター、そこではワクチン接種にまつわる相談が更に多様化すると思われます…", "…きます。年少児への接種勧奨に伴って、コールセンター、そこではワクチン接種にまつわる相談が更に多様化すると思われます。感染して回復した方、それ…", "…、それからＨＰＶとかほかのワクチンを優先したいという方、いろいろ追加接種の時期に迷っている方もあります。いずれは抗体価試験が導入されて、あら…", "…。いずれは抗体価試験が導入されて、あらかじめ抵抗力を確認してから追加接種するなど、変化していくんだろうと思いますけれども、そうしたエビデンス…", "…うと思いますけれども、そうしたエビデンス集積を怠らずに、より個別的な接種計画に役立つ支援を展開していただきたいと思います。いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/30", "sentence": []}]}]}]