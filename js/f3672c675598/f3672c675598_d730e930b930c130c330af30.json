[{"date": "2024-04-05", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/12", "sentence": ["…共々に力を合わせて取り組んでいきたいと思っております。次に、海洋プラスチックごみに関してお伺いをいたします。昨年、Ｇ７サミットにおきましては…", "…ます。昨年、Ｇ７サミットにおきましては、二〇四〇年までに追加的なプラスチック汚染をゼロにするという野心が合意なされまして、更に積極的に取り組…", "…心が合意なされまして、更に積極的に取り組むこととなっております。プラスチック汚染に関する条約を作るために、二〇二二年から政府間交渉委員会、Ｉ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/16", "sentence": ["…先導的に役割を果たしていただけたらと思っております。世界的な海洋プラスチック問題ということになりますと、かなり大きな話であるように感じるんで…", "…りまして、ごみ削減に向けては個人レベルでも実践ができます。まずはプラスチックを使わない、そのことで廃棄量を減らす、そして、やむを得ず廃棄する…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/18", "sentence": ["…運を日本全体で醸成していただくように求めておきます。続きまして、プラスチック資源循環促進法が二〇二二年四月一日から施行されている状況について…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/20", "sentence": ["○柳本委員よろしくお願いします。あわせて、最近、プラスチック製品などの中には、リチウム電池が入っていて発火の原因となることも少なくないという…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/22", "sentence": ["○柳本委員これまで、使用済紙おむつ、そしてプラスチックのリサイクルということで質問を重ねさせていただきました。焼却工場で燃やすというこれまで…", "…いただいたところでもあります。また、先ほど来の使用済紙おむつとかプラスチック製品、これまで廃棄物と捉えていたものを全て貴重な資源と捉えて循環…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X00620240405/30", "sentence": []}]}, {"meeting_name": "衆議院 地域活性化・こども政策・デジタル社会形成に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt