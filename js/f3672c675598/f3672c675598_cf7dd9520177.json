[{"date": "2022-02-10", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/8", "sentence": ["…を立てていくことが重要であると考えます。臨時財政対策債の更なる抑制に向けて今後どのように取り組んでいくのか、総務省の見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/20", "sentence": ["…情を踏まえながら保健所の体制強化に取り組むため、国として責任を持って財政措置を拡充すべきだと考えます。総務省としての考えをお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/22", "sentence": ["…司や児童心理司の配置数を更に増員し、児童相談所の体制を一層強化するための財政措置を講じるべきだと考えますが、総務省の見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/28", "sentence": ["…て取組を行うといった視点がこれまで以上に重要になると考えます。自治体間連携に対する総務省の認識及びこれまでの取組についてお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/30", "sentence": ["…なことも考えておられるということであります。こういった取組を積極的に総務省としても推進をしていただきたいなというふうに思うわけでありますが、…", "…上に必要になると考えます。そこで、今後更なる自治体間連携を進めていくために総務省としてはどのように取組を行っていくのか、お伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/32", "sentence": []}]}]}]