[{"date": "2022-02-10", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/8", "sentence": ["…ただ、臨財債の発行を抑制したことなどを受けて、今般、臨時財政対策債の残高も縮減されたことについて、地方からも一定の評価というか喜びの声もある…", "…あるというふうに聞いておりますが、一方で、依然として臨時財政対策債の残高は五十兆円を超えております。将来に向けてこの臨財債の発行抑制、残高を…", "…の残高は五十兆円を超えております。将来に向けてこの臨財債の発行抑制、残高を縮減する流れを継続し、健全化への道筋を立てていくことが重要であると…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/12", "sentence": ["…傾向は確認されているところでありますが、直近の状況として、地方自治体における財政調整基金の残高はどのようになっているのか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X00420220210/32", "sentence": []}]}]}]