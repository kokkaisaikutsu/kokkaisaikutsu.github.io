[{"date": "2022-05-11", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/199", "sentence": ["…に多いと認識しています。そして、このこども家庭センター、様々な支援メニューとつなぐサポートプラン、そういったものが一つ目玉になってくると思い…", "…味では、要支援児童となってしまうかもしれないその前段階において支援メニューとつないで、実際にそのサービスを受けること、こういったことはこの制…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/201", "sentence": ["…誤解している人たちが、こども家庭センターで相談を受けて、実際に支援メニューを見せてもらうことによって、あっ、自分の家庭に少し困難がある、この…", "…容できると思うんですね。その上で、その受容した先にしっかりその支援メニューを実際に受けるためには、無料でこれは提供するわけではないと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/203", "sentence": ["…、要支援ではないけれども、全額それこそ自己負担の中で、そういう支援メニューを提供されると、家庭負担、子供の負担が軽減されるということを体感す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/213", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/215", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804260X01820220511/217", "sentence": []}]}]}]