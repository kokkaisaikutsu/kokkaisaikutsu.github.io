[{"date": "2021-05-11", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/82", "sentence": ["…て丁寧に対応をお願いしたいというふうに思っております。続きまして、個人情報保護制度関係について御質問させていただきたいと思います。今回の法案…", "…います。平成三十一年の一月二十三日には、我が国の民間部門においては個人情報保護制度がＥＵのＧＤＰＲに基づく十分性認定を受けたものでございます…", "…いないことから、十分性認定の対象とはなっておりません。また、現行の個人情報保護法では、大学その他の学術研究機関等が学術研究目的で個人情報を取…", "…行の個人情報保護法では、大学その他の学術研究機関等が学術研究目的で個人情報を取り扱う場合については一律現行では適用除外としているために、我が…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/171", "sentence": ["○石川博崇君ありがとうございます。続きまして、個人情報保護制度の一元化の意義についても確認をさせていただきたいと思います。昨年六月、当委員会…", "…ても確認をさせていただきたいと思います。昨年六月、当委員会における個人情報保護法案の改正案の質疑の中で、私は当時の衛藤担当大臣に、官民を通じ…", "…護法案の改正案の質疑の中で、私は当時の衛藤担当大臣に、官民を通じた個人情報保護に関する法制の一元化、これを進めることをお訴えをさせていただき…", "…ド感を持って取り組むと御答弁をいただいたところでございます。今回の個人情報保護制度の見直しによりまして、いわゆる二千個問題の解消、また国境を…", "…られることになります。また、今回のデジタル社会形成整備法案の中で、個人情報保護法の改正は最も重要な柱に位置付けられているとも認識をしておりま…", "…法の改正は最も重要な柱に位置付けられているとも認識をしております。個人情報保護法は、データの活用により新たな価値を生み出す一方で、個人の権利…", "…護していくための基盤であると考えますけれども、今回の関連法案における個人情報保護制度の一元化の意義について総理の御所見を伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/173", "sentence": ["…マイナンバー制度に対して様々な懸念の声もあるのも事実でございます。個人情報の追跡、名寄せ、突合が行われて、その個人情報が外部に漏えいするので…", "…のも事実でございます。個人情報の追跡、名寄せ、突合が行われて、その個人情報が外部に漏えいするのではないか、あるいは、成り済まし等によって個人…", "…ないか等の懸念が今なお残っているのが事実かと思います。また、近年、個人情報漏えい事案も発生していることから、こうした国民の懸念がなかなか払拭…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/175", "sentence": []}]}]}, {"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/179", "sentence": ["…協議の中で我が党は主張させていただいたのは、必要最小限度の原則及び個人情報の保護への配慮規定、これを盛り込むべきだということを訴え、結果とし…", "…り込まれたことは高く評価をいたします。この規定の意義を伺うとともに、個人情報の適正な管理についての小此木大臣の見解をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/181", "sentence": ["○石川博崇君今回、この必要最小限度の規定、そして個人情報保護に関する留意規定が総則の第三条に加えられたことによりまして、この法案全体を貫く運…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/187", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/189", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/191", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/193", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/195", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/197", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/199", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/203", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/205", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X02520210608/209", "sentence": []}]