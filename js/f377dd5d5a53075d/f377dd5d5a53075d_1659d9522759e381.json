[{"date": "2020-11-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/97", "sentence": ["…たけれども、今延びておりますが、何としても結果を出すことが必要でございます。茂木外務大臣、いかに取り組むか、御説明をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/99", "sentence": ["…平和と安全のために極めて重要なこの点、先般、ＡＲＦの閣僚会合で茂木外務大臣から指摘をしていただいたこと、評価を申し上げたいと思います。今後も…", "…臣から指摘をしていただいたこと、評価を申し上げたいと思います。今後も継続して取り組んでいただきたいと思いますが、外務大臣、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/101", "sentence": ["…命を担っているのが唯一の戦争被爆国である我が国であるというふうに考えております。この点について茂木外務大臣の御所見をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/103", "sentence": ["○石川博崇君ありがとうございます。今日は初めて外務大臣から、この核禁条約の発効によって保有国と非保有国の対立と分断が深まることは避けなければ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315261X00220201106/105", "sentence": []}]}]}]