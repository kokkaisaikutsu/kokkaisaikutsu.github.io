[{"date": "2021-05-11", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/78", "sentence": ["…マイナンバーカードについてお伺いをしたいと思います。というよりもＪ―ＬＩＳですね、マイナンバーカードの発行業務を行っているＪ―ＬＩＳですけれ…", "…よりもＪ―ＬＩＳですね、マイナンバーカードの発行業務を行っているＪ―ＬＩＳですけれども、今回国のガバナンスを抜本的に強化することとなっており…", "…可、業務評価等を行う、国の役割が抜本的に強化されると。また、このＪ―ＬＩＳの財務や業務の方針を決定する機関、代表者会議というものがありますが…", "…になっております。このように、国のガバナンスが強化される一方で、Ｊ―ＬＩＳ法第三十三条には、機構の運営に要する費用は地方自治体、地方公共団体…", "…た趣旨は何なのか。また、国がこのように関与を強化する中で、やはりＪ―ＬＩＳに対する補助あるいは支援、財政的な面も含めてしっかりやっていくこと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X01720210511/175", "sentence": []}]}]}]