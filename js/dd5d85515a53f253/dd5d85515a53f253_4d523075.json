[{"date": "2024-06-07", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/120", "sentence": ["…んでしょうというようなことをおっしゃる方たちもいらっしゃる。今日は、前田審議官、水俣病問題の担当ということですから。前田審議官以下、環境省の…", "…いらっしゃる。今日は、前田審議官、水俣病問題の担当ということですから。前田審議官以下、環境省の事務方は、皆さんが死ぬのを待っているんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/122", "sentence": ["○川内委員適切に事務を行っていくという言葉は、先ほどの前田審議官の言葉と矛盾しますよね。自分も全面的な解決に向けてしっかりと懇談の場で協議を…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/128", "sentence": ["○川内委員今大臣が意見交換の場という言葉を使われたんですが、既に前田審議官は協議の場とおっしゃっていらっしゃるので、大臣が協議の場と言わない…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/134", "sentence": ["…拠に基づいていない判決だとか、記者会見で述べられたりしていますよね。だけれども、国際的に認められた科学的根拠というのは何ですか、前田審議官。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/150", "sentence": []}]}]}]