[{"date": "2024-06-07", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/120", "sentence": ["…や環境省の歴史の中で、先ほどからいろいろな指摘が出ているわけですが、事務方の中にはいろいろな思いがあるんでしょう、それで、患者団体や水俣病関…", "…いらっしゃる。今日は、前田審議官、水俣病問題の担当ということですから。前田審議官以下、環境省の事務方は、皆さんが死ぬのを待っているんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/134", "sentence": ["…多量に摂取することによって発症する病、それが水俣病である。今、大臣は事務方から説明を受けて、ごまかされているんですよ。公健法上の水俣病では、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/144", "sentence": ["…ることについて、ちょっと残りの時間、議論したいんですけれども、環境省事務方は、通知で示されている判断条件自体は否定されていないのだということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/148", "sentence": ["…という判決が出たわけですから、最高裁でですよ。だから、私は、環境省の事務方の人にいろいろなことを教えていただいていても、裁判に勝ったとか負け…", "…いてね、スイッチを切らないでよ、平成二十五年の判決を受けて、環境省の事務方に聞いたら、五十二年判断条件を見直さないという意思決定をした意思決…", "…ち上げをするじゃなくて、検討会の立ち上げを検討するでいいです、ちょっと考えてみる、事務方と話し合ってみるということぐらいは言ってくださいよ。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/150", "sentence": []}]}]}]