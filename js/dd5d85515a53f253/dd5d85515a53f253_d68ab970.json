[{"date": "2024-06-07", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/124", "sentence": ["…のを聞かせていただいて、物すごく安心をいたしました。じゃ、協議の場の論点は何ですか。協議していくわけですね。協議の場の論点を教えてください。", "…のを聞かせていただいて、物すごく安心をいたしました。じゃ、協議の場の論点は何ですか。協議していくわけですね。協議の場の論点を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/126", "sentence": ["…ゃったわけですが、協議の場というふうに言い換えられているわけですね。論点としては、要望事項が論点になるということになっている。そうすると、大…", "…場というふうに言い換えられているわけですね。論点としては、要望事項が論点になるということになっている。そうすると、大臣、水俣病特措法の申請期…", "…水俣病被害者あるいは水俣病患者がいらっしゃるのではないかということも論点になるという理解でよろしいですね。大臣、そうだよと言えばいいんですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304006X01420240607/150", "sentence": []}]}]}]