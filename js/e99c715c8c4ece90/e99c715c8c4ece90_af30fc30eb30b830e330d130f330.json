[{"date": "2023-11-08", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/151", "sentence": ["…安全対策、お願いをしたいと思っております。ちょっと順番を変えて、クールジャパンについてお伺いをさせていただきます。私は初当選して、七年前初め…", "…私は初当選して、七年前初めての質問がこの内閣委員会で、そのときもクールジャパンの質問をしたんですが、昨日、問取りに来られた方から資料をいただ…", "…たんですが、昨日、問取りに来られた方から資料をいただいて、日本はクールジャパンがうまくいっていないわけではないんだという説明をされて、それは…", "…得意な分野、不得意な分野がおありでしょうけれども、日本の強みを最大に生かした新たなクールジャパン戦略についてお伺いをいただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121204889X00220231108/155", "sentence": []}]}]}, {"date": "2024-04-10", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/14", "sentence": ["…す。是非、今後も引き続きよろしくお願いをしたいと思います。次に、クールジャパンについて、アウトバウンドについてお伺いをします。私、初当選させ…", "…から諦めたという話がありました。そこで質問なんですが、このようなクールジャパンのアウトバウンド、海外展開をするに際して、どのような手当てがあ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X00920240410/16", "sentence": []}]}]}]