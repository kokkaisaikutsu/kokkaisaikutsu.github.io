[{"date": "2021-06-10", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/41", "sentence": ["…、しっかり問題点の指摘、また対策を求めていきたいと思います。次に、公立病院におけるワクチン接種体制の強化について、これは総務省にお伺いをいた…", "…にお伺いをいたします。お手元に配っておりますが、五月十八日付けで「公立病院における新型コロナワクチンの接種体制の強化に向けた協力依頼について…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/43", "sentence": ["○吉田忠智君公立病院に対して要請がなされて、同じ自治体あるいは隣接する自治体からの派遣要請もございますし、また民間に対する、あるいは集団接種…", "…場への派遣、兼業、これ兼業になるわけでありますが、要請ということで公立病院から派遣する場合と、あるいは兼業とする場合とあるわけであります。そ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/45", "sentence": ["…というようなことも付随して出てくると思います。基本的にはそれぞれの公立病院の自主性、主体性を尊重しながら、総務省としても適切に是非助言をして…", "…も適切に是非助言をしていただきたいと思います。また、厚生労働省も、公立病院以外の公的病院、また医学部附属病院などはこれ文科省の所管であります…", "…は医師会病院でありますとか、そういう公的機関からの派遣についても、公立病院の派遣に準じた形で、是非きめ細やかな対応をしていただきますようにお…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414601X01620210610/66", "sentence": []}]}]}]