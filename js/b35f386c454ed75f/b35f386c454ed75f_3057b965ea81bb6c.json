[{"date": "2022-11-08", "meeting": [{"meeting_name": "衆議院 政治倫理の確立及び公職選挙法改正に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/121", "sentence": ["…律のどこにも記されていないというのを大変腹立たしく思ってきました。地方自治法の八十九条に、「普通地方公共団体に議会を置く。」とだけしか書かれ…", "…いう答申をいただいております。これは大臣、是非、年明けの通常国会で地方自治法を改正をして、地方議会の役割をしっかりと条文の中に追記をしていく…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/123", "sentence": ["…きますと、やはり地方議会の活性化といったものの一つの起爆剤として、地方自治法を改正をして地方議会の位置づけ、役割をしっかりと明記をしていくと…", "…は大変重要な取組だというふうに思いますので、是非、次期通常国会には地方自治法改正案を御提出をいただきますよう強く期待をいたしまして、質問を終…"]}]}]}]