[{"date": "2022-11-08", "meeting": [{"meeting_name": "衆議院 政治倫理の確立及び公職選挙法改正に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/119", "sentence": ["…度調査会は、十月二十四日の専門小委員会において、地方議会改革に対する答申素案を公表されたところであります。統一地方選挙を来年春に控えまして、…", "…春に控えまして、地方議会改革というものが求められるわけですけれども、まずは、この答申素案の概要を、簡単で結構です、総務省、説明してください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/121", "sentence": ["…しか書かれていない。これではということをずっと思ってきました。今回、答申では、そういった部分については、地方議会の責務とか役割とか、地方議員…", "…、地方議員はかくあるべしといったようなことを条文に追記すべきだという答申をいただいております。これは大臣、是非、年明けの通常国会で地方自治法…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004577X00620221108/123", "sentence": []}]}]}]