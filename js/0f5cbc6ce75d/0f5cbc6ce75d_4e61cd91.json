[{"date": "2023-01-27", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00420230127/17", "sentence": ["…察を交えて議論を挑んでみたい。賃金が上がらない構造とは、第一に企業の慎重過ぎる経営であり、第二に短期主義を礼賛し続けた歴代政府の経済政策その…", "…ずもって、なぜ内部留保が膨らんだかと考えると、不安だからであります。慎重にならねば生き残れないと経験させられたからであります。一九九〇年代半…", "…で今でいうスタートアップを手掛けてほとんど失敗したので、新しい仕事は慎重に考えようと学んだ。毎日銀行からお金を返してほしいと要求され、新たに…", "…は控えようと学んだ。それらの学びを経た世代は、賃上げや新しい挑戦には慎重にならざるを得ず、できるだけ多くの内部留保を持つことが正しい経営だと…", "…げで経営陣が替わることなく危機を乗り切ることができた世代であります。慎重な経営が正しいと体験してきた経営トップは、コロナ禍で更に慎重になるの…", "…ります。慎重な経営が正しいと体験してきた経営トップは、コロナ禍で更に慎重になるのではないか。これをいかに解きほぐすかが論点であると考えますが…", "…がこの論点から逃げているようにしか思えない。内部留保が膨らんだ原因と慎重過ぎる企業経営に係る私の観察について、総理の御意見を伺ってみたいので…", "…について、総理の御意見を伺ってみたいのであります。ところで、こうした慎重過ぎる経営が合理的だとみなされる決定打となったのが、短期主義を礼賛す…", "…ければならない。短期主義へと追い立ててきた経済政策を本質的に改めて、慎重過ぎる企業経営を解きほぐし、我が国に集う一人一人の持ち味や強みを草の…", "…一種農地を問わず無秩序に太陽光発電を導入することは、食料安全保障上、慎重にならなければならないのであります。既に不適切な事例が複数発生してお…"]}]}]}, {"date": "2023-04-13", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00820230413/130", "sentence": ["…いですよという意見だったかと