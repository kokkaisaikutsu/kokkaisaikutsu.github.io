[{"date": "2021-03-25", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/34", "sentence": ["…開かれていないということは事実かと思います。つまり、会議体はあっても形骸化しておる。担当してくれということを言われたとしても、どうやら、恐ら…", "…うことを言われたとしても、どうやら、恐らく、メンバーでないから、その形骸化している状況を追認している状況になっているのではないかと思います。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/36", "sentence": ["…ね、現行の内閣府設置法において。じゃ、原子力立地会議が実質上十年以上形骸化している現状をどうするのか。原子力立地会議というものは、この法律に…", "…いう意味では、ここに担当大臣として追加するということによって、実際に形骸化している状況を改善することが必要でないかと私は考えます。その上で、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414889X00720210325/54", "sentence": []}]}]}]