[{"date": "2021-03-19", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/77", "sentence": ["…いたのか。三月十二日のヒアリングにおいては、建材メーカーが加盟する各工業会で統計が取られているとのことでありました。どの工業会にどんな統計が…", "…日のヒアリングにおいては、建材メーカーが加盟する各工業会で統計が取られているとのことでありました。どの工業会にどんな統計があるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/79", "sentence": ["…の議員からも、国には資料を出させる責任があると強く提出を求めたところであります。工業会に求めて提出をいただきたいと思いますが、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/81", "sentence": ["…対大事なんです。是非、国会からも要求があったということで、省の方から工業会の方に要求してください。アスベスト問題については以上です。副大臣、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X00320210319/109", "sentence": []}]}]}]