[{"date": "2021-06-04", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/62", "sentence": ["…言を発して、様々な取組が始まろうとしています。二〇三〇年の二酸化炭素排出量四六％削減を政府として打ち出しましたけれども、温暖化対策は待ったな…", "…して打ち出しましたけれども、温暖化対策は待ったなしであります。温室効果ガスの排出において、農業分野での排出はどういう状況になっておりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/66", "sentence": ["…効果ガスを減らしていく上で、輸入飼料の問題、ここの長距離輸送によって排出される温室効果ガスの問題、これはやはりしっかり考えていかなければなら…", "…でしょうか。あるいは、輸入飼料も含めたライフスタイル全体にわたる炭素排出量、これらについても把握する必要があると思います。フードマイレージ、…", "…も把握する必要があると思います。フードマイレージ、長距離輸送によって排出される温室効果ガス、そしてカーボンフットプリント。ライフサイクル、生…", "…フットプリント。ライフサイクル、生産から廃棄まで全てにわたっての炭素排出量、これらについての把握というのはできているんでしょうか。環境省、農…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404006X01420210604/80", "sentence": []}]}]}]