[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/100", "sentence": ["…わず、平等な支援を要求しているわけであります。そこで、伺います。災害救助法やそれから支援法の適用の自治体の被災者と、そうでないところの自治体…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/108", "sentence": ["…カーペットなどの要望が百六十人から出されたということであります。災害救助法の生活必需品として、家電製品は支給されない状況にあります。この通知…", "…必需品として、家電製品は支給されない状況にあります。この通知が、災害救助事務取扱要領には、わざわざ認められないものとして、テレビ、冷蔵庫、掃…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304339X00420201119/110", "sentence": ["…本地震のときにも、私、指摘しました。まだこれが解決されていない。災害救助法には、「現に救助を必要とする者に対して、これを行う。」と書かれてい…", "…私、指摘しました。まだこれが解決されていない。災害救助法には、「現に救助を必要とする者に対して、これを行う。」と書かれているわけですね。そし…", "…要とする者に対して、これを行う。」と書かれているわけですね。そして、救助の種類に、「被服、寝具その他生活必需品の給与又は貸与」と書かれている…"]}]}, {"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/104", "sentence": []}]}]}]