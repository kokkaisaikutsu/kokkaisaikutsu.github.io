[{"date": "2022-02-17", "meeting": [{"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/66", "sentence": ["…とになります。そこでお伺いしますけれども、この七七年の環境省が示した基準というのは、どのような医学的な調査、根拠に基づくものなんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/68", "sentence": ["…はありません。日本精神神経学会は、一九九八年に、国の七七年判断条件は医学的根拠を裏づける具体的なデータがない、誤りだと見解を発表しています。…", "…をしています。これに対して、判断条件の作成に関わった医師たちからは、医学的根拠に基づく反論は示されていないじゃないですか。そのために、七七年…", "…であります。患者の苦しみに向き合わず、実際に患者を救済できていない、医学的な根拠がない、この基準はもうやめるべきではありませんか。いかがです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/78", "sentence": []}]}]}, {"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第五分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/140", "sentence": ["…、びまん性胸膜肥厚は三年以上、肺がんは十年以上となっています。これは医学的根拠をもって定められていますが、石綿肺については、最低暴露期間が何…", "…用されないんです。この矛盾をどのように厚労省は考えていますか。こうした矛盾を生み出す通達、事務連絡はどのような医学的根拠があるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/142", "sentence": ["…ゃないですか。この三年以上の差を有するという場合、これは削除すべきじゃないですか。そして、医学的根拠はあるんですか。もう一回答えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/144", "sentence": ["…二〇〇六年には、厚生労働省と環境省が合同で、石綿による健康被害に係る医学的判断に関する考え方という報告書を出しているじゃありませんか。石綿肺…", "…答えいただきたいと思います。もう一つ、石綿肺の最低暴露期間について、医学的に検討して、そして新たな通知を出すよう見直すべきではありませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105267X00120230220/146", "sentence": []}]}]}]