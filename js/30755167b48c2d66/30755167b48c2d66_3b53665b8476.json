[{"date": "2022-02-17", "meeting": [{"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/66", "sentence": ["…とになります。そこでお伺いしますけれども、この七七年の環境省が示した基準というのは、どのような医学的な調査、根拠に基づくものなんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/68", "sentence": ["…はありません。日本精神神経学会は、一九九八年に、国の七七年判断条件は医学的根拠を裏づける具体的なデータがない、誤りだと見解を発表しています。…", "…をしています。これに対して、判断条件の作成に関わった医師たちからは、医学的根拠に基づく反論は示されていないじゃないですか。そのために、七七年…", "…であります。患者の苦しみに向き合わず、実際に患者を救済できていない、医学的な根拠がない、この基準はもうやめるべきではありませんか。いかがです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00220220217/78", "sentence": []}]}]}]