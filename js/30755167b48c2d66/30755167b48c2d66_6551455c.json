[{"date": "2022-03-10", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/84", "sentence": ["○田村（貴）委員続いて、仮設住宅への同性カップルの入居について質問します。私の事務所の聞き取り調査では、九州、沖縄八県と県庁所在地、政令市の…", "…、九州、沖縄八県と県庁所在地、政令市の九市、計十七自治体のうち十三は入居対象となっています。検討中やその他も四自治体となっています。ですから…", "…す。検討中やその他も四自治体となっています。ですから、同性カップルの入居については認められる方向になっている。この中で、自治体のパートナーシ…", "…れども、被災時に同居していた二人であれば、この二人の関係を証明しなくとも入居対象になると思うんですけれども、内閣府、考え方はどうでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/86", "sentence": ["…、災害公営住宅はどうでしょうか。ここも、パートナーシップ制度を根拠に入居対象としている自治体があるわけでありますけれども、その災害公営住宅が…", "…ことになってきて、アンバランスが生まれるのではないかと思います。この入居については、どういうふうに考えておられますか。国交省、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/141", "sentence": []}]}]}]