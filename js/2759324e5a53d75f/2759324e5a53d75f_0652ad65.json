[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304183X00220201119/11", "sentence": ["…をめぐる状況や、あるいは世界各国の状況を見渡してみても、人々の間に、分断の大きさ、そしてそのことの社会への影響、改めて私たち一人一人が銘記す…", "…となってきているのではないでしょうか。そのような、ややもすると社会の分断があおられがちな現在の時代背景を踏まえれば、この憲法審査会においても…", "…の時代背景を踏まえれば、この憲法審査会においても、かねてにも増して、分断を意識しなくていいような、融和をより意識した運営が必要になってきてい…", "…ら、それもきちんと結論を出していく。そういう運営をすることが、特に、分断が大きいと言われかねないこの世の中において、この憲法審査会をうまくま…"]}]}, {"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/68", "sentence": []}]}]}]