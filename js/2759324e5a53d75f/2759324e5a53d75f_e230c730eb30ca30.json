[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/150", "sentence": ["…でいうと、一回目、二回目、ファイザー製を打った人たちは八五％です。モデルナを打った方は一五％。それだけ差があるんですよ。ところが、二月末まで…", "…までと言われました、二月末までに、政府が配ったワクチンの数は、大体モデルナが六割なんです。ファイザーが四割なんです。ということは、人口の四割…", "…四割なんです。ということは、人口の四割ぐらいの方々がファイザーからモデルナに乗り換えていただかないと、モデルナでいいよと希望していただいて接…", "…割ぐらいの方々がファイザーからモデルナに乗り換えていただかないと、モデルナでいいよと希望していただいて接種してもらわないと、二月までには希望…", "…です。総務大臣にお尋ねしますけれども、人口四割の方々がファイザーじゃなくてモデルナでいいという希望をするという前提での調査になっていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/152", "sentence": ["…なんです。希望する内容自体が、人口四割ぐらいの方々がファイザーからモデルナに乗り換えていただかなければならないにもかかわらず、そういうことは…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/