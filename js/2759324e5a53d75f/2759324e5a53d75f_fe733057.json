[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304183X00220201119/11", "sentence": []}]}, {"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/46", "sentence": ["…大臣は、資料の一枚目ですけれども、大臣就任後、大体一カ月内外ぐらいに現地を訪れ、行政、漁協関係者や、かつ、もちろん一番大切な原告、弁護団の皆…", "…関係者や、かつ、もちろん一番大切な原告、弁護団の皆さんとの意見交換を現地視察も含めて行っていらっしゃいました。ずらりと、見ていただくと、この…", "…。ちょっとこれは異例でしたね、異例でした。にもかかわらずまだ一度も、現地を訪問し、原告団、弁護団等との話合いを持たれていない、こういう状況は…", "…すけれども、なぜ大臣は今、もうきょうで二カ月近くですね、二カ月近く、現地を訪問し、原告団、弁護団と意見交換を行うということを前の大臣とは違っ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/48", "sentence": ["…出張を既にされていますね。出張が悪いと言っているわけじゃないんです。現地を見ていただくことは極めていいことなので、私は、どんどん新型コロナウ…", "…を絞りますよ。そういった形でも結構なので、やる気を示していただくためにもできるだけ早く現地に来ていただきたいと思いますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/68", "sentence": []}]}]}, {"date": "2022-03-15", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00320220315/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00320220315/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00320220315/60", "sentence": ["…ていただいて、野上大臣からこういう答弁をいただきました。江藤前大