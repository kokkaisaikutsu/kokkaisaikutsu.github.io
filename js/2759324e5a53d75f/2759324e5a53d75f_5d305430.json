[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/165", "sentence": ["○大串（博）委員これは、認識のそごがありましたで済ませていいんですか。極めて大きなことですよ。九月三日に米軍が日本入国前検査をやめて、私たち…", "…らず、米軍は、日本に伝えましたよ、外務省は、聞いていませんよ、認識のそごがありました、その一言で済ませていいんですか。どのような認識のそごが…", "…、外務省は、聞いていませんよ、認識のそごがありました、その一言で済ませていいんですか。どのような認識のそごがあったんですか。お話しください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/167", "sentence": ["…さんに対しても説明責任があるんじゃないですか。それを考えると、認識のそごで片づけるのは、私は甘いと思いますよ。委員長、これは、認識のそごが何…", "…識のそごで片づけるのは、私は甘いと思いますよ。委員長、これは、認識のそごが何であったか、紙で委員会に出してもらうように、これは済まないですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/169", "sentence": ["…の閣議後記者会見で、その後、こうおっしゃっていますね。こうした認識のそごが生じたのは、米側の措置との整合性を確保する外務省の取組に不十分な点…", "…止めているところでございますとおっしゃっていますね。すなわち、認識のそごが生じたことに対して、外務省の取組に不十分な点があったとおっしゃって…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/173", "sentence": ["…大串（博）委員大臣は、金曜日、こう言っているんですよ。こうした認識のそごが生じたのは、外務省の取組が不十分な点があったと。この認識のそご、こ…", "…識のそごが生じたのは、外務省の取組が不十分な点があったと。この認識のそご、この原因が、外務省の取組が不十分だったということを言っているんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/179", "sentence": []}]}]}]