[{"date": "2022-03-04", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/103", "sentence": ["…がこれまでもあります、二つ大きなラインがあって、一つは、十六回に及ぶ有識者会議、分科会も含めて、有識者会議の結論を経ての内容なので、個人が影…", "…きなラインがあって、一つは、十六回に及ぶ有識者会議、分科会も含めて、有識者会議の結論を経ての内容なので、個人が影響を及ぼすことはなかったとい…", "…私は、この二つの説明とも全く説明にならないなと思うんですよ。十六回の有識者の検討会議の議事録も全部見させていただきましたけれども、皆さんも経…", "…冒頭、事務局から説明があるんです、資料の。それで、その資料を基にこの有識者の皆さんは議論されるんです。十八名もいらっしゃいます。もちろん座長…", "…も、三回目には既にそれぞれの提言の骨子案が事務局から示されて、それを有識者が議論するというていで進んでいるんです。骨子案を作ったのは誰か聞き…", "…のは誰か聞きました、事務方の皆さんに。これは、事務方が作って骨子案を有識者に提示している。すなわち、事務方のトップであれば、自分が影響を行使…", "…たことがあるから、お分かりになると思いますよ。それに対して、十六回の有識者の審議会の議論を経ているから個人がゆがめられるわけないと。とんでも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00620220304/119", "sentence": []}]}]}, {"date": "2022-05-27", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/37", "sentence": ["…ったのはつい最近です、国土交通省から。国土交通省で、先ほど繰り返し、有識者の対策検討会議で議論して改善していくと言われていますけれども、斉藤…", "…議で議論して改善していくと言われていますけれども、斉藤大臣、こんなふうにコピペして渡していたということを有識者の皆さんには知らせていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/39", "sentence": ["○大串（博）委員有識者に渡していると言われました。私たち、これをもらったのは先週です。有識者に渡されたのはいつですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X02020220527/44", "sentence": ["○大串（博）委員昨日の午後に私が国土交通省の方に、こんな重要な書類、有識者の皆さんに見ていただいて、国土交通省に落ち度がなかったのか判断して…", "…いて、国土交通省に落ち度がなかったのか判断してもらわなきゃならない、有識者の方々は知っているのかと言ったら、昨日の昼の段階では知らなかったん…", "…ら質問を受けて、そして今日取り上げられることが分かって、おっ取り刀で有識者の皆さんに昨日お伝えした、これが事実じゃないですか。違いますか。今…", "…う一度総理にお尋ねします。国土交通省は、自分たちのこういう問題でさえ有識者検討会に伝えていなかった。総理に、時間が来ましたので、要りませんけ…", "…もそうですけれども、国土交通省もそれに値すると思っています。第三者で有識者の検討会をやり直していただきたい、そのことを申し上げて、終わります…"]}]}]}]