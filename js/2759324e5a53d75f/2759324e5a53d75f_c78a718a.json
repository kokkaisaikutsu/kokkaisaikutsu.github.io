[{"date": "2020-11-19", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304183X00220201119/11", "sentence": []}]}, {"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/52", "sentence": ["○大串（博）委員私、きのうちょっと気になったんです。きのうも大臣談話に沿って解決することが望ましいとおっしゃいましたけれども、大臣談話に沿っ…", "…気になったんです。きのうも大臣談話に沿って解決することが望ましいとおっしゃいましたけれども、大臣談話に沿って解決するとはどういうことですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/54", "sentence": ["…るんです。ここは何とかしなきゃいかぬということだと思うんですね。大臣談話にある、開門によらない基金による和解ということでは私は進まないと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/62", "sentence": ["○大串（博）委員江藤大臣の談話を引かれたのはわかりました。和解しないということを言ってくださいとここで申し上げたら、和解しないとは言われなか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305007X00620201119/68", "sentence": []}]}]}]