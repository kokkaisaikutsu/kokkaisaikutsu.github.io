[{"date": "2022-02-07", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/150", "sentence": ["…接種に関して、慎重論があるんですね。全国でいうと、一回目、二回目、ファイザー製を打った人たちは八五％です。モデルナを打った方は一五％。それだ…", "…末までに、政府が配ったワクチンの数は、大体モデルナが六割なんです。ファイザーが四割なんです。ということは、人口の四割ぐらいの方々がファイザー…", "…。ファイザーが四割なんです。ということは、人口の四割ぐらいの方々がファイザーからモデルナに乗り換えていただかないと、モデルナでいいよと希望し…", "…にならないんです。総務大臣にお尋ねしますけれども、人口四割の方々がファイザーじゃなくてモデルナでいいという希望をするという前提での調査になっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/152", "sentence": ["…もらわれただけなんです。希望する内容自体が、人口四割ぐらいの方々がファイザーからモデルナに乗り換えていただかなければならないにもかかわらず、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01120220207/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X0112