[{"date": "2022-08-03", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/24", "sentence": ["○議長（尾辻秀久君）この際、特別委員会の設置についてお諮りいたします。災害に関する諸問題を調査し、その対策樹立に資するため、委員二十名から成…", "…するため、委員三十五名から成る東日本大震災復興特別委員会を、それぞれ設置いたしたいと存じます。まず、災害対策特別委員会、政治倫理の確立及び選…", "…員会、消費者問題に関する特別委員会並びに東日本大震災復興特別委員会を設置することについて採決をいたします。以上の六特別委員会を設置することに…", "…災復興特別委員会を設置することについて採決をいたします。以上の六特別委員会を設置することに御異議ございませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/25", "sentence": ["…君）御異議ないと認めます。よって、災害対策特別委員会外五特別委員会を設置することに決しました。次に、政府開発援助等及び沖縄・北方問題に関する…", "…しました。次に、政府開発援助等及び沖縄・北方問題に関する特別委員会を設置することについて採決をいたします。本特別委員会を設置することに賛成の…", "…縄・北方問題に関する特別委員会を設置することについて採決をいたします。本特別委員会を設置することに賛成の諸君の起立を求めます。〔賛成者起立〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/26", "sentence": ["○議長（尾辻秀久君）過半数と認めます。よって、本特別委員会を設置することに決しました。本院規則第三十条の規定により、議長は、議席に配付いたし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120915254X00120220803/35", "sentence": []}]}, {"meeting_name": "参議院 議院運営委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120914024X00120220803/2", "sentence": []}]}]}]