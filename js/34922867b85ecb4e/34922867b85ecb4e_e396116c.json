[{"date": "2022-03-01", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/96", "sentence": ["…とができるか、少なくとも命を助けることができるのかという視点で申し上げたいと思います。一つ目。日本の難民制度について、概要を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/100", "sentence": ["○鈴木（庸）委員となりますと、今御案内のように、難民の認定率は〇・四％、この枠組みの中でいってしまうのかなと私は大変強い危惧を覚えております…", "…御覧いただけますでしょうか。こちらの一枚目の方が、ウクライナ周辺国の難民への対応。ポーランドに関しては、ここに、乗車券の無料化とか、ＰＣＲ検…", "…裏を見ていただくと分かるんですけれども、これはポーランド政府が作った難民のサポートアプリです。ウクライナを助けよう、これはポーランド語の直訳…", "…マニアもモルドバもハンガリーもドイツも、そしてアメリカも、ウクライナ難民に対して多くの政策を取っています。その上で、改めてお伺いをいたします…", "…カも、ウクライナ難民に対して多くの政策を取っています。その上で、改めてお伺いをいたします。日本は、ウクライナ難民に対して今何をしていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X00220220301/123", "s