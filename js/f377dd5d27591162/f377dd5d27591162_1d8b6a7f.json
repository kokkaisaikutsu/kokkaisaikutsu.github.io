[{"date": "2022-11-09", "meeting": [{"meeting_name": "参議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014183X00220221109/40", "sentence": []}]}, {"meeting_name": "参議院 政治倫理の確立及び選挙制度に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/49", "sentence": ["…れました。私も、政務官の言うところの生産性がない当事者の一人として抗議にも参加をいたしました。寄稿文を撤回、謝罪するおつもりはございますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/51", "sentence": ["○石川大我君全くひどい話だと思います。重く受け止めるということと、謝罪をし撤回をするということは全く違うと思いますよ。この新潮45という雑誌…", "…ない寄稿の内容がもうじゃかじゃか出てくるわけですよ。このことに対してもしっかりと反省をしていただいて、撤回、謝罪をすべきなんじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/55", "sentence": ["○石川大我君そういったことであれば、これしっかりと撤回をして、そして謝罪をするべきなんじゃないでしょうか。これ、かたくなに謝罪をしない、撤回…", "…をして、そして謝罪をするべきなんじゃないでしょうか。これ、かたくなに謝罪をしない、撤回をしないということは、全国に残念ながらいらっしゃるＬＧ…", "…な感情を持っている人たちに、これでいいんだと、政務官、撤回もしないし謝罪もしないじゃないか、やっぱり俺たちは間違っていないんだという、そうい…", "…やっぱり俺たちは間違っていないんだという、そういった差別主義的な人たちにお墨付きを与えることになりませんか。謝罪、撤回をすべきだと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014578X00320221109/59", "sentence": []}, {"url": "https://kokkai.ndl.