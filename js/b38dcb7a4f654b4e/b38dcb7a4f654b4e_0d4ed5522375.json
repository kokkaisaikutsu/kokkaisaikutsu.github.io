[{"date": "2022-03-08", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/105", "sentence": ["…その辺の状況がやはり不安視されます。新型コロナウイルスが建設産業にどのような影響を与えているのか、不動産・建設経済局長に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/107", "sentence": ["…も伺っております。コロナ禍の中、技能実習生など外国人労働者の受入れを今後どのように進めていくのか、不動産・建設経済局長に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/109", "sentence": ["…んだんではないかというふうに思っています。三回目のワクチン接種における職域接種の調整状況について、不動産・建設経済局長に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814319X00220220308/129", "sentence": []}]}]}, {"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/36", "sentence": ["…に適正、適切に反映されるような取組が必要と考えますが、国土交通省としてどのように取り組むのか、長橋不動産・建設経済局長に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/38", "sentence": ["…思っております。アスファルト合材の価格転嫁につきまして国土交通省としてどのように取り組むのか、長橋不動産・建設経済局長に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/42", "s