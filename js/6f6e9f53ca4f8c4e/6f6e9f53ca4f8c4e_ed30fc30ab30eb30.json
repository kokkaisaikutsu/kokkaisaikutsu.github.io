[{"date": "2022-04-12", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/8", "sentence": ["○湯原委員ありがとうございます。今、鉄道局では、ローカル鉄道が人口減少になって危機的状況なので、地域との協働環境、つまり、赤字のローカル線を…", "…人口減少になって危機的状況なので、地域との協働環境、つまり、赤字のローカル線をどうしましょうかという、地域とあくまでも鉄道事業者との協働です…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/10", "sentence": ["○湯原委員ありがとうございます。一部のローカル線で、廃止か存続かという二者択一の在り方ではなくて、維持することの再評価、つまり、ローカル線を…", "…かという二者択一の在り方ではなくて、維持することの再評価、つまり、ローカル線を再評価して、利用者の視点に立って再構築をしていくという御答弁で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01120220412/24", "sentence": []}]}]}]