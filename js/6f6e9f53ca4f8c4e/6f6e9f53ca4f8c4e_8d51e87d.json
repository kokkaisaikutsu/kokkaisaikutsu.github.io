[{"date": "2023-02-14", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/28", "sentence": ["…生労働省の方で、高齢者数がピークになる二〇四〇年へ向けて、地域医療の再編に向けた議論を始め、病床削減など、病院再編統合を促す方向になると。一…", "…四〇年へ向けて、地域医療の再編に向けた議論を始め、病床削減など、病院再編統合を促す方向になると。一昨年、その前から議論はあったんですけれども…", "…一月であります。厚生労働省では、私が仄聞した件でありますけれども、医療再編計画等々について今どういう状況なのか、教えてもらいたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00320230214/36", "sentence": []}]}]}]