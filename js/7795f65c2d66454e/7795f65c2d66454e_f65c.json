[{"date": "2022-04-11", "meeting": [{"meeting_name": "衆議院 北朝鮮による拉致問題等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/1", "sentence": ["○長島委員長これより会議を開きます。北朝鮮による拉致問題等に関する件について調査を進めます。この際、お諮りいたします。本件調査のため、本日、…", "…健裕君、経済産業省貿易経済協力局貿易管理部長風木淳君、海上保安庁長官奥島高弘君、防衛省大臣官房サイバーセキュリティ・情報化審議官上田幸司君、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/2", "sentence": ["○長島委員長御異議なしと認めます。よって、そのように決しました。―――――――――――――"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/3", "sentence": ["○長島委員長質疑の申出がありますので、順次これを許します。梅谷守君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/19", "sentence": ["○長島委員長じゃ、時間が来ておりますので、簡潔に。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/21", "sentence": ["○長島委員長次に、野間健君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/39", "sentence": ["○長島委員長次に、太栄志君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/61", "sentence": ["○長島委員長次に、三木圭恵君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/75", "sentence": ["○長島委員長次に、美延映夫君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/93", "sentence": ["○長島委員長次に、鈴木敦君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/106", "sentence": ["○長島委員長次に、笠井亮君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/120", "sentence": ["○長島委員長次に、浜地雅一君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/132", "sentence": ["○長島委員長次に、中川郁子君。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/142", "sentence": ["○長島委員長次回は、公報をもってお知らせすることとし、本日は、これにて散会いたします。午後四時七分散会"]}]}]}]