[{"date": "2022-03-08", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805254X00920220308/10", "sentence": []}]}, {"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/5", "sentence": ["…久君）清水委員にお答えを申し上げます。人というものは、やはり誰からも支配されず、誰からも管理されずに自らの人生を自己決定をする、自分で決めて…", "…するために、自由であるとか、基本的人権の尊重であるとか、あるいは法の支配、民主主義、こういった価値観、あるいは人道という概念、こういうものを…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/7", "sentence": ["…支援というものに力を傾けてまいりました。これは、その地域における法の支配の定着に貢献する取組であります。例えば法の立案でありますとか、あるい…", "…であるとか人材の育成とかですね、そういう協力を通じて、その地域に法の支配という考え方がしっかりと根付いていくような、そういう取組を長年にわた…", "…ることによって、インド太平洋、自由で開かれたインド太平洋において法の支配があまねく浸透していくように、これからも力を尽くしていきたいと考えて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00220220308/123", "sentence": []}, {"url": "https://kokka