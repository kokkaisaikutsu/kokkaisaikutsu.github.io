[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第三分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/232", "sentence": ["○古川国務大臣令和四年度法務省所管等予算につきまして、その概要を御説明申し上げます。法務省は、法秩序の維持、国民の権利擁護などの任務の遂行を…", "…に取り組んでいくため、現下の厳しい財政事情の下ではありますが、所要の予算の確保に努めております。法務省の一般会計予算額の総額は八千六十七億八…", "…下ではありますが、所要の予算の確保に努めております。法務省の一般会計予算額の総額は八千六十七億八千三百万円であり、所管別に区別いたしますと、…", "…デジタル庁所管として計上されている法務省関係の政府情報システム経費の予算額は六百億九千三百万円、国土交通省所管として計上されている法務省関係…", "…通省所管として計上されている法務省関係の国際観光旅客税財源充当事業の予算額は二十九億五百万円となっております。また、復興庁所管として計上され…", "…復興庁所管として計上されている法務省関係の東日本大震災復興特別会計の予算額は、一億七千二百万円となっております。何とぞ、よろしく御審議くださ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/302", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/326", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805268X00120220216/328", "sentence": []}]}]}, {"date": "2022-04-14", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815206X00620220414/9