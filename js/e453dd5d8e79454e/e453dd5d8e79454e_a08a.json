[{"date": "2023-02-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/295", "sentence": ["…岡市において会議を開催いたしました。会議におきましては、福岡県知事服部誠太郎君、日本労働組合総連合会福岡県連合会事務局長矢田信浩君、株式会社…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/385", "sentence": ["…く皆様におかれましては、御多用中にもかかわらず御出席をいただきまして、誠にありがとうございます。どうか忌憚のない御意見をお述べいただきますよ…", "…次に、本日御意見をお述べいただく方々を御紹介いたします。福岡県知事服部誠太郎君、日本労働組合総連合会福岡県連合会事務局長矢田信浩君、株式会社…", "…ゼンフーズ株式会社代表取締役会長河津善博君、以上四名の方々でございます。それでは、まず、服部誠太郎君に御意見をお述べいただきたいと存じます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/387", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/389", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/391", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/393", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/394", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/406", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/422", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/430", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/439", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/448", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X01020230213/463", "sentence": ["…しては、御多忙の中、長時間にわたりまして貴重な御意見をお述べいただき、誠にありがとうございました。また、この会議開催のため格段の御協力をいた…"]}]}]}]