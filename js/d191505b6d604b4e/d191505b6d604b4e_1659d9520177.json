[{"date": "2022-03-30", "meeting": [{"meeting_name": "参議院 政治倫理の確立及び選挙制度に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/6", "sentence": ["…に投票が実施可能かどうかという点も踏まえて、現地の実情を把握している外務省とともに慎重に検討を行う必要があると考えております。なお、在外選挙…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/18", "sentence": ["…て登録申請のために在外公館に出向くことが困難な場合があることについて外務省から伺ったところでございます。先ほど少しずつでも改善に向けて努力を…", "…在外公館に出向いていただくことなく登録申請を受け付けることについて、外務省とともに検討を進めてまいりました。結果、本年四月一日以降、準備が整…", "…、本年四月一日以降、準備が整った在外公館から順次これを実施することといたしました。今後、外務省とも連携をしながらその周知を図ってまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/22", "sentence": ["…先ほど来御答弁していますように、林外務大臣にも、お話があったように、外務省とやっぱり連携することが必要だと思います。国によって実情も違います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814578X00320220330/104", "sentence": []}]}]}]