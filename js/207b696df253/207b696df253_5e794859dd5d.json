[{"date": "2023-04-24", "meeting": [{"meeting_name": "衆議院 決算行政監視委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/262", "sentence": ["…で取り組んできたわけでございます。そういった中で、当時は千葉、東京、神奈川、京都、奈良、大阪、兵庫、広島と八都府県に三十一校しか設置をされて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/264", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/266", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/270", "sentence": ["…そこに夜間中学があって、これはいいんですよ、県立じゃなくても。例えば神奈川でも、分かりやすいのは、横浜市と川崎市の夜間中学は、それぞれ市内の…", "…きました。ここは、広域に、県が中心になって、県とも連携しながら、他の神奈川の、川崎や横浜以外の自治体と連携をして、それも受け入れていくという…", "…以外の自治体と連携をして、それも受け入れていくということで、ようやく神奈川もほぼほぼ、もし希望すれば入れる状況が整っていったんです。ですから…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104132X00120230424/282", "sentence": []}]}]}]