[{"date": "2020-11-27", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/8", "sentence": ["…い。そのときに、やはり、来年の一月に入りましたら、早速に大学入学の共通テストが一月十六、十七、第二回目が三十、三十一で、ほとんどがこの一回目…", "…私立の大学であるとか、例えば一般入試の方が中止になって、そしてこの共通テストの成績で合否を判定をしたり、あるいは受験のやり方を急遽変更するよ…", "…うというふうに私は思っております。そういった意味では、まずは、この共通テストというものの意味合いが、ある意味ではセーフティーネット的な大事な…", "…られることはよくわかっておりますけれども、大臣も記者会見において、共通テストを中止するということは想定をしていないけれども、本当に最悪の場合…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305124X00520201127/33", "sentence": []}]}]}]