[{"date": "2021-03-25", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/147", "sentence": ["…、河野大臣御答弁いただいたので再度質問させていただきますけれども、この申合せのとおりにやって、そういう報告書が作られるとお考えになりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/149", "sentence": ["…報告の必要ない案件になってしまいます。つまり、この申合せを守るならば報告書というのはできないということになります。河野大臣、いかがでしょうか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/151", "sentence": ["○浅田均君河野大臣、あのね、徹底されているから、あの報告書なんて農水省においては一個も、一つも出てきていないんですね。だから、そういう点を踏…", "…触があった、こういう異様な接触がありましたということを根拠に書かれた報告書があるかどうか、一回再チェックしていただきたいと思います。多分ない…", "…と思います。多分ないと思いますよ、多分ない。この申合せがあるがゆえに報告書が書かれないのだとしたら、国家公務員制度改革基本法というのは何で作…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01620210325/167", "sentence": []}]}]}]