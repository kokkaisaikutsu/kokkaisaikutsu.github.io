[{"date": "2021-03-05", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/321", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/323", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/325", "sentence": ["○浅田均君ありがとうございます。また尾身先生に御出席いただいております。午前中からも議論がありましたけれども、二週間緊急事態宣言を一都三県で…", "…節性インフルエンザ並みになったときとお考えになっているんでしょうか。尾身先生のコロナの終えんという、終息ということはどういう事態であるのかと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/327", "sentence": ["…貴重な御見解を聞かせていただきまして、ありがとうございます。それで、尾身先生には、大変御多忙のところ、昨日、感染研からのレポートを御覧いただ…", "…るところと全然考え方が違う意見が載っていましたので、その意見に関して尾身先生の御見解をお伺いしたいと思うんですが、一点目は、緊急事態宣言は著…", "…いと、ＧｏＴｏトラベルは第三波の原因ではないと、かもしれないとしているんですが、この点に関しまして尾身先生はどういうふうにお考えでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/329", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/331", "sentence": ["○浅田均君尾身先生におかれましては、御多用中お越しいただきまして、本当にありがとうございます。これでもう御退席いただいて結構でございますので…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/333", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/335", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/337", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/339", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/343", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/345", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X00520210305/347", "sentence": []}]}]}]