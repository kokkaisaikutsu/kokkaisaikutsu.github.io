[{"date": "2021-12-10", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715254X00320211210/10", "sentence": ["…外国人の新規入国停止を解除する条件は何でしょうか、総理に伺います。濃厚接触者に十四日間自宅待機してもらうよりは、看護師さんのいる濃厚接触者専…", "…す。濃厚接触者に十四日間自宅待機してもらうよりは、看護師さんのいる濃厚接触者専用のホテル等に入ってもらう方が安心できると思いますが、強制でき…"]}]}]}, {"date": "2022-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/284", "sentence": ["…が、時間が短い、平均二・六日と言われております。この二・六日の中で濃厚接触者を特定して囲い込むというのは非常に難しいと思われます。感染症法上…", "…必要があるわけですね。感染拡大抑制のために疫学調査をやる、それから濃厚接触者を特定する、そういう作業が感染症法上の要請として行政、保健所に掛…", "…たと。そういう、みなし陽性とかいう言葉も出てきておりますし、みなし濃厚接触者、そういう言葉も出てきております。だから、もう本当の感染症法上の…", "…御家族がかかった。高熱が出た、何日間か休まれた。でも、周りの方は、濃厚接触者であるからといって自宅待機一週間とか、そういうことはありません。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/288", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/290", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/292", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/294", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/296", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/298", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/300", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/302", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/304", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00920220307/306", "sentence": []}]}]}]