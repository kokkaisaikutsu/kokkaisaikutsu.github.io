[{"date": "2022-03-10", "meeting": [{"meeting_name": "衆議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/25", "sentence": ["…って議論をしていただきたいとお願いをいたします。二番目のテーマは、災害対策に関するノウハウの蓄積と継承とタイトルをつけたんですが、どうやって…", "…れども、それだけではない。もちろん、全てノウハウの塊でありますこの災害対策について、どういう体制をつくっていくのかということ、これが私は大問…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/27", "sentence": ["…ございます。私は、本当に、内閣府防災の皆さんの取組というのが日本の災害対策を支えているというふうに思います。今、百人少々の組織だと思いますが…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804339X00320220310/36", "sentence": []}]}]}]