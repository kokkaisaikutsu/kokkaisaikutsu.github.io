[{"date": "2022-10-24", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/37", "sentence": ["○佐藤（英）委員持続的な賃上げを実現するためには、多くの人への学び直しの機会の提供や、その取組を進める企業、特に中小企業への手厚い公的な支援…", "…長分野に重点を置いて教育訓練給付や求職者支援制度を拡充し、個人の学び直しを後押ししていくなど、人への投資も抜本的に強化をすべきと考えます。総…", "…投資も抜本的に強化をすべきと考えます。総理は、所信演説で、個人の学び直しやリスキリングへの公的支援について、五年で一兆円のパッケージに拡充す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/43", "sentence": []}]}]}, {"date": "2022-10-26", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/38", "sentence": ["…時金について伺いますが、これまで、平均的な出産費用の状況を踏まえて見直しが行われてまいりました。平成二十一年に四十二万円に引き上げられました…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/46", "sentence": ["…働問題、特に人への投資について伺ってまいりたいと思います。特に、学び直しの機会の提供には、各企業の積極的な取組が不可欠であります。企業向けの…", "…間、予算を充てることが容易ではありません。中小企業などにおいても学び直しの機会が十分に提供されるよう、よりよい手厚い支援が必要と考えますが、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/48", "sentence": ["…訓練給付や求職者支援制度を拡充するなどして、労働者個人の主体的な学び直しを積極的に支援すべきではないでしょうか。その際、デジタル分野等の成長…", "…リカレント教育を実施している大学を学習地域拠点とすることにより、学び直しを推進することも考えられるのではないでしょうか。さらに、非正規労働者…", "…にかかわらず能力開発等を受けられるようにするための措置も必要であります。これら個々人の学び直しの在り方についての御見解も、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004260X00220221026/54", "sentence": []}]}]}]