[{"date": "2023-03-08", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00720230308/5", "sentence": ["…は、ＮＩＳＡ口座を利用した年間投資額及び生涯投資額が引き上げられ、非課税保有期間も恒久化されるとしています。政府はその政策目的を眠った現預金…", "…、富裕層は、年間投資額の範囲内で短期的に売買を繰り返して、譲渡所得非課税の恩恵をフルに活用することも想定されます。衆議院財務金融委員会におけ…", "…に示すべきです。金融担当大臣に答弁を求めます。ＮＩＳＡ拡充は金融所得課税の強化と一体で進めるべきであり、かつて民主党政権においてＮＩＳＡを導…", "…全く不十分です。岸田総理は、これまでの委員会審議においても、金融所得課税の強化に対し、マーケットへの影響を考慮しとの答弁を繰り返していますが…", "…、税制における応能負担原則の回復です。本法律案において金融所得の総合課税化への道筋が開けたことは前向きに受け止めたいと思いますが、そこに課さ…", "…。政府は、所得税の世界で累進性が損なわれている現状において、金融所得課税の見直しについて今後どのように進めるのか、明確な日程とともにお示しく…"]}]}]}, {"date": "2023-03-14", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/57", "sentence": ["…抑制する効果があるというふうに思いますし、共産党さんが、内部留保への課税、で、それを財源に中小企業の支援の原資とするということを含め、という…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/69", "sentence": ["…割見るのを三年、半分を三年としている意味、だから、その六年間のうちに課税事業者に転換してくださいということを言っているわけじゃないんですよね…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114370X00320230314/73", "sentence": []}]}]}, {"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "