[{"date": "2020-12-16", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/132", "sentence": ["…であれば、ボーナスカット分について穴埋めをします、この例えば包括支援交付金などを使ってそれができますということを現場に伝えるということが何で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304889X00720201216/142", "sentence": []}]}]}, {"date": "2022-03-10", "meeting": [{"meeting_name": "衆議院 政治倫理の確立及び公職選挙法改正に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/76", "sentence": ["…を確認します。一九九五年、政党助成制度導入以降、二〇二一年まで、政党交付金の総額は幾らになっているでしょうか。また、これまでに交付金を受け取…", "…度導入以降、二〇二一年まで、政党交付金の総額は幾らになっているでしょうか。また、これまでに交付金を受け取った政党の数は幾つになるでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/78", "sentence": ["…でに、八千五百四十億円、四十五政党ということでした。二〇二一年に政党交付金を受け取っている政党、そして、各党がこれまでに受け取った政党交付金…", "…十五政党ということでした。二〇二一年に政党交付金を受け取っている政党、そして、各党がこれまでに受け取った政党交付金額は幾らになるでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/80", "sentence": ["…変えてしまったという経緯があります。現状はどうか、お尋ねします。直近の二〇二〇年分で、各党の収入に占める政党交付金の依存率は何％でしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804577X00320220310/89", "sentence": []}]}]}]