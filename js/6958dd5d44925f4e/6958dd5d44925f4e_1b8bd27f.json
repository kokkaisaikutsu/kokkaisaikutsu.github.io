[{"date": "2022-04-15", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/157", "sentence": ["…自転車の扱いですから、運転免許が必要となります。運転免許に関して、現行の電動キックボードの免許試験内容、講習内容について説明いただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/159", "sentence": ["○塩川委員ですから、適性試験、学科試験、また三時間の原付講習という形で、安全教育、道交法のルールをしっかりと身につけるという場を設けているわ…", "…と身につけるという場を設けているわけであります。技能試験とか高速道路講習がないぐらいで、自動車免許と同様の内容であります。このような形で安全…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X01920220415/206", "sentence": []}]}]}]