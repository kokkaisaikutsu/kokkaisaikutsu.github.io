remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/56", "sentence": ["…ております。尾身分科会会長は、バブルの中の関係者の感染対策も必要で、ＩＯＣや日本の組織委員会、政府、自治体が同じ目線、方向性で実施していくこ…", "…織委員会、政府、自治体が同じ目線、方向性で実施していくことが大事だ、ＩＯＣにも日本の状況を知ってもらい、理解してもらうことが大事だと、感染リ…", "…てもらい、理解してもらうことが大事だと、感染リスクなどに関する見解をＩＯＣにも伝えたいと述べておられます。ＩＯＣには、このような専門家の見解…", "…と、感染リスクなどに関する見解をＩＯＣにも伝えたいと述べておられます。ＩＯＣには、このような専門家の見解を受け止める用意はあるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/58", "sentence": ["…の分科会の会長でもある尾身会長などが取りまとめる提言、見解について、ＩＯＣにはそういった見解を受け止める用意があるのかということなんですが。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/60", "sentence": ["○塩川委員ですから、尾身会長などの提言が出された場合には、それはきちっとＩＯＣに伝えますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/62", "sentence": ["○塩川委員ＩＯＣの委員などが利用するホテルですけれども、この間、オリンピックファミリーについて、五つ星、四つ星ホテルのスイートルームを含む専…", "…として行っているということも示されているところであります。こういったＩＯＣ関係者が宿泊するホテルについては、大会特別料金で一括して契約してお…", "…るホテルについては、大会特別料金で一括して契約しており、組織委員会がＩＯＣとの契約に基づきその一部を負担しているということですが、この分担に…", "…一部を負担しているということですが、この分担について見直しが進んで、ＩＯＣが全額負担する方向で調整されているという国会でのやり取りも承知して…", "…進んで、ＩＯＣが全額負担する方向で調整されているという国会でのやり取りも承知しておりますが、ＩＯＣが全額負担することにはなったんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120404889X03120210609/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/12040