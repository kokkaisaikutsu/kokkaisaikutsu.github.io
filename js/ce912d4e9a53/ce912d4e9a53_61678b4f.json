[{"date": "2023-05-11", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/52", "sentence": ["…あったかと思っております。私の地元である埼玉も非常に早い段階で独自の条例を制定したわけでありますが、これらは、全ての都道府県に一律に義務づけ…", "…施をしておるものであります。現在、三十三の道県において、独自性のある条例制定が進み、新たな官民の連携協力の動きや県域を越えた種子供給体制の整…", "…いるところでありますので、廃止した法律を復活させるということは考えておらず、各地方自治体の独自性のある条例については、否定は申し上げません。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/111", "sentence": []}]}]}]