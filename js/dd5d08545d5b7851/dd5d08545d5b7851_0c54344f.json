[{"date": "2023-05-12", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X02120230512/12", "sentence": ["…識、見解を伺います。欧米諸国では、難民認定申請者の面接時に弁護士等の同伴が認められている上、面接の様子は全て録音、録画され、審査を行う上での…", "…拠として取り扱われています。一方、日本では、一部の年少者などに限って同伴者の立会いを認める運用が試行されている以外、一次審査における弁護士の…", "…者の立会いを認める運用が試行されている以外、一次審査における弁護士の同伴は認められておらず、面接の録音、録画も一切認められておりません。言葉…", "…知識も不足がちな難民申請者が適切な申立てを行う上で、面接時に弁護士や同伴者の立会いを認めるべきと考えますが、法務大臣の見解を求めます。また、…"]}]}]}, {"date": "2023-05-16", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/305", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/309", "sentence": ["…ているんです。審査プロセスの透明化の話、私は本会議のときに、いわゆる同伴者の立会いと、それから録音、録画をやったらどうですかという質問させて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01420230516/311", "sentence": []}]}]}, {"date": "2023-05-18", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/350", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/352", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/354", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/356", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/358", "sentence": ["…審査プロセスの透明化のことで、これは代表質問のときにも、いわゆるその同伴者の同席、審査に当たってですね、それと録音、録画の話について質問させ…", "…ただいたわけなんですけれども。改めてお聞かせいただきたいんですけど、同伴者を入れなくても大丈夫なんだという今の手続の正当性については大臣も御…", "…すし、これまでも法務省からの説明を受けているんですけど、審査のときに同伴者を、介添え人をそこまでかたくなに入れないということをおっしゃってい…", "…たことの合理性の根拠になるんじゃないのかなと思うんですけど、これは次長で結構です、なぜ同伴者を入れることをそこまでかたくなに嫌がるんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/360", "sentence": ["○川合孝典君済みません、信用性の問題から同伴者を認めない、要はその同伴者がその申請者を誘導するかもしれないということ、という意味ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/362", "sentence": ["○川合孝典君同伴者が同伴に当たってのルールを決めればいいだけなんじゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/364", "sentence": ["…そういう障害を取り除いた上で、いわゆる審査、一回目の面接に当たっての同伴者が入るということなどについても検討すればいいんじゃないのかなと私は…", "…思うんですが、実態も含めて是非聞き取りを行っていただいた上で、いわゆる同伴者をどうするのかということについて御検討いただけませんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/366", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/368", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/370", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/372", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/374", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/376", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115206X01520230518/378", "sentence": []}]}]}]