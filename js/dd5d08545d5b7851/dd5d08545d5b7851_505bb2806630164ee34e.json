[{"date": "2023-03-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/339", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/343", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/345", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/347", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/349", "sentence": ["…政府として合計特殊出生率を設定するということ自体が若い世代の方々、子育て世代の方々に対する押し付けになるとは私は考えてはおりません。あくまで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/351", "sentence": ["…とを聞いて実は数字を取っています。したがって、全てのいわゆる若者、子育て世代の方々の希望調査をした上での数字ではないということであります。Ｚ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/353", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/355", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/357", "sentence": ["…一・二％という数字なんですね。この数字が示すことは、いわゆる本当に子育て世代としてこれから支出を、家計の支出を強いられる世代の人たちは、そも…", "…本のいびつな人口ピラミッドの中で少数派となってしまっている子ども・子育て世代に対してどう支援をするのかということが問われているんだと私思うん…", "…ているということを重く受け止めていただきたいんですが。ちなみに、総理、この人口の構成見て、子育て世代の人数の少なさについてどう思われますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/361", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/363", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/365", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/367", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/369", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/371", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/373", "sentence": []}]}]}]