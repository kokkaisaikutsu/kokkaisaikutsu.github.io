[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/287", "sentence": ["…の二十四日、この時点で既にウエスト・テキサス・インターミディエートの原油先物価格は百ドルを一時期超えました。現在も百ドル前後で一バレル推移し…", "…ッター当たり二百二十円台まで上昇いたします。あわせて、北海ブレントの原油先物価格についても二、三日前に百五ドルを記録しておりますので、そうす…", "…われていると私は思っておりまして、ちなみに総理は、今のこの燃料価格、原油価格の高騰状態、原油高というのはいつ頃まで続くと想定して政策を講じよ…", "…ておりまして、ちなみに総理は、今のこの燃料価格、原油価格の高騰状態、原油高というのはいつ頃まで続くと想定して政策を講じようとしていらっしゃる…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/293", "sentence": ["…ガソリンを売れないんですよ。このタイムラグがある上に、ガソリン価格、原油価格が上昇しているということが相まって、今補助金を細々と入れていって…", "…行う。それでも、先ほど指摘させていただいたように、更にガソリン価格、原油価格が上がる可能性があるわけです。そうなったときに、そのリスクヘッジ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/305", "sentence": []}]}]}]