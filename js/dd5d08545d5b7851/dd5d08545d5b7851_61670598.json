[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/285", "sentence": ["…思います。ここからは、私ども国民民主党が強く主張しておりますトリガー条項の凍結解除についてでありますが、ガソリン補助金についてまず御質問させ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/293", "sentence": ["…総理に指摘をさせていただきたいと思うんですけれども、私どもがトリガー条項の凍結解除に対して極めてこだわって主張させていただいているんですけれ…", "…の暫定税率が延長できなくなったことがありましたが、その結果、トリガー条項が発動したことで、一か月間だけ実は燃料価格が下がっているんです。その…", "…ラスになることなわけであります。したがって、私としては、このトリガー条項を発動するということで目に見える形でガソリン、灯油価格を下げるという…", "…ます。しかしながら、本予算が仮に成立した後であったとしても、トリガー条項の凍結解除をやるかどうかということについては、これは岸田総理の決断い…", "…いるということであります。私から改めて確認をさせていただきたいんですが、トリガー条項の凍結解除の議論、いつからやっていただけるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/305", "sentence": []}]}]}]