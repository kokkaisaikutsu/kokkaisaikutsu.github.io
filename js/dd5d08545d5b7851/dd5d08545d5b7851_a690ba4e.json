[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/277", "sentence": ["…した声が来ているということであります。今ウクライナにいらっしゃる在留邦人をどう安全を確保するのかということの議論をしていただいておりますけど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/281", "sentence": ["…質問の方に入らせていただきたいと思います。昨日までの国会審議で、在留邦人の、失礼、今、ウクライナ国内にいらっしゃる在留邦人がおよそ百二十人ほ…", "…の国会審議で、在留邦人の、失礼、今、ウクライナ国内にいらっしゃる在留邦人がおよそ百二十人ほどだということは伺いました。既にキエフの市内でも戦…", "…戦闘状態が始まっているといった情報も飛び交っている状況の中、この在留邦人の安全確保に細心の注意を払う必要があるということは、これは今までも繰…", "…するといったような望ましくない事態が生じた場合に、この百二十人の在留邦人の方々の安全をどう確保していくのかといったようなことも含めて、極めて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/287", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/289", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/291", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/305", "sentence": []}]}]}]