[{"date": "2022-03-04", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/279", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/281", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/283", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/285", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/287", "sentence": ["…、恐らくこれだったら接種した方がいいんじゃないかって話だと思うんですが、この八百三十四という数字の分母と分子を教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/289", "sentence": ["○梅村聡君つまり、これ比較と書いてあるんですけれども、比較する分母が意味が全然違うんですね。左側はワクチンを打った方みんなですから何百万人と…", "…おられるわけです。ところが、右側のかかった場合というのは入院した方が分母ですから、四千七百九十八分の四人ですよね。これ全く分母が違うものを比…", "…は入院した方が分母ですから、四千七百九十八分の四人ですよね。これ全く分母が違うものを比べる意味があるんかという話ですよ。それだったら、ワクチ…", "…は、国民が知りたいデータの比較をしないと、これ入院した患者さんだけの分母に持ってきて載せることが、私はパンフレットとして考え直さないといけな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/291", "sentence": ["○梅村聡君余計理解しにくくなっていると思いますので、ちゃんと分母の条件はそろえていただきたいということを申し上げたいと思っております。ちょっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/293", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/295", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/297", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/299", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00820220304/303", "sentence": []}]}]}]