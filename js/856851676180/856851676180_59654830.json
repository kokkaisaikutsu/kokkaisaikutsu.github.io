[{"date": "2022-11-16", "meeting": [{"meeting_name": "参議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/96", "sentence": ["…ということは、これは契約では当然ありませんし、あるいは、じゃ、宗教の教えの中で、あなたのそういうお金に対する執着が問題なんだから一回自分から…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/98", "sentence": ["…も。じゃ、ちょっとこれ逆にお聞きするんですけど、この民事執行法の中の四分の一という基準、この基準の根拠について教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/104", "sentence": ["…うのはどれぐらい行われてきたのか、また充実させるというのは今後どういう形で充実させていくのか、ちょっと具体的に教えていただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014536X00320221116/110", "sentence": []}]}]}]