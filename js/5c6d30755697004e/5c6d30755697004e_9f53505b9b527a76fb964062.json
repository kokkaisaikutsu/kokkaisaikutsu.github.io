[{"date": "2023-03-06", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/44", "sentence": ["○国務大臣（浜田靖一君）原子力発電所などに対する攻撃に際しては、自衛隊は、事態に応じ、関係機関と緊密に連携しながら対処していくことになります…", "…の共同訓練などを積み重ねていますが、三文書の下、今後も引き続き、原子力発電所等における各種事態発生時を想定した共同訓練等を、各種訓練を実施し…", "…や関係機関相互の連携強化等を図ってまいります。昨年十二月には、各原子力発電所の警備に関し、インフラ事業者が初めて参加する関係機関の連携枠組み…", "…うした枠組みも活用しながら、引き続き連携強化のための取組を進め、原子力発電所などに対する攻撃に際し、国民の命、そして平和な暮らしを守り抜いて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/407", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/409", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00520230306/411", "sentence": []}]}]}]