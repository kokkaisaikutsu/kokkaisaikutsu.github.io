: "https://kokkai.ndl.go.jp/txt/121005206X00620221109/357", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00620221109/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00620221109/361", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00620221109/363", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005206X00620221109/372", "sentence": []}]}]}, {"date": "2022-11-10", "meeting": [{"meeting_name": "参議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/3", "sentence": ["…いたします。今後は、私の真意がしっかりと伝わっていくように、発言には慎重を期してまいりたいというふうに考えています。以上です。───────…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/39", "sentence": ["…ある、国民の間でもいろんな議論がございます。法務大臣としては、やはり慎重に、粛々とですね、慎重に慎重を期しながら法の執行をしていく、そういう…", "…んな議論がございます。法務大臣としては、やはり慎重に、粛々とですね、慎重に慎重を期しながら法の執行をしていく、そういう立場にあると思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X00520221110/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015206X0052022111