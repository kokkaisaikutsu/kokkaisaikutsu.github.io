[{"date": "2023-05-11", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/65", "sentence": ["…げておりました。日本は農産物の輸入国でありますので、自国の農作物の生産性向上はメリットはありますが、ほかのＧ７の構成国は輸出国でありますので…", "…はメリットはありますが、ほかのＧ７の構成国は輸出国でありますので、生産性向上の文言を盛り込むことができなかったというふうに認識しております。…", "…、有言実行されたという捉え方をしております。しかし、国内報道では、生産性向上と持続可能な農業を両立させるという条件付で合意に至った、こういう…", "…て、即効性に乏しいという課題も指摘されております。今回のＧ７農業大臣声明の意義をいま一度、生産性向上の観点から教えていただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105007X00920230511/85", "sentence": []}]}]}]