[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/5", "sentence": ["…の更なる設置数の増加を図るとともに、狩猟者の実施隊員への移行・加入の促進等、必要な措置を的確に講じること。また、実施隊における多様な人材の活…", "…し、必要な措置を講じること。四捕獲等をした鳥獣についての有効な利用の促進に当たっては、食品、愛玩動物用飼料又は皮革としての利用促進と併せて、…", "…効な利用の促進に当たっては、食品、愛玩動物用飼料又は皮革としての利用促進と併せて、動物園での飼料としての利用、油脂や骨の加工製品化等、幅広く…", "…の加工製品化等、幅広く多様な利用の在り方について引き続き検討し、その促進のために必要な措置を講じること。その際、一層の利用拡大を図るためには…", "…に制定された国産ジビエ認証制度の趣旨及び目的を踏まえて、同制度の普及促進を図るとともに、認証に取り組む事業者に対するきめ細かな支援を行うこと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01620210608/37", "sentence": []}]}]}, {"date": "2021-06-10", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/6", "sentence": ["…、川上だけではなくてそれを使うところまで一体的に整備をして木材利用を促進していこうという、こういう考え方の下で進んできたので、今回ちょっと名…", "…りますけれども、是非これを、この法律が成立することによってより利用の促進につながっていくよう、与野党協力をしてやっていきたいなというふうに思…", "…てやっていきたいなというふうに思います。質問に入ります。まず、木材の利用を促進する意義についてどのようにお考えになられるか、お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X01720210610/8", "sentence": ["○田名部匡代君公共建