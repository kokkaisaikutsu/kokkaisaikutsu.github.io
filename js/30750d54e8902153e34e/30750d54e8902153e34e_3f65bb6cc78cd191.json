[{"date": "2023-03-23", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/29", "sentence": ["○田名部匡代君今パネルでお示ししていますけれども、総理の政治資金パーティーのお土産にロゴの入ったおまんじゅうとペンが配られた。これは申請があ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/31", "sentence": ["…の、条件だとおっしゃいましたよね。昨日確認させていただいたんです。政治資金パーティーは明らかな政治活動だというふうに思いますけれども、なら私…", "…政治活動には使用できないということを昨日確認したんです。そしたら、政治資金パーティーは政治活動なのかというふうに聞かれました。政治活動です。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/34", "sentence": ["○田名部匡代君いや、これが、後援会と入ったペンもそうですし、政治資金パーティーだったことから、これは特定の政治活動ではないのですかということ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01320230323/64", "sentence": []}]}]}]