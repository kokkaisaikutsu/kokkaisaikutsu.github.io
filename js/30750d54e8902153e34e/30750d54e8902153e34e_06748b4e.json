[{"date": "2020-09-18", "meeting": [{"meeting_name": "参議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/1", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/2", "sentence": ["○委員長（田名部匡代君）理事の辞任についてお諮りいたします。武田良介さん及び増子輝彦さんから、文書をもって、都合により理事を辞任したい旨の申…", "…たします。武田良介さん及び増子輝彦さんから、文書をもって、都合により理事を辞任したい旨の申出がございました。これを許可することに御異議ござい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/3", "sentence": ["…員長（田名部匡代君）御異議ないと認め、さよう決定いたします。この際、理事の補欠選任を行いたいと存じます。理事の選任につきましては、先例により…", "…、さよう決定いたします。この際、理事の補欠選任を行いたいと存じます。理事の選任につきましては、先例により、委員長の指名に御一任願いたいと存じ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/4", "sentence": ["○委員長（田名部匡代君）御異議ないと認めます。それでは、理事に長浜博行さん及び浜口誠さんを指名いたします。─────────────"]}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120214319X00120200918/14", "sentence": []}]}]}]