[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/40", "sentence": ["…す。市町村は、人・農地プラン策定に当たって、基盤法第十九条で、政令で定めるところにより地域計画を定めるとされています。これ、どのようなことを…", "…策定に当たって、基盤法第十九条で、政令で定めるところにより地域計画を定めるとされています。これ、どのようなことを政令で定めるのか、お答えくだ…", "…当たって、基盤法第十九条で、政令で定めるところにより地域計画を定めるとされています。これ、どのようなことを政令で定めるのか、お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/44", "sentence": ["…りました。続いて、令和七年までに農業を担う者ごとに利用する農用地等を定め、これを地図に表示する、まさにこれ目標地図、ことを内容とする地域計画…", "…どういう人なのか。あわせて、基盤法第十九条三項、農業を担う者ごとに利用する農用地等を定めというのは、具体的には何を意味しているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/62", "sent