[{"date": "2022-04-05", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/25", "sentence": ["…いますけれども、過去に政府備蓄米を主食用に提供した事例というのは学校給食、熊本地震の際の給食用としての精米八十六万トン、海外食糧援助などです…", "…に政府備蓄米を主食用に提供した事例というのは学校給食、熊本地震の際の給食用としての精米八十六万トン、海外食糧援助などです。学校給食や子供食堂…", "…地震の際の給食用としての精米八十六万トン、海外食糧援助などです。学校給食や子供食堂は、食糧法のこれ第四十九条一項、政令で定めるところにより、…", "…べきと思ったので、これを改めて取り上げさせてもらっていますけど、学校給食や子供食堂に備蓄米を供給できるのは教育の用に供するということだと思い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00620220405/37", "sentence": []}]}]}]