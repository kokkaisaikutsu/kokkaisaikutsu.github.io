[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/59", "sentence": ["…いただきたいと思います。先日、我が党の田島委員から質問がありました。安倍前総理、民放の報道番組で、核保有についてまさに議論を呼びかけるような…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/61", "sentence": ["…ました、核共有。実は、平成二十九年、我が党の白眞勲委員からも、当時の安倍総理にこのことについて質問されておられるんですね。当時の安倍総理は、…", "…、当時の安倍総理にこのことについて質問されておられるんですね。当時の安倍総理は、やはりこれは非核三原則を堅持していくという立場だと、そして、…", "…っかりとその立場を守っていくという御発言をされているんですね、当時、安倍総理は。しかし、この間、民放のテレビ番組において、その議論を呼びかけ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/99",