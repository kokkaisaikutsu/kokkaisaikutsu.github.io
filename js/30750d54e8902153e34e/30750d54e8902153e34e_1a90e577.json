[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/31", "sentence": ["…べきだと思っています。で、大臣、もう一つですね、衆議院の委員会で次官通知の見直しについて触れられたようであります。今回、私たち立憲民主党が衆…", "…。今回、私たち立憲民主党が衆議院に提出した修正の中にも、この事務次官通知というか競争力強化八条四号についての削除を求めることを書き込みました…", "…の削除を求めることを書き込みました。まあ削除されないまでも、事務次官通知はしっかりと見直していく。まさにその知見の民間への提供ということです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/47", "sentence": []}]}]}]