[{"date": "2023-11-21", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/8", "sentence": ["○若宮委員今総理が御答弁いただきました可処分所得、これを増やしていくことが何よりだというふうに私も思っております。そして、その可処分所得が増…", "…いくことが何よりだというふうに私も思っております。そして、その可処分所得が増えたことによって、増えたお金の分を消費に回す、その消費に回った分…", "…ろうかと思っています。デフレマインドを払拭するには、国民全体の可処分所得を上げる、そして、そのために減税を実施するということは一つの方策でも…", "…なります。そして何よりも、今回のまた特徴というのは、非課税世帯よりも所得がちょっと高い方々にもしっかりと目を向けていくということも大きなポイ…", "…いうふうにも思われております。さらには、非課税世帯ではないために、低所得者の支援、こういった対象からも外れてしまうということも考えられます。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121205261X00520231121/38", "sentence": []}]}]}]