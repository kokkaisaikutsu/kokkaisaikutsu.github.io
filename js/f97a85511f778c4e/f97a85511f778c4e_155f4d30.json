[{"date": "2022-03-14", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/234", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/242", "sentence": ["…す。この中でもう一つ、孤独、孤立に関する公明党の昨年の実態調査では、引きこもり支援の必要性というものが改めて浮き彫りになりました。人口規模の…", "…も足りないといった声も寄せられました。また、私が先日訪問いたしました引きこもりなどの総合相談を行っているセンターでは、コロナ禍では対面相談が…", "…による相談支援をかなり活発に実施をされておりました。特に昨年からは、引きこもり経験者によるピアサポーターがズームを活用した居場所づくりという…", "…といった、そういう居場所というものがまだまだ少ないとお聞きしました。引きこもりの問題は、当事者に寄り添い、どこまでも当事者目線による支援とい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/246", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/248", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/250", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/252", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01320220314/254", "sentence": []}]}]}]