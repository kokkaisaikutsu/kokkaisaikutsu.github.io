[{"date": "2023-03-17", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/88", "sentence": ["…日本には海底火山を含めて百十一もの活火山がございます。このうち、火山噴火予知連絡会は常時監視が必要なものとして五十の活火山を選定をしておりま…", "…必要なものとして五十の活火山を選定をしております。当然、火山の監視や噴火予知に関する体制の構築というものが重要になるわけですが、その担い手で…", "…変課題になっております。二〇一四年に長野、岐阜両県にまたがる御嶽山が噴火をして、死者、行方不明者六十三人という戦後最悪の火山災害となりました…", "…す。火山研究者の不足というのは我が国の喫緊の課題であり、火山の監視や噴火予知に関する日本の水準を引き上げていくためにも私は必要なことであると…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115104X00420230317/106", "sentence": []}]}]}]