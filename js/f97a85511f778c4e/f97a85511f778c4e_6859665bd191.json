[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/140", "sentence": ["○竹内真二君大臣、よろしくお願い申し上げます。次に、奨学金の代理返還制度についてお聞きします。これまで企業から社員に直接支援する方式のみであ…", "…てお聞かせください。また、制度について知られていない面もあり、企業と奨学金の貸与者双方に周知をすべきではないでしょうか。文部科学省の見解をお…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/142", "sentence": ["…、より多くの企業の登録を更に促進していくべきと考えますけれども、この奨学金返還支援に関する末松文部科学大臣の御認識をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/144", "sentence": []}]}]}]