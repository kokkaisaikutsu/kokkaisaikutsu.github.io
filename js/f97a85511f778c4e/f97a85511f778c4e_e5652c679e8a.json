[{"date": "2022-10-27", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/143", "sentence": ["…外国につながる子供たちといいますのは、外国籍であったり、日本国籍でも日本語が不自由なために修学や進学に困難を抱えている子供たちであります。特…", "…会とＮＰＯの共催で多言語説明会を開催しております。また、多文化教育や日本語教育の専門知識を持つ多文化教育コーディネーターの派遣事業によって、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/145", "sentence": ["…みません。二〇二三年度から、この外国につながる生徒の皆さん方に対する日本語の授業が卒業単位として認定されることになります。中退率が下がったと…", "…も、やはり五・五％に上る中で重要な取組であるわけですが、小中学校での日本語の授業でも相当教員の皆さんが不足しております。高校での授業というも…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/147", "sentence": ["…、小中学校から高校進学、さらには就職や進学までのこの各段階で、やはり日本語教育を含めた伴走型の支援というものがやはり急がれていると思います。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015104X00220221027/151", "sentence": []}]}]}]