[{"date": "2022-05-10", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/38", "sentence": ["…象に作った電気通信事業法で、ネット上で情報通信事業を営む企業全般の行為を規制することに至った検討の経緯も含めて、お聞かせ願えますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/46", "sentence": ["…員どうもありがとうございます。規制対象となる登録者数を一千万人とした経緯と今後について、ここでもう一度確認をさせていただきたいんですが、ＥＵ…", "…あります。そこで、規制対象となる登録者数の基準を一千万人としたことについての経緯と、今後の見直しの可能性についてお聞かせ願えますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804601X01620220510/52", "sentence": []}]}]}]