[{"date": "2022-10-27", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/113", "sentence": ["…願いをしたいと思います。続きまして、マイナンバーカードと健康保険証の一体化について尋ねたいと思います。現行の健康保険証を二〇二四年秋に廃止を…", "…と思います。現行の健康保険証を二〇二四年秋に廃止をし、マイナカードと一体化したマイナ保険証への切替えを目指す政府方針の発表に対し、特に高齢者…", "…義務化することで普及促進を図るという政府の考えは十分に理解できます。一体化により就職や離職のたびに保険証を切り替える必要がなくなる、あるいは…", "…取組が必要です。そこで、厚生労働省に伺います。マイナカードと保険証の一体化のメリット、これを国民の皆様にきちんと御理解をいただくことが何より…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014260X00220221027/128", "sentence": []}]}]}]