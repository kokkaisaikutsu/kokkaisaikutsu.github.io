[{"date": "2023-06-01", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/124", "sentence": ["…なところなんですけれども。血液製剤の確保に不安があるために、緊急時の供血使用というリスクを冒しながら体制確保に取り組んでいることが先日の地元…", "…じられていました。報道によりますと、先月二十二日、奄美大島地区緊急時供血者登録制度連絡協議会が開かれたそうです。この協議会は、献血に協力をす…", "…用として供給される製剤に対して、医師の責任の下で院内採血される緊急時供血は生血のために感染症の有無が検査されていないなどのリスクを抱えます。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01720230601/128", "sentence": []}]}]}]