[{"date": "2023-02-16", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/6", "sentence": ["…い申し上げます。続きまして、地方税法等の一部を改正する法律案の自動車税制についてお伺いをいたします。国にとって、今や自動車は生活の必需品であ…", "…いてもこれら目標に向けた取組が行われているわけであります。ですから、税制についてもカーボンニュートラルの目標の実現に積極的に貢献すべきであり…", "…体の重要な財源でもあるということであります。これらを踏まえて、今回の税制改正における車体課税の改正の内容及び考え方を中川政務官にお伺いいたし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/8", "sentence": ["…聞いております。先ほども申し上げましたが、納税者の納得感がある公平な税制を守っていかなければ、やはり信頼をいただけないというふうに思うわけで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/22", "sentence": []}]}]}]