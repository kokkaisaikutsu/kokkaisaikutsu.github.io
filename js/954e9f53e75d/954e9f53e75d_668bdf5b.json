[{"date": "2022-03-29", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/6", "sentence": ["…ってこない、そういうトラブルの話もあったりしました。あるいは、これは警察行政になりますけれども、ストーカーに追われているような気がする、何と…", "…、ストーカーに追われているような気がする、何とかしてほしいけれども、警察に行ってもなかなかねという話があったり、もう一つは、今度は民事になり…", "…かない方もいらっしゃいます。もう一つ、よくお話で聞いたのは、やはり、警察とか国とか県のふだん行き来のないような役所には敷居が高くて行きにくい…", "…ということで、市民くらしの相談課というんですけれども、職員に加えて、警察のＯＢとか、あるいは弁護士さんや司法書士さんと連携を取って、何でもい…", "…相談に来てください、あとは振り分けを市の方で行って、これは刑事だから警察の方におつなぎしましょう、これは消費相談だから消費者生活センターの方…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804536X00320220329/14", "sentence": []}]}]}, {"date": "2023-02-16", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/22", "sentence": ["…惑われます。国に電話する人もいれば、県に電話する人、市に電話する人、警察に電話する人、あるいは水道局とか消防に電話する人、それぞれ必死の思い…"]}]}]}]