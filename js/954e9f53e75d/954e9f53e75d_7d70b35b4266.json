[{"date": "2022-05-11", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/12", "sentence": ["…も寄与するよう、よろしくお願いしたいと思います。次に、ガス事業者間の災害時の連携強化について伺います。本改正案で、災害時におけるガス事業者間…", "…。次に、ガス事業者間の災害時の連携強化について伺います。本改正案で、災害時におけるガス事業者間の連携計画の事前策定を義務づけられるということ…", "…、既に二〇二〇年には電気事業法が改正されて、一般送配電事業者に対し、災害時連携計画を作成、届出する制度ができているわけであります。そこでお伺…", "…が、なぜ前回の電気事業法改正時に、同じ重要なライフラインであるガス分野でも災害時連携計画の策定を義務づけなかったのか、御所見をお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804080X01420220511/14", "sentence": []}]}]}, {"date": "2023-02-16", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/18", "sentence": ["…必要があります。防災・減災のための取組の推進に当たりましては、大規模災害時の防災・減災対策に必要な施設の設備や、災害への対応能力の向上を図る…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/20", "sentence": ["…官は、総務省の中で行政相談等を担当されているものと承知しております。災害時には、困り事を抱えた多くの被災者からの相談があると思っております。…", "…は、困り事を抱えた多くの被災者からの相談があると思っております。この災害時における行政相談の取組について、長谷川政務官にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104601X00420230216/22", "sentence": []}]}]}]