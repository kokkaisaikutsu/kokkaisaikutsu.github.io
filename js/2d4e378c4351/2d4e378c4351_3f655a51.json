[{"date": "2021-06-09", "meeting": [{"meeting_name": "参議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/12", "sentence": ["…正国民投票という国の最高法規に関わるものでありますので、できるだけ各政党間の幅広い合意を形成する必要があると考えます。今後、丁寧な議論を行っ…", "…するのか、訓示的な規定にとどめるのか、第二に、出し手の、広告主である政党側の自主規制、第三に、受け手である事業者側の自主的な取組を推進しつつ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/37", "sentence": ["…条項に基づいて、これからどのような規制が必要なのか、また適当なのか、政党間で真摯な議論を踏まえた上で幅広い合意を形成する必要があると考えてい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/41", "sentence": ["…きましては不要とも確定的には申し上げられませんので、これは附則の四条二項に基づきまして、今後政党間で真摯な議論が必要だというふうに思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414183X00520210609/110", "sentence": []}]}]}]