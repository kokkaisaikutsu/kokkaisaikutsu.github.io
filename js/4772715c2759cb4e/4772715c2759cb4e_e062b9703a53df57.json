[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/58", "sentence": ["…い。これ徳永委員も言われたと思うんですけれども。で、その中でも復興拠点区域、まあ帰還困難区域でも復興拠点区域、これについては、この会計検査院…", "…ですけれども。で、その中でも復興拠点区域、まあ帰還困難区域でも復興拠点区域、これについては、この会計検査院の報告、これ二枚目の資料に書いてあ…", "…きにも聞いたんですけれども、やはりだからこれもやらないと、特にその拠点区域というのは、もう線量が高いことは分かっているわけですよね、データと…", "…ータとして。だとしたら、これは本当に、最終処分に向けた過程で、この拠点区域内のどうやって再生利用をやるかというのは物すごく大きな問題になって…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/60", "sentence": ["○片山大介君大臣、その拠点区域内の量というのは今後入れていくということでよろしいですかね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/77", "sentence": []}]}]}]