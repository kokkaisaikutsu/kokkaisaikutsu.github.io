[{"date": "2023-04-20", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/51", "sentence": ["…と私、消防団について話を聞きたいと思います。消防団については、もう地域防災の要なんですけど、御存じのように、もう団員の数がどんどん減っていっ…", "…、そして、これが減っていることによって何が起きているかと。やっぱり地域防災の懸念が起きていて、それで、各自治体のその消防団の定員の数がどんど…", "…例改正まで行っている自治体が出てきているんですけど、やっぱりこれは地域防災の低下につながるとは思うんですが、そこの懸念、どのように考えている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00920230420/57", "sentence": ["○片山大介君消防団員は本当に地域防災の要だと思いますので、是非頑張って増やしていっていただきたいと思います。終わります。"]}]}]}]