[{"date": "2022-04-20", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815254X01820220420/14", "sentence": ["…れば、人事評価をより公正に行うためにも、研修の成果を客観的に評価する仕組みが必要ではありませんか。今後、研修制度を更に改善していくためにも必…", "…です。給特法の見直しに当たっては、個々の教員の努力や実績が反映される仕組みを考慮すべきと考えますが、現在文科省が検討している給特法の見直しの…"]}]}]}, {"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/127", "sentence": ["…、この国会で、国際卓越研究大学を認定して大学ファンドによる助成を行う仕組みの法案が今こうやって議論されている。まあ、恐らく成立するんでしょう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/129", "sentence": ["…募集打切りにするのか、それとも、あとほかにもいいのが出てきたらそれ入れ替えたりするのか、ちょっとそこの考え方、仕組みを教えていただけますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/149", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X01020220517/157", "sentence": []}]}]}]