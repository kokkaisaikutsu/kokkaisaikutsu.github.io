[{"date": "2021-06-08", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/58", "sentence": ["…ども、やはりだからこれもやらないと、特にその拠点区域というのは、もう線量が高いことは分かっているわけですよね、データとして。だとしたら、これ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/62", "sentence": ["…会計検査院では、私、もう一つ気になっているのがあって、福島県内で空間線量の測定をやっているんですよね。五十六万地点でやっている。そのうちの一…", "…っている。そのうちの一万三千地点で、除染する前よりも除染した後の方が線量が上がっているんですよね。それで、これを環境省にどういうことなんだろ…", "…となんだろうというふうに聞いたら、これ例えば自然現象か何かでちょっと線量が流れたというか、そういうことがあるんじゃないかみたいなことを言った…", "…を言ったんですが、更にこのデータ見てみると、除染前よりも除染後の方が線量が上がって、さらに、その後のモニタリングで更に上がっていっているんで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X01520210608/77", "sentence": []}]}]}]