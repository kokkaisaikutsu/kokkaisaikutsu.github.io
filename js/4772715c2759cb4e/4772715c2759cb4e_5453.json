[{"date": "2021-04-22", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/92", "sentence": ["…やっているかなと思うのと、それで、実は環境省、七年前に国立公園における協働型管理運営の推進という通知を出していて、その中で、総合型協議会を通…", "…園における協働型管理運営の推進という通知を出していて、その中で、総合型協議会を通じていろいろと国立公園のビジョン、管理運営の方針、行動計画な…", "…回打ち出しているんですね。それで、今回はこの新しい計画の下にまた新たに協議会をつくってとかという前提をつくっているんですけれども、これ同じよ…", "…同じようなことを七年前にもやっていて、そのときの、七年前に求めた総合型協議会というのは、この七年間で十三しかできていないようなんですけれども…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414006X00720210422/110", "sentence": []}]}]}]