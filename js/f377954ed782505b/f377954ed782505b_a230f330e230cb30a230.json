[{"date": "2020-11-17", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/117", "sentence": ["…余りと、大量な処理を必要とされます。天候が優れない時期などは強烈なアンモニア臭を発生して、先ほどからありますその農泊ですね、農泊事業という周…", "…温、加熱乾燥させて水分を三〇％以下に減少します。約四時間で微生物がアンモニアを分解して、臭いのしないさらさらの土状になります。おがくず代わり…", "…視察に行ったことがございますが、現地に行かないと分からないほど牛のアンモニア臭というのはすごくて、生きたもののふん尿を処理するというのがいか…", "…くて、生きたもののふん尿を処理するというのがいかに重労働であるか、アンモニア臭というのがどのくらいきついのかも体験してまいりました。この臭い…", "…は日本国はアピールすることができるということにつながっていきます。アンモニアを分解する微生物は、北海道の場合ではクマザサ生息地から大量に入手…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/121", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/123", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00220201117/140", "sentence": []}]}]}]