[{"date": "2021-04-20", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/83", "sentence": ["…二十四年度の設立時点において、既に役員十名、職員三十六名、四十六名の定員が確保されておりました。実際に設立の翌年度には四十五人の役職、役職員…", "…というんですね、が雇用されておりまして、設立当時にこのような大規模な定員を確保して雇用したことは、投資規模に応じて必要な組織体制の整備を図っ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415007X00920210420/98", "sentence": []}]}]}, {"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/210", "sentence": ["…ですが、ちょっと質問を変えさせていただきます。一時保護所の今の言った定員について質問させていただきます。一時保護のための一時保護所という施設…", "…で、置き去りとか非行などについて子供を一時的に預かると、保護するという施設でございます。全国に何か所あって、定員は今何人でございましょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/214", "sentence": ["…はスーパーバイザーであって、ここに、一時保護所のところに来て、そこの定員の方たちが実際に子供たちの面倒を見ると