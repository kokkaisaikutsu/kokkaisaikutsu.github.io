[{"date": "2020-11-26", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/67", "sentence": ["…。なぜ今反対運動が起きているのかという、その反対の理由を把握しないと誤解も解けません。それがコミュニケーションなので、教えてください。大臣は…", "…、教えてください。大臣は、この反対の理由ですね、何が反対されていて、誤解されているということじゃなくて反対の理由というのが何だとお心の中で把…", "…られるのか。種苗法の審議を今国会でやることになっていますが、反対派の誤解が解けないのは農水省の努力不足ではないかと私は思うんですね。誤解を解…", "…派の誤解が解けないのは農水省の努力不足ではないかと私は思うんですね。誤解を解くキャンペーンというのは、ホームページで、ツールで読んでください…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120315007X00420201126/169", "sentence": []}]}]}]