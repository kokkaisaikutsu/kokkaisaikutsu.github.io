[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/331", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/333", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/335", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/337", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/339", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/341", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/343", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/345", "sentence": ["…なリーダーが選ばれても他国への侵略ができないようにするための条項が憲法九条なのですと、きっぱりとツイッターで書かれた方がいらっしゃいます。か…", "…本維新の会の松井代表はこれに反論をされておられました。日本の平和は憲法九条の文言があるから守られてきたんだという、こういうコメントなんですが…", "…なんですが。総理にお伺いします。総理は既に何度も聞かれていることだとは存じておりますが、憲法九条についてどのようなお考えかをお述べください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/347", "sentence": ["○石井苗子君ありがとうございます。私も、もちろん憲法九条は大切ですが、大切ですが、日米安保の下できちんと防衛力を整備してきたことで日本の平和…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/349", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/351", "sentence": []}]}]}]