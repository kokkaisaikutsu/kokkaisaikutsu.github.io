[{"date": "2021-06-02", "meeting": [{"meeting_name": "参議院 災害対策特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414339X00720210602/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414339X00720210602/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414339X00720210602/21", "sentence": ["…と痛感したところであります。予算面では、緊急三か年対策が、本年度の補正予算を皮切りとしまして、五か年加速化対策として十五兆円規模で継続される…", "…対策、私の地元の兵庫県の方でも、皆さん、自治体の方も喜んでいます。補正予算でのスタートということで、地元では、継続的な予算が担保されていない…", "…されたことは私自身も評価したいと思いますが、一方で心配しているのは補正予算の使いにくさであります。私も、兵庫県議時代に補正予算の使いにくさに…", "…配しているのは補正予算の使いにくさであります。私も、兵庫県議時代に補正予算の使いにくさについてはよく耳にしていますし、繰越しの関係で執行期間…", "…い、発注の手続に時間を要するなどでした。その上で、一月末に成立した補正予算では年度末まで実質二か月ぐらいしかありません。県議会での補正予算の…", "…た補正予算では年度末まで実質二か月ぐらいしかありません。県議会での補正予算の審議や工事に必要な期間を考えれば、実態としては、そのほとんどの予…", "…越しまで含めた最大に確保できる事業実施期間は、当初予算に比べると、補正予算の場合は明らかに短くなってしまいます。地元住民の丁重な対応のために…", "…ますが、来年度の当初予算と一体的に切れ目なく取組を進める観点から、補正予算については明許繰越しと事故繰越しを行った上で更に四年目へと繰り越す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414339X00720210602/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414339X00720210602/26", "sentence": []}]}]}, {"date": "2023-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00620230307/32", "sentence": []}, {