[{"date": "2021-03-22", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/20", "sentence": ["…〇％ほどの減収に収まっております。こうした状況を踏まえまして、先ほど大臣も触れられておりましたが、経産省の既存の補助金とか文化庁の積極的な公…", "…者及び実演家への支援策をどのように考えているのか、また文化、芸術、エンタメ業界の社会的意義について梶山大臣の御見解をお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/22", "sentence": ["…は人間だということも改めて大事にしていきたいなと思っています。先ほど大臣が指摘されました、答弁されましたように、今度はちょっとＪ―ＬＯＤｌｉ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/24", "sentence": ["○加田裕之君江島副大臣、ありがとうございます。やはり、そのスタッフ体制を強化する、増強するということ、それからまた概算払という形、もちろん、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00120210322/34", "sentence": []}]}]}, {"date": "2021-05-13", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/7", "sentence": ["…自由民主党、加田裕之でございます。まず初めに、コロナ対策について梶山大臣にお伺いしたいんですけれども、昨日から一部地域では緊急事態宣言の延長…", "…その他の今回の緊急事態宣言により影響を受ける事業者への支援策について、緊急の対策を強く求めたいと考えますが、大臣の御所見をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414080X00420210513/19", "sentence": []}]}]}]