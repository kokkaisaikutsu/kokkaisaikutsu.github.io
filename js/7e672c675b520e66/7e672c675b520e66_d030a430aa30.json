[{"date": "2022-11-28", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/217", "sentence": ["…税対象として軽油引取税を課す仕組みとしております。このため、御指摘のバイオディーゼル燃料が混和された軽油についても、課税対象となる引取りの時…", "…しておりますが、御指摘のような特例措置の可能性については、混和されたバイオディーゼル燃料の数量を正確に把握する仕組みが必須であること、重油や…", "…では、脱炭素社会を目指し、再生可能エネルギーの供給体制の強化や地域のバイオマス利活用促進に貢献するために、特定の事業者との間で、製造、流通過…", "…事業者との間で、製造、流通過程を正確に把握する仕組みを構築した上で、バイオディーゼル燃料と混和した軽油のうち、バイオディーゼル燃料相当分につ…", "…する仕組みを構築した上で、バイオディーゼル燃料と混和した軽油のうち、バイオディーゼル燃料相当分について軽油引取税を免除する独自の制度を設けて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00720221128/336", "sentence": []}]}, {"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00620221128/109", "sentence": []}, {"url": "https://k