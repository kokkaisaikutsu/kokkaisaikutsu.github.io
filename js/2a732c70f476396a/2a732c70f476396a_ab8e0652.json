[{"date": "2023-05-19", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/82", "sentence": ["…りまして、法令遵守も当然の義務です。マイナンバーカードが顔写真付きの身分証であることが義務化の障害であるということは政府はこれまで説明してき…", "…とは政府はこれまで説明してきていますが、では反対に、写真なしで有効な身分証などあり得るのでしょうか。現在、運転免許証やパスポートを持たない国…", "…スポートを持たない国民も一定数いるわけですが、日常生活において写真付身分証明書を求められる機会は銀行口座の開設や確定申告を始めとして頻繁にあ…", "…座の開設や確定申告を始めとして頻繁にありまして、そのたびに写真付きの身分証がない場合には複数の身分証を求められて余計に手間が掛かるわけです。…", "…して頻繁にありまして、そのたびに写真付きの身分証がない場合には複数の身分証を求められて余計に手間が掛かるわけです。この点を踏まえて、なぜマイ…", "…かるわけです。この点を踏まえて、なぜマイナンバーカードが顔写真付きの身分証であることが義務化の障害なのか、分かりやすく説明をお願いいたします…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X