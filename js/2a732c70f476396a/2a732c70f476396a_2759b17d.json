[{"date": "2023-07-26", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/89", "sentence": ["…政権時代に、政府・与党社会保障改革検討本部が作成した社会保障・税番号大綱というのがあるんです。この五ページを抜き書きしましたので、御覧になっ…", "…載がありますね。また、マイナ保険証についても、資料一の三枚目、同じく大綱の、番号制度で何ができるかを説明した部分があります。こういう記載があ…", "…と。これって、あれですね、立憲民主党の方々いらっしゃるけれども、この大綱に書かれていることと、今、立憲民主党がやっていることというのは、あら…", "…いただいて、そして話を進めたいと思うんですけれども。この二〇〇九年の大綱に記載されている方針は、現在でも継続して今回のマイナカードの基になっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/110", "sentence": []}]}]}]