[{"date": "2022-12-06", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/81", "sentence": ["…でもいいし、あるいは絵はがきみたいな、そういう映像でもいいんですが、風車が建っている、それから太陽光パネルもある。そういうときに、牛が、羊で…", "…ど、放牧されている。そこに四角くコンクリートがうがってあって、そこに風車が建っていると。これごく普通の田園風景ですが、これ農業が行われている…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/89", "sentence": ["…ロワットのエリアをつくって、そこに港から一気に攻め込んでいく、そこで風車を建てるというふうに普通は考える。ところが、日本の案件はその指定区域…", "…って、そこに兵たんを造っていく、そうすると、いろんな工場がそこに押し寄せる、そして何百もの風車を造る、これはヨーロッパ全部そうなっています。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121014080X00520221206/91", "sentence": []}]}]}]