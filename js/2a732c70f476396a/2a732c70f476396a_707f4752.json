[{"date": "2023-06-06", "meeting": [{"meeting_name": "参議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/103", "sentence": ["○猪瀬直樹君続いて、外国公務員贈賄に対する罰則強化について伺います。今回、ＯＥＣＤからの勧告を踏まえて罰則を強化するということなんですが、昔…", "…に対する罰則強化について伺います。今回、ＯＥＣＤからの勧告を踏まえて罰則を強化するということなんですが、昔の昭和の時代には、アジア、アフリカ…", "…たのでしょうか。また、その後、現在までの世界的な規制強化の経緯、また現状における諸外国との罰則レベルの比較について、西村大臣にお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/105", "sentence": ["…ような事例は、今でも一部の国では見受けられると思うんですね。このような事例も今回強化された罰則の対象となるんでしょうか。これは参考人ですね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/107", "sentence": ["○猪瀬直樹君こういう贈収賄を防いでいくためには、罰則の強化だけではなくて、諸外国政府への働きかけや海外で活動する日本企業へのサポートなど、様…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114080X01420230606/111", "sentence": []}]}]}]