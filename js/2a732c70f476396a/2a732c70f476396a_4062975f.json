[{"date": "2023-04-28", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X01920230428/13", "sentence": ["…歩みが遅過ぎると言わざるを得ません。総務省のホームページには、国民の所得状況が把握しやすくなり、税や社会保障の負担を不当に免れることや不正受…", "…ているだけに見えます。総務省が掲げる公平公正な社会の実現、そのための所得状況等の把握をいつどのように行っていくのか、その計画について、責任者…", "…が本丸で、十分に活用が進んでいるとは言えません。現在の地方税に基づく所得情報は、当該年から半年、一年程度経過したものとなり、迅速な情報取得を…", "…取得を行うことが難しいが、国税庁及び地方税当局との情報連携を強化し、所得把握の早期化を検討し、支援金などの迅速な給付についてつなげるべきでは…", "…どの迅速な給付についてつなげるべきではないのか。また、現在利用可能な所得情報は他の情報に十分ひも付いておらず、きめ細かな制度設計等を行うこと…", "…で活用された住民税非課税情報だけでなく、制度設計や給付において、世帯所得も含め、より詳細な情報も活用できるよう制度や体制の整備を図るべきと思…", "…いうふうに答弁していますが、中央及び地方税当局との情報連携強化や世帯所得も含めた詳細な情報を活用できるよう、今後仮に他省庁が改革の障壁となる…"]}]}]}, {"date": "2023-05-19", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/82", "sentence": ["…と思うんですがね。マイナンバーカード自体は、全国民に付与され、国民の所得の把握にも活用されているわけです。そもそも、教育、勤労、納税は国民の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X01120230519/104", "se