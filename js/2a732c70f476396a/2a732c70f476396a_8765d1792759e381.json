[{"date": "2022-10-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/125", "sentence": ["…アルがあるんだけれど、これ必要ですか。これは、まず、これ国家の根本に関わるから、総理にちょっとお尋ねしたいです。文科大臣にも聞きますけどね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/127", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/131", "sentence": ["…アルは駄目だとチェックするのが大臣の、政治家の仕事なんですよ。前の文科大臣の末松さんは、外で体育やるときにはマスク要らないってやったんですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/147", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00220221020/152", "sentence": []}]}]}, {"date": "2023-03-02", "meet