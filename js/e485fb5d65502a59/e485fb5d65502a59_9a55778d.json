[{"date": "2022-02-09", "meeting": [{"meeting_name": "衆議院 財務金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/130", "sentence": ["…、一方で、祖父母や親から子へ、高齢者から若年層に資金移動を促し消費を喚起するという観点からは、この制度は有用であると考えております。先ほどの…", "…贈与税の減税など、世代間の資金移動を促すような、そしてそれに伴って消費の喚起を活発化させる、そういったような施策は検討しているのでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804376X00320220209/132", "sentence": ["…います。消費が停滞する現在、高齢者層から若年層に資金移動を促し消費を喚起することは、低迷する日本経済へ十分な刺激策となり得ると考えております…"]}]}]}]