[{"date": "2020-11-11", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/155", "sentence": ["…、九月までに百八十一名、コロナの患者さんを受け入れてくださいました。公立病院ではありません。ＪＡですから公的病院に分類されるところと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/157", "sentence": ["…に及びます。神奈川県下でコロナの患者さんを受け入れた病院は三十八。国公立が十七、公的あるいは民間が二十一です。公的あるいは公立であれば、特に…", "…院は三十八。国公立が十七、公的あるいは民間が二十一です。公的あるいは公立であれば、特に公立であれば、国や市町村、自治体の補助もというか、それ…", "…が十七、公的あるいは民間が二十一です。公的あるいは公立であれば、特に公立であれば、国や市町村、自治体の補助もというか、それも大変ですけれども…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304260X00220201111/171", "sentence": []}]}]}]