[{"date": "2024-04-26", "meeting": [{"meeting_name": "衆議院 経済産業委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/50", "sentence": ["…、サプライチェーン全体にその効果を波及させることが必要であると考えられますが、経済産業省としてどのように考えているのか、お尋ねをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/56", "sentence": ["…いくと考えられますが、スタートアップを支援する意義と、法案で講ずる措置によりどのような効果を狙っているのか、経済産業省の見解をお伺いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304080X01320240426/58", "sentence": []}]}]}, {"date": "2024-05-24", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/4", "sentence": ["…ルの実現に向けてしっかり取り組んでいく必要があると考えております。経済産業省が先日開催した基本政策分科会において、エネルギー基本計画の見直し…", "…風力について、国が第六次エネルギー基本計画に掲げた導入目標達成に向けた現在の進捗と、これまでの評価について、経済産業省にお伺いをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/6", "sentence": ["…喜ばしいことであります。そこで、洋上風力に関して、地域経済の発展や、関連する産業基盤形成に向けた国の取組状況を経済産業省にお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/12", "sentence": ["…を実施する予定と聞いておりますが、国としてどのような課題を解決していきたいと考えて実証しようとするのか。経済産業省に見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/14", "sentence": ["…いて、計画倒れせず、しっかりと実現していくことが重要であると考えます。現在の取組状況と今後の見通しについて、経済産業省にお尋ねをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/16", "sentence": []}]}]}]