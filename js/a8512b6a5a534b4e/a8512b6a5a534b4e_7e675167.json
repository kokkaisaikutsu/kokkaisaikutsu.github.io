[{"date": "2024-05-24", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/8", "sentence": ["…面積を有する我が国のＥＥＺにおける経済活動を後押しする枠組みとなりますが、本法案の我が国海洋政策に与える意義を松村大臣にお尋ねをいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/10", "sentence": ["○冨樫委員松村大臣、ありがとうございます。ＥＥＺは、広大で、沿岸とはかなり離れていることから、洋上風力を進める上で様々な課題があると考えます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121304889X01620240524/16", "sentence": ["…で大変大事な法律であります。是非よろしくお願いを申し上げながら、終わりたいと思います。松村大臣、頑張ってください。よろしくお願いいたします。"]}]}]}]