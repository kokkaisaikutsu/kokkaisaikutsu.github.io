[{"date": "2022-04-26", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/126", "sentence": ["…Ｔベンチャー企業なども含まれているわけでして、これ国内に限らず、外へ流出、いわゆる悪意ある大企業が中小企業と連携をして、そして最先端技術が売…", "…る大企業が中小企業と連携をして、そして最先端技術が売買又はこの技術が流出してしまう、こういう動きをどこまで調査することができるのか。仮にこの…", "…きるのか。仮にこの日本の最先端技術がこれらの悪意あるそういった企業に流出した場合は、その国で例えば兵器となって使用されてしまうという事態に陥…", "…あります。この技術の民生利用、どのようにチェックをして、我が国の技術流出を守るために何が必要なのかという視点でこの質問させていただきました。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/129", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/131", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X01320220426/139", "sentence": []}]}]}]