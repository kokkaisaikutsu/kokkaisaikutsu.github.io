[{"date": "2023-04-21", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X01720230421/11", "sentence": ["…金一千万円超の法人の事業者には、フリーランスに製造委託等をする場合、書面の交付義務や禁止行為等の規制が及んでおりました。これに対し本法律案で…", "…に業務委託を行う事業者に対し、禁止行為や就業環境整備の規制、さらに、書面又は電磁的方法による契約内容の明示義務は、従業員を雇用していない事業…"]}]}]}, {"date": "2023-04-25", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/152", "sentence": ["…していっていただきたいというふうに思います。下請法では、発注に際して書面の交付が原則で、下請事業者の承諾があった場合には電磁的方法も可能とさ…", "…た場合には電磁的方法も可能とされているということです。本法律案では、書面又は電磁的方法のどちらも並列な扱いとされるなど、この柔軟な取扱いが可…", "…請法と本法律案の双方が適用対象の取引の場合、これはどうなるんでしょうか。あくまで書面の交付が原則となるのか、お聞かせいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01120230425/163", "sentence": []}]}]}]