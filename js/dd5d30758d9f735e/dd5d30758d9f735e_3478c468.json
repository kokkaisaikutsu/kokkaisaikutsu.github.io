[{"date": "2022-05-17", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/79", "sentence": ["○川田龍平君それでは、ワクチン破棄の可能性について質問させていただきます。これ、ファイザー、モデルナ両社製のワクチンの使用状況は、一回、二回…", "…に報道では、四月には大阪市がモデルナ製ワクチン八万回を使用期限切れで破棄を発表しましたし、先週十三日にも京都市でも八万回分の破棄の見通しを発…", "…用期限切れで破棄を発表しましたし、先週十三日にも京都市でも八万回分の破棄の見通しを発表しました。現在の三回目の接種状況が進まない中で、その他…", "…ミュレーションはできているのでしょうか。当然、使用期限が切れるものは破棄しなければならないと思います。接種を希望する方に対しては有効期限内の…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/81", "sentence": ["…状況であると思われます。有効期限、これいつまでなのでしょうか。このまま行くと大量破棄という可能性もあると思いますが、厚労省の見解を求めます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/85", "sentence": ["…議論を経ずに使用してきたことが、チェック機能が働かなくなりワクチンの破棄ということにもつながってきているのではないかと思うところです。緊急購…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01420220517/96", "sentence": []}]}]}]