[{"date": "2022-05-24", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/95", "sentence": ["…園には、学校保健安全法により安全計画の策定が義務付けられていますが、保育所についてはこうした事件を、事故を防止するための安全計画がありません…", "…の小西洋之議員が昨年の十二月に本会議の代表質問でこの問題を取り上げ、保育所における安全計画策定に係る法改正の必要性を訴えてまいりました。残念…", "…修正案を提出するに至り、修正議決されました。今回の衆議院修正により、保育所を含む児童福祉施設等に対し、安全計画の策定が義務化されることとなり…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/116", "sentence": []}]}]}, {"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/1