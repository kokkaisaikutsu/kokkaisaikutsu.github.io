[{"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/65", "sentence": ["…守せずに、当初の仕様書、落札額のままで立地条件に適合しない綾瀬倉庫の賃貸契約を締結したことが明らかとなっています。また、当初の契約は平成二十…", "…、仕様書の立地条件に適合しないにもかかわらず引き続き一年間綾瀬倉庫を賃貸借する延長契約を締結したこと、さらに、綾瀬倉庫では想定される洪水が発…", "…されないと判明した際に、改めて入札せずに仕様書よりも立地条件の悪い綾瀬倉庫の賃貸契約を落札額のままで締結した具体的な経緯を説明してください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/82", "sentence": []}]}]}]