[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/67", "sentence": ["○川田龍平君厚労省の林課長は、ＥＴＶ特集、さきの番組で、監査は機能しているのかという質問に対して次のように述べています。私たちは、直接監査す…", "…しているのかという質問に対して次のように述べています。私たちは、直接監査する立場というよりは、都道府県に監査の基本的な枠組みをお伝えして、し…", "…うに述べています。私たちは、直接監査する立場というよりは、都道府県に監査の基本的な枠組みをお伝えして、しっかりやってくださいとお伝えする立場…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X00220230309/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X0022023