[{"date": "2021-08-05", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/29", "sentence": ["…する質問をさせていただきたいと思います。あした八月六日、七十六回目の広島原爆の日ですが、広島への原爆投下直後、いわゆる黒い雨を浴びた住民八十…", "…だきたいと思います。あした八月六日、七十六回目の広島原爆の日ですが、広島への原爆投下直後、いわゆる黒い雨を浴びた住民八十四人全員を被爆者と認…", "…を浴びた住民八十四人全員を被爆者と認め、被爆者健康手帳の交付を命じた広島高裁の判決に対し、国は上告を断念して、七月二十九日に判決が確定しまし…", "…点から、原告だけでなく、原告と同じように黒い雨を浴びた人たち、そして広島だけでなく長崎で原爆の被害に遭われた方々も高裁判決と同じ水準で救済す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X00220210805/49", "sentence": []}]}]}]