[{"date": "2022-04-26", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/64", "sentence": ["…と緊急承認制度について改めて確認をさせてください。条件付承認制度は、希少疾病用医薬品などで検証的な大規模試験の実施が困難な医薬品を早期に実用…", "…るというものであり、その有効性確認は基本は第三相試験であるが、ただし希少疾病では第二相で有効性が判断される場合があり、承認する制度と理解して…", "…大規模な事象のときであると認識していますので、緊急承認される医薬品は希少疾病用医薬品は対象外になると思いますが、厚生労働省の見解を求めます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01020220426/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X0102022