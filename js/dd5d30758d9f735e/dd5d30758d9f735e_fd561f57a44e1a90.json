[{"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/42", "sentence": ["…水大臣には先般予算委員会でお聞きいたしましたので、本日は文科大臣と国土交通大臣、この日本の食の安全保障における今の現状、それぞれのお立場でど…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/45", "sentence": ["…実施しておりますが、なかなか空き家の数が減少しないという現状です。国土交通大臣は、ダーチャというロシアの菜園付住宅、御存じでしょうか。平日が…", "…ながると思うんですが、省庁横断の政策の連携が重要になってきますので、是非、国土交通大臣、それから農林水産大臣の見解をお聞きしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/65", "sentence": []}]}]}, {"date": "2022-05-16", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/80", "sentence": ["○川田龍平君最後、国土交通大臣、三問まとめて質問させていただきます。国土交通省、各空港等に常設している非常用発電設備の代替として、令和二年度…", "…川田龍平君最後、国土交通大臣、三問まとめて質問させていただきます。国土交通省、各空港等に常設している非常用発電設備の代替として、令和二年度の…", "…講じた上で、この可搬形の電源設備を適切に保管するためのことについての国土交通大臣の是非認識と今後の検討について教えていただければと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00820220516/82", "sentence": []}]}]}]