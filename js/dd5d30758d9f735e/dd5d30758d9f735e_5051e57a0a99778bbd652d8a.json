[{"date": "2020-12-03", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/118", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/122", "sentence": ["…と思います。次に、三番の質問に入らせていただきます。厚生労働省の児童養護施設入所児童等調査によると、お配りした資料によると、平成三十年二月一…", "…、平成三十年二月一日現在で、心身に何らかの障害を持っている児童は児童養護施設において三六・七％に上ります。また、親から虐待を受けた経験のある…", "…ります。また、親から虐待を受けた経験のある子は六五・六％に上り、児童養護施設に入所する理由が、放任・怠惰、虐待・酷使、棄児、養育拒否を合算、…", "…イサービスなども再申請が必要となります。今年の九月に東京都にある児童養護施設で働く自立支援コーディネーターからお話を伺ったところによれば、親…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/126", "sentence": ["○川田龍平君都内の児童養護施設で育った子供が退所後に近所の障害者グループホームに入所しようとしたところ、親の居住地が都外である、いわゆる都外…", "…運営費加算が入らないとして入所を断られたとの例もあると聞きます。児童養護施設に入所する子供の中には虐待を受けて親から離れた子供も多いというの…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/128", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314260X00720201203/133", "sentence": []}]}]}, {"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/113", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/117", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01820220607/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X0182022060