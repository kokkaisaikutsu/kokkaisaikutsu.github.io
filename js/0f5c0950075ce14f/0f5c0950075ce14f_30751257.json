[{"date": "2022-05-26", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/26", "sentence": ["…、幾つか具体的な議論をさせていただきたいと思います。まずは、デジタル田園都市国家構想であります。通称デジ田というふうに言われておりますが、ま…", "…に頼らずに自走化をすることができます。そういったことがまさにデジタル田園都市国家構想の中で様々既に起ころうとしていて、そして、この交付金、既…", "…べきなのではないかというふうに思います。政府の中で、これからデジタル田園都市国家構想総合戦略を打ち立て、それに基づいて、今、第二期のまち・ひ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/28", "sentence": ["…ありがとうございます。このデジ田の大本は、大平正芳元総理が唱えられた田園都市国家構想でございます。非常に先見性があることをおっしゃっていて、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805261X01920220526/44", "sentence": []}]}]}]