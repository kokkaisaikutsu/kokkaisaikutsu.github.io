l.go.jp/txt/121114889X01320230509/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/92", "sentence": []}]}]}]