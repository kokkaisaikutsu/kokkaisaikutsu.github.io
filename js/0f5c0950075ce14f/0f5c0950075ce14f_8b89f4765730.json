67X00520230411/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105367X00520230411/175", "sentence": []}]}]}, {"date": "2023-04-21", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/8", "sentence": ["…れを支援をするということを重点計画に書いてございます。重点計画自体も見直しておりますし、実態調査も二回ほどさせていただきました。そういう意味…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/10", "sentence": ["…、この重点計画の継続性、非常に大切だと思っております。他方で、不断の見直しも重要でございまして、重点計画に記載する具体の施策の内容につきまし…", "…での議論の内容などを踏まえ、現行の重点計画の記載内容から必要に応じて見直しを行ったものが記載されることになるというふうにも考えてございます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/12", "sentence": ["…りますことから、本法律案では、孤独・孤立対策の重点計画全体についての見直しの期限などを確定的に定めることはいたしておりません。今後設置するこ…", "…となる孤独・孤立対策推進本部におきまして、重点計画の内容と併せて、こうした見直しの考え方についても決定をさせていただきたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/22", "sentence": ["○小倉国務大臣この見直し期間の話でございます。法案の附則第三条で、御指摘のとおり五年となっております。これは、ほかの基本法的な性質を持つ法律…", "…。これは、ほかの基本法的な性質を持つ法律の例も踏まえまして、五年後に見直しを検討することとしているところであります。その後の見直しをどうする…", "…て、五年後に見直しを検討することとしているところであります。その後の見直しをどうするかということでありますが、それにつきましては、施行後の施…", "…いうことでありますが、それにつきましては、施行後の施策の実施状況等も踏まえまして、見直しをどう行うか、しっかり判断をしたいと考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104889X01520230421/37