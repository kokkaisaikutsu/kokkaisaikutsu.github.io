事さを尊重していきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/105", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805124X01220220603/109", "sentence": []}, {"url": 