[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/148", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/150", "sentence": ["…施術所については、その名称が例えば接骨院であろうが整骨院であろうが、保健所に開設届を出して、その受理された名前でしか営業できないんですよね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/152", "sentence": ["○大島九州男君もう一回聞きますよ。いいですか。あのね、保健所に開設届を出している受理された名前以外で営業することはできますか、できませんか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/154", "sentence": ["…どっちがあれかといったら、最近はもう整骨院の方が多いんですよ、新たに開設する人は、これ常識。じゃ、保健所が受け取ってそれを認めているわけです…", "…せるなと。だから、引っ越すときとか移転のときには、じゃ、保健所にその開設届を出し直して、名前を整骨院じゃ駄目だというふうなことを言う権利なん…", "…う権利なんて何もないですよ。だから、整骨院の先生たちは、保健所にその開設の変更届を出さなければそのまま整骨院って使えばいいんです。そしてまた…", "…ばそのまま整骨院って使えばいいんです。そしてまた、整骨院という名前で開設届を保健所が、出して受理しないというところがあるなら、それは今まで受…"]}]}]}, {"date": "2023-05-09", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/106", "sentence": ["…議論で、国民が理解しにくく、整形などと紛らわしいと、業界としては新規開設者が整骨院と称することができないことはやむを得ないといった意見をいた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X01320230509/116", "sentence"