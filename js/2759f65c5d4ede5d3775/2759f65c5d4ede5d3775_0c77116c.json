[{"date": "2023-03-09", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/313", "sentence": ["…というふうに思っております。沖縄の子供を取り巻く環境は、一人当たりの県民所得が全国最下位であったり、また母子世帯の出現率や高等学校等の進学率…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/315", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/317", "sentence": ["…いろんなお金をたくさん出してきていると思うんですが、それでもってその県民の所得が低いというのは、まあお金は出しているけど県民に行き渡っていな…", "…それでもってその県民の所得が低いというのは、まあお金は出しているけど県民に行き渡っていないという結果なんだろうなと。昔から私は一つの案として…", "…そうなっているということは、それは非常に、慈愛の雨を降らしても、直接県民に行かず、上を見たら大きな屋根が付いていて、その雨どいに行った税金が…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/319", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/321", "sentence": ["…だった二〇二〇年の三月から四月にかけて各新聞のマスコミが合同で行った県民世論調査によれば、在沖縄米軍基地をどうするのがよいのかという問いに、…", "…定して、南西諸島の防衛力整備を進めております。今年一月に各社が行った県民世論調査においても過半数が支持しないというふうに答えておりますけれど…", "…世論調査においても過半数が支持しないというふうに答えておりますけれども、この県民の民意に対してどのように向き合っていらっしゃるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/323", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/325", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/327", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114889X00320230309/329", "sentence": []}]}, {"meeting_name": "参議院 予算委員会公聴会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/125", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115262X00120230309/128", "sentence": []}, {"url": "https://kokkai.nd