[{"date": "2021-12-22", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705007X00220211222/8", "sentence": []}]}, {"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/83", "sentence": ["○大臣政務官（下野六太君）お答えいたします。酪農ヘルパーは酪農家の休日確保等に貢献するとともに、酪農就農者の育成の役割も担っております。酪農…", "…認識しております。特に、都府県におきましては酪農家の減少により酪農ヘルパーの業務量の変動が大きいため、離職が早まったり、人材確保が困難な状況…", "…、離職が早まったり、人材確保が困難な状況となりやすいと聞いており、ヘルパーの待遇改善が重要と考えます。これまでも人材確保の支援を行ってきたと…", "…も人材確保の支援を行ってきたところですが、令和三年度から新たに酪農ヘルパーの給与の引上げに対応した奨励金の交付等の支援を追加したところであり…", "…金の交付等の支援を追加したところであります。今後とも、ゆとりを持って酪農を営めるように、酪農ヘルパーの確保と利用拡大に取り組んでまいります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/115", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715007X00120211222/117", "sentence": []}]}]}, {"date": "2022-12-09", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/93", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/97", "sentence": ["…現実があるようでありまして、どのくらいの割合の方がその制度を、酪農ヘルパーの制度を利用して休みを取得しているのでしょうか。ちょっと答えも、計…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121015007X00520221209/99", "sentence": []}, {"url": "https://kokkai.ndl.