[{"date": "2022-05-12", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/61", "sentence": ["…農地が増加している現状に鑑み、今回の改正におきましては、新たに農用地保全事業を活性化計画に位置付けることとし、当該事業の円滑な実施を支援する…", "…措置を講ずることとしております。このほか、農山漁村振興交付金により、活性化施設の整備や農用地の保全のための取組を支援することとしております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X01320220512/195", "sentence": []}]}]}]