[{"date": "2022-04-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/22", "sentence": ["…うのが嫌だとか言っている人たちも「信濃の国」は大合唱するんです。長野県民をユニファイするいい歌なんですが、その中の二番に、自慢話が続くわけで…", "…アカミミガメもないんです。碓氷トンネルが障害になるのか、真面目な長野県民はそんなものを持ち帰らないのか。多分、寒さ、そういうものの関係だろう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/24", "sentence": ["…とに、二〇一九年、断トツびりが三重県なんですよ。ここに、こういうのに県民性が出るんだ。長野は、ろくすっぽ真っすぐな道路がないから、ちょっと急…", "…き者はいると思いますが、立ち所に殺処分をしたりして自分でやりますよ。県民によって差があると思いますが。ついでに、じゃ、大臣のところ。大臣のと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/34", "sentence": []}]}]}]