[{"date": "2022-04-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/26", "sentence": ["…五年だそうです、短いですね。これは、卵を産んで、飼っているところでも繁殖してしまうんだ。だけれども、今飼っているのには愛情が湧いたりする。子…", "…わいいかもしれませんけれども、びしばしやってください。私の提案です。繁殖を禁止し、寿命五年だったら、今飼っているのだけ。大臣が、終生飼養、終…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/28", "sentence": ["…だらだら飼っていいなんて、それは指定した意味がないんですよ。だから、繁殖は絶対禁止にすべきですよ、自己繁殖。交換とか譲渡はいいとか、そんな、…", "…定した意味がないんですよ。だから、繁殖は絶対禁止にすべきですよ、自己繁殖。交換とか譲渡はいいとか、そんな、なまくらなものはやめるべきですよ。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/34", "sentence": []}]}]}]