[{"date": "2022-12-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/22", "sentence": ["…したいんですが、二〇〇四年に、健康調査をやってほしいといって、当時の熊本県知事が言っているんですよ。ところが、全然応じていないんです。何でな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/24", "sentence": ["…、出ていくんですよ、働いているんですよ。何か俺、おかしいと。しかし、熊本に住んでいたら、鹿児島ぐらい近かったら、それはおかしい、水俣病じゃな…", "…ーモア・ミナマタ第二次訴訟というのが四地裁でも出ているんです。当然、熊本、そして東京にいっぱい来ているから東京、それから大阪、分かりますよね…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004006X00420221222/34", "sentence": []}]}]}]