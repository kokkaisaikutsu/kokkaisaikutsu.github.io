[{"date": "2022-04-22", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/26", "sentence": ["…めて、新しいのを飼わない、侵入の予防と早期発見、早期防除というのをマニュアルも作ったそうですけれどもね。私のところには全然。作ってどうやって…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/28", "sentence": ["…とするというのを、それをやってもらいたいと思いますよ。そうしたら、マニュアルなんかに、冷凍庫に入れて殺処分をすればいいんだと。これもまた残酷…", "…ていない。人任せで、びしっとやるでもない、方向も示していない、防除マニュアルでだらだらだらだら書いてあるだけで、何をどうやったらいいんだか書…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00820220422/34", "sentence": []}]}]}]