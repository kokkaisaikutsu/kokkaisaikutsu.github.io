[{"date": "2020-11-19", "meeting": [{"meeting_name": "参議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/15", "sentence": ["…れから、もう一つ大事な点があります。それは、やっぱり科学者はいろんな仮説を立てて、それを世界で連携できる人と力を合わせて世論形成をする力を持…", "…う、そういうふうに思うのが大半の考えであるにもかかわらず、いや、この仮説は正しいと思う人たち。それは、発見した人、科学者たち、大学のそういう…", "…日本におきます企業内のそういう科学者たちの考え、彼らが持っている今の仮説、もっと丁寧に聞き取って、またその努力を励まし、そして政治の勢いを活…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120314006X00220201119/19", "sentence": []}]}]}]