[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/17", "sentence": ["…こで、総理大臣にお願いがあります。経済制裁の結果、もちろん日本の国民生活も不便を強いられるかもしれません。まず国民生活への負の影響、これを最…", "…果、もちろん日本の国民生活も不便を強いられるかもしれません。まず国民生活への負の影響、これを最小限にとどめるよう最善の政策のラインアップをお…", "…る努力はするけれども、ウクライナの市民や家族と連帯する思いを込めて、生活に影響があっても一緒にこの経済制裁を支えてもらいたいと、そう発信する…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/19", "sentence": ["…帯にエネルギー供給を通じて貢献すべき、Ｇ７議長予定国として説得していただければ、国民生活への影響も少しは緩和されると思います。お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/33", "sentence": []}]}]}]