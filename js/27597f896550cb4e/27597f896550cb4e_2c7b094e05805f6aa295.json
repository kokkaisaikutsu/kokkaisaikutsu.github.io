[{"date": "2022-05-11", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/51", "sentence": ["…大人が決めることじゃなくて、子供が、あるいは子供の側に立つ独立した第三者機関が決めるべきだというふうに思います。そこで、配付資料を見ていただ…", "…どもオンブッドという名称で、既に、子供の権利の擁護のための独立した第三者機関を設置すべきだというのを掲げさせていただいています。一九八一年に…", "…九八年に条例を制定した兵庫県の川西市を筆頭に、全国約四十の自治体が第三者機関を設けています。更に言えば、与党の公明党も、昨年の衆議院選挙の公…", "…ー設置というのを掲げている。私は、子供の権利の擁護のための独立した第三者機関を設置しないという選択肢はないんだと思います。そこで、具体的な在…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X02420220511/65", "sentence": []}]}]}]