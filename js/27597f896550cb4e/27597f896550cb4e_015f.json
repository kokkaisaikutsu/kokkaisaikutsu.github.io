[{"date": "2020-11-26", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/78", "sentence": ["…も、消費者庁の対応が後手に回ったことがこうした被害をここまで拡大させてしまったこと、このことに対する大臣の反省の弁をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/82", "sentence": ["○大西（健）委員私は、被害者の皆さんに寄り添う答弁が少しやはり欲しかったなと思うんですが、ただ、もし少しでも責任を感じていただいているなら、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/86", "sentence": ["…の救済に充てることができます。今すぐ確たる御返答はできないかもしれませんが、ぜひ被害者に寄り添った答弁を伊藤副大臣にお願いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120304536X00320201126/90", "sentence": []}]}]}]