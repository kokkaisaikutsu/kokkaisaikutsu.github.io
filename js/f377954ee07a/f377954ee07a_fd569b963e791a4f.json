[{"date": "2022-03-02", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/308", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/310", "sentence": ["…は会見で、今回のウクライナの侵略行為は、欧州のみならずアジアを含む国際社会の秩序に影響する重大な深刻な事態であると認識をしているとおっしゃっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/312", "sentence": ["…招いてはならないと思っております。ウクライナ侵略前、ロシアに対する国際社会の、この時代にＧ８加盟国の武力侵略などあり得ないと言っていたわけで…", "…侵略の抑止効果を高めるには、台中が互いに隷属しない関係であることを国際社会が広く認知して、台湾の主権を揺らがないものとすることが重要なことで…", "…上に、台湾が国際組織、ＣＰＴＰＰやＷＨＯなどに参加できるよう強力に国際社会へ後押しすべきだと考えますけれども、総理の考えをお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/314", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/316", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/318", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/320", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/322", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/324", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/326", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00620220302/328", "sentence": []}]}]}]