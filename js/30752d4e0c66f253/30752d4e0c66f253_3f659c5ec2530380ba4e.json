[{"date": "2024-03-07", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/42", "sentence": ["…のか、また福祉避難所の運用にどのような課題が生じたかについて、また全国的に福祉避難所の指定が促進されているかについて、政府参考人に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/46", "sentence": ["…も非高齢者に比べて高い状況にあると思います。受刑者数に占める高齢者の割合、それから再犯率の傾向、再犯に至る背景について政府参考人に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/66", "sentence": ["…地域の団体や自治会、こういったものをしっかり巻き込んでいくべきではないかなというふうに思っておりますが、この点について政府参考人に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/70", "sentence": ["…うふうな声が多数聞かれております。この物価高騰への影響に対して今回の報酬改定がどのように対応されているのか、政府参考人に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/72", "sentence": ["…りました。これ、処遇改善、しっかりと稼ぎなさいということなのか、件数で稼ぎなさいということなのか、どういう改定なのか、政府参考人に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121315261X00620240307/76", "sentence": []}]}]}, {"date": "2024-04-12", "meeting": [{"meeting_name": "参議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/7", "sentence": ["…既往歴があったというふうに発表されています。この既往歴と健康被害による死亡との関係について、現時点での見解を政府参考人に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/9", "sentence": ["…この被害拡大防止の上では製品の回収というのは非常に大事でありますが、現在の回収状況はどんなふうになっているでしょうか、政府参考人に伺います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/11", "sentence": ["…の体制や法制度においてどんな問題があったのか、今後、速やかな周知、広報、回収等を行う上での今後の対応について政府参考人に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/13", "sentence": ["…いのかなというふうに考えております。この原因物質の探索、分析について、今後の取組あるいは時期的なめどについて政府参考人に伺いたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314536X00420240412/19", "sentence": []}]}]}]