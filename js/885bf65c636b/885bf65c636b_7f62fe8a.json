[{"date": "2022-11-17", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/48", "sentence": []}]}, {"meeting_name": "衆議院 地方創生に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/80", "sentence": ["…七条の二項において、全ての予備費の支出については、内閣は事後の国会の承諾を得なければならないとされておりまして、財政法においては、政府が予備…", "…、政府が予備費に関する調書を次の通常国会において国会に提出して、その承諾を求めなければならないと定められていますが、これも、過去においては新…", "…は新聞等で、このプロセスが守られていないという批判をされてきました。実際に、調書作成から国会承諾といったプロセスの履行状況を教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/82", "sentence": ["…いるということで、これは国会側の問題だと思いますし、長年、次の常会で承諾というプロセスが経られていないというのが、いろいろな予備費の使われ方…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004773X00320221117/90", "sentence": []}]}]}]