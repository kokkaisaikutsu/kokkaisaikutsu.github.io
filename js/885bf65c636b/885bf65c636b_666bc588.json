[{"date": "2022-10-24", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/174", "sentence": ["…九四五年八月十八日、占守島という千島列島の北端の島において、日本軍が武装解除のさなかソ連軍による侵攻を受けました。日本の守備隊による抗戦でソ…", "…侵攻は阻まれたものの、その後停戦となり、占守島そして幌筵島の日本軍の武装は解除されました。この占守島の戦いで日本が抗戦したことが、結果として…", "…す。しかしながら、その後、千島列島や南樺太はソ連に支配され、日本軍は武装解除後シベリアに抑留されるという、誰もが知る悲惨な悲劇につながってお…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005261X00420221024/180", "sentence": []}]}]}]