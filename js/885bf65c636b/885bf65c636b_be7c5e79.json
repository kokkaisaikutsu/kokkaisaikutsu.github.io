[{"date": "2022-04-27", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/295", "sentence": ["…、かつ不明瞭で、インターネット上における誹謗中傷に関しては、被害者の精神的とか金銭的な負担と釣合いとか公平性というのは、量刑を引き上げたとし…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/297", "sentence": ["…れども、死に至った原因は、必ずしも外部的名誉だけじゃなくて、内面的、精神的なダメージがあったというふうに思っています。この点、立憲さんの案で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/299", "sentence": ["○守島委員考慮し得る、精神的ダメージも含めてという答えなんですけれども、そうなると、侮辱罪の中で加味し得るといったところで、量刑で加味された…", "…と思っています。誹謗中傷で人の生理的機能を害する、つまり、人を極度の精神疾患の状態に陥れ、その結果として自死を招くということは、むしろ、例え…", "…けれども、まず、一般論として、人を誹謗中傷して、その結果、ノイローゼ等の精神的な疾患を生じさせた場合、傷害罪が成立するのか、教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/301", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/303", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/305", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/307", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/309", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/311", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/313", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/315", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805206X01320220427/317", "sentence": []}]}]}]