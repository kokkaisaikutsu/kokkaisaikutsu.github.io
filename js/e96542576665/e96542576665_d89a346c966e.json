[{"date": "2022-10-26", "meeting": [{"meeting_name": "衆議院 文部科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/201", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/203", "sentence": ["…であり、対策が急務となっております。校舎の構造体耐震化率は九九・七と高水準でありますが、いまだ耐震性がない建物が二百八十八棟存在するのも事実…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/205", "sentence": ["…早坂委員そうですね。非構造部材の耐震点検実施率は、本当に、九六・一、高水準なんですが、耐震対策実施率は六六・一％と、七割にも届かないんですよ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/207", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/209", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/211", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121005124X00220221026/213", "sentence": []}]}]}]