[{"date": "2022-03-29", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/47", "sentence": ["…も、金融庁とも連携しながら金融機関に対して、地域で問題が発生している案件に関してはしっかりと共有していただく、そんな提案をしたいと思いますが…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/49", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/57", "sentence": ["…発倍率というのは、むしろ、ほっておいても民間がみんなやりたがっていた案件だったからこういう数字になっている可能性というのはありませんか、大臣…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/69", "sentence": ["…はたくさんあるということ、そういう中で、非常に地域を心配させるような案件を何とか止めていきたいということと同時に、もっと推進すべきところはも…", "…ふうに考えておるわけでございます。投資したソーラーの中で、ソーラーシェアが今までに案件として行われたことがあるのかをお尋ねしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/71", "sentence": ["…解が進んでいるという説明を聞いております。まさにこういうところこそ、案件が何も入ってこなかったからやりませんでしたというのは、先ほどの馬場さ…", "…ルをこのソーラーシェアに関してはしっかりと適用外にしていただいて、事業案件をつくっていただきたいというふうに思いますが、大臣、いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00420220329/78", "sentence": []}]}