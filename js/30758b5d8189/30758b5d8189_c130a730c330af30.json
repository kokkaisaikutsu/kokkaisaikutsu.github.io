[{"date": "2022-12-08", "meeting": [{"meeting_name": "衆議院 原子力問題調査特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/100", "sentence": ["…やり取りというのは二段階ございますね。最初の段階というのはファクトチェックを行う会合でございまして、年間二千回ほどあると聞いております。そし…", "…年間二千回ほどあると聞いております。そして、第二段階がそのファクトチェックに基づいた審査会合ということでありまして。私の理解、当時の説明は、…", "…ます。議事の概要の公開にとどまっているのが最初に申し上げたファクトチェックのヒアリングの部分だというふうに理解しておりますが、当時の更田委員…", "…と、私はもうそろそろ、二百回の審査は公開だけれども二千回のファクトチェックは公開は技術的に無理だ、こういう答弁は成り立たないというふうに思っ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/102", "sentence": ["…ているのは、安全審査の透明性と同じレベルにその前段階であるファクトチェックの会合も引き上げるべきではないかと。それができないということですか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/114", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/116", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320221208/119", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004194X00320