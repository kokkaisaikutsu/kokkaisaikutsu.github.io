[{"date": "2022-03-08", "meeting": [{"meeting_name": "衆議院 環境委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/32", "sentence": ["…ろいろ造作物を造っちゃいけないというのが前提なんです。まず全面的にネガティブゾーンなんですね、その中に認めたところはオーケーというポジティブ…", "…ろんありませんが、今これだけ日本の国民が苦しんでいるものに対して、ネガティブゾーン、ポジティブではなくてネガティブゾーンということでアプロー…", "…が苦しんでいるものに対して、ネガティブゾーン、ポジティブではなくてネガティブゾーンということでアプローチしていく、そういう制度設計は考えられ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/34", "sentence": ["…員温対法の改正をなさったときにポジティブゾーンという言葉が出てきましたけれども、ネガティブゾーンという考え方は議論に、俎上にのったんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/36", "sentence": ["○田嶋委員比較考量してネガティブゾーンという手法をやめようという議論が行われたのかという質問なんですけれども。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/38", "sentence": ["…。本当に申し訳ないという気持ちがあります。今、温対法の趣旨からしてネガティブゾーンはそぐわないとは、どういうことなんですかね。推進する法律だ…", "…、いかがですか、大臣、今の話を聞いて。役所の、温対法の趣旨からしてネガティブは検討せずポジティブでいきましたとなんか説得されませんよ、私は。…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804006X00220220308/56", "sentence": []}]}]}]