[{"date": "2021-05-19", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415254X02320210519/17", "sentence": ["…担割合の変更にもかかわらず高齢者の方々が安心して医療を受けるために、配慮措置が設けられました。公明党の強い要請を受け、当初、一月分の負担増加…", "…は評価をいたします。厚生労働大臣にその趣旨をお伺いするとともに、この配慮措置が確実に適用されるためにどのような対応を考えているのか、御所見を…"]}]}, {"meeting_name": "参議院 憲法審査会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414183X00220210519/11", "sentence": []}]}]}, {"date": "2021-05-27", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/190", "sentence": ["…高齢になればなるほど医療費は当然上がっていく、そういうことに対して、配慮措置として、党の提言も受けて、一月分の負担増が上限三千円としたわけで…", "…も受けて、一月分の負担増が上限三千円としたわけであります。まず、この配慮措置について局長にお伺いしたいと思いますが、本会議での私の質問に対し…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/192", "sentence": ["…ありますが、本当にそうであるのかという点と、あわせて、政府としてこの配慮措置の活用状況を把握すべきと考えますが、御所見いただきたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120414260X01920210527/210", "sentence": []}]}]}]