[{"date": "2021-12-20", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/172", "sentence": ["…進と密接に連携して取り組んでいるところです。このため、今後はＥＢＰＭ推進を担う行革事務局に統計改革推進室の業務を移管することとしたものです。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120715261X00320211220/181", "sentence": []}]}]}, {"date": "2022-02-25", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/172", "sentence": ["…込みの低い資金は返納するというＰＤＣＡサイクルを確立していることが重要という観点から基金に係る行革の取組を行ってきているところでございます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/180", "sentence": ["…係府省庁において適切に行われているものというふうに考えておりますし、行革としては、ＰＤＣＡサイクルをしっかりと回すということは行革における責…", "…るものというふうに考えておりますし、行革としては、ＰＤＣＡサイクルをしっかりと回すということは行革における責任だというふうに考えております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/182", "sentence": ["…てその結果は公表しているところでございます。その公表プロセスのところにはしっかりと行革として関わらせていただいております。（発言する者あり）"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/188", "sentence": ["○国務大臣（牧島かれん君）行革のプロセスにおいては基金シートに基づいて有識者の方々と議論をしているわけですけれども、その中には補正も含まれて…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/192", "sentence": ["…るように議論がなされているというふうに受け止めておりますし、しっかり行革としても、その基金シート、基金の在り方、検討は不断に行っていくという…", "…行革としても、その基金シート、基金の在り方、検討は不断に行っていくということは私ども行革として行わなければならないものと受け止めております。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X00320220225/361", "sentence": []}]}]}]