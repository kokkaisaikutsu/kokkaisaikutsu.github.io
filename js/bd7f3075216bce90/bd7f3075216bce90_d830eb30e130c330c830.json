[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/160", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/164", "sentence": ["○羽田次郎君今御説明にあったヘルメットについてですが、八八式二型というふうにお聞きしておりますが、ＮＡＴＯが採用しているヘルメットと比較する…", "…八八式二型というふうにお聞きしておりますが、ＮＡＴＯが採用しているヘルメットと比較するとかなり防弾性能が劣って、ＡＫ47などの自動小銃による…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/166", "sentence": ["…により多くの空爆がされているという現実がございます。その八八式二型ヘルメットのストラップは固定式で暴風の侵入を防ぐ形状のパットがヘルメット内…", "…二型ヘルメットのストラップは固定式で暴風の侵入を防ぐ形状のパットがヘルメット内部に付いていないため、付いていないという御説明をいただいておる…", "…ないという御説明をいただいておるんですが、爆風を受けたときに頭部とヘルメットの内側の隙間から暴風、爆風が入って、圧力で頭蓋骨を損傷してしまう…", "…があるという指摘も聞いております。そしてまた、爆風が下から入ると、ヘルメットの重みも相まって頸部に重大な損傷を与える可能性もあると。そして、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/168", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/170", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/172", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/174", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/176", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/178", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X00420220324/185", "sentence": []}]}]}]