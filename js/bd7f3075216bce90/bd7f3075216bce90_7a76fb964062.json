[{"date": "2022-06-07", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/34", "sentence": ["…ゃるんであれば、その言葉を信じたいとは思いますが。ただ、当然、原子力発電所に対する攻撃というのはジュネーブ条約違反であるのは明白ですし、それ…", "…ことはできないというふうに原子力防災担当をする大臣が明言されますと、発電所を有する自治体や地域住民は不安な日々を過ごさざるを得ないというふう…", "…ておりますので、原発を攻撃する暴挙が現実に起きる中で、今後その原子力発電所どうしていくのかという、これは国民的な議論をしていかなければならな…", "…らないと私は改めて感じております。ロシアは、病院、学校、劇場、原子力発電所などあらゆる施設に無差別的な攻撃を続けていて、多くの子供も犠牲とな…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/46", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/52", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/56", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120813950X01520220607/