[{"date": "2023-01-24", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115254X00220230124/10", "sentence": ["…与党内での混乱により、通常国会冒頭となってしまいました。決算審議を予算編成に反映させるという参議院の取組をないがしろにする事態を招いたことに…", "…も加わり、巨額の予備費が更に計上されるなど、財政民主主義を無視した予算編成が繰り返されました。この先もしっかりと対策を打つためには、これまで…", "…えて、なぜこれだけの多額の繰越額や不用額が生じたのか、とりわけ補正予算編成時における各経費の緊要性や積算、執行の見通しについても徹底的に検証…", "…改善していないことを意味しているのではないでしょうか。各府省等は、予算編成時には、予算書に加えて、豊富な補足資料を自主的に公表しています。予…"]}]}]}, {"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/63", "sentence": ["…前後のＯＤＡ予算を計上してきたスウェーデンも、二〇二三から二五年の予算編成では国内ファーストが強調されて、各年のＯＤＡ予算をＧＮＩ比〇・八八…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00620230424/87", "sentence": []}]}]}]