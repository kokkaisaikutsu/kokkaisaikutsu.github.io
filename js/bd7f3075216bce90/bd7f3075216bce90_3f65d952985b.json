[{"date": "2022-11-15", "meeting": [{"meeting_name": "参議院 外交防衛委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/146", "sentence": ["○羽田次郎君このスパイ防止法に関して、小野田防衛大臣政務官の御認識、お考えはいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/148", "sentence": ["○羽田次郎君今年七月七日の参議院選の最終盤、小野田政務官の個人演説会で、スパイ防止法に反対するのってスパイじゃないですかと私は思うんですよと…", "…らっしゃらないので、どうかそこはお許しいただければと思います。小野田政務官は政見放送では、日本の文化と表現の自由を守りますとおっしゃられてい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/154", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/156", "sentence": ["○羽田次郎君改めて大臣政務官の御見解というのを理事会で協議していただくということでよろしいでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121013950X00620221115/158", "sentence": ["…あるかもしれませんけど、活発な議論のためにも、特に発信力のある小野田政務官におかれましては、スパイとかというレッテルを貼るようなことは慎重に…", "…勢いらっしゃるのも確かです。ですので、そうしたことも踏まえて、小野田政務官にも是非、その議論をするときに相手がスパイだとか言うようなことがな…"]}]}]}]