[{"date": "2021-12-13", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/228", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/230", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/234", "sentence": ["…名な事例は小渕内閣当時の地域振興券ですね。これは事務的にもいいんですけれども、その地域振興券の経済波及効果はどういうふうに分析されましたか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/236", "sentence": ["…るんです。前の経企庁、今の内閣府もしっかり分析しているとおり、経済波及効果について言えば、現金であれ、クーポンであれ、減税であれ、三割は消費…", "…かかりますし、手続も変わりますよね。ですから、何で、同じような経済波及効果しかないのであれば、もっと簡便な、私は減税でもいいと思いますよ、消…", "…けれども、クーポン券であれ、現金であれ、減税であれ、残念ながら経済波及効果は同じなんですから、そこは迅速性とか、簡便性とか、手続の簡易性とか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/238", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/240", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/242", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/245", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/247", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/249", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/251", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/254", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/257", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/259", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/261", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/265", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705261X00220211213/267", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/12070526