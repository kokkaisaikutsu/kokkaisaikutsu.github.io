ps://kokkai.ndl.go.jp/txt/121015261X00620221201/347", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/349", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/351", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/353", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/355", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/357", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/359", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121015261X00620221201/361", "sentence": ["○田村智子君先ほど来言っているとおり、そのミサイル迎撃システムは軍縮ももたらさなかった、安全ももたらさなかった、むしろ厳しい安全環境をもたら…"]}]}]}]