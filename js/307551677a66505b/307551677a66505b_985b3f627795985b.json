[{"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/118", "sentence": ["…七か国への働きかけが必要ではないかと考えます。特に中国などアジアの国に日本政府としての働きかけの検討をしていないか、官房長官、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/120", "sentence": ["…経済協力についてもお聞きします。三月十一日、衆議院内閣委員会で松野官房長官は、八項目の協力プランを含むロシアとの経済分野の協力に関する政府事…", "…算案の修正はしないけれど凍結など執行を止めるのか、一体何をどう見直すのか見直さないのか、説明いただきたいと思います。官房長官、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/124", "sentence": ["…し、侵略行為を続けて正当化する国とは経済協力はできないと、私はその表明が必要だと思います。これは官房長官にお答えいただきたい。いかがですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/126", "sentence": ["…挙を見れば明らかです。岸田政権の下で、この安倍政権時代のロシア外交について抜本的な見直し行うべきだと思いますが、官房長官、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/128", "sentence": ["…の政治決断をすべきだということを強く求めて、ロシアの問題については以上ですので、官房長官、経産省、外務省の皆さん、退席いただいて構いません。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/142", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814889X00320220316/144", "sentence": []}]}]}]