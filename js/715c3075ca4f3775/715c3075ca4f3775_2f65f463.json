[{"date": "2022-03-16", "meeting": [{"meeting_name": "参議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815007X00320220316/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00320220316/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00320220316/10", "sentence": ["…良区などと一体になって知恵を出す、自治体も国もそうした地域の話合いを支援するといった仕組みをつくっていくことが本当に必要かなと思います。もう…", "…たいわけでありますが、地域での徹底した話合いが行われるよう国が必要な支援策を講ずるということが、まあ国にばっかり頼るわけじゃありませんが、そ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815007X00320220316/12", "sentence": []}]}]}, {"date": "2022-05-09", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/14", "sentence": ["…持てないというふうに思うんですね。農業高校への農業機械導入をしっかり支援することが必要ですし、また、農業機械メーカーに協力してもらって授業や…", "…いうふうに思います。そうなると、農業高校の予算は県が基本とはいえ、農林水産省もしっかり支援していくべきですが、農林水産省のお考えを聞きます。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814103X00720220509/24", "sentence": []}]}]}]