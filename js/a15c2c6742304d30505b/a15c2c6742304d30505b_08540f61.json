[{"date": "2022-02-16", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/159", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/163", "sentence": ["…ワーク化に当たって、やはり今御答弁いただいたとおり、住民の理解そして合意を得る、この点は絶対怠ってはならない点だと思います。住民の理解と合意…", "…民の理解そして合意を得る、この点は絶対怠ってはならない点だと思います。住民の理解と合意を前提とするべきだと思います。もう一度お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/165", "sentence": ["○岡本（あ）分科員ありがとうございます。議会だけじゃなくて住民の合意という点、踏み込んでいただいてありがたいと思いますし、是非その点も書き込…", "…たいと思いますし、是非その点も書き込んでいただきたいと思います。この合意の取り方については、議会の承認を得たらオーケーと思いがちなところ、そ…", "…せしたから、丁寧に説明したからオーケーという使われ方がよくされます。合意を取るということの重要性、この点については是非、今、書き込んでいただ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805272X00120220216/179", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/107", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/109", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/111", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805274X00120220216/113", "sentence": []}, 