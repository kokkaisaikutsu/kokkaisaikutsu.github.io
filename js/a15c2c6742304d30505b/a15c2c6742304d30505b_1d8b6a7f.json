[{"date": "2022-10-27", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/40", "sentence": ["…いう意味で使われたかということと、昨日の御答弁の中では、やはり撤回、謝罪をするべきだ、傷ついた方がいらっしゃること、これを認めていらっしゃる…", "…をするべきだ、傷ついた方がいらっしゃること、これを認めていらっしゃるので、この点は撤回、謝罪をするべきだと思います。この点をお答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/42", "sentence": ["…ゃいます。傷ついた方に対して、どういう言葉をかけますか。私は、やはり謝罪をして、撤回をするべきだと思います。ブログではなくて、ここでお答えく…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/44", "sentence": ["…が、杉田議員の資質を問いたいと思います。やはり、傷ついた方がいらっしゃることに対して、反省ではなく謝罪が必要だと思います。いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/46", "sentence": ["○岡本（あ）委員納得いきません。四年前の謝罪がないとスタートにも立てないということ、お気づきになりませんか。もう一度お答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00220221027/67", "sentence": []}]}]}, {"date": "2022-12-06", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00820221206/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00820221206/33", "sentence": []}, {