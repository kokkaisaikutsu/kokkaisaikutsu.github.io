[{"date": "2022-04-21", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/43", "sentence": ["…を御覧ください。二〇二〇年のランニングコストは約十一億、収入は約一・五億、収支で九億の赤字が出ています。二〇二一年の収入はいかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/45", "sentence": ["…まり、収入はないんですよ。そうすると、二年間、経費は二十一億ぐらい掛かって、その間の収入は一・五、つまりもう既に二十億の赤字じゃないですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/49", "sentence": ["○蓮舫君ですから、二年間で二十億の赤字になっている。これ、誰が払うんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/61", "sentence": ["…まり、税金由来で、新国立競技場の計画が遅れれば遅れるほど、もう二十億の赤字の見通しがある。収入がないと大臣も認めた。国民が払うんですよ。これ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/63", "sentence": ["○蓮舫君開き直らないでいただけますか。維持をするだけで、税金で赤字を補填し続けなければいけないんです。ランニングコストは、さっき言いました、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/65", "sentence": ["…収入は一・五億、既に二十二・五億足りないという計算になるんです。民間が事業を始めるまで赤字は出続けます。これは誰が負担していくんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/67", "sentence": ["○蓮舫君コンセッション、民間事業化が始まったら赤字は出ないという認識でしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/77", "sentence": ["…よる負の影響が見通せない中でも収支をしっかりと見通しを立てて、そして、赤になるか黒になるか、日々の努力を積み重ねて結果を出そうという努力をし…", "…けは、観客席が幾ら、どれぐらい埋まるか分からないから見通しが立てない、赤字になるかもしれないし黒字になるかもしれない、赤字になったら税金で補…", "…るか分からないから見通しが立てない、赤字になるかもしれないし黒字になるかもしれない、赤字になったら税金で補填。こういう考え方でいいんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/79", "sentence": ["…ボールなどの会場となった有明アリーナを除く五つの施設が年間十億円以上の赤字見通しとなりました。七十八億円を投じたカヌー会場、年間一・六億円の…", "…赤字見通しとなりました。七十八億円を投じたカヌー会場、年間一・六億円の赤字、その上に、波を和らげる装置にカキが大量に付着し、除去費用だけで昨…", "…を掛けて整備されましたが、年間百万人もの利用があったとしても六・四億の赤字見通しです。千六百億円、それにザハ・デザイン時代のもの入れて二千億…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/81", "sentence": ["…見せてくださいよ。二千億もの税金を投じて造ったもので、もう既に二十億の赤字が見通しされてて、民間事業がいつになるのかも分からなくて、それまで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815104X00620220421/83", "sentence": ["…てください。せめて、それを国民に見せることによって、年間十億もの国税で赤字を補填していく理解を得る努力をするべきだと私は思います。是非その考…"]}]}]}]