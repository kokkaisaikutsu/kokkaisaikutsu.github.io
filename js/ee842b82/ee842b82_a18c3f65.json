[{"date": "2022-05-30", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/12", "sentence": ["○蓮舫君私は、これまで財政規律を守る立場ではありましたが、この中で財政出動は仕方ないと思っています。特に今の円安と物価高、財政出動をしなけれ…", "○蓮舫君私は、これまで財政規律を守る立場ではありましたが、この中で財政出動は仕方ないと思っています。特に今の円安と物価高、財政出動をしなけれ…", "…が、この中で財政出動は仕方ないと思っています。特に今の円安と物価高、財政出動をしなければ国民生活を守れないと思っている。ただ、この二年間の百…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/34", "sentence": ["…います。しかも、この区の住民平均年収は千百八十五万円、全国一位。区の財政基準はトップファイブに入ります。財政調整基金は五百十四億円。この自治…", "…年収は千百八十五万円、全国一位。区の財政基準はトップファイブに入ります。財政調整基金は五百十四億円。この自治体に何で一・三億円配るんですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/36", "sentence": ["○蓮舫君国の予算の使われ方を審議する財務大臣の諮問機関、財政審は、この交付金について何と言っていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120815261X01820220530/42", "sentence": ["…ういう事業を行ってどういう効果があったかとい