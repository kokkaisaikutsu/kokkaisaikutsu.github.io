[{"date": "2023-12-12", "meeting": [{"meeting_name": "参議院 文教科学委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/13", "sentence": ["…ＳＴＩの議論を経た最終まとめ、文科省内の検討会議の論点整理、国際卓越研究大学法の施行を経て、合議体はそもそも国際卓越研究大学の要件として必置…", "…め、文科省内の検討会議の論点整理、国際卓越研究大学法の施行を経て、合議体はそもそも国際卓越研究大学の要件として必置するものだったでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/17", "sentence": ["…うでしょう。閣議決定したフォローアップの文字には、国立大学が国際卓越研究大学となる上で必要となる経営方針を定めるための合議体の措置を可能とす…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/35", "sentence": ["…すよ。文科省内、高等教育局内で会議を重ね、三年来の議論を経て国際卓越研究大学に必置とした運営方針会議をほかの国立大学にまで広げると決めていっ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121215104X00720231212/49", "s