[{"date": "2021-03-15", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/257", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/260", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/262", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/264", "sentence": ["○平木大作君この放送法の出資規制違反についても少しお伺いしていきたいと思います。東北新社、放送法のこの出資規制違反ですね、具体的に指摘をされ…", "…反についても少しお伺いしていきたいと思います。東北新社、放送法のこの出資規制違反ですね、具体的に指摘をされて、かつ、これまでの議論の中で、申…", "…なったわけであります。改めて中島社長にお伺いしますが、この外資による出資比率規制ってどのように認識をそもそもされているのか、そして、申請のと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/266", "sentence": ["…っていないというふうに思っております。結局、これ、許認可の前提として出資比率の規制があるわけでありまして、そういう規制の下にある事業体にとっ…", "…でありまして、そういう規制の下にある事業体にとっては、ある意味、この出資比率を維持するとか、その要件を満たすことというのは経営そのものなわけ…", "…訳として通らない話だというふうに思っております。改めて、私、当初この出資規律違反の話を聞いたときに、これ、もしかすると、いわゆる資本構成にす…", "…ゃ、中島社長、お伺いしますが、この接待の場以外も含めて、企業としてこの出資比率規制違反見逃すように総務省に働きかけたことはあるんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/268", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/270", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/272", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/274", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/276", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/278", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/280", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/284", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/286", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120415261X01120210315/288", "sentence": []}]}]}, {"date": "2022-04-11", "meeting": [{"meeting_name": "参議院 決算委員会",