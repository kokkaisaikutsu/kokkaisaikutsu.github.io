[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/188", "sentence": ["…所と同一事業所で雇入れ以前の三年間に通算して三か月を超える職業訓練や実習などを行った場合には助成金の対象から外すという要件があります。なぜ、…", "…助成金の対象から外すという要件があります。なぜ、通算して三か月を超える職業訓練や実習などを行った場合、助成金の対象外としているんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/190", "sentence": ["…も何度も丁寧に、企業にも協力してもらいながら特定求職者に合った訓練や実習など実施して、モチベーション上げて一般就労できる状況まで持っていって…", "…ています。一般就労ができる状況になるまでどれぐらいの期間の訓練だとか実習が必要かというのは、特定求職者の状況によって異なります。是非、特定求…", "…となってどういう場合が対象外になるのかよく分かりません。週二回以内の実習を三か月以内であったらマルで、週三回以上だったらバツというような対応…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/192", "sentence": ["…活困窮者のところで受けて、そして、その人に合った訓練場所を確保して、実習、訓練、様々な選択肢を準備して、受け入れる企業もよく分からないですか…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/208", "sentence": []}]}]}]