[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/180", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/182", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/184", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/188", "sentence": ["…たって解消していただきたいことがあります。この特開金には、雇い入れた事業所と同一事業所で雇入れ以前の三年間に通算して三か月を超える職業訓練や…", "…ていただきたいことがあります。この特開金には、雇い入れた事業所と同一事業所で雇入れ以前の三年間に通算して三か月を超える職業訓練や実習などを行…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/190", "sentence": ["…ましたとおり、これ訓練実施イコール雇用予約じゃないんですね。あくまで事業所という場所を活用した支援なんです。雇用は前提となっていないんです。…", "…んです。最初から雇用の約束ないんですね。にもかかわらず、認定就労訓練事業所で訓練を始めた場合に、開始時から雇用予約ありとみなされてしまい、特…", "…職者の状況によって異なります。是非、特定求職者の実態を踏まえて、同一事業所、一律、一律通算三か月以内という要件を見直していただけないでしょう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/208", "sentence": []}]}]}]