[{"date": "2023-05-18", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/162", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/164", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/169", "sentence": ["…考え方に基づいていることから、整備に当たって活用できる補助制度に資本単価一立法メートル当たり九十円以上という要件が課されております。そのため…", "…思うんです。だからこそお伺いしたいんですが、是非、移管を機にこの資本単価要件を廃止してもらいたいという自治体の声、物すごく多いです。半数以上…", "…いですけど、半数ぐらい、それぐらい当てはまっておりまして、是非、資本単価要件を廃止するような自治体の水道施設整備に対する財政支援の在り方、要…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/183", "sentence": ["…、お取り組みいただきたいと思っております。令和五年度から配管工の労務単価というものが見直しをされました。しかしながら、この見直しに当たっての…", "…工事というものの実態についても調査をしていただきまして、実態に即した労務単価というものを設定していただきたいと思いますが、いかがでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/186", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/188", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/190", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/192", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/194", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X01320230518/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114260X013