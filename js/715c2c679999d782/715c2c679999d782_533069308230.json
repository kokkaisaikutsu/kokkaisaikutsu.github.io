[{"date": "2022-05-24", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/151", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/159", "sentence": ["…周りの大人に足りなかったんだと思います。今回、先ほど来より出ていますこども家庭センターにおいては、是非、これ全て子供を対象としているセンター…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/161", "sentence": ["…たって子供の居場所を始め地域の子供たちのため様々な活動を実施しているこどもの里に行ってまいりました。地域の居場所は、子供たちにとって逃げ場で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/163", "sentence": ["…て、通える、子供たちが通える範囲で是非考えていただきたいと思います。こどもの里では、子供の居場所以外に様々な事業を実施するとしているんですが…", "…なものになるのではないかと思いますが、是非この制度設計に当たっては、こどもの里の取組も参考にしつつ、子供たちのニーズに合った形で柔軟に運用で…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/171", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/173", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/175", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/177", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/179", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/181", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/183", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/185", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X01620220524/187", "sentence": []}]}]}]