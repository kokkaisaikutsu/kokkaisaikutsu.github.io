[{"date": "2022-03-09", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/29", "sentence": ["…ーでより深刻なのは、誰にも相談することができず、ケアの負担が過重で、離職に至るケースが多いことです。こうした中で、近年、コマツなど一部の企業…", "…びつけるといった取組がなされています。ダブルケアによって優秀な人材が離職せざるを得ない状況は、個人にとって不幸なことであるばかりでなく、組織…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/31", "sentence": ["…（司）委員ありがとうございます。今日的な課題であるダブルケア、かつ、離職リスクを非常に高めるものですので、しっかり対応して、職員が安心して働…", "…どのようにされているのか、お伺いします。また、サービス残業の状況、長期休職者数、離職者の実態把握はどこまでされているのか、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/143", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/147", "sentence": []}]}]}]