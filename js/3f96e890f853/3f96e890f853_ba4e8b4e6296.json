[{"date": "2022-03-09", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/23", "sentence": ["…阿部（司）委員おはようございます。日本維新の会、阿部司です。本日は、人事院制度と霞が関の職場環境の改善についてお伺いしたいと思います。まず冒…", "…お伺いしたいと思います。まず冒頭、恐縮ですけれども、川本総裁に、再確認の意味も含めまして、人事院の果たす役割と機能についてお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/25", "sentence": ["○阿部（司）委員川本総裁から直々に、人事院の役割について確認をさせていただきました。給与等勧告制度については、歴史的な成り立ちや重要性は理解…", "…な方策の研究等、不断の取組をされるよう要望いたします。一方で、私は、人事院には、働き方改革につながる勤務条件等の制度改善、時代の要請に合った…", "…の役割を果たしていただきたいと思います。そこで、お伺いいたしますが、人事院には、人事行政の専門機関として、国内外の人事制度の調査研究を行い、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/27", "sentence": ["○阿部（司）委員ありがとうございます。これからは、人事院の機能のうち、勧告以外の機能、特に時代の要請に応え得る人事施策の展開といった部分の強…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/133", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/135", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/137", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/141", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/143", "sentence": ["…中途採用者の賃金について改革を進めていく必要があると思うんですけれども、これまでの議論を踏まえまして、人事院総裁の御見解をお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/145", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00720220309/147", "sentence": []}]}]}]