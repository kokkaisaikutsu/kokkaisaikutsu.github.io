[{"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/48", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/50", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/52", "sentence": ["…当の見直しをしてほしい、そういう要望を受けて、大体、担当者、課長補佐レベルの方に来ていただいて、それで議論するんですよ。二〇一九年も二〇二〇…", "…いて、それで議論するんですよ。二〇一九年も二〇二〇年も、その課長補佐レベルの方は、これは問題ですねという認識を強く持ってくれたんです。大臣、…", "…なると、もう悪循環。すごくこれは切実な問題で、二〇一九年の段階で担当レベルの人は問題だと言ってくれたんだけれども、残念ながら全然前に進んでい…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/54", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/56", "sentence": ["…ってとか、そういう状況じゃないと思っているんです、私は。もう課長補佐レベルでは、問題意識はかなりあるんですよ。だけれども、やはり政治力で、よ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/58", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/60", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/62", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/64", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/66", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/70", "sentence": []}]}]}]