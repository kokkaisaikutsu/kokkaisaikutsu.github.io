[{"date": "2022-03-23", "meeting": [{"meeting_name": "衆議院 国土交通委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/57", "sentence": ["…たように、ここにあるように、成田から羽田に移すものではない、成田との路線開設や増便を望んでいる国や航空会社は多く、羽田に国際便を振り向けたと…", "…が、令和二年の十月なんですが、全日空が、国際線の再開時には羽田空港に路線を集約すること、そういう方針を発表したんですね。それに対して、千葉県…", "…議会が危機感を持ちまして、当時の赤羽大臣宛てに、成田空港における国際路線再開に関する要請と題する文書を当時の和田航空局長に手渡しました。それ…", "…担うとする従来からの方針を踏まえ、両空港のバランスを考慮した上で国際路線再開を進めること、二つ目は、成田空港の国際線ネットワークの維持に向け…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/59", "sentence": ["…配されておったんですが、何と、昨年七月以降、全日空と日本航空が、北米路線の一部を羽田発着から成田発着に一時的に変更する対応を取っているんです…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804319X00420220323/83", "sentence": []}]}]}]