[{"date": "2023-04-03", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/85", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/87", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/89", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/91", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/93", "sentence": ["…だいていました。二〇一六年の一月十九日は、参議院の予算委員会で、当時、菅官房長官に対しても質疑したんですが、なかなか政府を動かすことができな…", "…民党に移ってきまして、二〇二一年の一月二十四日ですね、二年ちょっと前、菅前総理に、ネットと政治について相談したいというふうにして公邸、官邸に…", "…直談判を、一時間にわたりこども庁について提言しました。実は、そのときの菅総理の手応え感、余り感じられなかったんですが、後日、官房長官、実は加…", "…名以上も集まってきたというものであります。そして、四月一日には、当時の菅総理・総裁から自民党党内に本部を立ち上げるよう指示がありまして、そし…", "…上がって、党内でいろいろ議論をしてきました。ところが、その年の総裁選に菅総理が不出馬を表明されましてちょっと先行きが不透明になっちゃったんで…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/95", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/97", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/99", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/101", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/103", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114103X00220230403/106", "sentence": []}]}]}]