[{"date": "2022-12-10", "meeting": [{"meeting_name": "参議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121015254X01220221210/24", "sentence": ["…まう寄附の勧誘等の実態の指摘もあります。このような社会的に許容し難い悪質な寄附の勧誘行為の禁止については、これに対する勧告、命令等の行政上の…", "…ることを避けながら、宗教教義等を隠れみのとして財産を巻き上げるような悪質な寄附等を対象とする内容になっており、懸念を払拭するものになっていま…"]}]}]}, {"date": "2023-07-26", "meeting": [{"meeting_name": "参議院 地方創生及びデジタル社会の形成等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/7", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/9", "sentence": ["…予定があるんでしょうか。特に、逆に言うと、デジタル庁そのものがかなり悪質だったのかどうか、そういうことも含めて御見解いただけますでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115360X00120230726/17", "sentence": []}]}]}]