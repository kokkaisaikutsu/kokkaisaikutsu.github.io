[{"date": "2022-04-19", "meeting": [{"meeting_name": "参議院 財政金融委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/69", "sentence": ["…理解していただくことが重要であると考える次第でございます。我が国は、アジアから唯一Ｇ７に参加している国でございます。Ｇ７以外の諸国との連携に…", "…す。Ｇ７以外の諸国との連携につきましては、岸田総理自身が先頭に立ってアジアなどの各国に対する働きかけを行っている旨を述べられていることも承知…", "…ことも承知している次第でございます。今後も、ＷＴＯ加盟国を始め、特にアジア諸国に対しまして、ロシアの非道な行為を許さないという意思を広く伝え…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/77", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/79", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/81", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/83", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814370X01120220419/85", "sentence": []}]}]}]