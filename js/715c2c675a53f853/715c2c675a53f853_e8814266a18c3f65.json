[{"date": "2023-03-16", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/70", "sentence": ["…ていただきたいと思います。令和五年度の地方財政計画におきましては、臨時財政対策債の発行を前年度比マイナス〇・八兆円と抑制し、平成十三年度の制…", "…兆円程度の見込みと、いまだ巨額の借入金残高を抱えております。また、臨時財政対策債の残高は四十九・一兆円、交付税特別会計借入金の残高は二十八・…", "…うした債務の縮減、これは着実に進めるべきでございまして、そのために臨時財政対策債の発行抑制も行われたものと思いますけれども、地方財政の健全化…", "…けれども、地方財政の健全化に向けて取り組まれていると思います。この臨時財政対策債は令和四年度までの間の特例措置とされていたところで、今回の改…", "…の改正では令和七年度まで延長することになっております。そこで、この臨時財政対策債の発行を抑制することへの認識をまずお聞きをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X00420230316/90", "sentence": []}]}]}]