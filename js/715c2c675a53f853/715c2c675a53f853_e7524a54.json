[{"date": "2023-04-24", "meeting": [{"meeting_name": "参議院 行政監視委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/68", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/74", "sentence": ["…ましては、総務省の行政評価局が制度導入から五年を経過した昨年の四月に勧告を出しております。総務省からその勧告の概要、報告をいただきたいと思い…", "…は、総務省の行政評価局が制度導入から五年を経過した昨年の四月に勧告を出しております。総務省からその勧告の概要、報告をいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/76", "sentence": ["…検証という三つのポイントから成るということでございますけれども、この勧告からおよそもう一年が経過をしております。厚生労働省にお聞きしたいと思…", "…経過をしております。厚生労働省にお聞きしたいと思いますけれども、この勧告を受けてどのような見直しを検討しているのか、確認をしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/84", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/86", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114281X00320230424/88", "sentence": []}]}]}]