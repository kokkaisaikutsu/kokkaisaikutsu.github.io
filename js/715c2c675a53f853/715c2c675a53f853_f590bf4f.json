[{"date": "2023-04-25", "meeting": [{"meeting_name": "参議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/61", "sentence": ["…環境の向上を目指すという点で、是非委員の皆様に御賛同いただきたいのが郵便投票の対象者拡大ということでございます。自民、公明両党では、国政や地…", "…制度で介護の必要度が最も重い要介護五などに限定的に認められているこの郵便投票につきまして、要介護三と四の人にも対象を拡大する公職選挙法の改正…", "…で、各党各会派の皆様の御理解をいただければと思います。そこで、総務省には、この郵便投票の対象拡大に関する見解に関してお伺いしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/63", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/65", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/67", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/69", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/71", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/73", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/75", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121114601X01020230425/78", "sentence": []}]}]}]