[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/153", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/155", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/157", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/159", "sentence": ["○田所分科員郵便局におけるマイナンバーカード申請受付についてお伺いをいたします。令和六年秋の保険証の廃止を目指して、マイナンバーカードを全て…", "…カードの交付申請受付や引渡しについても、住民にとって身近な場所である郵便局を活用することが有効と考えますが、総務省としての御意見をお伺いいた…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/161", "sentence": ["…すし、それがＤＸなのかなという感じもいたします。今、実証実験として、郵便局で行政のサービスを代替するということで、住民票とか納税証明書、戸籍…", "…公金の取扱事務を私人に委託するような、そういった緩和もしている中で、郵便局も、しっかりとこれまで実績もありますので、局員がそういった行為がで…", "…というふうに思っております。地域のユニバーサルサービスの拠点としての郵便局の活用の可能性を広げるということを、是非考えてもらいたいというふう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/169", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00220230221/171", "sentence": []}]}, {"meeting_name": "衆議院 予算委員会第八分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/25", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/27", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/29", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105273X00220230221/33", "sentence": []}, {"url":