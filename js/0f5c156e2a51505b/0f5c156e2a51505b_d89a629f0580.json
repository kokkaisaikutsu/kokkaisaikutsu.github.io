[{"date": "2020-11-02", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/43", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/49", "sentence": ["…いう厳然たる事実があります。二〇二二年には団塊の世代が七十五歳以上の高齢者となり始め、その後、その数は高どまりを続けることになります。こうし…", "…八三％に上るという結果が示されました。政治は、二〇二二年に始まる後期高齢者の急増を目前にして、こうした不安の声に応えていかなければならないと…", "…ません。このような中で、年齢によって、こちらは現役世代です、こちらは高齢者ですと一まとめにしていくのではなく、全世代で支え合う、特に高齢者同…", "…らは高齢者ですと一まとめにしていくのではなく、全世代で支え合う、特に高齢者同士でもより支え合う、より助け合う、そうした視点を持つことが必要で…", "…ことが必要ではないかと考えます。田村厚生労働大臣に質問をいたします。高齢者医療の改革に当たって、どのような方向性、選択肢を持って進めていこう…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/51", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/53", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/55", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/57", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/59", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/61", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120305261X00220201102/63", "sentence": []}]}]}]