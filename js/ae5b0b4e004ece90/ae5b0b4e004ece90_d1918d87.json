[{"date": "2023-02-08", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/10", "sentence": ["…ついて質問をさせていただきます。パネル一を御覧ください。我が国の家計金融資産二千兆円は、半分以上がリターンの少ない現預金で保有されており、年…", "…、投資信託等に投資できる環境が整備されており、米国では二十年間で家計金融資産が三・四倍、英国では二・三倍になっている一方、我が国では一・四倍…", "…充、恒久化、第二に、確定拠出年金制度の改革、第三に、資産形成に関する金融経済教育の機会提供という三つを柱としております。そして、会長代行であ…", "…月々の確定拠出年金の運用先を考えていただくためにも、資産形成に関する金融経済教育の機会提供を推進し、中立的立場からアドバイスを行う公的な資産…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00820230208/24", "sentence": []}]}]}]