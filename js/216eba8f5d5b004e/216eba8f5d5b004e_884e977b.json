[{"date": "2023-02-21", "meeting": [{"meeting_name": "衆議院 予算委員会第六分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/110", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/112", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105274X00220230221/114", "sentence": ["…いかない。また、畑作中心の地域では、また肥料等々が高騰して、新年度の予算でも、春肥ぐらいまではめどがついているけれども、今後、秋肥、さらに令…", "…確かに今、国の会計システムは単年度制ですから、余りにも長期にわたって予算をつけるということは無理だというのは分かりますけれども、例えば国土強…", "…かりますけれども、例えば国土強靱化のように、五年ぐらいのスパンを見て予算をつけるぞというのは、あれは本当に建設、土木業の方々にしてみれば大変…"]}]}]}]