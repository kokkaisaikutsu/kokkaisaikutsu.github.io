[{"date": "2022-04-11", "meeting": [{"meeting_name": "衆議院 北朝鮮による拉致問題等に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/26", "sentence": ["…れども。それで、私が非常にいつも疑問に思うこと、それは、なぜ北朝鮮は日本人の拉致を行ったか。これは、よく、小泉総理が訪朝されたとき、二〇〇二…", "…の妄動主義者らが英雄主義に走ってかかる行為を行ったんだと。何のために日本人を拉致したのか。一つ目は、特殊機関で日本語の学習ができるようにする…", "…も当時の金日成さんとは七回会っているんですが、九二年に訪朝したとき、日本人が拉致されている、それを主席はどう思うかと。いや、それはおかしい、…", "…かと。いや、それはおかしい、日本の報道を見たけれども、拉致は工作員の日本人化教育のためとなっているけれども、しかし、ここには、北朝鮮にはです…", "…同胞が多く住んでいる、教育はその人たちに頼めばいいんだ、危険を冒して日本人を拉致する必要はない。確かにそうなんですよね。日本語ができる人、日…", "…できる人、日本語世代の人、日本から帰った人、いっぱいいますから、何で日本人を拉致しなきゃいけないのか、この辺のちょっと根本的なことが正直解明…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/32", "sentence": ["…、今もよく出る論調として、北朝鮮は非常に経済的に苦しいんだ、だから、日本人の拉致被害者を帰還させることで日本から経済的な援助を引き出すんだ、…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805253X00320220411/38", "sentence": []}]}]}, {"date": "2023-02-20", "meeting": [{"meeting_name": "衆議院 予算委員会第二分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/34", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105272X00120230220/38"