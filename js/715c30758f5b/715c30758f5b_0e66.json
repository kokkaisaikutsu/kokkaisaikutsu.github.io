[{"date": "2022-03-24", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/1", "sentence": ["…生労働省職業安定局長田中誠二君外八名を政府参考人として出席を求め、その説明を聴取することに御異議ございませんか。〔「異議なし」と呼ぶ者あり〕"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/2", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/3", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/4", "sentence": ["○委員長（山田宏君）御異議ないと認め、さよう決定いたします。また、明二十五日に参考人の出席を求め、その意見を聴取することに御異議ございません…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/5", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/7", "sentence": ["○委員長（山田宏君）雇用保険法等の一部を改正する法律案を議題といたします。まず、政府から趣旨説明を聴取いたします。後藤厚生労働大臣。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/9", "sentence": ["○委員長（山田宏君）以上で趣旨説明の聴取は終わりました。これより質疑に入ります。質疑のある方は順次御発言願います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/138", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/139", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/140", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/232", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/236", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120814260X00420220324/251", "sentence": []}]}]}]