[{"date": "2022-11-17", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/84", "sentence": ["…員について、当日、選挙運動を一切していなかったということが言えるか、断言できますかというのが一つと、それから、皆さん全員出陣式には出なかった…", "…言えるか、断言できますかというのが一つと、それから、皆さん全員出陣式には出なかったと断言できますかということ、お答えいただきたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/86", "sentence": ["…を受け取っている元市議の方も含めて、一切の方が選挙運動をしていないと断言できますかということなんですよ。そこまできちんと調査されていますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/88", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/90", "sentence": ["…たら、全員についてきちんと調べるべきじゃないですか。今、ないとここで断言できますか。一切、この方全員が選挙運動をしていない、労務者報酬をもら…", "…運動をしていない、労務者報酬をもらっている方が選挙運動をしていないと断言できますか。そして、もし後で出てきたら大臣を辞めると今ここで言えます…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/92", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/94", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00320221117/96", "sentence": []}]}]}]