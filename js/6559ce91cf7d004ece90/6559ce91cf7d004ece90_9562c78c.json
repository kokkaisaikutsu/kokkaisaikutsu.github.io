[{"date": "2022-11-29", "meeting": [{"meeting_name": "衆議院 総務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/20", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/22", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/30", "sentence": ["…リカはやはりさすがに、ＡＩとかも含めてということですけれども、巨額の投資をしているということだと思います。日本はこれまで幾ら使いましたかとい…", "…は。二つ伺いたくて、これまでの予算が大体、この補正を入れて千五百億円ぐらいになるんでしたっけね。民間はどのぐらい投資しているか分かりますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/32", "sentence": ["…うに思います。日本は、今後ですけれども、これからどのぐらい政府として投資をしていこうとしているのか、あるいは、それを呼び水にして民間にどれぐ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/34", "sentence": ["…す。失礼ですけれども、金額が出てこないところを見ると、そういう長期の投資計画がないということだと思うんですね。やはり、補正予算が出てくると、…", "…ろなものを介しているわけだから、そこに使う半導体とか、そういう技術に投資をしてもいいんじゃないかと思うんですが、その二点、伺いたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/36", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/38", "sentence": ["…が今必要なんでしょうか。単年度予算できちんと財源を確保して、計画的に投資計画を作って、中長期の計画を作って、防衛費なんかもそうですけれども、…", "…恒久的に基金をつくるんでしょうか。なぜ、本予算の方で、例えば電波利用財源あるいは一般会計財源を使って計画的な投資をしていかないんでしょうか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/40", "sentence": ["…臣、いかがですか。ビヨンド５Ｇの社会を実現するために、しっかり計画を立てて投資をしていくということをお話しいただきたいと思うんですけれども。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004601X00720221129/42", "sentence": []}]}]}, {"date": "2023-06-08", "meeting": [{"meeting_name": "衆議院 憲法審査会", "remarks": [{"url": "https:/