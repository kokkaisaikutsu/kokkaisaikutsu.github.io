[{"date": "2024-05-13", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/23", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/25", "sentence": ["…そこで、アニメのノウハウの共通化、これ支援必要だと考えているんですけど、この点に関する文科大臣の意気込みも含めて、お考えをお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/27", "sentence": ["…スタッフの現場研修や人材交流の機会提供などの支援が考えられますけれども、これらの点について、意気込みを含めて大臣のお考えをお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/29", "sentence": ["…ギャラリーなどのネットワークがこれ強化が重要だと私は考えています。その点に関して、現状の支援策などがあれば、意気込みを含めて教えてください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/31", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/43", "sentence": ["…意義なんですけれども、そういった民の取組の後押しという点を含めて、政府による今後の観光ＤＸの取組について、意気込みを大臣よりお答えください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00620240513/49", "sentence": []}]}]}, {"date": "2024-06-10", "meeting": [{"meeting_name": "参議院 決算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/30", "sentence": ["…は文化で食っていくんだということを宣言していただきたいんだけれども、そこまでとは言いませんけれども、総理の意気込みと決意をお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/34", "sentence": ["…スト、クリエーターの海外展開に支援していただきたいと思っているんですけれども、海外展開の強化に対する意気込みを、大臣、是非お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/36", "sentence": ["…業について取り上げられていますけれども、その検討内容も踏まえて、今の政府での検討状況と今後の方針と意気込みについて、総理、お願いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/38", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/40", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/42", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/44", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/46", "sentence": ["…私は思っています。日本が率先して文化の力でこういった世界を目指すべきだと思うんですけれども、できれば総理の決意や意気込みをお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121314103X00920240610/48", "sentence": []}]}]}]