[{"date": "2024-02-09", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/155", "sentence": ["…伊東良孝でございます。今日は、食料・農業・農村基本法の改定について、総理並びに坂本農水大臣にお伺いをいたしたい、こう思います。まず、元日に起…", "…が起きたわけでございますけれども、この復旧につきまして、見通しにつきまして、総理にその御決意を是非お聞かせいただきたいと思う次第であります。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/157", "sentence": ["○伊東（良）委員是非、地域の皆様方また被災された皆様方に総理からの強烈なメッセージ、こう受け止めておりますので、よろしくお願いを申し上げたい…", "…発展と地域コミュニティーの維持の観点から、本法案の改正となりますが、総理の基本的な改正への考え方をお聞かせをいただきたいというふうに思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/159", "sentence": ["…主要作物の備蓄管理や在庫管理、また輸入を含む緊急調達等について、再構築、強化すべきと思いますが、総理はどのようにお考えか、お聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/167", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305261X00720240209/170", "sentence": []}]}]}, {"date": "2024-03-26", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/7", "sentence": ["…（良）委員御苦労さまでございます。いま少し前まで衆議院の本会議で、総理大臣また坂本農水大臣から様々御答弁を聞いていたところであります。また今…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/9", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/21", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121305007X00420240326/24", "sentence":