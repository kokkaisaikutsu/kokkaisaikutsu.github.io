[{"date": "2023-03-28", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/259", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/261", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/263", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/265", "sentence": ["○山本太郎君先日、イギリスの国防担当大臣がウクライナに劣化ウラン弾も提供する発言をされました。外務省、劣化ウラン弾とは何ですか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/267", "sentence": ["○山本太郎君劣化ウランに関して、国連の環境計画はがんの増加リスクを指摘。二〇〇八年、欧州議会は、致命的な健康影響に関する多くの証言があると指…", "…議会は、致命的な健康影響に関する多くの証言があると指摘、加盟国に劣化ウランを兵器利用しないように決議しています。総理、イギリスに対して劣化ウ…", "…多くの証言があると指摘、加盟国に劣化ウランを兵器利用しないように決議しています。総理、イギリスに対して劣化ウラン弾供与しないよう求めますか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/269", "sentence": ["…兵器ですよ、これ。通常兵器と言っているのは戦争屋だけですよ。総理、ゼレンスキーさんに直接、劣化ウラン弾は使うべきではないと進言されましたか。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/271", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/273", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/275", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/277", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/282", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X01620230328/295", "sentence": []}]}]}]