[{"date": "2022-03-02", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/243", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/245", "sentence": ["…しかも、その委員会のメンバー、何でしょうか。読売新聞の論説とか、違憲立法を保身のために忖度した元内閣法制局長官とか、およそ国民の良心を代表す…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00520220302/250", "sentence": ["…でも、それに対する深い議論がなされた形跡もありません。また、政府は、立法理由の一つとして、サイバー対策における国際連携の重要性を述べています…", "…たことを見れば明らかです。国際連携のためにも本法案の改正が必要という立法事実自体が成り立っていません。ただし、サイバーの脅威に対してしっかり…"]}]}]}]