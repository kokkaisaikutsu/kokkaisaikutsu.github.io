[{"date": "2022-02-09", "meeting": [{"meeting_name": "衆議院 内閣委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/120", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/122", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/124", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/126", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/128", "sentence": ["…向いたり郵送するなども必要になる、そんなものばかりです。コロナ患者が役所の窓口にわざわざ行って申請するって、これ、あり得ますか。むちゃくちゃ…", "…、このままでは餓死する、自宅に食料は全くない、残金二百円。ほかにも、役所に相談しても、陽性なら保健所から食料が届くからそれを食べておいて、そ…", "…べておいて、そう言われて何日たっても食料が届かない、やっとつながった役所の電話、食料支援をお願いします、そう言うと、手が回らない、ウーバーイ…", "…したくても陽性で家から出られない、そう訴えても、体調がよくなってから役所に来てくださいねという対応。これは、このまま放置していたら陽性者から…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/130", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/132", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/134", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/136", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120804889X00320220209/138", "sentence": []}]}]}]