[{"date": "2023-03-10", "meeting": [{"meeting_name": "衆議院 外務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/217", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/219", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/221", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/223", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/225", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/227", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/229", "sentence": ["…北方特別委員会で外務省が示した見解は全く違っています。当日の委員会で山下新太郎大臣官房審議官は、米国のトマホークには当時三種類あり、そのうち…", "…種類あり、そのうち二つが通常弾頭の非核だと答弁しています。その上で、山下審議官は、「それじゃ日本の自衛隊は非核トマホークを装備できますか。」…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/231", "sentence": ["…も、質問は違う話をしているのだから、余り当たらないと思うんですよね。山下審議官は、これは議事録なんですけれども、社会党の川崎寛治議員から、「…", "…すか。」という極めてシンプルな質問を受けているんですね。これに対して山下審議官は、外務省の審議官は、自衛隊のことなので自分から答えるのが適当…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/233", "sentence": ["…核トマホークを装備できますかという端的な質問なんですよ。これに対して山下審議官は、できへんと言っていると言っているわけですやんか。それを、違…", "…ると、憲法上の判断を避けてきたわけです。しかし、今お話ししたように、山下審議官の答弁はそうではない。非核トマホークを自衛隊が装備できるのかと…", "…ストレートに答えている。それをはっきりしておきたいと思います。だから、そのような山下審議官の答弁があったという事実ははっきりしていますよね。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/235", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/237", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/239", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/241", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/244", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121103968X00220230310/246", "sentence": []}]}]}]