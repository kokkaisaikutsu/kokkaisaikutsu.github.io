[{"date": "2023-01-30", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/33", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/35", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/37", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/39", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/41", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/43", "sentence": ["…っております。今、八割という話がありましたけれども、例えば南米とかアフリカとか、そういうところとはまだまだなんです。今日は資料で、人口の多い…", "…て、十一位ということになっておりますが、二〇五〇年になると、例えばアフリカの国は現在三か国ぐらいしか入っていませんが五か国に、それで、二一〇…", "…んそうした途上国にシフトしていってということになります。先日、私、アフリカ議員連盟の事務局長としてセーシェルとモーリシャスにもお伺いしまして…", "…してセーシェルとモーリシャスにもお伺いしまして、モーリシャスでは、アフリカのほとんどの国と自由貿易協定を自分たちがやっていて、是非ともうちと…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/45", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/47", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105261X00220230130/49", "sentence": []}]}]}]