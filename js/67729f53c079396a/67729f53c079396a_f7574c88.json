[{"date": "2022-12-06", "meeting": [{"meeting_name": "衆議院 消費者問題に関する特別委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/10", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/12", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/14", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/16", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/18", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/20", "sentence": ["…を消費者庁が所管をするというようなことで妥当であるのか、そして、この執行をやはり消費者庁がやっていくのか、それとも、もっと政府全体で改めて体…", "…費者庁がやっていくのか、それとも、もっと政府全体で改めて体制を強化してやっていくのか、ここについての今後の執行体制についてお聞かせください。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/22", "sentence": ["○牧原委員その執行体制は結構重要な課題に私はなるんだというふうに思います。やはり、これまでの消費者庁の皆さんの執行とは一段また違うフェーズに…", "…はなるんだというふうに思います。やはり、これまでの消費者庁の皆さんの執行とは一段また違うフェーズになると思いますので、是非その強化に取り組ん…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121004536X00420221206/34", "sentence": ["○牧原委員いずれにしても、今後の執行が極めて大切でございますので、ここは政府、あるいは与野党を超えて、全力でみんなで取り組んでいくべきことだ…"]}]}]}]