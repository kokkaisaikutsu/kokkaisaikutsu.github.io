[{"date": "2023-04-18", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/196", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/198", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/200", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/202", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/204", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/206", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/208", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/210", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/212", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/214", "sentence": ["…は、もう一点、この法案が成立していた場合、令和四年度末時点における仮放免後の逃亡者は約千四百人、速報値となっておりますが、監理措置制度があれ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/216", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/218", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/220", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01020230418/222", "sentence": []}]}]}, {"date": "2023-04-19", "meeting": [{"meeting_name": "衆議院 法務委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/388", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/390", "sentence": ["○漆間委員ちょっとまた、仮放免の判断については後ほど詳細にお聞きさせていただきたいと思います。ちょっと話題が飛んで済みませんが、次に、国際機…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/392", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/394", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/396", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/398", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/400", "sentence": ["…いいたします。次に、昨日もちょっと申し上げさせていただきましたが、仮放免後に逃亡した人の人数が、令和四年度末の速報値で約千四百人となり、令和…", "…新型コロナウイルス感染症の感染拡大に伴い、収容施設の密を避けるため仮放免制度を積極活用したことも影響したのかと思いますが、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/402", "sentence": ["…密の回避と逃亡防止は両立していくべきだと考えます。今後、監理措置や仮放免制度を活用しつつ、どのような対策を取っていくのか、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/404", "sentence": ["…立していれば、昨日のお話ですと、ウクライナ難民やコロナ禍で爆増した仮放免中の逃亡者の事案などで、様々なところが実は対応できていたという御答弁…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/406", "sentence": ["…べきかなと思っております。続きましての質問に移らせていただきます。仮放免制度、またちょっと詳細についてお伺いしたいんですけれども、今回の法改…", "…いんですけれども、今回の法改正では、監理措置制度が新設される一方、仮放免制度についても見直しが行われ、健康上、人道上その他これらに準ずる理由…", "…他これらに準ずる理由により一時的に収容を解除する制度とすることとされました。今般、仮放免制度を見直すこととした趣旨についてお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/408", "sentence": ["○漆間委員現在の仮放免制度では、理由の教示については法律上の規定はありませんが、運用上はどうなっているのか、西山さんにお伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/410", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/412", "sentence": ["○漆間委員仮放免制度でも書面なんですけれども、その書面の通知に関してはどの程度詳細な理由が通知されるのか、お伺いいたします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121105206X01120230419/414", "sentence": []}]}]}]