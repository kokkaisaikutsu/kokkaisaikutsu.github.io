[{"date": "2023-04-24", "meeting": [{"meeting_name": "衆議院 決算行政監視委員会第四分科会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/142", "sentence": ["…ころでございました。ですので、今回は、法務省の方に、宗教に関する人権擁護の質問をさせていただきたいと思っております。まず最初に、宗教に関係す…", "…ります。まず最初に、宗教に関係する人権侵害の被害申告を受けた場合、人権擁護局ではどのように対応するのか、教えてください。大臣、お願いします。"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/144", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/146", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/148", "sentence": ["…にて、宗教に関する相談というのは存在していると思いますけれども、人権擁護の観点から、トラブル団体と言われている宗教に対して今後どのように対応…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/150", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/152", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/154", "sentence": ["…ね。でも、一方で、しっかりと法務省さんが対応してくださっている、人権擁護局にたくさん御相談が来ている、法テラスを含め、それをしっかりと受け止…", "…事実をしっかりと受け止めていただきたいなと思っております。多分、人権擁護局さん、これからも長く闘いを続けていかなければならないことだと思って…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/156", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/158", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/161", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/163", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/165", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121104131X00120230424/167", "sentence": []}]}]}]