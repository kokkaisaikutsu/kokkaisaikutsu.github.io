[{"date": "2023-03-01", "meeting": [{"meeting_name": "参議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/439", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/441", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/443", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/445", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/447", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/449", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/451", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/454", "sentence": ["…んでいただきたいと思います。ありがとうございます。次に、少子化対策、子育て支援政策についてお伺いをいたします。衆議院また参議院においても、児…", "…度五百五十六兆円まで回復し、税収は過去最高の六十七兆円となりました。子育て世帯の女性の就業率は七九％程度まで上昇しましたし、国民生活基礎調査…", "…百四十万円程度上昇しております。加えて、待機児童の解消が進みまして、子育てしながら安心して働ける環境が整備をされたこともあって、合計特殊出生…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/456", "sentence": ["…りますので、これは是非実現してほしいと私も思います。また、収入が高い子育て世帯からは、収入が高くても住宅ローンや多額の税金を納めなければなら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/458", "sentence": ["…うことについても目を向けていただけるものだと思います。私、自分自身も子育てをしておりますので、まだまだ仕事と家庭の両立という観点からは取り残…", "…点からは取り残された課題があるということを実感しております。総理も、子育ての対策強化に向けた指示の中で、学童、放課後児童クラブですね、この点…", "…わけですね、夏休み。そういう方の中には、まあフルタイムで働きながらの子育ては難しいな、パートタイム労働を選ぼうかなという方も中にはいらっしゃ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/462", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/464", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/466", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/468", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/121115261X00220230301/471", "sentence": []}]}]}]