[{"date": "2022-04-06", "meeting": [{"meeting_name": "衆議院 農林水産委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/22", "sentence": ["…いただきたいと思います。先月の二十九日、総理の方から緊急経済対策の取りまとめの指示が出されまして、調達先の多様化、あるいは、飼料の高騰の問題…", "…けであります。去る五日の日にも、関係閣僚会議で、総理からは四月中の取りまとめということを重ねて御指示があったというふうに伺っておりまして、是…", "…いうふうに伺っておりまして、是非、農林水産省におかれましても、今般取りまとめをされます対策に関して手厚い支援が盛り込まれるということを御期待…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/24", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/26", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/28", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/30", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/32", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120805007X00820220406/34", "sentence": []}]}]}]