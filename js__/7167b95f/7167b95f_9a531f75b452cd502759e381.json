[{"date": "2022-08-25", "meeting": [{"meeting_name": "参議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/66", "sentence": ["○東徹君日本維新の会の東徹でございます。冒頭、大臣から、厚生労働大臣、三度担当することになりましたという御挨拶がありました。加藤大臣は、二年…", "…ことになりましたという御挨拶がありました。加藤大臣は、二年前にも厚生労働大臣をされておってこのコロナの対応にも当たっておられましたし、そして…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/68", "sentence": ["…ですし、官房長官も経験されたので、是非、三度目の担当大臣として、厚生労働大臣として迅速な決断ができるように私は期待をいたしておりますので、よ…", "…でもかんでもやっぱり判断していくことは非常に難しいですし、じゃ、厚生労働大臣なんですか、それともコロナ担当大臣なんですか、いろいろありました…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/70", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/72", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/74", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/76", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/78", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/80", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/82", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120914260X00120220825/84", "sentence": []}]}]}]