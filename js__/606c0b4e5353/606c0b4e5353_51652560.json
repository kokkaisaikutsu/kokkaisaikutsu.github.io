[{"date": "2022-08-19", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/92", "sentence": ["…に対応していただくようにお願いをしておきたいと思います。続きまして、救急搬送の切迫について引き続きお伺いをしていきたいと思います。資料の一番…", "…過去最多とあります。先日も報道で、末期がんの患者さんがコロナ罹患し、救急車が来たにもかかわらず、受入先が見つからず、亡くなったという報道もあ…", "…した。当然、コロナの問題も大変重要なんですけれども、やはり、この三次救急であったり、脳梗塞、心筋梗塞、こういう本来受けるべき医療が受けられな…", "…療が受けられないということは非常に重要であるかと思っております。この救急搬送困難が起こっている事由について、消防庁にお伺いをしたいと思います…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/94", "sentence": ["…れども、新聞記事になるんですが、シャープ七一一九ということで、これは救急車を呼ぶべきかどうするか悩んだときに電話をする相談ダイヤルであります…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/96", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/110", "sentence": []}]}]}]