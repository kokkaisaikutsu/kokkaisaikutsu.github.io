[{"date": "2022-08-19", "meeting": [{"meeting_name": "衆議院 厚生労働委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/90", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/92", "sentence": ["…応していただくようにお願いをしておきたいと思います。続きまして、救急搬送の切迫について引き続きお伺いをしていきたいと思います。資料の一番目を…", "…いただきたいと思います。こちらの方は、消防庁の発表によりますと、緊急搬送困難事案が八月八日から十四日の一週間で全国で六千七百四十七件に上り、…", "…が受けられないということは非常に重要であるかと思っております。この救急搬送困難が起こっている事由について、消防庁にお伺いをしたいと思います。"]}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/94", "sentence": ["…ネックであるという指摘もあります。このシャープ七一一九も含めて、緊急搬送の切迫についての対策、これを今後どのようにやっていくかについてお伺い…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/96", "sentence": ["…、更なる拡充のためにやっていただきたいですし、これだけじゃなく、緊急搬送はもっともっと今大変な状況ですから、取組を進めていただきたいなと思っ…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/98", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/100", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/102", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/104", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/106", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/108", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120904260X00220220819/110", "sentence": []}]}]}]