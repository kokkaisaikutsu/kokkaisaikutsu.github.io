[{"date": "2021-12-08", "meeting": [{"meeting_name": "衆議院 本会議", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120705254X00220211208/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705254X00220211208/11", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120705254X00220211208/14", "sentence": ["…改正に取り組むことは、まさに私の本意であります。また、憲法五十三条の解釈については、これまで法制局長官が度々答弁してきたとおりであると考えて…", "…まで法制局長官が度々答弁してきたとおりであると考えております。岸田内閣においても、その解釈に基づき、憲法の規定を遵守してまいります。（拍手）"]}, {"url": "https://kokkai.ndl.go.jp/txt/120705254X00220211208/16", "sentence": []}]}]}]