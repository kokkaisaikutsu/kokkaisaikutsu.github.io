[{"date": "2020-04-28", "meeting": [{"meeting_name": "衆議院 予算委員会", "remarks": [{"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/4", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/6", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/8", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/11", "sentence": ["…じくスピードの問題として、窓口対応あるいは事務の問題が多くの国民から不満として指摘をされています。今回の緊急経済対策、資金繰り対策を始め、さ…", "…際、実務に入っていきますと、この窓口対応あるいは手続、大変遅いという不満、これが全国で今、大きな高まりを見せています。柔軟な対応を求めている…", "…とか、あるいは二週間、三週間待てというような声ですとか、国民の大きな不満がこうした状況に対して寄せられています。例えば、政策金融公庫では、四…", "…これは私も思いますし、国民の多くの皆さんが強くこういった状況に対して不満を持っていること、我々はこれはしっかり政治として受けとめなければなら…"]}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/13", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/15", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/17", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/19", "sentence": []}, {"url": "https://kokkai.ndl.go.jp/txt/120105261X02020200428/21", "sentence": []}]}]}]